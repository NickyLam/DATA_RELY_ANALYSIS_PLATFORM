# PostgreSQL 配置
POSTGRES_USER=datahub
POSTGRES_PASSWORD=datahub123
POSTGRES_DB=datahub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Neo4j 配置
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123
NEO4J_HOST=localhost
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# DataHub 配置
DATAHUB_GMS_HOST=localhost
DATAHUB_GMS_PORT=8080
DATAHUB_FRONTEND_HOST=localhost
DATAHUB_FRONTEND_PORT=9002

# Elasticsearch 配置
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Kafka 配置
KAFKA_BOOTSTRAP_SERVER=localhost:9092

# Backend API 配置
BACKEND_HOST=localhost
BACKEND_PORT=8000
API_DOCS_URL=http://localhost:8000/docs

# Frontend 配置
FRONTEND_HOST=localhost
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_DATAHUB_URL=http://localhost:9002

# 数据库连接字符串
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
NEO4J_URI=bolt://${NEO4J_HOST}:${NEO4J_BOLT_PORT}
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}