create table RRP_EAST.EAST5_KHXXB_TMP
(
  khtybh   VARCHAR2(70),
  cjrq     VARCHAR2(8),
  data_src VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on column RRP_EAST.EAST5_KHXXB_TMP.khtybh
  is '客户统一编号';
comment on column RRP_EAST.EAST5_KHXXB_TMP.cjrq
  is '采集日期';
comment on column RRP_EAST.EAST5_KHXXB_TMP.data_src
  is '数据来源';

