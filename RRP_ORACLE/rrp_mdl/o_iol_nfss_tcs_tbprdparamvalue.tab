create table RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE
(
  table_name  VARCHAR2(48),
  prd_code    VARCHAR2(30),
  field_code  VARCHAR2(48),
  field_value VARCHAR2(150),
  start_dt    DATE,
  end_dt      DATE,
  id_mark     VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE
  is '无名';
comment on column RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE.table_name
  is '表名';
comment on column RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE.prd_code
  is '产品编号';
comment on column RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE.field_code
  is '字段代码';
comment on column RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE.field_value
  is '字段值';
comment on column RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE.start_dt
  is '开始日期';
comment on column RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE.end_dt
  is '结束日期';
comment on column RRP_MDL.O_IOL_NFSS_TCS_TBPRDPARAMVALUE.id_mark
  is '删除标识';

