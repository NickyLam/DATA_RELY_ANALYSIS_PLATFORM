  inputdate             DATE,
  bailaccount           VARCHAR2(80),
  bailcurrency          VARCHAR2(3),
  settlementaccountname VARCHAR2(160),
  loanaccountbankname   VARCHAR2(200),
  baseratetype          VARCHAR2(4),
  updateorgid           VARCHAR2(64),
  pdgamorfg             VARCHAR2(1),
  loanaccountorgid      VARCHAR2(80),
  belongdept            VARCHAR2(36),
  policyversionid       VARCHAR2(64),
