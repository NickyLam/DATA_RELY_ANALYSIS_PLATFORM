  overdueratefloattype  VARCHAR2(36),
  remark                VARCHAR2(4000),
  ratemodel             VARCHAR2(36),
  ratefloattype         VARCHAR2(36),
  islowrisk             VARCHAR2(2),
  lendingorgid          VARCHAR2(160),
  commissionpaysum      NUMBER(18,2),
  clno                  VARCHAR2(64),
  segrptamount          NUMBER(24,6),
  bailratio             NUMBER(24,6),
  transserialno         VARCHAR2(80),
  payfrequencyunit      VARCHAR2(36),
