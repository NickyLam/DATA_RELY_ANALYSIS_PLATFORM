create table RRP_MDL.YDCP_TABLE
(
  table_a    VARCHAR2(100),
  table_name VARCHAR2(300),
  zd         VARCHAR2(300),
  zd_name    VARCHAR2(300),
  zd_lx      VARCHAR2(300),
  zd_id      VARCHAR2(300),
  xysy       VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

