create table RRP_MDL.O_ICL_CMM_RETL_LOAN_CRDT_LMT_INFO
(
  etl_dt                            DATE,
  lp_id                             VARCHAR2(60),
  lmt_cont_id                       VARCHAR2(60),
  lmt_cont_cn_name                  VARCHAR2(500),
  lmt_appl_flow_num                 VARCHAR2(60),
  cust_id                           VARCHAR2(60),
  tax_num                           VARCHAR2(250),
  bus_breed_id                      VARCHAR2(60),
  prod_id                           VARCHAR2(60),
  prod_name                         VARCHAR2(1000),
  actv_flg                          VARCHAR2(10),
  circl_flg                         VARCHAR2(10),
  low_risk_bus_flg                  VARCHAR2(10),
  cust_type_cd                      VARCHAR2(10),
  prod_type_cd                      VARCHAR2(100),
  tenor_type_cd                     VARCHAR2(10),
  curr_cd                           VARCHAR2(10),
  main_guar_way_cd                  VARCHAR2(10),
  sub_guar_way_cd                   VARCHAR2(10),
  status_cd                         VARCHAR2(10),
  bus_breed_name                    VARCHAR2(100),
  loan_happ_type_cd                 VARCHAR2(30),
  tenor                             VARCHAR2(60),
  begin_dt                          DATE,
  exp_dt                            DATE,
  belong_org_id                     VARCHAR2(60),
  belong_brch_id                    VARCHAR2(60),
  acct_instit_id                    VARCHAR2(60),
  mgmt_org_id                       VARCHAR2(60),
  crdt_lmt                          NUMBER(30,2),
  occu_crdt_lmt                     NUMBER(30,2),
  surp_crdt_lmt                     NUMBER(30,2),
  crdt_open_amt                     NUMBER(30,2),
  lower_ocup_up_level_crdt_open_amt NUMBER(30,6),
  lower_ocup_up_level_crdt_nmal_amt NUMBER(30,6),
  job_cd                            VARCHAR2(10),
  etl_timestamp                     TIMESTAMP(6),
  borw_usage_type_cd                VARCHAR2(10),
  cust_mgr_id                       VARCHAR2(60),
  termnt_dt                         DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_RETL_LOAN_CRDT_LMT_INFO
