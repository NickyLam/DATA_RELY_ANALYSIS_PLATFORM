create table RRP_MDL.O_IOL_IBMS_TTRD_HX_COUNTERPARTY_REGISTRY
(
  registry_id       NUMBER(16),
  entry_id          VARCHAR2(45),
  entry_date        VARCHAR2(15),
  inst_id           NUMBER(16),
  global_flow_no    VARCHAR2(75),
  flow_no           VARCHAR2(75),
  flow_inner_sn     VARCHAR2(15),
  i_code            VARCHAR2(75),
  a_type            VARCHAR2(30),
  m_type            VARCHAR2(30),
  p_type            VARCHAR2(30),
  p_class           VARCHAR2(150),
  i_name            VARCHAR2(383),
  subj_code         VARCHAR2(30),
  debit_credit_flag VARCHAR2(2),
  red_blue_flag     VARCHAR2(2),
  value             NUMBER(31,2),
  currency          VARCHAR2(5),
  prod_code         VARCHAR2(24),
  prod_name         VARCHAR2(383),
  party_acct_code   VARCHAR2(150),
  party_acct_name   VARCHAR2(150),
  party_bank_code   VARCHAR2(150),
  party_bank_name   VARCHAR2(300),
  state             VARCHAR2(2),
  update_time       VARCHAR2(29),
  start_dt          DATE,
  end_dt            DATE,
  id_mark           VARCHAR2(10),
  etl_timestamp     TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IBMS_TTRD_HX_COUNTERPARTY_REGISTRY
  is '华兴交易对手登记簿';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_HX_COUNTERPARTY_REGISTRY.registry_id
