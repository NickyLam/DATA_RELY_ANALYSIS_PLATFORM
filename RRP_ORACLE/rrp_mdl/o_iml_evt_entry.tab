comment on column RRP_MDL.O_IML_EVT_ENTRY.create_tm
  is '创建时间';
comment on column RRP_MDL.O_IML_EVT_ENTRY.update_tm
  is '更新时间';
comment on column RRP_MDL.O_IML_EVT_ENTRY.final_modif_operr_id
