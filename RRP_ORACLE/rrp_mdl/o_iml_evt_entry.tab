comment on column RRP_MDL.O_IML_EVT_ENTRY.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_EVT_ENTRY.job_cd
  is '任务编码';
comment on column RRP_MDL.O_IML_EVT_ENTRY.etl_timestamp
