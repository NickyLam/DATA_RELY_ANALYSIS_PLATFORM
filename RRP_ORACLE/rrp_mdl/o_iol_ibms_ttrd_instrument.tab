comment on column RRP_MDL.O_IOL_IBMS_TTRD_INSTRUMENT.t_path
  is '交易对手客户分类';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_INSTRUMENT.p_class_act
  is '会计产品分类';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_INSTRUMENT.issuer_id
