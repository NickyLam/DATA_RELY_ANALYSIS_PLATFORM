comment on column RRP_MDL.O_IOL_IBMS_TTRD_INSTRUMENT.remain_term_day
  is '剩余期限';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_INSTRUMENT.issue_volume
  is '发行数量';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_INSTRUMENT.state
