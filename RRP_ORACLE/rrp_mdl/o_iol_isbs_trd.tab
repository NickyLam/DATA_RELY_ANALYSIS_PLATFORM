comment on column RRP_MDL.O_IOL_ISBS_TRD.bchkeyinr
  is '所属机构INR';
comment on column RRP_MDL.O_IOL_ISBS_TRD.branchinr
  is '业务所属机构INR';
comment on column RRP_MDL.O_IOL_ISBS_TRD.dfrate
  is '代付利率';
comment on column RRP_MDL.O_IOL_ISBS_TRD.pntinr
  is '父业务主键';
comment on column RRP_MDL.O_IOL_ISBS_TRD.tenday
  is '最大到期日';
comment on column RRP_MDL.O_IOL_ISBS_TRD.stttendat
