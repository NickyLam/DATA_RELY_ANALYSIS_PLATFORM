create table RRP_MDL.O_ICL_CMM_BANK_CARD_BASIC_INFO
(
  etl_dt                    DATE,
  lp_id                     VARCHAR2(60),
  card_no                   VARCHAR2(60),
  vouch_no                  VARCHAR2(60),
  vouch_mgmt_id             VARCHAR2(60),
  nc_card_no                VARCHAR2(60),
  magt_ctrl_id              VARCHAR2(500),
  card_name                 VARCHAR2(90),
  start_use_flg             VARCHAR2(10),
  vtual_card_flg            VARCHAR2(10),
  vouch_kind_cd             VARCHAR2(10),
  card_type_cd              VARCHAR2(10),
  co_card_type_cd           VARCHAR2(10),
  card_status_cd            VARCHAR2(10),
  card_level_cd             VARCHAR2(10),
  make_card_flow_num        VARCHAR2(60),
  make_card_dt              DATE,
  effect_dt                 DATE,
  invalid_dt                DATE,
  use_brch_range            VARCHAR2(60),
  card_holder_name          VARCHAR2(750),
  card_holder_cert_type_cd  VARCHAR2(10),
  card_holder_cert_no       VARCHAR2(500),
  final_tran_dt             DATE,
  final_tran_flow           VARCHAR2(60),
  final_offline_tran_dt     DATE,
  offline_tran_tot_amt      NUMBER(30,2),
  bal_uplmi                 NUMBER(30,2),
  sig_cash_tran_lmt         NUMBER(30,2),
  auto_load_tshold          NUMBER(30,2),
  auto_load_amt             NUMBER(30,2),
  acm_load_amt              NUMBER(30,2),
  acm_unload_amt            NUMBER(30,2),
  curr_bal                  NUMBER(30,2),
  cust_id                   VARCHAR2(60),
  card_bin                  VARCHAR2(60),
  job_cd                    VARCHAR2(10),
  corp_stl_card_flg         VARCHAR2(10),
  main_card_card_no         VARCHAR2(60),
  std_prod_id               VARCHAR2(60),
  main_card_flg             VARCHAR2(10),
  card_psbook_merge_one_flg VARCHAR2(10),
  nomi_card_flg             VARCHAR2(10),
  make_card_appl_id         VARCHAR2(60),
  card_iss_org_id           VARCHAR2(60),
  card_iss_teller_id        VARCHAR2(60),
  card_iss_dt               DATE,
  pin_card_teller_id        VARCHAR2(60),
  pin_card_dt               DATE,
  pin_card_rs_descb         VARCHAR2(100),
  change_card_cnt           NUMBER(22)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_BANK_CARD_BASIC_INFO
  is '银行卡基本信息';
comment on column RRP_MDL.O_ICL_CMM_BANK_CARD_BASIC_INFO.etl_dt
