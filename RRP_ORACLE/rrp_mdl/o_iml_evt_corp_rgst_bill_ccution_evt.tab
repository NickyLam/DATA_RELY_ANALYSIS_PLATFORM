create table RRP_MDL.O_IML_EVT_CORP_RGST_BILL_CCUTION_EVT
(
  evt_id                   VARCHAR2(100),
  lp_id                    VARCHAR2(60),
  rgst_id                  VARCHAR2(60),
  bill_id                  VARCHAR2(60),
  recv_id                  VARCHAR2(60),
  prod_id                  VARCHAR2(60),
  prod_name                VARCHAR2(375),
  bill_med_cd              VARCHAR2(10),
  bill_type_cd             VARCHAR2(10),
  bus_type_cd              VARCHAR2(10),
  bus_attr_cd              VARCHAR2(10),
  bus_dir_cd               VARCHAR2(10),
  bill_src_cd              VARCHAR2(10),
  bill_num                 VARCHAR2(90),
  bill_sub_intrv_id        VARCHAR2(60),
  bill_amt                 NUMBER(30,2),
  tran_dt                  DATE,
  reqer_type_cd            VARCHAR2(10),
  reqer_name               VARCHAR2(375),
  reqer_soci_crdt_cd       VARCHAR2(30),
  reqer_acct_type_cd       VARCHAR2(10),
  reqer_acct_id            VARCHAR2(60),
  reqer_acct_name          VARCHAR2(750),
  reqer_open_bank_no       VARCHAR2(45),
  reqer_mem_cd             VARCHAR2(30),
  reqer_org_cd             VARCHAR2(30),
  recver_type_cd           VARCHAR2(10),
  recver_name              VARCHAR2(375),
  recver_soci_crdt_cd      VARCHAR2(30),
  recver_acct_type_cd      VARCHAR2(10),
  recver_acct_id           VARCHAR2(60),
  recver_acct_name         VARCHAR2(750),
  recver_open_bank_no      VARCHAR2(45),
  recver_mem_cd            VARCHAR2(30),
  recver_org_cd            VARCHAR2(30),
  discnt_int_rat           NUMBER(18,8),
  discnt_actl_amt          NUMBER(30,2),
  not_ngbl_cd              VARCHAR2(10),
  onl_clear_flg            VARCHAR2(10),
  enter_id                 VARCHAR2(60),
  enter_acct_bank_no       VARCHAR2(45),
  reply_idf_cd             VARCHAR2(10),
  recv_dt                  DATE,
  refuse_pay_cd            VARCHAR2(10),
  refuse_pay_remark_info   VARCHAR2(750),
  recs_type_cd             VARCHAR2(10),
  actl_int                 NUMBER(30,2),
  int_accr_exp_dt          DATE,
  int_payer_name           VARCHAR2(375),
  int_payer_acct_id        VARCHAR2(60),
  int_payer_open_bank_name VARCHAR2(375),
  comm_fee                 NUMBER(30,2),
  todos                    NUMBER(30,2),
  pay_int_ratio            NUMBER(18,6),
  buyer_pay_int_int        NUMBER(30,2),
  tot_int                  NUMBER(30,2),
  stop_pay_type_cd         VARCHAR2(10),
  stop_pay_rs_descb        VARCHAR2(750),
  remit_stop_pay_type_cd   VARCHAR2(10),
  remit_stop_pay_rs_descb  VARCHAR2(750),
  surp_tenor               NUMBER(10),
  stl_amt                  NUMBER(30,2),
  stl_rest_cd              VARCHAR2(10),
  stl_dt                   DATE,
  payoff_type_cd           VARCHAR2(10),
  tran_status_cd           VARCHAR2(10),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
