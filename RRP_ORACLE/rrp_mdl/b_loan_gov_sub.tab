create table RRP_MDL.B_LOAN_GOV_SUB
(
  data_dt                 CHAR(8) not null,
  lgl_rep_id              VARCHAR2(200),
  org_id                  VARCHAR2(200),
  rcpt_id                 VARCHAR2(200) not null,
  lcl_govfinpltf_loan_typ VARCHAR2(10),
  lcl_govfinpltf_loan_dir VARCHAR2(10),
  repy_cptl_src           VARCHAR2(10),
  mtg_plg_typ             VARCHAR2(10),
  gua_typ                 VARCHAR2(10),
  crdt_typ                VARCHAR2(10),
  dept_line               VARCHAR2(500),
  data_src                VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_LOAN_GOV_SUB
  is '地方政府融资平台贷款子表';
comment on column RRP_MDL.B_LOAN_GOV_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_GOV_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_LOAN_GOV_SUB.org_id
  is '机构编号';
comment on column RRP_MDL.B_LOAN_GOV_SUB.rcpt_id
  is '借据编号';
comment on column RRP_MDL.B_LOAN_GOV_SUB.lcl_govfinpltf_loan_typ
  is '地方政府融资平台贷款类型';
comment on column RRP_MDL.B_LOAN_GOV_SUB.lcl_govfinpltf_loan_dir
  is '地方政府融资平台贷款投向';
comment on column RRP_MDL.B_LOAN_GOV_SUB.repy_cptl_src
  is '还款资金来源';
comment on column RRP_MDL.B_LOAN_GOV_SUB.mtg_plg_typ
  is '抵质押类型';
comment on column RRP_MDL.B_LOAN_GOV_SUB.gua_typ
  is '保证类型';
comment on column RRP_MDL.B_LOAN_GOV_SUB.crdt_typ
  is '信用类型';
comment on column RRP_MDL.B_LOAN_GOV_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.B_LOAN_GOV_SUB.data_src
  is '数据来源';
alter table RRP_MDL.B_LOAN_GOV_SUB
  add constraint PK_B_LOAN_GOV_SUB primary key (DATA_DT, RCPT_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

