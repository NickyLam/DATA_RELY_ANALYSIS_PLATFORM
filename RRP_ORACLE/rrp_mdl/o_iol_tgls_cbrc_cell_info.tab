create table RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO
(
  subsys        NUMBER,
  shetcd        VARCHAR2(16),
  itemcd        VARCHAR2(32),
  cellid        NUMBER,
  itemna        VARCHAR2(256),
  crcycd        VARCHAR2(3),
  upitem        VARCHAR2(32),
  totltp        VARCHAR2(1),
  totllv        NUMBER,
  status        VARCHAR2(1),
  plusfg        VARCHAR2(1),
  begndt        DATE,
  overdt        DATE,
  inptfg        VARCHAR2(1),
  fomutp        VARCHAR2(1),
  foluma        VARCHAR2(4000),
  datatp        VARCHAR2(12),
  fomuds        VARCHAR2(4000),
  remark        VARCHAR2(1024),
  unitnm        NUMBER,
  verson        NUMBER,
  coluna        VARCHAR2(800),
  rowsna        VARCHAR2(800),
  stacid        NUMBER(9),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10),
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO
  is '数据项信息表';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.subsys
  is '子系统编号';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.shetcd
  is '报表编码';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.itemcd
  is '数据项编码';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.cellid
  is '数据项id';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.itemna
  is '数据项名称';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.crcycd
  is '数据项币种';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.upitem
  is '上级数据项';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.totltp
  is '汇总类别';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.totllv
  is '汇总层次';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.status
  is '数据项状态';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.plusfg
  is '加减标志';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.begndt
  is '启用日期';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.overdt
  is '停用日期';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.inptfg
  is '0：指标公式1：excel公式2：静态值';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.fomutp
  is '取值方式';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.foluma
  is '取数公式';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.datatp
  is '值类型num:数字类型char:字符类型date:日期类型';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.fomuds
  is '取数公式说明';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.remark
  is '备注';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.unitnm
  is '数据单位';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.verson
  is '版本号';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.coluna
  is '数据项对应列名称';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.rowsna
  is '数据项对应行名称';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.stacid
  is '账套';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_TGLS_CBRC_CELL_INFO.id_mark
