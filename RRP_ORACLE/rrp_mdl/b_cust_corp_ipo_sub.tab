create table RRP_MDL.B_CUST_CORP_IPO_SUB
(
  data_dt       CHAR(8) not null,
  lgl_rep_id    VARCHAR2(200),
  cust_id       VARCHAR2(200),
  ipo_typ       VARCHAR2(10) not null,
  ctry_cd       VARCHAR2(10),
  ipo_co_stk_cd VARCHAR2(200) not null,
  dept_line     VARCHAR2(500),
  data_src      VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_CUST_CORP_IPO_SUB
  is '单一法人客户上市情况子表';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.cust_id
  is '客户编号';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.ipo_typ
  is '上市类型';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.ctry_cd
  is '国家代码';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.ipo_co_stk_cd
  is '上市公司股票代码';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.B_CUST_CORP_IPO_SUB.data_src
  is '数据来源';
alter table RRP_MDL.B_CUST_CORP_IPO_SUB
  add constraint PK_B_CUST_CORP_IPO_SUB primary key (DATA_DT, IPO_TYP, IPO_CO_STK_CD)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

