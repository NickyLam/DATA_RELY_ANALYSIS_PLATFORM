create table RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA
(
  lp_id              VARCHAR2(100),
  holiday_type_cd    VARCHAR2(30),
  local_cty_rg_cd    VARCHAR2(30),
  local_prov_cd      VARCHAR2(30),
  holiday_dt         DATE,
  holiday_type_descb VARCHAR2(500),
  wd_flg             VARCHAR2(10),
  fit_range_cd       VARCHAR2(30),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA
  is '地区节假日参数';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.holiday_type_cd
  is '假日类型代码';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.local_cty_rg_cd
  is '所在国家和地区代码';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.local_prov_cd
  is '所在省代码';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.holiday_dt
  is '假日日期';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.holiday_type_descb
  is '假日类型描述';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.wd_flg
  is '工作日标志';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.fit_range_cd
  is '适用范围代码';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.job_cd
  is '任务编码';
comment on column RRP_MDL.O_IML_REF_RG_HOLIDAY_PARA.etl_timestamp
  is 'etl处理时间戳';

