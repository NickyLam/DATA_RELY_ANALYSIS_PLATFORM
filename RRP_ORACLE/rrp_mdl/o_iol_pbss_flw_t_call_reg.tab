create table RRP_MDL.O_IOL_PBSS_FLW_T_CALL_REG
(
  id                      VARCHAR2(32),
  biz_account             VARCHAR2(32),
  cust_name               VARCHAR2(100),
  cust_id                 VARCHAR2(30),
  br_code                 VARCHAR2(9),
  principal_name          VARCHAR2(100),
  principal_tel           VARCHAR2(50),
  principal_phone         VARCHAR2(50),
  fin_contect_name        VARCHAR2(100),
  fin_contect_tel         VARCHAR2(50),
  fin_contect_phone       VARCHAR2(50),
  chrg_name1              VARCHAR2(100),
  chrg_tel1               VARCHAR2(50),
  chrg_phone1             VARCHAR2(50),
  chrg_name2              VARCHAR2(100),
  chrg_tel2               VARCHAR2(50),
  chrg_phone2             VARCHAR2(50),
  create_date             DATE,
  update_date             DATE,
  tr_type                 VARCHAR2(1),
  create_opr              VARCHAR2(50),
  update_opr              VARCHAR2(50),
  account_escape_check    VARCHAR2(1),
  acc_esc_less_check      VARCHAR2(15),
  check_one               VARCHAR2(1),
  state                   VARCHAR2(1),
  principal_no_check      VARCHAR2(1),
  fin_contect_no_check    VARCHAR2(1),
  chrg_no_check1          VARCHAR2(1),
  chrg_no_check2          VARCHAR2(1),
  principal_order         VARCHAR2(1),
  fin_contect_order       VARCHAR2(1),
  chrg_order1             VARCHAR2(1),
  chrg_order2             VARCHAR2(1),
  acct_name               VARCHAR2(80),
  open_acct_date          VARCHAR2(8),
  modify_date             VARCHAR2(8),
  funds_escape_check      VARCHAR2(1),
  all_escape_check        VARCHAR2(1),
  not_funds_escape_check  VARCHAR2(1),
  other_busi_check        VARCHAR2(200),
  principal_funds_check   VARCHAR2(1),
  fin_contect_funds_check VARCHAR2(1),
  chrg_funds_check1       VARCHAR2(1),
  chrg_funds_check2       VARCHAR2(1),
  all_check               VARCHAR2(1),
  start_dt                DATE,
  end_dt                  DATE,
  id_mark                 VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_PBSS_FLW_T_CALL_REG
