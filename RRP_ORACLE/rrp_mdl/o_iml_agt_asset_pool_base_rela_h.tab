comment on column RRP_MDL.O_IML_AGT_ASSET_POOL_BASE_RELA_H.asset_scr_rule_id
  is '资产筛选规则编号';
comment on column RRP_MDL.O_IML_AGT_ASSET_POOL_BASE_RELA_H.obj_type
  is '对象类型';
comment on column RRP_MDL.O_IML_AGT_ASSET_POOL_BASE_RELA_H.start_dt
