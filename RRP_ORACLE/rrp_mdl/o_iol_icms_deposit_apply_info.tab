create table RRP_MDL.O_IOL_ICMS_DEPOSIT_APPLY_INFO
(
  serialno             VARCHAR2(32),
  remake               VARCHAR2(200),
  cusname              VARCHAR2(80),
  grteac               VARCHAR2(40),
  pigeonholedate       DATE,
  pdrifv               NUMBER(11,7),
  inputorgid           VARCHAR2(40),
  cntrtp               VARCHAR2(1),
  exchangedate         DATE,
  otrvbldn             VARCHAR2(1),
  crcycd               VARCHAR2(3),
  otrvacno             VARCHAR2(40),
  fxfltp               VARCHAR2(1),
  approvestatus        VARCHAR2(18),
  hascancel            VARCHAR2(2),
  isopen               VARCHAR2(2),
  batchserialno        VARCHAR2(32),
  initexchangeserialno VARCHAR2(32),
  exchangetime         DATE,
  interestrate         NUMBER(24,6),
  bailsum              NUMBER(24,6),
  inputuserid          VARCHAR2(8),
  updateuserid         VARCHAR2(8),
  contractno           VARCHAR2(40),
  putoutno             VARCHAR2(40),
  matudt               DATE,
  subaccount           VARCHAR2(40),
  exchangeserialno     VARCHAR2(30),
  businesstype         VARCHAR2(40),
  otsusbtp             VARCHAR2(1),
  updateorgid          VARCHAR2(12),
  tranam               NUMBER(18,2),
  exchangestate        VARCHAR2(2),
  dataid               VARCHAR2(40),
  balance              NUMBER(24,6),
  inputdate            DATE,
  grtetp               VARCHAR2(1),
  putoutdate           DATE,
  pdrifd               VARCHAR2(3),
  isdiscountflag       VARCHAR2(10),
  migtflag             VARCHAR2(80),
  cusid                VARCHAR2(40),
  interestmethod       VARCHAR2(10),
  maturity             DATE,
  prcsna               VARCHAR2(50),
  acptno               VARCHAR2(40),
  opertp               VARCHAR2(1),
  termcd               VARCHAR2(3),
  otfrsptp             VARCHAR2(1),
  otfzremk             VARCHAR2(100),
  initexchangedate     DATE,
  businesssum          NUMBER(24,6),
  otrvacna             VARCHAR2(80),
  updatedate           DATE,
  acctno               VARCHAR2(40),
  otfrozsq             VARCHAR2(20),
  pdrifm               VARCHAR2(1),
  inputtype            VARCHAR2(20),
  bailinterestmethod   VARCHAR2(12),
  deposittermtype      VARCHAR2(5),
  depositterm          NUMBER(22),
  bailinterestrate     NUMBER(24,6),
  depositbaserate      NUMBER(24,6),
  bailterm             VARCHAR2(4),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_DEPOSIT_APPLY_INFO
