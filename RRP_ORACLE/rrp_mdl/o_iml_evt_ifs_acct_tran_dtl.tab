create table RRP_MDL.O_IML_EVT_IFS_ACCT_TRAN_DTL
(
  etl_dt            DATE,
  evt_id            VARCHAR2(60),
  lp_id             VARCHAR2(60),
  tran_flow_id      VARCHAR2(60),
  acct_id           VARCHAR2(60),
  dep_sub_acct_id   VARCHAR2(60),
  cust_id           VARCHAR2(60),
  ext_prod_id       VARCHAR2(100),
  tran_dt           DATE,
  tran_tm           VARCHAR2(15),
  tran_type_cd      VARCHAR2(30),
  tran_chn_cd       VARCHAR2(10),
  tran_status_cd    VARCHAR2(30),
  tran_org_id       VARCHAR2(60),
  call_sys_id       VARCHAR2(60),
  debit_crdt_dir_cd VARCHAR2(10),
  tran_amt          NUMBER(30,2),
  cntpty_acct_id    VARCHAR2(60),
  cntpty_acct_name  VARCHAR2(150),
  cntpty_org_id     VARCHAR2(60),
  dep_rcpt_bal      NUMBER(30,2),
  provi_flg_cd      VARCHAR2(10),
  provi_tm          TIMESTAMP(6),
  ext_flow_id       VARCHAR2(60),
  job_cd            VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_IFS_ACCT_TRAN_DTL
  is '联合存款账户交易明细';
