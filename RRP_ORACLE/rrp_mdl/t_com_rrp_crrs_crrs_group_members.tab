create table RRP_MDL.T_COM_RRP_CRRS_CRRS_GROUP_MEMBERS
(
  rid               VARCHAR2(100) not null,
  customer_code     VARCHAR2(100) not null,
  nationality_code  VARCHAR2(40),
  member_name       VARCHAR2(200),
  member_code       VARCHAR2(100),
  organization_code VARCHAR2(40),
  register_code     VARCHAR2(44),
  member_type       CHAR(1),
  parent            CHAR(1),
  customer_name     VARCHAR2(100),
  data_dt           VARCHAR2(40) not null,
  issued_no         VARCHAR2(100),
  rpt_org_no        VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;

