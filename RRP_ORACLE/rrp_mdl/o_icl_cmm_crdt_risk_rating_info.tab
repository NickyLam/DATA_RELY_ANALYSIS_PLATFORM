comment on column RRP_MDL.O_ICL_CMM_CRDT_RISK_RATING_INFO.oper_teller_id
  is '经办柜员编号';
comment on column RRP_MDL.O_ICL_CMM_CRDT_RISK_RATING_INFO.rgst_teller_id
