  appl_apved_dt                        DATE,
  termnt_cont_rs_rgst_dt               DATE,
  cont_invalid_dt                      DATE,
  start_work_dt                        DATE,
  batch_no                             VARCHAR2(250),
  plan_lics_id                         VARCHAR2(60),
  arch_land_lics_id                    VARCHAR2(60),
  envir_im_ass_lics_id                 VARCHAR2(60),
  cnstr_lics_id                        VARCHAR2(60),
  other_lics_id                        VARCHAR2(60),
