  int_rat_adj_ped_cd                   VARCHAR2(30),
  col_int_type_cd                      VARCHAR2(30),
  non_asset_handov_status_cd           VARCHAR2(30),
  mode_pay_cd                          VARCHAR2(30),
  main_repay_way_cd                    VARCHAR2(30),
  int_rat_type_cd                      VARCHAR2(30),
  ic_way_cd                            VARCHAR2(30),
  repay_ped_cd                         VARCHAR2(30),
  tenor_type_cd                        VARCHAR2(30),
  buy_house_type_cd                    VARCHAR2(30),
  gover_crdt_supt_way_cd               VARCHAR2(30),
  gover_crdt_type_cd                   VARCHAR2(30),
  cdb_crdt_breed_cd                    VARCHAR2(30),
  log_benefc_rg_cd                     VARCHAR2(30),
  loan_char_cd                         VARCHAR2(30),
  invest_char_cd                       VARCHAR2(30),
  margin_int_rat_type_cd               VARCHAR2(30),
  margin_int_accr_method_cd            VARCHAR2(30),
  guar_nestle_proj_loan_type_cd        VARCHAR2(30),
  lmt_tra_finan_flg                    VARCHAR2(10),
  lmt_sign_agt_flg                     VARCHAR2(10),
