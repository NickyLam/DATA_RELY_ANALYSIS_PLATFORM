  guartor_cnt                          NUMBER(10),
  mtg_estate_cnt                       NUMBER(10),
  buy_cnt                              NUMBER(10),
  lmt_usable_org_range                 VARCHAR2(45),
  lmt_deduct_amt                       NUMBER(30,8),
  cargo_name                           VARCHAR2(375),
  loan_proj_name                       VARCHAR2(375),
  major_guartor_name                   VARCHAR2(375),
  guar_tot_val                         NUMBER(30,2),
  guar_rat                             NUMBER(30,8),
  base_period_crdt_level               VARCHAR2(45),
  syn_risk_degree                      NUMBER(30,8),
  low_risk_guar_amt                    NUMBER(30,2),
  provi_resv                           NUMBER(30,2),
  cls_freq                             NUMBER(30,8),
  idtfy_lev                            VARCHAR2(45),
  ovdue_int_accr_way_cd                VARCHAR2(30),
  devper_carry_to_net_amnt             NUMBER(30,2),
  non_asset_handov_doc_lt              VARCHAR2(1000),
  grace_period_fix_second_marke        VARCHAR2(30),
  repay_grace_period                   VARCHAR2(60),
  repay_grace_period_corp              VARCHAR2(30),
  loan_prop_code                       VARCHAR2(30),
  int_rat_exec_way_cd                  VARCHAR2(60),
  buy_house_char                       VARCHAR2(60),
  buy_tot_area                         VARCHAR2(60),
  imp_loan_proj                        VARCHAR2(30),
  m_l_ratio                            NUMBER(30,8),
  loan_distr_status                    VARCHAR2(30),
  cont_fulfil_situ                     VARCHAR2(30),
  termnt_situ                          VARCHAR2(30),
  termnt_rs                            VARCHAR2(1000),
  proj_tot_invest                      NUMBER(18,2),
  capital                              NUMBER(18,2),
  setup_proj_batch_file                VARCHAR2(250),
  other_lics                           VARCHAR2(250),
  ncds_abbr                            VARCHAR2(100),
  margin_int_rat_level                 VARCHAR2(100),
  onl_lmt_bal                          NUMBER(30,2),
  land_use_cert_id                     VARCHAR2(100),
  land_use_cert_dt                     DATE,
  land_plan_lics_id                    VARCHAR2(100),
  land_plan_lics_dt                    DATE,
  cnstr_lics_dt                        DATE,
  proj_plan_lics_dt                    DATE,
  buyer_name                           VARCHAR2(250),
  seller_name                          VARCHAR2(250),
  trade_tran_content                   VARCHAR2(3000),
  stat_use_open_bal                    NUMBER(30,8),
  commer_inv_info_desc                 VARCHAR2(100),
  commer_inv_curr_cd                   VARCHAR2(10),
  commer_inv_amt                       NUMBER(30,2),
  commer_inv_kind_cd                   VARCHAR2(100),
  job_cd                               VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
