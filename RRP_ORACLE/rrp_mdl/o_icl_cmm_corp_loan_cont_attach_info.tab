  crdtc_guar_flg                       VARCHAR2(10),
  sup_chain_fin_mode_bus_flg           VARCHAR2(10),
  m_l_claus_exist_flg                  VARCHAR2(10),
  cont_termnt_flg                      VARCHAR2(10),
  housing_mtg_flg                      VARCHAR2(10),
  fin_sys_cont_flg                     VARCHAR2(10),
  consm_serv_class_fin_flg             VARCHAR2(10),
  green_crdt_fin_flg                   VARCHAR2(10),
  obank_open_flg                       VARCHAR2(10),
  three_old_tf_or_city_update_proj_flg VARCHAR2(10),
  overs_loan_flg                       VARCHAR2(10),
  cont_begin_dt                        DATE,
  cont_exp_dt                          DATE,
  fir_distr_dt                         DATE,
