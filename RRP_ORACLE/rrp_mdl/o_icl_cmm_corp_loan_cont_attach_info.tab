  margin_int_rat                       NUMBER(30,8),
  manu_id                              VARCHAR2(300),
  pm_id                                VARCHAR2(60),
  actl_contr_no                        VARCHAR2(60),
  loan_enter_acct_acct_num             VARCHAR2(60),
  secd_repay_num                       VARCHAR2(60),
  comm_fee_expns_num                   VARCHAR2(60),
  non_asset_idtfy_org_id               VARCHAR2(60),
