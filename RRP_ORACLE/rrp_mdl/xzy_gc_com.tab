create table RRP_MDL.XZY_GC_COM
(
  gcb          VARCHAR2(800),
  mbbm         VARCHAR2(800),
  tab_comments VARCHAR2(4000),
  column_name  VARCHAR2(512),
  col_comments VARCHAR2(4000)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

