create table RRP_MDL.O_IML_EVT_BANK_PC_EDIT_TRAN_FLOW
(
  evt_id                 VARCHAR2(60),
  lp_id                  VARCHAR2(60),
  flow_num               VARCHAR2(60),
  tran_tm                TIMESTAMP(6),
  tran_dt                DATE,
  tran_code              VARCHAR2(100),
  tran_order             VARCHAR2(100),
  unify_cust_id          VARCHAR2(60),
  user_seq_num           VARCHAR2(60),
  tran_chn_cd            VARCHAR2(20),
  cust_name              VARCHAR2(500),
  menu_id                VARCHAR2(100),
  tran_status_cd         VARCHAR2(10),
  tran_return_code       VARCHAR2(500),
  fail_rs_descb          VARCHAR2(2000),
  tran_acct_num          VARCHAR2(60),
  tran_amt               NUMBER(30,2),
  curr_cd                VARCHAR2(10),
  chn_send_flow_id       VARCHAR2(1000),
  sorc_sys_flow_id       VARCHAR2(100),
  core_tran_flow_id      VARCHAR2(60),
  comm_fee               NUMBER(30,2),
  parent_flow_id         VARCHAR2(60),
  src_flow_seq_id        VARCHAR2(60),
  auth_refuse_rs         VARCHAR2(250),
  visit_flow_id          VARCHAR2(60),
  core_tran_dt           DATE,
  callout_tran_code      VARCHAR2(100),
  cust_ip                VARCHAR2(500),
  curr_server_host_name  VARCHAR2(100),
  req_src_server_ip      VARCHAR2(60),
  cust_termn_mac_addr    VARCHAR2(30),
  cust_termn_oper_sys    VARCHAR2(30),
  cust_termn_brow        VARCHAR2(60),
  cust_termn_equip_model VARCHAR2(30),
  cust_termn_equip_id    VARCHAR2(60),
  session_id             VARCHAR2(250),
  rela_flow_id           VARCHAR2(60),
  save_cert_way_cd       VARCHAR2(10),
  auth_status_cd         VARCHAR2(10),
  bank_agent_flg         VARCHAR2(10),
  auth_role_seq_num      VARCHAR2(10),
  submit_core_dt         DATE,
  submit_core_tm         TIMESTAMP(6),
  tran_tot_qtty          NUMBER(30),
  remark                 VARCHAR2(1000),
  bus_flow_num           VARCHAR2(100),
  chain_way_track_no     VARCHAR2(60),
  ups_flow_num           VARCHAR2(100),
  etl_dt                 DATE,
  src_table_name         VARCHAR2(100),
  job_cd                 VARCHAR2(10),
  etl_timestamp          TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
