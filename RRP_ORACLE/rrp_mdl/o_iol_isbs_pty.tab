create table RRP_MDL.O_IOL_ISBS_PTY
(
  inr           VARCHAR2(12),
  extkey        VARCHAR2(36),
  nam           VARCHAR2(60),
  ptytyp        VARCHAR2(23),
  accusr        VARCHAR2(12),
  hbkaccflg     VARCHAR2(2),
  hbkconflg     VARCHAR2(2),
  hbkinr        VARCHAR2(12),
  heqaccflg     VARCHAR2(2),
  heqconflg     VARCHAR2(2),
  heqinr        VARCHAR2(12),
  prfctr        VARCHAR2(9),
  resusr        VARCHAR2(12),
  rskcls        VARCHAR2(9),
  rskcty        VARCHAR2(3),
  rsktxt        VARCHAR2(53),
  uil           VARCHAR2(3),
  ver           VARCHAR2(6),
  akkbra        VARCHAR2(5),
  akkcom        VARCHAR2(12),
  akkreg        VARCHAR2(3),
  lidcndflg     VARCHAR2(2),
  lidmaxdur     NUMBER(4),
  trdcndflg     VARCHAR2(2),
  trdtentot     NUMBER(5),
  trdtenini     NUMBER(5),
  trdtenext     NUMBER(5),
  trdextnmb     NUMBER(5),
  badcndflg     VARCHAR2(2),
  badtenext     NUMBER(4),
  adrsta        VARCHAR2(2),
  seltyp        VARCHAR2(2),
  buytyp        VARCHAR2(2),
  sla           VARCHAR2(5),
  etgextkey     VARCHAR2(12),
  nam1          VARCHAR2(105),
  juscod        VARCHAR2(15),
  bilvvv        NUMBER(8,5),
  cunqii        VARCHAR2(5),
  idcode        VARCHAR2(48),
  idtype        VARCHAR2(2),
  bchkeyinr     VARCHAR2(12),
  clscty        VARCHAR2(9),
  procod        VARCHAR2(3),
  trnman        VARCHAR2(3),
  speeco        VARCHAR2(2),
  idtyp1        VARCHAR2(6),
  ratstm        VARCHAR2(4000),
  banktyp       VARCHAR2(5),
  godcus        VARCHAR2(2),
  imginr        VARCHAR2(12),
  bankno        VARCHAR2(30),
  drccod        VARCHAR2(30),
  bnkkey        VARCHAR2(48),
  bnkref        VARCHAR2(30),
  risran        VARCHAR2(15),
  imginr2       VARCHAR2(12),
  risrantxt     VARCHAR2(765),
  idcodlst      VARCHAR2(300),
  idtyplst      VARCHAR2(90),
  iscrb         VARCHAR2(2),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10),
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ISBS_PTY
  is '当事人信息';
