create table RRP_MDL.XZY_REF
(
  sql               VARCHAR2(2428),
  owner             VARCHAR2(512),
  name              VARCHAR2(512),
  referenced_name   VARCHAR2(512),
  referenced_column VARCHAR2(512) not null,
  tab_chg           VARCHAR2(800)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

