create table RRP_MDL.O_IOL_NCBS_CL_TRANSFER_DETAIL
(
  asset_acct_status     VARCHAR2(10),
  balance               NUMBER(17,2),
  ccy                   VARCHAR2(3),
  client_no             VARCHAR2(16),
  dd_no                 NUMBER(5),
  internal_key          NUMBER(15),
  prod_type             VARCHAR2(12),
  cmisloan_no           VARCHAR2(64),
  company               VARCHAR2(20),
  narrative             VARCHAR2(400),
  sale_batch_no         VARCHAR2(50),
  accounting_status     VARCHAR2(3),
  last_change_date      DATE,
  tran_timestamp        VARCHAR2(26),
  loan_no               VARCHAR2(50),
  pack_reference        VARCHAR2(50),
  sale_reference        VARCHAR2(50),
  sale_cancel_batch_no  VARCHAR2(50),
  amortized_int         NUMBER(20,2),
  circle_buy_flag       VARCHAR2(1),
  circle_buy_reference  VARCHAR2(50),
  pack_cancel_batch_no  VARCHAR2(50),
  circle_buy_date       DATE,
  sale_float_amount     NUMBER(20,2),
  circle_buy_batch_no   VARCHAR2(50),
  sale_cancel_reference VARCHAR2(50),
  redeem_reference      VARCHAR2(50),
  pack_batch_no         VARCHAR2(50),
  pack_cancel_reference VARCHAR2(50),
  asset_detail_seq_no   VARCHAR2(50),
  redeem_date           DATE,
  redeem_batch_no       VARCHAR2(50),
  pack_tran_date        DATE,
  asset_contract_seq_no VARCHAR2(50),
  redeem_float_amount   NUMBER(17,2),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NCBS_CL_TRANSFER_DETAIL
  is '资产转让合同明细表';
