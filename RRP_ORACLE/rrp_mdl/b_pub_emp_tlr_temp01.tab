create table RRP_MDL.B_PUB_EMP_TLR_TEMP01
(
  tlr_no VARCHAR2(30),
  emp_id VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress
nologging;
comment on table RRP_MDL.B_PUB_EMP_TLR_TEMP01
  is '员工柜员映射表';
comment on column RRP_MDL.B_PUB_EMP_TLR_TEMP01.tlr_no
  is '柜员号';
comment on column RRP_MDL.B_PUB_EMP_TLR_TEMP01.emp_id
  is '员工编号';

