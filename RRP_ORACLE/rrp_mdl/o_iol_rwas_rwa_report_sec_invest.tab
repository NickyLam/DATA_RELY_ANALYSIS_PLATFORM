comment on column RRP_MDL.O_IOL_RWAS_RWA_REPORT_SEC_INVEST.assettype_id
  is '资产类型id';
comment on column RRP_MDL.O_IOL_RWAS_RWA_REPORT_SEC_INVEST.subject_cd
