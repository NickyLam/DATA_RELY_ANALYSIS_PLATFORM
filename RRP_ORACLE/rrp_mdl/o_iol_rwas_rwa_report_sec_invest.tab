comment on column RRP_MDL.O_IOL_RWAS_RWA_REPORT_SEC_INVEST.org_cd
  is '组织机构代码';
comment on column RRP_MDL.O_IOL_RWAS_RWA_REPORT_SEC_INVEST.cust_name
