create table RRP_MDL.O_IOL_ICMS_FLOW_OBJECT
(
  etl_dt         DATE,
  objecttype     VARCHAR2(64),
  objectno       VARCHAR2(64),
  phasetype      VARCHAR2(64),
  applytype      VARCHAR2(64),
  flowno         VARCHAR2(64),
  flowname       VARCHAR2(160),
  phaseno        VARCHAR2(64),
  phasename      VARCHAR2(160),
  objdescribe    VARCHAR2(1000),
  objattribute1  VARCHAR2(400),
  objattribute2  VARCHAR2(400),
  objattribute3  VARCHAR2(400),
  objattribute4  VARCHAR2(400),
  objattribute5  VARCHAR2(400),
  orgid          VARCHAR2(64),
  orgname        VARCHAR2(160),
  userid         VARCHAR2(64),
  username       VARCHAR2(160),
  inputdate      DATE,
  archivetime    DATE,
  applyno        VARCHAR2(64),
  flowstate      VARCHAR2(400),
  processinstno  VARCHAR2(64),
  processtaskno  VARCHAR2(64),
  relativetaskno VARCHAR2(64),
  serialno       VARCHAR2(64),
  tasktype       VARCHAR2(64),
  version        VARCHAR2(64),
  baseflowno     VARCHAR2(64),
  archive        VARCHAR2(12),
  migtflag       VARCHAR2(200),
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_FLOW_OBJECT
  is '资产证券化参与方信息历史';
comment on column RRP_MDL.O_IOL_ICMS_FLOW_OBJECT.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IOL_ICMS_FLOW_OBJECT.objecttype
