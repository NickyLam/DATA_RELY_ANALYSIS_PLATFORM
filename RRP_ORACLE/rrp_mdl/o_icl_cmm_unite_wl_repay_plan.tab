create table RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_PLAN
(
  etl_dt                     DATE,
  lp_id                      VARCHAR2(60),
  dubil_id                   VARCHAR2(100),
  cust_id                    VARCHAR2(60),
  prod_id                    VARCHAR2(60),
  tot_perds                  NUMBER(10),
  repay_perds                NUMBER(10),
  repay_sub_perds            NUMBER(10),
  value_dt                   DATE,
  repaybl_dt                 DATE,
  payoff_dt                  DATE,
  pric_turn_ovdue_dt         DATE,
  int_turn_ovdue_dt          DATE,
  inst_status_cd             VARCHAR2(30),
  ovdue_flg                  VARCHAR2(10),
  repay_flg                  VARCHAR2(10),
  curr_cd                    VARCHAR2(10),
  pric_ovdue_days            NUMBER(22),
  int_ovdue_days             NUMBER(22),
  curr_issue_recvbl_pric     NUMBER(30,2),
  curr_issue_int_recvbl      NUMBER(30,2),
  curr_issue_recvbl_pric_bal NUMBER(30,2),
  curr_issue_int_recvbl_bal  NUMBER(30,2),
  curr_issue_ovdue_pric_pnlt NUMBER(30,2),
  curr_issue_ovdue_int_pnlt  NUMBER(30,2),
  job_cd                     VARCHAR2(10),
  init_tot_perds             NUMBER(10),
  init_repay_perds           NUMBER(10),
  init_value_dt              DATE,
  grace_dt                   DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_PLAN
  is '联合网贷还款计划';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_PLAN.etl_dt
  is '数据日期';
