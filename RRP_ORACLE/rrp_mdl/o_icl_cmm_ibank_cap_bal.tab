create table RRP_MDL.O_ICL_CMM_IBANK_CAP_BAL
(
  etl_dt              DATE,
  lp_id               VARCHAR2(60),
  intnal_cap_acct_id  VARCHAR2(60),
  ext_cap_acct_id     VARCHAR2(60),
  acct_name           VARCHAR2(500),
  tran_market_id      VARCHAR2(100),
  exchg_acct_id       VARCHAR2(60),
  open_acct_bank_no   VARCHAR2(90),
  open_acct_bank_name VARCHAR2(500),
  open_acct_dt        DATE,
  cntpty_cust_id      VARCHAR2(60),
  cntpty_id           VARCHAR2(60),
  cntpty_name         VARCHAR2(250),
  intnal_cap_acct_num VARCHAR2(90),
  cap_acct_type_cd    VARCHAR2(10),
  intnal_acct_num     VARCHAR2(90),
  intnal_acct_name    VARCHAR2(375),
  pay_int_freq        VARCHAR2(15),
  prod_type_id        VARCHAR2(60),
  prod_cls_name       VARCHAR2(250),
  subj_id             VARCHAR2(60),
  int_rat_def_id      VARCHAR2(60),
  int_rat             NUMBER(18,8),
  cap_type_cd         VARCHAR2(10),
  bal_type_cd         VARCHAR2(10),
  curr_cd             VARCHAR2(10),
  actl_bal            NUMBER(38,8),
  froz_bal            NUMBER(38,8),
  aval_bal            NUMBER(38,8),
  stl_dt              DATE,
  open_dt             DATE,
  entry_org_id        VARCHAR2(60),
  belong_org_id       VARCHAR2(60),
  job_cd              VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_IBANK_CAP_BAL
  is '同业资金余额';
comment on column RRP_MDL.O_ICL_CMM_IBANK_CAP_BAL.etl_dt
  is '数据日期';
comment on column RRP_MDL.O_ICL_CMM_IBANK_CAP_BAL.lp_id
  is '法人编号';
