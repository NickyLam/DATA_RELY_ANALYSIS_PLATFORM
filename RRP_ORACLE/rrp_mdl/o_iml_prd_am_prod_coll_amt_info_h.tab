create table RRP_MDL.O_IML_PRD_AM_PROD_COLL_AMT_INFO_H
(
  prod_id          VARCHAR2(100),
  lp_id            VARCHAR2(100),
  finc_prod_id     VARCHAR2(100),
  calc_start_dt    DATE,
  begin_dt         DATE,
  coll_amt         NUMBER(38,8),
  td_coll_amt      NUMBER(38,8),
  prft_type_cd     VARCHAR2(60),
  creator_name     VARCHAR2(500),
  create_dept      VARCHAR2(500),
  init_create_dt   DATE,
  updater_name     VARCHAR2(500),
  latest_update_dt DATE,
  etl_dt           DATE,
  src_table_name   VARCHAR2(100),
  job_cd           VARCHAR2(10),
  etl_timestamp    TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PRD_AM_PROD_COLL_AMT_INFO_H
  is '资管产品募集金额信息历史';
