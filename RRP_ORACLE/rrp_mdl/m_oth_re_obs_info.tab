create table RRP_MDL.M_OTH_RE_OBS_INFO
(
  data_dt            CHAR(8) not null,
  lgl_rep_id         VARCHAR2(200),
  biz_id             VARCHAR2(200) not null,
  seq_no             VARCHAR2(200) not null,
  exst_cash_obs_amt  NUMBER(30,2),
  cash_obs_start_dt  CHAR(8),
  cash_obs_exp_dt    CHAR(8),
  re_mtg_biz_cont_id VARCHAR2(200),
  dept_line          VARCHAR2(500),
  data_src           VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.M_OTH_RE_OBS_INFO
  is '资产再变现障碍信息';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.biz_id
  is '业务编号';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.seq_no
  is '流水号';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.exst_cash_obs_amt
  is '存在变现障碍金额';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.cash_obs_start_dt
  is '变现障碍起始日期';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.cash_obs_exp_dt
  is '变现障碍到期日期';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.re_mtg_biz_cont_id
  is '再抵押业务合同号';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.dept_line
  is '部门条线';
comment on column RRP_MDL.M_OTH_RE_OBS_INFO.data_src
  is '数据来源';

