create table RRP_MDL.O_IOL_IBMS_TBSI_ACCRUALDETAIL
(
  i_code            VARCHAR2(150),
  a_type            VARCHAR2(30),
  m_type            VARCHAR2(30),
  tg_code           VARCHAR2(15),
  ad_cfid           VARCHAR2(15),
  stream_id         VARCHAR2(150),
  ad_startdate      VARCHAR2(15),
  ad_enddate        VARCHAR2(15),
  ad_fixingdate     VARCHAR2(15),
  self_id           VARCHAR2(15),
  ad_actualrate     NUMBER(38,6),
  ad_yearfraction   NUMBER(38,6),
  ad_fixingrate     NUMBER(38,6),
  ad_spread         NUMBER(38,6),
  ad_caprate        NUMBER(38,6),
  ad_floorrate      NUMBER(38,6),
  ad_multiplier     NUMBER(38,6),
  imp_time          VARCHAR2(29),
  real_i_code       VARCHAR2(45),
  ad_paymentdate    VARCHAR2(15),
  ad_interestamount NUMBER(38,6),
  pe_code           VARCHAR2(45),
  i_code_rpt        VARCHAR2(195),
  ad_notionalamount NUMBER(38,6),
  start_dt          DATE,
  end_dt            DATE,
  id_mark           VARCHAR2(10),
  etl_timestamp     TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IBMS_TBSI_ACCRUALDETAIL
