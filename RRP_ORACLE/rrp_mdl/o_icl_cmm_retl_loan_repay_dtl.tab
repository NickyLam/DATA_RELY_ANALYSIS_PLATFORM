create table RRP_MDL.O_ICL_CMM_RETL_LOAN_REPAY_DTL
(
  etl_dt                       DATE,
  lp_id                        VARCHAR2(60),
  acct_id                      VARCHAR2(60),
  dubil_id                     VARCHAR2(100),
  cont_id                      VARCHAR2(60),
  cust_id                      VARCHAR2(60),
  repay_acct_id                VARCHAR2(60),
  repay_flow_id                VARCHAR2(60),
  repay_dt                     DATE,
  repaybl_dt                   DATE,
  repay_perds                  NUMBER(10),
  repay_sub_perds              NUMBER(10),
  adv_repay_flg                VARCHAR2(10),
  ovdue_repay_flg              VARCHAR2(10),
  comp_repay_flg               VARCHAR2(10),
  bf_repay_status_cd           VARCHAR2(10),
  repay_post_repay_status_cd   VARCHAR2(10),
  acru_non_acru_cd             VARCHAR2(10),
  tran_cd                      VARCHAR2(10),
  curr_cd                      VARCHAR2(10),
  dtl_seq_num                  VARCHAR2(60),
  repay_evt_cd                 VARCHAR2(10),
  repay_evt_descb              VARCHAR2(60),
  currt_repay_recvbl_acru_int  NUMBER(30,2),
  currt_repay_coll_acru_int    NUMBER(30,2),
  currt_repay_recvbl_over_int  NUMBER(30,2),
  currt_repay_coll_over_int    NUMBER(30,2),
  currt_repay_recvbl_acru_pnlt NUMBER(30,2),
  currt_repay_coll_acru_pnlt   NUMBER(30,2),
  currt_repay_recvbl_pnlt      NUMBER(30,2),
