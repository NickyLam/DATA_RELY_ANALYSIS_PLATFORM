  currt_repay_pric             NUMBER(30,2),
  currt_repay_int              NUMBER(30,2),
  currt_repay_pnlt             NUMBER(30,2),
  currt_repay_comp_int         NUMBER(30,2),
  currt_repay_fee              NUMBER(30,2),
  unbd_int                     NUMBER(30,2),
  job_cd                       VARCHAR2(10),
  strk_bal_flg                 VARCHAR2(10)
)
partition by range (ETL_DT)
(
