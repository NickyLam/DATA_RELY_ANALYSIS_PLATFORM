create table RRP_MDL.O_IOL_ICMS_ORG_BELONG
(
  orgid         VARCHAR2(64),
  managetype    VARCHAR2(12),
  belongorgid   VARCHAR2(64),
  updateuserid  VARCHAR2(64),
  inputorgid    VARCHAR2(64),
  updateorgid   VARCHAR2(64),
  inputuserid   VARCHAR2(64),
  updatedate    DATE,
  inputdate     DATE,
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10),
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_ICMS_ORG_BELONG
  is '机构管辖表机构管辖信息';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.orgid
  is '机构编号';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.managetype
  is '管辖类型';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.belongorgid
  is '所属机构编号';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.updateuserid
  is '更新人';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.inputorgid
  is '登记机构';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.updateorgid
  is '更新机构';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.inputuserid
  is '登记人';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.updatedate
  is '更新日期';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.inputdate
  is '登记日期';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IOL_ICMS_ORG_BELONG.etl_timestamp
  is 'ETL处理时间戳';

