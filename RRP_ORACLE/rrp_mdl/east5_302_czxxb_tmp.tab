create table RRP_MDL.EAST5_302_CZXXB_TMP
(
  rid        VARCHAR2(50) not null,
  jrxkzh     VARCHAR2(30),
  nbjgh      VARCHAR2(30),
  khtybh     VARCHAR2(70),
  khmc       VARCHAR2(450),
  zjlb       VARCHAR2(60),
  zjhm       VARCHAR2(70),
  czh        VARCHAR2(60),
  hqckzh     VARCHAR2(60),
  czlx       VARCHAR2(30),
  ygbz       VARCHAR2(3),
  qyrq       VARCHAR2(8),
  qygyh      VARCHAR2(30),
  czzt       VARCHAR2(30),
  bbz        VARCHAR2(600),
  cjrq       VARCHAR2(8),
  dept_no    VARCHAR2(10),
  src_sys_id VARCHAR2(10),
  issued_no  VARCHAR2(50),
  org_no     VARCHAR2(20),
  address    VARCHAR2(200),
  khxm       VARCHAR2(200),
  yhjgdm     VARCHAR2(30),
  khmc_orig  VARCHAR2(450),
  zjhm_orig  VARCHAR2(70),
  khmc_oth   VARCHAR2(5),
  gsfzjg     VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.rid
  is '数据主键';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.jrxkzh
  is '金融许可证号';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.nbjgh
  is '内部机构号';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.khtybh
  is '客户统一编号';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.khmc
  is '客户名称';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.zjlb
  is '证件类别';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.zjhm
  is '证件号码';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.czh
  is '存折号';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.hqckzh
  is '存款账号';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.czlx
