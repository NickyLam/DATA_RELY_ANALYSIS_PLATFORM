comment on column RRP_MDL.EAST5_302_CZXXB_TMP.cjrq
  is '创建日期';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.dept_no
  is '部门编号';
comment on column RRP_MDL.EAST5_302_CZXXB_TMP.src_sys_id
