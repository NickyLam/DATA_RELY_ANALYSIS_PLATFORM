create table RRP_MDL.O_IOL_RWAS_RPT_ASSET_SECURITIZATION
(
  data_date                   DATE,
  loan_ref_no                 VARCHAR2(150),
  sec_items_issue_no          VARCHAR2(150),
  sec_items_issue_name        VARCHAR2(150),
  items_tranche_no            VARCHAR2(60),
  items_tranche_name          VARCHAR2(150),
  on_off_id                   VARCHAR2(30),
  sec_priority_rating_flag    VARCHAR2(30),
  market_type_id              VARCHAR2(15),
  org_cd                      VARCHAR2(45),
  org_name                    VARCHAR2(150),
  overdue_days                NUMBER(22),
  five_class_cd               VARCHAR2(30),
  five_class_name             VARCHAR2(30),
  product_no                  VARCHAR2(45),
  product_name                VARCHAR2(150),
  sec_sp_rating_cd            VARCHAR2(30),
  sec_rating_org_cd           VARCHAR2(30),
  sec_rating_org_name         VARCHAR2(150),
  sec_ecternal_rating_cd      VARCHAR2(30),
  items_tranche_due_day       DATE,
  items_seniority             VARCHAR2(30),
  issue_amt_total             NUMBER(18,2),
  amt_cur                     NUMBER(18,2),
  sec_stc_flag                VARCHAR2(30),
  anew_asset_sec_flag         VARCHAR2(30),
  sec_start_date              DATE,
  sec_end_date                DATE,
  sec_pool_a                  NUMBER(25,9),
  sec_pool_d                  NUMBER(25,9),
  sec_pool_t                  NUMBER(25,9),
  sec_pool_mr                 NUMBER(25,9),
  sec_rating_floor_rw         NUMBER(25,9),
  sec_rating_ceil_rw          NUMBER(25,9),
  sec_orig_rw                 NUMBER(18,6),
  sec_pool_rw                 NUMBER(18,6),
  sec_rw                      NUMBER(18,6),
  sec_rw_adj                  NUMBER(18,6),
  ccy_cd                      VARCHAR2(15),
  ccy_name                    VARCHAR2(45),
  subject_cd                  VARCHAR2(24),
  subject_name                VARCHAR2(300),
  accrued_subject_cd          VARCHAR2(24),
  accrued_subject_name        VARCHAR2(300),
  receivable_subject_cd       VARCHAR2(24),
  receivable_subject_name     VARCHAR2(300),
  accrued_receiv_subject_cd   VARCHAR2(24),
  accrued_receiv_subject_name VARCHAR2(300),
  intadj_subject_cd           VARCHAR2(24),
  intadj_subject_name         VARCHAR2(300),
  fairchange_subject_cd       VARCHAR2(24),
  fairchange_subject_name     VARCHAR2(300),
  provision_subject_cd        VARCHAR2(24),
  provision_subject_name      VARCHAR2(300),
  balance                     NUMBER(18,2),
  balance_hcurr               NUMBER(18,2),
  receivable_int              NUMBER(18,2),
  accrued_receiv_int          NUMBER(18,2),
  accrued_int                 NUMBER(18,2),
  int_adj                     NUMBER(18,2),
  fair_value_change           NUMBER(18,2),
  provision                   NUMBER(18,2),
  asset_balance               NUMBER(18,2),
  ead_orig                    NUMBER(18,2),
  ccf                         NUMBER(18,6),
  ead_afterccf                NUMBER(18,2),
  ead_afterpro                NUMBER(18,2),
  rwa                         NUMBER(18,2),
  after_miti_rwa              NUMBER(18,2),
  after_adj_rwa               NUMBER(18,2),
  report_no                   VARCHAR2(30),
  report_line_no              VARCHAR2(60),
  load_date                   VARCHAR2(30),
  book_type_id                VARCHAR2(30),
  etl_dt                      DATE,
  etl_timestamp               TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_RWAS_RPT_ASSET_SECURITIZATION
  is '内部管理报表_资产证券化';
comment on column RRP_MDL.O_IOL_RWAS_RPT_ASSET_SECURITIZATION.data_date
