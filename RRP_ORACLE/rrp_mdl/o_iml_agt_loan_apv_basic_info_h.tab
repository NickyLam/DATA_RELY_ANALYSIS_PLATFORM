create table RRP_MDL.O_IML_AGT_LOAN_APV_BASIC_INFO_H
(
  apv_flow_num  VARCHAR2(100),
  appl_flow_num VARCHAR2(100),
  start_dt      DATE,
  end_dt        DATE,
  apv_amt       NUMBER(20,2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IML_AGT_LOAN_APV_BASIC_INFO_H
  is '公司贷款审批';
comment on column RRP_MDL.O_IML_AGT_LOAN_APV_BASIC_INFO_H.apv_flow_num
  is '批复号';
comment on column RRP_MDL.O_IML_AGT_LOAN_APV_BASIC_INFO_H.appl_flow_num
  is '审批号';
comment on column RRP_MDL.O_IML_AGT_LOAN_APV_BASIC_INFO_H.start_dt
  is '开始日期';
comment on column RRP_MDL.O_IML_AGT_LOAN_APV_BASIC_INFO_H.end_dt
  is '结束日期';
comment on column RRP_MDL.O_IML_AGT_LOAN_APV_BASIC_INFO_H.apv_amt
  is '审批金额';

