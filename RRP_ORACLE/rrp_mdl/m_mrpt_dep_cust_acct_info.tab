create table RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO
(
  data_dt            VARCHAR2(10),
  cust_acct_id       VARCHAR2(60),
  open_acct_dt       DATE,
  acct_status_cd     VARCHAR2(10),
  vouch_form_cd      VARCHAR2(10),
  acct_belong_org_id VARCHAR2(60),
  vouch_kind_cd      VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO
  is '存款主账户信息表-手工报表专用';
comment on column RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO.cust_acct_id
  is '客户账户编号';
comment on column RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO.open_acct_dt
  is '开户日期';
comment on column RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO.acct_status_cd
  is '账户状态代码';
comment on column RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO.vouch_form_cd
  is '凭证形式代码';
comment on column RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO.acct_belong_org_id
  is '账户所属机构编号';
comment on column RRP_MDL.M_MRPT_DEP_CUST_ACCT_INFO.vouch_kind_cd
  is '凭证种类代码';

