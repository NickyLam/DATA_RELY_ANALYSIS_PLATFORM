create table RRP_MDL.O_IML_AST_COL_DEP_RCPT_INPWN_INFO
(
  col_id           VARCHAR2(100),
  lp_id            VARCHAR2(100),
  dep_rcpt_type_cd VARCHAR2(30),
  dep_rcpt_amt     NUMBER(30,8),
  dep_rcpt_int_rat NUMBER(30,8),
  dep_term         NUMBER(22),
  curr_cd          VARCHAR2(30),
  subscr_acct_id   VARCHAR2(100),
  stop_pay_acct_id VARCHAR2(100),
  liab_acct_id     VARCHAR2(100),
  sub_acct_num     VARCHAR2(60),
  acct_name        VARCHAR2(500),
  aval_amt         NUMBER(30,8),
  vouch_no         VARCHAR2(100),
  effect_dt        DATE,
  vouch_type_cd    VARCHAR2(30),
  value_dt         DATE,
  exp_dt           DATE,
  prod_id          VARCHAR2(100),
  prod_name        VARCHAR2(500),
  cust_id          VARCHAR2(100),
  other_comnt      VARCHAR2(4000),
  start_dt         DATE,
  end_dt           DATE,
  id_mark          VARCHAR2(10),
  src_table_name   VARCHAR2(100),
  job_cd           VARCHAR2(10),
  etl_timestamp    TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AST_COL_DEP_RCPT_INPWN_INFO
  is '押品存单质押信息';
