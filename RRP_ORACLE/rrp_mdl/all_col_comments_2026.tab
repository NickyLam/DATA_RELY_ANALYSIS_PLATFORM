create table RRP_MDL.ALL_COL_COMMENTS_2026
(
  owner         VARCHAR2(128),
  table_name    VARCHAR2(128),
  column_name   VARCHAR2(128),
  comments      VARCHAR2(4000),
  origin_con_id NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

