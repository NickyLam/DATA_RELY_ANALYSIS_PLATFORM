create table RRP_MDL.O_IML_REF_DIST_CD
(
  rg_cd          VARCHAR2(10),
  rg_name        VARCHAR2(100),
  city_cd        VARCHAR2(10),
  city_name      VARCHAR2(100),
  prov_cd        VARCHAR2(10),
  prov_name      VARCHAR2(100),
  four_rg_cd     VARCHAR2(30),
  pbc_rg_cd      VARCHAR2(30),
  base_std_flg   VARCHAR2(10),
  std_id         VARCHAR2(60),
  etl_dt         DATE,
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_REF_DIST_CD
  is '行政区划代码表';
comment on column RRP_MDL.O_IML_REF_DIST_CD.rg_cd
  is '地区代码';
comment on column RRP_MDL.O_IML_REF_DIST_CD.rg_name
  is '地区名称';
comment on column RRP_MDL.O_IML_REF_DIST_CD.city_cd
  is '市代码';
comment on column RRP_MDL.O_IML_REF_DIST_CD.city_name
  is '城市名称';
comment on column RRP_MDL.O_IML_REF_DIST_CD.prov_cd
  is '省代码';
comment on column RRP_MDL.O_IML_REF_DIST_CD.prov_name
  is '省名称';
comment on column RRP_MDL.O_IML_REF_DIST_CD.four_rg_cd
  is '四位地区代码';
comment on column RRP_MDL.O_IML_REF_DIST_CD.pbc_rg_cd
  is '人行地区代码';
comment on column RRP_MDL.O_IML_REF_DIST_CD.base_std_flg
  is '基础标准标志';
comment on column RRP_MDL.O_IML_REF_DIST_CD.std_id
  is '标准编号';
comment on column RRP_MDL.O_IML_REF_DIST_CD.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IML_REF_DIST_CD.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_REF_DIST_CD.job_cd
  is '任务编码';

