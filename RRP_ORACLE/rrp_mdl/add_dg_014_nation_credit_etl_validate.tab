create table RRP_MDL.ADD_DG_014_NATION_CREDIT_ETL_VALIDATE
(
  datainput_id   VARCHAR2(32) not null,
  data_date      VARCHAR2(10),
  acct_org_num   VARCHAR2(20),
  jywym          VARCHAR2(200),
  khwym          VARCHAR2(50),
  khmc           VARCHAR2(200),
  zwjgmc         VARCHAR2(60),
  jydsjydgb      VARCHAR2(60),
  gbfxjydslb     VARCHAR2(60),
  zqzwgx         VARCHAR2(60),
  sfzqzq         VARCHAR2(10),
  jwzqzqlb       VARCHAR2(60),
  gbfxywpzlb     VARCHAR2(60),
  sjdqrq         VARCHAR2(10),
  gbfxzqzwsyqxqj VARCHAR2(60),
  wjfl           VARCHAR2(10),
  yqtsqj         VARCHAR2(10),
  tjye           NUMBER(20,6),
  ysyjlx         NUMBER(20,6),
  zmjz           NUMBER(20,6),
  dbjtjzzb       NUMBER(20,6),
  sfwyjtgbfxbbzc VARCHAR2(10),
  yjtgbfxbbbl    NUMBER(10,2),
  yjtgbfxbbje    NUMBER(20,6),
  fxzygb         VARCHAR2(60),
  fxzrflb        VARCHAR2(60),
  fxzysxje       NUMBER(20,6),
  fxzyje         NUMBER(20,6),
  jwzwrgb        VARCHAR2(60),
  blxhgb         VARCHAR2(30),
  gbfxdj         VARCHAR2(30),
  sfwydylyxgj    VARCHAR2(10),
  sys_source     VARCHAR2(100),
  sfwcygjydylxm  VARCHAR2(10),
  sys_data_date  VARCHAR2(20) not null,
  sys_data_case  VARCHAR2(32) not null,
  sys_operator   VARCHAR2(256),
  sys_oper_org   VARCHAR2(32) not null,
  sys_oper_date  VARCHAR2(20),
  sys_data_state VARCHAR2(10),
  sys_order_no   NUMBER(19),
  error_mark     VARCHAR2(2),
  flow_node_id   VARCHAR2(32),
  comments       VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.ADD_DG_014_NATION_CREDIT_ETL_VALIDATE
