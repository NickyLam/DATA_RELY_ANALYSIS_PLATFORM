create table RRP_MDL.XZY_A_DEP
(
  owner            VARCHAR2(128),
  name             VARCHAR2(128),
  type             VARCHAR2(18),
  referenced_owner VARCHAR2(128),
  referenced_name  VARCHAR2(128),
  referenced_type  VARCHAR2(18)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

