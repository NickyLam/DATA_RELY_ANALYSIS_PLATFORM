create table RRP_MDL.O_ICL_CMM_IBANK_FIN_INSTM
(
  etl_dt                     DATE,
  lp_id                      VARCHAR2(60),
  fin_instm_id               VARCHAR2(500),
  asset_type_id              VARCHAR2(60),
  market_type_id             VARCHAR2(60),
  fin_instm_name             VARCHAR2(375),
  fin_instm_abbr             VARCHAR2(250),
  std_prod_id                VARCHAR2(60),
  prod_type_cd               VARCHAR2(10),
  asset_type_name            VARCHAR2(250),
  prod_cls_tenor_cd          VARCHAR2(10),
  issue_org_id               VARCHAR2(60),
  discov_org_cls_name        VARCHAR2(500),
  issue_dt                   DATE,
  value_dt                   DATE,
  exp_dt                     DATE,
  tenor_cd                   VARCHAR2(10),
  base_rat_id                VARCHAR2(60),
  int_accr_base_cd           VARCHAR2(10),
  int_rat_adj_way_cd         VARCHAR2(10),
  issue_way_cd               VARCHAR2(10),
  cty_cd                     VARCHAR2(10),
  curr_cd                    VARCHAR2(10),
  fac_val_amt                NUMBER(38,8),
  fac_val_int_rat            NUMBER(18,8),
  fwd_int_rat_curve          VARCHAR2(750),
  disct_int_rat_curve        VARCHAR2(750),
  risk_wt                    NUMBER(18,8),
  pay_int_ped_cd             VARCHAR2(10),
  pay_int_freq               NUMBER(18),
  fir_pay_int_dt             DATE,
  belong_org_id              VARCHAR2(60),
  issuer_cust_id             VARCHAR2(60),
  mger_cust_id               VARCHAR2(60),
  mger_id                    VARCHAR2(60),
  mger_name                  VARCHAR2(750),
  mgmt_mode_cd               VARCHAR2(60),
  cashflow_get_way_cd        VARCHAR2(30),
  spec_aim_vector_type_cd    VARCHAR2(60),
  spec_aim_vector_code       VARCHAR2(90),
  am_prod_stat_code          VARCHAR2(90),
  issuer_id                  VARCHAR2(60),
  issuer_rg_cd               VARCHAR2(60),
  move_way_cd                VARCHAR2(60),
  non_uder_asset_cls_cd      VARCHAR2(60),
  non_uder_asset_subclass_cd VARCHAR2(60),
  dr_input_freq_cd           VARCHAR2(10),
  dr_effect_dt               DATE,
  dr_exp_dt                  DATE,
  margin_dr_ratio            NUMBER(18,8),
  hxb_dep_rcpt_dr_ratio      NUMBER(18,8),
  tbond_dr_ratio             NUMBER(18,8),
  chn_pb_bond_dr_ratio       NUMBER(18,8),
  chn_cb_dr_ratio            NUMBER(18,8),
  chn_pub_dept_dr_ratio      NUMBER(18,8),
  other_dr_ratio             NUMBER(18,8),
  dr_prod_descb_info         VARCHAR2(500),
  dr_acct_id                 VARCHAR2(250),
  dr_acct_bal                NUMBER(30,8),
  fund_open_dt               DATE,
  actl_finer_cust_id         VARCHAR2(60),
  actl_finer_name            VARCHAR2(750),
  actl_finer_group_name      VARCHAR2(500),
  set_open_tenor_start_dt    DATE,
  set_open_tenor_end_dt      DATE,
  set_open_flg               VARCHAR2(10),
  set_open_ped_cd            VARCHAR2(20),
  open_type_cd               VARCHAR2(20),
  usage_descb                VARCHAR2(500),
  guar_way_comb              VARCHAR2(750),
  crdt_class_proj_flg        VARCHAR2(10),
  job_cd                     VARCHAR2(10),
  list_dt                    DATE,
  this_ped_open_termnt_dt    DATE,
  this_ped_hold_exp_dt       DATE,
  cash_manage_flg            VARCHAR2(10),
  green_fin_flg              VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
