comment on column RRP_MDL.O_IML_AGT_INTSTL_AMT_H.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_AGT_INTSTL_AMT_H.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_AGT_INTSTL_AMT_H.id_mark
