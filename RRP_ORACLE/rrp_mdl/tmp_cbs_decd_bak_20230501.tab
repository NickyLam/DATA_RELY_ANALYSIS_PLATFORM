comment on column RRP_MDL.TMP_CBS_DECD_BAK_20230501.med_id
  is '介质编号';
comment on column RRP_MDL.TMP_CBS_DECD_BAK_20230501.dept_line
  is '部门条线';
comment on column RRP_MDL.TMP_CBS_DECD_BAK_20230501.data_src
