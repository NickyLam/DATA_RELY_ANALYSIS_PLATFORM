create table RRP_MDL.TMP_CBS_DECD_BAK_20230501
(
  data_dt    CHAR(8) not null,
  lgl_rep_id VARCHAR2(200),
  acc_id     VARCHAR2(200) not null,
  med_id     VARCHAR2(200) not null,
  dept_line  VARCHAR2(500),
  data_src   VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TMP_CBS_DECD_BAK_20230501.data_dt
  is '数据日期';
comment on column RRP_MDL.TMP_CBS_DECD_BAK_20230501.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.TMP_CBS_DECD_BAK_20230501.acc_id
