create table RRP_MDL.O_IML_EVT_ELEC_BILL_TRAN_FLOW
(
  evt_id              VARCHAR2(60),
  bill_id             VARCHAR2(60),
  lp_id               VARCHAR2(60),
  info_type_cd        VARCHAR2(10),
  bill_num            VARCHAR2(90),
  reqer_cate_cd       VARCHAR2(30),
  reqer_name          VARCHAR2(750),
  reqer_orgnz_cd      VARCHAR2(30),
  reqer_acct_num      VARCHAR2(90),
  reqer_open_bank_no  VARCHAR2(90),
  recver_name         VARCHAR2(750),
  recver_orgnz_cd     VARCHAR2(30),
  recver_acct_num     VARCHAR2(90),
  recver_open_bank_no VARCHAR2(90),
  recv_dt             DATE,
  onl_clear_cd        VARCHAR2(10),
  not_ngbl_cd         VARCHAR2(10),
  int_rat             NUMBER(18,8),
  redem_int_rat       NUMBER(18,8),
  tran_amt            NUMBER(30,2),
  redem_actl_amt      NUMBER(30,2),
  discnt_kind_cd      VARCHAR2(10),
  appl_dt             DATE,
  sugst_pay_amt       NUMBER(30,2),
  refuse_pay_cd       VARCHAR2(10),
  recs_type_cd        VARCHAR2(10),
  payoff_dt           DATE,
  lh_buy_tran_id      VARCHAR2(60),
  tran_status_descb   VARCHAR2(375),
  bill_status_cd      VARCHAR2(30),
  tran_id             VARCHAR2(60),
  h_data_flg          VARCHAR2(100),
  etl_dt              DATE,
  src_table_name      VARCHAR2(100),
  job_cd              VARCHAR2(10),
  etl_timestamp       TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_ELEC_BILL_TRAN_FLOW
  is '银联网联交易关系子表';
comment on column RRP_MDL.O_IML_EVT_ELEC_BILL_TRAN_FLOW.evt_id
