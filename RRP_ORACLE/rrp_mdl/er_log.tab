create table RRP_MDL.ER_LOG
(
  res_time DATE,
  res      VARCHAR2(4000)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.ER_LOG
  is 'er日志';
comment on column RRP_MDL.ER_LOG.res
  is '结果Y或者N';

