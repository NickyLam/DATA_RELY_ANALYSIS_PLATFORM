create table RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01
(
  cust_id                 VARCHAR2(60),
  open_acct_brac_id       VARCHAR2(60),
  onl_bank_cust_status_cd VARCHAR2(10),
  open_acct_tm            TIMESTAMP(6),
  final_tran_tm           TIMESTAMP(6),
  sign_yqt_flg            VARCHAR2(10),
  sign_yqt_tm             TIMESTAMP(6),
  oa_wrtoff_tm            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.cust_id
  is '客户号';
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.open_acct_brac_id
  is '开户网点编号';
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.onl_bank_cust_status_cd
  is '网银客户状态代码';
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.open_acct_tm
  is '开户时间';
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.final_tran_tm
  is '最后交易时间';
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.sign_yqt_flg
  is '签约银企通标志';
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.sign_yqt_tm
  is '签约银企通时间';
comment on column RRP_MDL.TMP_M_MRPT_CONL_BK_CUST_DTL_01.oa_wrtoff_tm
  is 'OA注销时间';

