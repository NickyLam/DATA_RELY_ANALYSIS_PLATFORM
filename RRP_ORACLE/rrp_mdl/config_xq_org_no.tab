create table RRP_MDL.CONFIG_XQ_ORG_NO
(
  org_no     VARCHAR2(128),
  tar_org_no VARCHAR2(128),
  ys_org_no  VARCHAR2(128)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

