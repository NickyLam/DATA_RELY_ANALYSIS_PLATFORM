create table RRP_MDL.O_IOL_FAMS_REP_ASSET_POSITION
(
  cdate             VARCHAR2(50),
  assetcode         VARCHAR2(50),
  assetname         VARCHAR2(200),
  vdate             VARCHAR2(50),
  mdate             VARCHAR2(50),
  custrate          VARCHAR2(50),
  basis             VARCHAR2(50),
  position          NUMBER(30,2),
  criceamt          NUMBER(30,2),
  tdylossamt        NUMBER(30,2),
  unpayamt          NUMBER(30,2),
  friceamt          NUMBER(30,2),
  sppiactmdate      VARCHAR2(50),
  accounttype       VARCHAR2(10),
  assettype         VARCHAR2(50),
  detailassettype   VARCHAR2(200),
  profittype        VARCHAR2(10),
  assettypeone      VARCHAR2(10),
  assettypetwo      VARCHAR2(10),
  assettypethree    VARCHAR2(10),
  assettypefour     VARCHAR2(10),
  assettypesecone   VARCHAR2(10),
  assettypesectwo   VARCHAR2(10),
  assettypeissueone VARCHAR2(10),
  maingrade         VARCHAR2(50),
  maingradeorg      VARCHAR2(50),
  creditgrade       VARCHAR2(50),
  creditgradeorg    VARCHAR2(50),
  termtype          VARCHAR2(50),
  investnature      VARCHAR2(50),
  isstandasset      VARCHAR2(10),
  investmenttype    VARCHAR2(10),
  customername      VARCHAR2(200),
  create_user       VARCHAR2(20),
  create_dept       VARCHAR2(32),
  create_time       TIMESTAMP(6),
  update_user       VARCHAR2(20),
  update_time       TIMESTAMP(6),
  start_dt          DATE,
  end_dt            DATE,
  id_mark           VARCHAR2(10),
  etl_timestamp     TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_FAMS_REP_ASSET_POSITION
  is '报表单据-账户持仓表';
comment on column RRP_MDL.O_IOL_FAMS_REP_ASSET_POSITION.cdate
  is '日期';
