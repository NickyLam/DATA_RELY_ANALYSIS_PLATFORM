create table RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB
(
  data_dt            CHAR(8) not null,
  lgl_rep_id         VARCHAR2(200),
  grp_cust_id        VARCHAR2(200) not null,
  act_cntlr_typ      VARCHAR2(10),
  ctry_cd            VARCHAR2(10),
  act_cntlr_nm       VARCHAR2(500),
  act_cntlr_cust_id  VARCHAR2(200),
  act_cntlr_crdl_typ VARCHAR2(10),
  act_cntlr_crdl_no  VARCHAR2(100) not null,
  regd_cd            VARCHAR2(200),
  dept_line          VARCHAR2(500),
  data_src           VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB
  is '集团客户实际控制人子表';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.grp_cust_id
  is '集团客户编号';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.act_cntlr_typ
  is '实际控制人类型';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.ctry_cd
  is '国家代码';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.act_cntlr_nm
  is '实际控制人名称';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.act_cntlr_cust_id
  is '实际控制人客户编号';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.act_cntlr_crdl_typ
  is '实际控制人证件类型';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.act_cntlr_crdl_no
  is '实际控制人证件号码';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.regd_cd
  is '登记注册代码';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.M_CUST_CORP_GRPCNTLR_SUB.data_src
  is '数据来源';

