create table RRP_MDL.O_ICL_CMM_CORP_LOAN_APPL_INFO
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  loan_appl_flow_num       VARCHAR2(60),
  rela_appl_flow_num       VARCHAR2(60),
  bus_breed_id             VARCHAR2(60),
  std_prod_id              VARCHAR2(60),
  cust_id                  VARCHAR2(60),
  appl_dt                  DATE,
  oper_org_cd              VARCHAR2(60),
  operr_id                 VARCHAR2(60),
  oper_dt                  DATE,
  rgst_org_cd              VARCHAR2(60),
  rgstrat_id               VARCHAR2(60),
  rgst_dt                  DATE,
  appl_way_cd              VARCHAR2(60),
  tenor_mon                NUMBER(10),
  loan_tenor               NUMBER(10),
  circl_lmt_flg            VARCHAR2(10),
  curr_cd                  VARCHAR2(10),
  appl_amt                 NUMBER(30,2),
  apved_dt                 DATE,
  latest_apv_amt           NUMBER(30,2),
  happ_type_cd             VARCHAR2(30),
  cap_src_cd               VARCHAR2(10),
  crdt_agt_id              VARCHAR2(60),
  bank_fin_tot             NUMBER(30,2),
  major_guartor_id         VARCHAR2(60),
  major_guar_way_cd        VARCHAR2(10),
  guar_way_1               VARCHAR2(10),
  guar_way_2               VARCHAR2(10),
  other_guar_way_flg       VARCHAR2(10),
  major_guartor_name       VARCHAR2(250),
  main_repay_way_cd        VARCHAR2(10),
  repay_ped_cd             VARCHAR2(10),
  sub_repay_way_cd         VARCHAR2(10),
  dir_cd                   VARCHAR2(10),
  usage_descb              VARCHAR2(2000),
  other_usage_descb        VARCHAR2(200),
  effect_flg               VARCHAR2(10),
  cust_type_cd             VARCHAR2(10),
  camp_corp_name           VARCHAR2(60),
  camp_chn_id              VARCHAR2(60),
  host_bk_bank_no          VARCHAR2(60),
  host_bank_name           VARCHAR2(250),
  patip_loan_bank_bank_no  VARCHAR2(250),
  patip_loan_bank_name     VARCHAR2(500),
  agent_bank_bank_no       VARCHAR2(60),
  agent_bank_name          VARCHAR2(250),
  agent_patip_loan_flg     VARCHAR2(10),
  low_risk_bus_flg         VARCHAR2(10),
  risk_type_cd             VARCHAR2(30),
  asset_risk_cls_cd        VARCHAR2(10),
  crdt_rg_cd               VARCHAR2(10),
  class_crdt_flg           VARCHAR2(10),
  group_crdt_corp_lmt      NUMBER(30,2),
  group_crdt_corp_open     NUMBER(30,2),
  group_crdt_ibank_lmt     NUMBER(30,2),
  group_crdt_ibank_open    NUMBER(30,2),
  loan_insure_guar_flg     VARCHAR2(10),
  remote_loan_flg          VARCHAR2(10),
  estate_fin_flg           VARCHAR2(10),
  gover_fin_flg            VARCHAR2(10),
  consm_serv_fin_flg       VARCHAR2(10),
  br_build_ifin_flg        VARCHAR2(10),
  green_crdt_fin_flg       VARCHAR2(10),
  turn_crdt_flg            VARCHAR2(10),
  bar_flg                  VARCHAR2(10),
  ta_crdt_flg              VARCHAR2(10),
  risk_mgr_simus_oper_flg  VARCHAR2(11),
  sm_flg                   VARCHAR2(10),
  ky_l_flg                 VARCHAR2(10),
  ts_flg                   VARCHAR2(10),
  apv_rest_flow_num        VARCHAR2(60),
  o_use_lmt_all_id         VARCHAR2(60),
  o_use_lmt_id             VARCHAR2(60),
  o_use_lmt_type_cd        VARCHAR2(60),
  ext_rating_rest_cd       VARCHAR2(60),
  ext_rating_org_name      VARCHAR2(250),
  ext_rating_dt            DATE,
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6),
  lmt_under_sellbl_prod_id VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
