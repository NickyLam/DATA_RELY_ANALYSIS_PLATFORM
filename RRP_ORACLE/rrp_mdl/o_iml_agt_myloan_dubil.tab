create table RRP_MDL.O_IML_AGT_MYLOAN_DUBIL
(
  agt_id                   VARCHAR2(100),
  lp_id                    VARCHAR2(60),
  dubil_id                 VARCHAR2(100),
  ext_prod_id              VARCHAR2(60),
  loan_status_cd           VARCHAR2(10),
  loan_usage_cd            VARCHAR2(10),
  loan_cap_use_position_cd VARCHAR2(10),
  distr_dt                 DATE,
  curr_cd                  VARCHAR2(10),
  distr_amt                NUMBER(30,2),
  loan_value_dt            DATE,
  loan_exp_dt              DATE,
  loan_cont_tenor          NUMBER(10),
  repay_way_cd             VARCHAR2(10),
  grace_period_days        NUMBER(10),
  src_int_rat_type_cd      VARCHAR2(10),
  int_rat_adj_way_cd       VARCHAR2(10),
  int_rat_adj_ped_corp_cd  VARCHAR2(10),
  int_rat_adj_ped_freq     VARCHAR2(10),
  loan_actl_day_int_rat    NUMBER(18,8),
  pric_repay_freq_cd       VARCHAR2(10),
  int_repay_freq_cd        VARCHAR2(10),
  guar_type_cd             VARCHAR2(10),
  crdt_appl_id             VARCHAR2(100),
  recvbl_num_type_cd       VARCHAR2(30),
  recvbl_acct_name         VARCHAR2(500),
  recvbl_acct_id           VARCHAR2(100),
  recvbl_bank_name         VARCHAR2(500),
  repay_num_type_cd        VARCHAR2(30),
  repay_acct_name          VARCHAR2(500),
  repay_acct_id            VARCHAR2(100),
  repay_bank_name          VARCHAR2(500),
  prod_type_cd             VARCHAR2(30),
  acctnt_dt                DATE,
  cont_status_cd           VARCHAR2(10),
  payoff_dt                DATE,
  loan_level5_cls_cd       VARCHAR2(10),
  acru_non_acru_flg        VARCHAR2(10),
  next_repay_dt            DATE,
  unpayoff_perds           NUMBER(10),
  ovdue_pd_cnt             NUMBER(10),
  pric_ovdue_days          NUMBER(10),
  int_ovdue_days           NUMBER(10),
  nomal_pric_bal           NUMBER(30,2),
  ovdue_pric_bal           NUMBER(30,2),
  loan_dir_indus_cd        VARCHAR2(10),
  cust_id                  VARCHAR2(60),
  cust_mgr_id              VARCHAR2(60),
  nomal_int_bal            NUMBER(30,2),
  ovdue_int_bal            NUMBER(30,2),
  ovdue_pric_pnlt_bal      NUMBER(30,2),
  ovdue_int_pnlt_bal       NUMBER(30,2),
  loan_exec_year_int_rat   NUMBER(18,10),
  lpr_int_rat              NUMBER(18,10),
  int_rat_float_spread_val NUMBER(18,10),
  int_rat_float_dir_cd     VARCHAR2(10),
  base_rat_type_cd         VARCHAR2(10),
  tran_type_cd             VARCHAR2(10),
  asset_thd_cls_cd         VARCHAR2(30),
  prod_id                  VARCHAR2(100),
  contri_type_cd           VARCHAR2(30),
  contri_ratio             NUMBER(38,8),
  white_list_cust_flg      VARCHAR2(10),
  cust_char_cd             VARCHAR2(30),
  farm_flg                 VARCHAR2(10),
  create_dt                DATE,
  update_dt                DATE,
  etl_dt                   DATE,
  src_table_name           VARCHAR2(100),
  happ_way_cd              VARCHAR2(30)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
