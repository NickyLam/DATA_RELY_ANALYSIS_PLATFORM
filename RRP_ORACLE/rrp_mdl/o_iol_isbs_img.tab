  is '未知';
comment on column RRP_MDL.O_IOL_ISBS_IMG.vldflg
  is '未知';
comment on column RRP_MDL.O_IOL_ISBS_IMG.fpid
  is '未知';
comment on column RRP_MDL.O_IOL_ISBS_IMG.invtp
  is '未知';
comment on column RRP_MDL.O_IOL_ISBS_IMG.invnb
  is '未知';
comment on column RRP_MDL.O_IOL_ISBS_IMG.invoicecode
  is '未知';
comment on column RRP_MDL.O_IOL_ISBS_IMG.untaxamt
  is '未知';
comment on column RRP_MDL.O_IOL_ISBS_IMG.invdt
  is '未知';
