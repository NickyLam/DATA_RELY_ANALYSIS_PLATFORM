comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.kpzt
  is '卡片状态';
comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.bbz
  is '备注';
comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.cjrq
  is '创建日期';
comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.dept_no
  is '部门编号';
comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.src_sys_id
