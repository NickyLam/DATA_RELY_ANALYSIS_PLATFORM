comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.address
  is '用户地址';
comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.yhjgdm
  is '银行机构代码';
comment on column RRP_MDL.EAST5_301_JJKXXB_TMP.khmc_orig
