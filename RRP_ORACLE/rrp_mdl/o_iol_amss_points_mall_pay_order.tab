create table RRP_MDL.O_IOL_AMSS_POINTS_MALL_PAY_ORDER
(
  serial_num            VARCHAR2(48),
  txn_date              TIMESTAMP(6),
  txn_time              TIMESTAMP(6),
  order_num             VARCHAR2(192),
  pay_type              NUMBER(1),
  pty_id                VARCHAR2(48),
  pty_rank              VARCHAR2(48),
  pty_name              VARCHAR2(48),
  iden_type_cd          VARCHAR2(48),
  cert_num              VARCHAR2(48),
  pty_open_org          VARCHAR2(48),
  agents_id             VARCHAR2(48),
  mrchd_type            NUMBER(1),
  txn_code              VARCHAR2(48),
  gross_qtty_amt        NUMBER(10,2),
  gross_qtty_points     NUMBER(10,2),
  points_type           VARCHAR2(48),
  entitlement_point     NUMBER(10,2),
  rem_amt               NUMBER(10,2),
  rem_points            NUMBER(10,2),
  rem_entitlement_point NUMBER(10,2),
  txn_status            VARCHAR2(3),
  payment_success_date  TIMESTAMP(6),
  pay_card_num          VARCHAR2(48),
  open_org_num          VARCHAR2(192),
  acct_num_name         VARCHAR2(192),
  bank_name             VARCHAR2(192),
  exch_brch_no          VARCHAR2(48),
  card_type             NUMBER(1),
  wthr_check_bal        NUMBER(1),
  fret_amt              NUMBER(10,2),
  cons_name             VARCHAR2(48),
  cons_ceph_num         VARCHAR2(48),
  cons_loc_prov         VARCHAR2(48),
  cons_loc_city         VARCHAR2(48),
  cons_loc_cuty         VARCHAR2(48),
  cons_loc_town         VARCHAR2(48),
  cons_dtl_loc          VARCHAR2(192),
  pick_goods_mode       VARCHAR2(48),
  pty_mgr_num           VARCHAR2(48),
  txn_org_num           VARCHAR2(48),
  orig_order_num        VARCHAR2(192),
  orig_trx_dt           VARCHAR2(48),
  srv_resp_code         VARCHAR2(48),
  srv_resp_info         VARCHAR2(384),
  merch_num             VARCHAR2(48),
  channel_id            VARCHAR2(48),
  cnsm_typ              NUMBER(1),
  physics_flag          NUMBER(1),
  create_time           TIMESTAMP(6),
  update_time           TIMESTAMP(6),
  create_emp            VARCHAR2(48),
  update_emp            VARCHAR2(48),
  pay_serial_num        VARCHAR2(48),
  pay_order_num         VARCHAR2(48),
  gross_fjl             NUMBER(10,2),
  rem_flj               NUMBER(10,2),
  return_flag           NUMBER(1),
  txn_num               VARCHAR2(180),
  notify_flag           NUMBER(1),
  notify_count          NUMBER(2),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_AMSS_POINTS_MALL_PAY_ORDER
  is '积分商城-订单表';
comment on column RRP_MDL.O_IOL_AMSS_POINTS_MALL_PAY_ORDER.serial_num
