create table RRP_MDL.O_IOL_FAMS_CHB_MONTH_REPORT_DETAIL
(
  termid               VARCHAR2(40),
  reporttype           VARCHAR2(20),
  propertycode         VARCHAR2(40),
  prodcounts           NUMBER(10),
  prodamount           NUMBER(24,6),
  prodnetamount        NUMBER(24,6),
  durationprodcounts   NUMBER(10),
  balance              NUMBER(24,6),
  bottombalance        NUMBER(24,6),
  customerprofit       NUMBER(24,6),
  bankprofit           NUMBER(24,6),
  prodyield            NUMBER(24,6),
  detailuuid           VARCHAR2(72),
  org_code             VARCHAR2(40),
  dept_code            VARCHAR2(40),
  reportuuid           VARCHAR2(72),
  etl_dt               DATE,
  prodpayamount        NUMBER(20,6),
  xgdurationprodcounts NUMBER(10),
  xgbalance            NUMBER(24,6),
  xgbottombalance      NUMBER(24,6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
