create table RRP_MDL.O_IML_EVT_CUST_ON_ACCT_TRAN
(
  evt_id                   VARCHAR2(250),
  lp_id                    VARCHAR2(100),
  on_acct_seq_num          VARCHAR2(60),
  on_acct_sub_acct_num     VARCHAR2(60),
  curr_cd                  VARCHAR2(30),
  cust_acct_num            VARCHAR2(60),
  cust_type_cd             VARCHAR2(30),
  cust_id                  VARCHAR2(100),
  cust_name                VARCHAR2(500),
  cert_no                  VARCHAR2(60),
  cert_type_cd             VARCHAR2(30),
  appl_cust_id             VARCHAR2(100),
  debit_crdt_flg           VARCHAR2(10),
  on_acct_tot              NUMBER(30,2),
  on_acct_amt              NUMBER(30,2),
  on_acct_bal              NUMBER(30,2),
  on_acct_exp_dt           DATE,
  cap_src_cd               VARCHAR2(30),
  tran_ref_no              VARCHAR2(60),
  tran_dt                  DATE,
  tran_tm                  DATE,
  tran_status_cd           VARCHAR2(30),
  cntpty_acct_name         VARCHAR2(500),
  cntpty_acct_id           VARCHAR2(100),
  cntpty_open_acct_org_id  VARCHAR2(100),
  cntpty_acct_bank_int_flg VARCHAR2(10),
  tran_teller_id           VARCHAR2(100),
  tran_org_id              VARCHAR2(100),
  tran_memo_descb          VARCHAR2(500),
  stl_acct_name            VARCHAR2(500),
  stl_acct_id              VARCHAR2(100),
  gold_bus_id              VARCHAR2(100),
  auth_teller_id           VARCHAR2(100),
  last_modif_dt            DATE,
  final_modif_dt           DATE,
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_CUST_ON_ACCT_TRAN
