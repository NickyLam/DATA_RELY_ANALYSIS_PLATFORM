create table RRP_MDL.O_IML_PRD_IBANK_CASHFLOW_DTL_H
(
  fin_instm_id       VARCHAR2(60),
  asset_type_id      VARCHAR2(60),
  market_type_id     VARCHAR2(60),
  lp_id              VARCHAR2(60),
  task_group_id      VARCHAR2(60),
  cashflow_id        VARCHAR2(60),
  int_rat_flow_id    VARCHAR2(60),
  pricing_envir_id   VARCHAR2(60),
  cfm_cashflow_flg   NUMBER(38,6),
  calc_dt            DATE,
  int_accr_start_dt  DATE,
  int_accr_end_dt    DATE,
  pay_dt             DATE,
  pay_amt            NUMBER(38,6),
  disct_rat          NUMBER(38,6),
  pric_amt           NUMBER(38,6),
  pre_pric_amt       NUMBER(38,6),
  int_amt            NUMBER(38,6),
  pre_int_amt        NUMBER(38,6),
  pay_bf_pric        NUMBER(38,6),
  pay_post_pric      NUMBER(38,6),
  option_premium     NUMBER(38,6),
  pre_option_premium NUMBER(38,6),
  curr_cd            VARCHAR2(30),
  stl_curr_cd        VARCHAR2(30),
  accu_pd            NUMBER(38,6),
  real_fin_instm_id  VARCHAR2(60),
  src_update_tm      DATE,
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
