  relativeserialno           VARCHAR2(64),
  remark                     VARCHAR2(3000),
  returnedaftermoney         NUMBER(24,6),
  returnedbeforemoney        NUMBER(24,6),
  returnedmoney              NUMBER(24,6),
  returnedmoneysum           NUMBER(24,6),
  serialno                   VARCHAR2(64),
  sqamount                   NUMBER(24,6),
  tradingplatform            VARCHAR2(32),
  transferaccount            VARCHAR2(200),
