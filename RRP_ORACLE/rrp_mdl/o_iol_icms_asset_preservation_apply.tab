  handledesc                 VARCHAR2(3000),
  disposaldate               VARCHAR2(24),
  creditbalance              NUMBER(24,6),
  lossamount                 NUMBER(24,6),
  customertype               VARCHAR2(20),
  gurantytype                VARCHAR2(20),
