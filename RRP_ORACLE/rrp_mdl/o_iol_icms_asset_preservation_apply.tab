  transferactualprice        NUMBER(24,6),
  transfercontractno         VARCHAR2(500),
  transferprice              NUMBER(24,6),
  transfertype               VARCHAR2(32),
  updatedate                 DATE,
  updateorgid                VARCHAR2(64),
  updateuserid               VARCHAR2(64),
  usetossfdj                 NUMBER(24,6),
  writeofftype               VARCHAR2(32),
  ysaccount                  VARCHAR2(200),
  ysaccountname              VARCHAR2(200),
  ysamount                   NUMBER(24,6),
  debtrepayassetid           VARCHAR2(64),
  debtrepayassetname         VARCHAR2(200),
  debtrepaysum               NUMBER(24,6),
  receivedate                DATE,
  debtrepayassettype         VARCHAR2(48),
  debtrepaymenttype          VARCHAR2(48),
