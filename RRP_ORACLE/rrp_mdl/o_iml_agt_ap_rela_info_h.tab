create table RRP_MDL.O_IML_AGT_AP_RELA_INFO_H
(
  agt_id         VARCHAR2(250),
  lp_id          VARCHAR2(100),
  disp_prop_id   VARCHAR2(100),
  obj_rela_id    VARCHAR2(250),
  obj_type_cd    VARCHAR2(250),
  obj_id         VARCHAR2(250),
  obj_name       VARCHAR2(1000),
  rela_dt        DATE,
  exec_status_cd VARCHAR2(30),
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10),
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10),
  etl_timestamp  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
comment on table RRP_MDL.O_IML_AGT_AP_RELA_INFO_H
  is '资产处置关联信息历史';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.agt_id
  is '协议编号';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.disp_prop_id
  is '处置方案编号';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.obj_rela_id
  is '对象关联编号';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.obj_type_cd
  is '对象类型代码';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.obj_id
  is '对象编号';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.obj_name
  is '对象名称';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.rela_dt
  is '关联日期';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.exec_status_cd
  is '执行状态代码';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.job_cd
  is '任务编码';
comment on column RRP_MDL.O_IML_AGT_AP_RELA_INFO_H.etl_timestamp
  is 'ETL处理时间戳';

