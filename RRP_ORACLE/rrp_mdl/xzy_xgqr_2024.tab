create table RRP_MDL.XZY_XGQR_2024
(
  序号        VARCHAR2(200),
  需求名称      VARCHAR2(1000),
  提出部门      VARCHAR2(600),
  是否满足业务需求  VARCHAR2(60),
  需求效果确认表编号 VARCHAR2(120),
  备注        VARCHAR2(2000)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

