create table RRP_MDL.O_IML_EVT_OS_INVEST_FINC_BUS_FLOW
(
  evt_id                       VARCHAR2(60),
  lp_id                        VARCHAR2(60),
  flow_num                     VARCHAR2(60),
  tran_dt                      DATE,
  tran_tm                      VARCHAR2(100),
  tran_code                    VARCHAR2(100),
  tran_status_cd               VARCHAR2(10),
  tran_return_code             VARCHAR2(100),
  fail_rs                      VARCHAR2(2000),
  tran_acct_num                VARCHAR2(60),
  tran_amt                     NUMBER(30,2),
  curr_cd                      VARCHAR2(10),
  whole_unify_cust_id          VARCHAR2(60),
  user_seq_id                  VARCHAR2(60),
  tran_chn_cd                  VARCHAR2(60),
  chn_send_flow_num            VARCHAR2(100),
  sorc_sys_flow_num            VARCHAR2(100),
  core_tran_flow_num           VARCHAR2(60),
  comm_fee                     NUMBER(30,2),
  visit_flow_num               VARCHAR2(100),
  core_tran_dt                 DATE,
  cust_ip_num                  VARCHAR2(250),
  curr_server_host_name        VARCHAR2(60),
  cust_termn_mac_addr          VARCHAR2(60),
  cust_termn_oper_sys_edit_num VARCHAR2(60),
  cust_termn_brow              VARCHAR2(60),
  cust_termn_equip_model       VARCHAR2(60),
  cust_termn_equip_id          VARCHAR2(100),
  logon_session_id             VARCHAR2(200),
  rela_flow_num                VARCHAR2(60),
  tran_jnl_info                VARCHAR2(2000),
  tran_type_code               VARCHAR2(100),
  cust_name                    VARCHAR2(200),
  save_cert_way_cd             VARCHAR2(10),
  camp_job_no                  VARCHAR2(60),
  pbc_flow_num                 VARCHAR2(60),
  tran_order_no                VARCHAR2(60),
  chain_way_track_no           VARCHAR2(100),
  sys_flow_num                 VARCHAR2(100),
  chn_id                       VARCHAR2(30),
  etl_dt                       DATE,
  src_table_name               VARCHAR2(100),
  job_cd                       VARCHAR2(10),
  etl_timestamp                TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
