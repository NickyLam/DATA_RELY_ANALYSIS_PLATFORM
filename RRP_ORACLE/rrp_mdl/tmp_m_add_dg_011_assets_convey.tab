create table RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY
(
  data_date    VARCHAR2(10),
  acct_org_num VARCHAR2(20),
  jywym        VARCHAR2(90),
  zwjgmc       VARCHAR2(300),
  khwym        VARCHAR2(45),
  khmc         VARCHAR2(150),
  cplx         VARCHAR2(30),
  cpmc         VARCHAR2(150),
  zqzrrq       VARCHAR2(15),
  zrfslb       VARCHAR2(75),
  zrfs         VARCHAR2(75),
  dybj         NUMBER(20,6),
  dzhzrhsxj    NUMBER(20,6),
  zrshqtdj     NUMBER(20,6),
  zcje         NUMBER(20,6),
  zczrjypt     VARCHAR2(150),
  zczrdjpt     VARCHAR2(150),
  zjjydslb     VARCHAR2(150),
  jydsmc       VARCHAR2(300),
  zqzryz       NUMBER(20,6),
  zqzrxyje     NUMBER(20,6),
  djptdjje     NUMBER(20,6),
  sys_source   VARCHAR2(150),
  sfsc         VARCHAR2(15),
  rmyhjydslb   VARCHAR2(150)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY
  is '补录表-对公-资产转让模型';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.data_date
  is '数据日期                 ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.acct_org_num
  is '账务机构编号             ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.jywym
  is '交易唯一码               ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zwjgmc
  is '账务机构名称             ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.khwym
  is '客户唯一码               ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.khmc
  is '客户名称                 ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.cplx
  is '产品类型                 ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.cpmc
  is '产品名称                 ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zqzrrq
  is '债权转让日期             ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zrfslb
  is '转让方式类别             ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zrfs
  is '转让方式                 ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.dybj
  is '对应本金                 ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.dzhzrhsxj
  is '调整后转让回收现金（元） ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zrshqtdj
  is '转让收回其他对价（元）   ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zcje
  is '自持金额（元）           ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zczrjypt
  is '资产转让交易平台         ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zczrdjpt
  is '资产转让登记平台         ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zjjydslb
  is '直接交易对手类别         ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.jydsmc
  is '交易对手名称             ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zqzryz
  is '债权转让原值（元）       ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.zqzrxyje
  is '债权转让协议金额（元）   ';
comment on column RRP_MDL.TMP_M_ADD_DG_011_ASSETS_CONVEY.djptdjje
