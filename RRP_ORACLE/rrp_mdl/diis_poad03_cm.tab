create table RRP_MDL.DIIS_POAD03_CM
(
  name         VARCHAR2(400),
  cust_id      VARCHAR2(100),
  fin_org_type VARCHAR2(40),
  fin_org_code VARCHAR2(28),
  uscc         VARCHAR2(100),
  obj_name     VARCHAR2(400),
  obj_id_type  VARCHAR2(4),
  obj_id_no    VARCHAR2(100),
  acct_no      VARCHAR2(64),
  tel_no       VARCHAR2(60),
  addr         VARCHAR2(180),
  data_dt      VARCHAR2(20)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.DIIS_POAD03_CM
  is '同业交易对手信息补充表';
comment on column RRP_MDL.DIIS_POAD03_CM.name
  is '债权人名称';
comment on column RRP_MDL.DIIS_POAD03_CM.cust_id
  is '识别码';
comment on column RRP_MDL.DIIS_POAD03_CM.fin_org_type
  is '金融机构类型';
comment on column RRP_MDL.DIIS_POAD03_CM.fin_org_code
  is '金融机构编码';
comment on column RRP_MDL.DIIS_POAD03_CM.uscc
  is '统一社会信用代码';
comment on column RRP_MDL.DIIS_POAD03_CM.obj_name
  is '法定代表人或单位负责人姓名';
comment on column RRP_MDL.DIIS_POAD03_CM.obj_id_type
  is '法定代表人或单位负责人证件类型';
comment on column RRP_MDL.DIIS_POAD03_CM.obj_id_no
  is '法定代表人或单位负责人证件号码';
comment on column RRP_MDL.DIIS_POAD03_CM.acct_no
  is '债权账户号码';
comment on column RRP_MDL.DIIS_POAD03_CM.tel_no
  is '单位联系电话';
comment on column RRP_MDL.DIIS_POAD03_CM.addr
  is '单位地址';
comment on column RRP_MDL.DIIS_POAD03_CM.data_dt
  is '数据日期';

