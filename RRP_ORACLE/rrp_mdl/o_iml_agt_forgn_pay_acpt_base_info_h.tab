create table RRP_MDL.O_IML_AGT_FORGN_PAY_ACPT_BASE_INFO_H
(
  agt_id                VARCHAR2(250),
  lp_id                 VARCHAR2(100),
  decl_id               VARCHAR2(100),
  temp_decl_flow_id     VARCHAR2(100),
  init_enty_id          VARCHAR2(100),
  oper_type_cd          VARCHAR2(30),
  modif_rs_comnt        VARCHAR2(750),
  decl_num              VARCHAR2(60),
  payer_type_cd         VARCHAR2(30),
  id_card_piece_no_code VARCHAR2(60),
  orgnz_cd              VARCHAR2(30),
  payer_name            VARCHAR2(750),
  recver_name           VARCHAR2(750),
  pay_curr_cd           VARCHAR2(30),
  pay_amt               NUMBER(30,2),
  remit_out_exch_rat    NUMBER(18,8),
  remit_out_amt         NUMBER(30,2),
  cny_acct_id           VARCHAR2(100),
  spot_exch_amt         NUMBER(30,2),
  fx_acct_id            VARCHAR2(100),
  other_amt             NUMBER(30,2),
  other_acct_id         VARCHAR2(100),
  stl_way_cd            VARCHAR2(30),
  bank_bus_id           VARCHAR2(100),
  actl_pay_curr_cd      VARCHAR2(30),
  actl_pay_amt          NUMBER(30,2),
  deduct_curr_cd        VARCHAR2(30),
  deduct_amt            NUMBER(30,2),
  lc_id                 VARCHAR2(100),
  issue_dt              DATE,
  tenor                 NUMBER(10),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  src_table_name        VARCHAR2(100),
  job_cd                VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
