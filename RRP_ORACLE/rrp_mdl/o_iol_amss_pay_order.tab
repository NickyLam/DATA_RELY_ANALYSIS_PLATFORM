create table RRP_MDL.O_IOL_AMSS_PAY_ORDER
(
  order_no                   VARCHAR2(32),
  mch_id                     NUMBER(11),
  mch_no                     VARCHAR2(16),
  mch_name                   VARCHAR2(128),
  out_trade_no               VARCHAR2(32),
  money                      NUMBER(11),
  refund_money               NUMBER(11),
  trade_state                NUMBER(11),
  add_time                   TIMESTAMP(6),
  trade_time                 TIMESTAMP(6),
  total_fee                  NUMBER(11),
  transaction_id             VARCHAR2(64),
  trade_type                 VARCHAR2(32),
  trade_name                 VARCHAR2(64),
  notify_state               NUMBER(1),
  notify_time                TIMESTAMP(6),
  charset                    VARCHAR2(6),
  sign_type                  VARCHAR2(16),
  update_version             NUMBER(11),
  center_id                  NUMBER(11),
  decrypt_key                VARCHAR2(16),
  notify_url                 VARCHAR2(255),
  fee_type                   VARCHAR2(10),
  cash_fee_type              VARCHAR2(10),
  cash_fee                   NUMBER(11),
  termtype                   VARCHAR2(32),
  termno                     VARCHAR2(32),
  shopno                     VARCHAR2(32),
  groupno                    VARCHAR2(32),
  bank_no                    VARCHAR2(32),
  agentno                    VARCHAR2(32),
  operno                     VARCHAR2(32),
  deparno                    VARCHAR2(32),
  body                       VARCHAR2(128),
  bank_type                  VARCHAR2(32),
  attach                     VARCHAR2(255),
  device_info                VARCHAR2(32),
  appid                      VARCHAR2(64),
  partner                    VARCHAR2(32),
  openid                     VARCHAR2(255),
  is_subscribe               VARCHAR2(16),
  coupon_fee                 NUMBER(11),
  mch_create_ip              VARCHAR2(32),
  pay_create_ip              VARCHAR2(32),
  return_url                 VARCHAR2(512),
  sub_partner                VARCHAR2(32),
  sub_appid                  VARCHAR2(64),
  sub_openid                 VARCHAR2(255),
  sub_is_subscribe           VARCHAR2(16),
  agentid                    VARCHAR2(32),
  data_sign                  VARCHAR2(128),
  modify_time                TIMESTAMP(6),
  fld_s1                     VARCHAR2(256),
  fld_s2                     VARCHAR2(256),
  fld_n1                     NUMBER(11),
  fld_n2                     NUMBER(11),
  fld_d1                     TIMESTAMP(6),
  client_type                VARCHAR2(32),
  sign_agentno               VARCHAR2(32),
  client_ip                  VARCHAR2(32),
  used_groupno               VARCHAR2(1),
  mch_discount_amount        NUMBER(13),
  plat_discount_amount       NUMBER(13),
  mch_rate_type              NUMBER(1),
  mch_rate                   NUMBER(11),
  cost_rate                  NUMBER(11),
  mch_theory_procedure_fee   NUMBER(13),
  mch_real_procedure_fee     NUMBER(13),
  mch_discount_fee           NUMBER(13),
  debit_card_brokerage_limit NUMBER(13),
  calc_state                 NUMBER(1),
  api_provider               NUMBER(11),
  acc_way_period             NUMBER(5),
  pay_center_id              VARCHAR2(32),
  quick_serial_no            VARCHAR2(256),
  acct_dt                    VARCHAR2(32),
  start_dt                   DATE,
  end_dt                     DATE,
  id_mark                    VARCHAR2(10),
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_AMSS_PAY_ORDER
  is '订单表';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.order_no
  is '订单号';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.mch_id
  is '商户ID.商户自增ID';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.mch_no
  is '商户编号.商户编号';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.mch_name
  is '商户名称';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.out_trade_no
  is '商户订单号';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.money
  is '交易金额';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.refund_money
  is '退款金额';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.trade_state
  is '交易状态.1：未支付，2：支付成功，3：已关闭，4：转入退款，8：已冲正，9：已撤销';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.add_time
  is '添加时间';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.trade_time
  is '交易时间';
