  is '通知状态';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.notify_time
  is '成功通知时间';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.charset
  is '消息编码';
