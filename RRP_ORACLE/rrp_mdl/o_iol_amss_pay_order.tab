comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.is_subscribe
  is '是否关注受理商户';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.coupon_fee
  is '优惠券金额';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.mch_create_ip
  is '商户服务器的IP';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.pay_create_ip
  is '支付服务器的IP';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.return_url
  is '回调URL';
comment on column RRP_MDL.O_IOL_AMSS_PAY_ORDER.sub_partner
