create table RRP_MDL.O_IML_PTY_SPV_CUST_INFO
(
  party_id             VARCHAR2(60),
  lp_id                VARCHAR2(60),
  spv_cust_id          VARCHAR2(100),
  spv_id               VARCHAR2(60),
  spv_name             VARCHAR2(250),
  spv_type_cd          VARCHAR2(30),
  am_prod_stat_type_id VARCHAR2(100),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  src_table_name       VARCHAR2(100),
  job_cd               VARCHAR2(10),
  cash_mgmt_prod_flg   VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_SPV_CUST_INFO
  is 'SPV客户信息';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.party_id
  is '当事人编号';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.spv_cust_id
  is 'SPV客户编号';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.spv_id
  is '特定目的载体编号';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.spv_name
  is 'SPV名称';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.spv_type_cd
  is 'SPV类型代码';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.am_prod_stat_type_id
  is '资管产品统计类型编号';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.start_dt
  is '起始日期';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.end_dt
  is '截止日期';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.job_cd
  is '任务代码';
comment on column RRP_MDL.O_IML_PTY_SPV_CUST_INFO.cash_mgmt_prod_flg
  is '现金管理产品标志';

