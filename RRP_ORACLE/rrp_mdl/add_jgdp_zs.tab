create table RRP_MDL.ADD_JGDP_ZS
(
  rpt_sys     VARCHAR2(64),
  rpt_batch   VARCHAR2(32),
  rpt_date_zs VARCHAR2(32),
  rpt_date_ht VARCHAR2(16),
  rpt_num     VARCHAR2(16),
  rpt_situate VARCHAR2(64),
  rpt_org     VARCHAR2(32),
  memo        VARCHAR2(256),
  memo_1      VARCHAR2(256),
  memo_2      VARCHAR2(256),
  memo_3      VARCHAR2(256)
)
partition by list (RPT_DATE_HT)
(
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 0
    initrans 1
    maxtrans 255,
  partition PARTITION_20231231 values ('20231231')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20240101 values ('20240101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.ADD_JGDP_ZS
  is '监管大屏展示补录表';
comment on column RRP_MDL.ADD_JGDP_ZS.rpt_sys
  is '报送系统/模块';
comment on column RRP_MDL.ADD_JGDP_ZS.rpt_batch
  is '报送批次';
comment on column RRP_MDL.ADD_JGDP_ZS.rpt_date_zs
  is '最晚报送时间';
comment on column RRP_MDL.ADD_JGDP_ZS.rpt_date_ht
  is '报送日期（后台）';
comment on column RRP_MDL.ADD_JGDP_ZS.rpt_num
  is '报表数';
comment on column RRP_MDL.ADD_JGDP_ZS.rpt_situate
  is '报送情况';
comment on column RRP_MDL.ADD_JGDP_ZS.rpt_org
  is '机构号';
comment on column RRP_MDL.ADD_JGDP_ZS.memo
  is '备注';
comment on column RRP_MDL.ADD_JGDP_ZS.memo_1
  is '预留字段1';
comment on column RRP_MDL.ADD_JGDP_ZS.memo_2
  is '预留字段2';
comment on column RRP_MDL.ADD_JGDP_ZS.memo_3
  is '预留字段3';

