create table RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER
(
  keepfolder_id        NUMBER,
  aspclient_id         NUMBER,
  keepfolder_code      VARCHAR2(30),
  keepfolder_shortname VARCHAR2(75),
  lastmodified         TIMESTAMP(6),
  costmethod           VARCHAR2(2),
  calcdayenddate1      NUMBER,
  calcdayenddate2      NUMBER,
  controlfactor        VARCHAR2(30),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER
  is '账户视图';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.keepfolder_id
  is '后台账户代码';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.aspclient_id
  is '部门代码';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.keepfolder_code
  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.keepfolder_shortname
  is '账户名称';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.lastmodified
  is '更新时间';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.costmethod
  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.calcdayenddate1
  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.calcdayenddate2
  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.controlfactor
  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.start_dt
  is '起始日期';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.end_dt
  is '截止日期';
comment on column RRP_MDL.O_IOL_CTMS_TBS_VS_KEEPFOLDER.id_mark
