create table RRP_MDL.S_S67_YP
(
  rcpt_id  VARCHAR2(200),
  confmamt NUMBER(20,2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.S_S67_YP
  is '过程临时表';
comment on column RRP_MDL.S_S67_YP.rcpt_id
  is '借据号';
comment on column RRP_MDL.S_S67_YP.confmamt
  is '分配我行确认价值';

