create table RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL
(
  id                VARCHAR2(60),
  buss_contract_id  VARCHAR2(60),
  dealed_no         VARCHAR2(30),
  trade_direct      VARCHAR2(8),
  busi_type         VARCHAR2(6),
  draft_type        VARCHAR2(6),
  draft_attr        VARCHAR2(6),
  trade_type        VARCHAR2(6),
  trade_date        VARCHAR2(12),
  trade_time        VARCHAR2(21),
  trade_status      VARCHAR2(6),
  settle_status     VARCHAR2(6),
  quote_no          VARCHAR2(24),
  brh_no            VARCHAR2(14),
  product_no        VARCHAR2(14),
  trader_id         VARCHAR2(15),
  fundation_acct    VARCHAR2(48),
  adver_brh_no      VARCHAR2(14),
  adver_pro_no      VARCHAR2(14),
  adver_trader_id   VARCHAR2(15),
  adver_fund_acct   VARCHAR2(48),
  quote_status      VARCHAR2(6),
  trace_reason      VARCHAR2(2),
  lock_flag         VARCHAR2(2),
  misc              VARCHAR2(675),
  reserver1         VARCHAR2(384),
  reserver2         VARCHAR2(384),
  last_upd_opr      VARCHAR2(45),
  last_upd_time     VARCHAR2(21),
  due_settle_status VARCHAR2(6),
  nesting_lock_flag VARCHAR2(2),
  anoclick_deal_no  VARCHAR2(30),
  click_type        VARCHAR2(6),
  own_mem_no        VARCHAR2(9),
  busi_branch_no    VARCHAR2(15),
  top_branch_no     VARCHAR2(15),
  deal_tenor_days   NUMBER(8),
  deal_settle_amt   NUMBER(18,2),
  deal_sum_count    NUMBER(8),
  deal_sum_amount   NUMBER(18,2),
  deal_pay_interest NUMBER(18,2),
  deal_yield_rate   NUMBER(13,6),
  create_time       VARCHAR2(21),
  create_by         VARCHAR2(45),
  start_dt          DATE,
  end_dt            DATE,
  id_mark           VARCHAR2(10),
  etl_timestamp     TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL
  is '对话报价成交单表';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.id
  is '主键ID';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.buss_contract_id
  is '业务表批次ID';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.dealed_no
  is '成交单编号';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.trade_direct
  is '交易方向： TDD01 转贴现买入 TDD02 转贴现卖出 CRD01 逆回购买入 CRD02 正回购卖出';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.busi_type
  is '业务类型： BT01 转贴现 BT02 质押式回购 BT03 买断式回购 BT06 央行卖票';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.draft_type
  is '票据类型： AC01 银承 AC02 商承';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.draft_attr
  is '票据介质： ME01 纸票 ME02 电票';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.trade_type
  is '成交方式: TT01 询价成交 TT02 匿名点击 TT03 点击成交 TT04 应急成交';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.trade_date
  is '成交日期';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.trade_time
  is '成交时间';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.trade_status
  is '成交状态： DS01 已成交 DS02 已撤销 DS03 待提票 DS05 提票超时 DS06 提票待确认 DS07 提票确认失败 DS08 提票确认成功';
comment on column RRP_MDL.O_IOL_BDMS_CES_QUOTE_DEAL.settle_status
