create table RRP_MDL.O_IOL_IBMS_TFND
(
  i_code                VARCHAR2(45),
  a_type                VARCHAR2(30),
  m_type                VARCHAR2(30),
  l_code                VARCHAR2(45),
  currency              VARCHAR2(5),
  country               VARCHAR2(3),
  q_type                VARCHAR2(3),
  f_name                VARCHAR2(225),
  p_class               VARCHAR2(90),
  f_date                VARCHAR2(15),
  f_opendate            VARCHAR2(15),
  f_manager             VARCHAR2(300),
  f_trustee             VARCHAR2(75),
  imp_date              VARCHAR2(15),
  pipe_id               NUMBER,
  p_type                VARCHAR2(45),
  chinesespell          VARCHAR2(300),
  state                 VARCHAR2(2),
  user_id               NUMBER(19),
  user_name             VARCHAR2(48),
  update_time           VARCHAR2(35),
  f_manager_code        VARCHAR2(150),
  f_trustee_code        VARCHAR2(150),
  issuer_id             NUMBER(16),
  f_invest_type         VARCHAR2(60),
  f_setupdate           VARCHAR2(15),
  f_manager_name        VARCHAR2(15),
  i_id                  NUMBER(19),
  is_idx                VARCHAR2(2),
  huge_redemption_ratio NUMBER(31,4),
  compounding_method    NUMBER,
  s_type                VARCHAR2(45),
  f_mtrdate             VARCHAR2(15),
  carry_forword_type    VARCHAR2(3),
  inv_order_id          VARCHAR2(75),
  par_value             NUMBER(20,6),
  pay_freq              VARCHAR2(9),
  f_grade_type          NUMBER,
  f_fullname            VARCHAR2(300),
  sales_channel         VARCHAR2(2),
  open_type             VARCHAR2(30),
  start_open_date       VARCHAR2(30),
  end_open_date         VARCHAR2(30),
  management_model      VARCHAR2(15),
  mitigation_freq       VARCHAR2(15),
  manager_value         VARCHAR2(300),
  main_code             VARCHAR2(45),
  f_name_full           VARCHAR2(300),
  pay_month             VARCHAR2(9),
  pay_day               VARCHAR2(9),
  run_term              VARCHAR2(8),
  p_i_code              VARCHAR2(45),
  p_a_type              VARCHAR2(30),
  p_m_type              VARCHAR2(30),
  manager_id            NUMBER(16),
  redemption_date       VARCHAR2(15),
  is_pub_offer          VARCHAR2(15),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IBMS_TFND
  is '基金表';
comment on column RRP_MDL.O_IOL_IBMS_TFND.i_code
  is '投资类型';
comment on column RRP_MDL.O_IOL_IBMS_TFND.a_type
  is '结转复利方式，0：单利；2：连续复利；仅对货币基金有效';
comment on column RRP_MDL.O_IOL_IBMS_TFND.m_type
  is '缓释频率';
comment on column RRP_MDL.O_IOL_IBMS_TFND.l_code
  is '本地代码';
comment on column RRP_MDL.O_IOL_IBMS_TFND.currency
  is '币种';
comment on column RRP_MDL.O_IOL_IBMS_TFND.country
