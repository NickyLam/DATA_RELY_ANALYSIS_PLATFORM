create table RRP_MDL.O_IOL_AMSS_CMS_MERCHANT_DETAIL
(
  merchant_detail_id             VARCHAR2(32),
  merchant_short_name            VARCHAR2(128),
  industr_id                     NUMBER(10),
  province                       VARCHAR2(64),
  city                           VARCHAR2(64),
  county                         VARCHAR2(64),
  address                        VARCHAR2(256),
  tel                            VARCHAR2(128),
  email                          VARCHAR2(64),
  web_site                       VARCHAR2(128),
  principal                      VARCHAR2(64),
  id_code                        VARCHAR2(128),
  principal_mobile               VARCHAR2(128),
  customer_phone                 VARCHAR2(128),
  fax                            VARCHAR2(256),
  license_photo                  VARCHAR2(300),
  indentity_photo                VARCHAR2(1000),
  protocol_photo                 VARCHAR2(1024),
  org_photo                      VARCHAR2(1024),
  other_doc                      VARCHAR2(2000),
  physics_flag                   NUMBER(4),
  data_source                    NUMBER(4),
  remark                         VARCHAR2(256),
  fld_s1                         VARCHAR2(1024),
  fld_s2                         VARCHAR2(256),
  fld_s3                         VARCHAR2(1024),
  fld_n1                         NUMBER(10),
  fld_n2                         NUMBER(10),
  fld_n3                         NUMBER(10),
  fld_d1                         TIMESTAMP(6),
  create_user                    NUMBER(10),
  create_emp                     VARCHAR2(32),
  create_time                    TIMESTAMP(6),
  update_time                    TIMESTAMP(6),
  interface_refund_audit         NUMBER(4),
  id_code_type                   NUMBER(10),
  business_license_name          VARCHAR2(128),
  account_code_photo             VARCHAR2(1000),
  fld_n4                         NUMBER(10),
  fld_n5                         NUMBER(20),
  fld_n6                         NUMBER(10),
  fld_n7                         NUMBER(10),
  fld_n8                         NUMBER(10),
  fld_s4                         VARCHAR2(512),
  fld_s5                         VARCHAR2(512),
  fld_s6                         VARCHAR2(3072),
  fld_s7                         VARCHAR2(512),
  fld_s8                         VARCHAR2(512),
  id_code_expire                 TIMESTAMP(6),
  business_license_expire        TIMESTAMP(6),
  lcaddress                      VARCHAR2(512),
  questionnaire                  VARCHAR2(1024),
  approval_form                  VARCHAR2(1024),
  thi_doc_id                     VARCHAR2(256),
  nationality_num                VARCHAR2(32),
  principal_profession           VARCHAR2(192),
  id_code_begin_time             TIMESTAMP(6),
  business_license_begin_time    TIMESTAMP(6),
  contacts_idcode                VARCHAR2(64),
  manage_type                    VARCHAR2(32),
  company_prove                  VARCHAR2(256),
  indoor_photo                   VARCHAR2(512),
  checkstand_photo               VARCHAR2(256),
  manager_principal_photo        VARCHAR2(256),
  register_ip                    VARCHAR2(64),
  icp_number                     VARCHAR2(64),
  merchant_label                 VARCHAR2(64),
  line_flag                      NUMBER(10),
  online_verifi_photo            VARCHAR2(512),
  sign_photo                     VARCHAR2(1024),
  protocol_pdf                   VARCHAR2(1024),
  customer_no                    VARCHAR2(128),
  handling_customer_manager_name VARCHAR2(64),
  handling_customer_manager_id   VARCHAR2(64),
  handling_bank_branch           VARCHAR2(64),
  customer_id                    VARCHAR2(20),
  trade_able_hours_begin         VARCHAR2(100),
  trade_able_hours_end           VARCHAR2(100),
  points_offer                   VARCHAR2(10),
  support_farmer_station         VARCHAR2(200),
  support_farmer                 NUMBER(1),
  thi_mch_id                     VARCHAR2(30),
  start_dt                       DATE,
  end_dt                         DATE,
  id_mark                        VARCHAR2(10),
  etl_timestamp                  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_AMSS_CMS_MERCHANT_DETAIL
  is '商户详细信息表';
