create table RRP_MDL.O_IML_EVT_SUGST_PAY_APPL_EVT
(
  evt_id                    VARCHAR2(100),
  lp_id                     VARCHAR2(100),
  appl_flow_num             VARCHAR2(90),
  hq_org_id                 VARCHAR2(100),
  org_id                    VARCHAR2(100),
  prod_id                   VARCHAR2(100),
  appl_tran_type_cd         VARCHAR2(30),
  appl_dt                   DATE,
  bill_type_cd              VARCHAR2(30),
  bill_med_cd               VARCHAR2(30),
  bill_id                   VARCHAR2(100),
  fac_val_amt               NUMBER(30,2),
  draw_dt                   DATE,
  exp_dt                    DATE,
  sugst_payer_cate_cd       VARCHAR2(30),
  sugst_payer_soci_crdt_cd  VARCHAR2(30),
  sugst_payer_name          VARCHAR2(750),
  sugst_payer_open_bank_num VARCHAR2(90),
  sugst_payer_org_cd        VARCHAR2(30),
  pay_bank_no               VARCHAR2(90),
  pay_bank_reply_cd         VARCHAR2(30),
  pay_bank_refuse_rs_cd     VARCHAR2(30),
  proc_status_cd            VARCHAR2(30),
  bill_status_cd            VARCHAR2(30),
  entry_status_cd           VARCHAR2(30),
  clear_rest_cd             VARCHAR2(30),
  cash_org_role_type_cd     VARCHAR2(30),
  err_cd                    VARCHAR2(90),
  modif_teller_id           VARCHAR2(100),
  final_modif_tm            VARCHAR2(30),
  final_modif_dt            DATE,
  etl_dt                    DATE,
  src_table_name            VARCHAR2(100),
  job_cd                    VARCHAR2(10),
  etl_timestamp             TIMESTAMP(6),
  recver_acct_num           VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_SUGST_PAY_APPL_EVT
  is '提示付款申请事件';
