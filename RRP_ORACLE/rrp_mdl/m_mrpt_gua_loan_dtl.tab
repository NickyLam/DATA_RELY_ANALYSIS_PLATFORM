  cont_id         VARCHAR2(100),
  rcpt_id         VARCHAR2(100),
  cust_id         VARCHAR2(30),
  distr_amt       NUMBER(20,4),
  distr_dt        VARCHAR2(10),
  loan_bal        NUMBER(20,4),
  loan_act_exp_dt VARCHAR2(10),
  gua_mode        VARCHAR2(30),
  data_src        VARCHAR2(100),
