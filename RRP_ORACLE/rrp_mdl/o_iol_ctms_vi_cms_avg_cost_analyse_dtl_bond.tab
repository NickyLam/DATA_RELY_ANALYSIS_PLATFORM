create table RRP_MDL.O_IOL_CTMS_VI_CMS_AVG_COST_ANALYSE_DTL_BOND
(
  query_end_date            VARCHAR2(12),
  security_id               VARCHAR2(24),
  security_name             VARCHAR2(192),
  start_date                VARCHAR2(12),
  end_date                  VARCHAR2(12),
  position                  NUMBER(17,2),
  residualqty               NUMBER(17,2),
  averagecost               NUMBER(17,2),
  dpaprice                  NUMBER(17,2),
  accruedinterest           NUMBER(17,2),
  assettype                 VARCHAR2(2),
  cname                     VARCHAR2(384),
  currency                  VARCHAR2(12),
  mduration                 NUMBER(27,12),
  pvbp                      NUMBER(27,12),
  pfolio_id                 NUMBER(5),
  pfolio_name               VARCHAR2(384),
  buztype                   VARCHAR2(75),
  keepfolder_id             NUMBER(22),
  keepfolder_code           VARCHAR2(30),
  keepfolder_shortname      VARCHAR2(75),
  org_id                    VARCHAR2(30),
  product_code              VARCHAR2(18),
  yield                     NUMBER(27,12),
  security_term_to_maturity VARCHAR2(192),
  security_type             VARCHAR2(24),
  couponinterestamt         NUMBER(23,8),
  dpa                       NUMBER(23,8),
  spread                    NUMBER(23,8),
  urpl                      NUMBER(23,8),
  etl_dt                    DATE,
  etl_timestamp             TIMESTAMP(6)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 0
    initrans 1
    maxtrans 255,
  partition PARTITION_20240630 values less than (TO_DATE(' 2024-07-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
    storage
    (
      initial 8M
      next 1M
      minextents 1
      maxextents unlimited
    ),
  partition PARTITION_20250930 values less than (TO_DATE(' 2025-10-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
