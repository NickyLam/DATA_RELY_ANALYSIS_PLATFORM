create table RRP_MDL.YBT_YL
(
  referenced_owner VARCHAR2(128),
  referenced_name  VARCHAR2(128),
  proc_name        VARCHAR2(128)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

