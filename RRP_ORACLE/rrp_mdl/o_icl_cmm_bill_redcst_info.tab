create table RRP_MDL.O_ICL_CMM_BILL_REDCST_INFO
(
  etl_dt                 DATE,
  lp_id                  VARCHAR2(60),
  bus_id                 VARCHAR2(60),
  batch_id               VARCHAR2(60),
  std_prod_id            VARCHAR2(60),
  bill_id                VARCHAR2(60),
  subj_id                VARCHAR2(60),
  int_adj_subj_id        VARCHAR2(60),
  bill_prod_id           VARCHAR2(60),
  bill_med_cd            VARCHAR2(10),
  bill_kind_cd           VARCHAR2(10),
  draw_dt                DATE,
  exp_dt                 DATE,
  actl_exp_dt            DATE,
  appl_dt                DATE,
  stl_dt                 DATE,
  repo_dt                DATE,
  bag_dt                 DATE,
  bag_tm                 TIMESTAMP(6),
  curr_cd                VARCHAR2(10),
  fac_val_amt            NUMBER(30,2),
  stl_amt                NUMBER(30,2),
  repo_amt               NUMBER(30,2),
  int_amt                NUMBER(30,2),
  discnt_int_rat         NUMBER(18,8),
  currt_bal              NUMBER(30,2),
  int_adj_bal            NUMBER(30,2),
  td_acru_int            NUMBER(30,2),
  currt_acru_int         NUMBER(30,2),
  bus_type_cd            VARCHAR2(10),
  cntpty_id              VARCHAR2(60),
  cntpty_name            VARCHAR2(375),
  cntpty_bank_no         VARCHAR2(90),
  cntpty_cate_cd         VARCHAR2(10),
  cntpty_type_cd         VARCHAR2(10),
  hxb_acpt_flg           VARCHAR2(10),
  bill_src_cd            VARCHAR2(10),
  stl_way_cd             VARCHAR2(10),
  discount_bill_flg      VARCHAR2(10),
  remote_bill_flg        VARCHAR2(10),
  acrd_policy_flg        VARCHAR2(10),
  refuse_flg             VARCHAR2(10),
  hold_days              NUMBER(18),
  defer_days             NUMBER(18),
  valid_flg              VARCHAR2(10),
  bus_status_cd          VARCHAR2(10),
  entry_status_cd        VARCHAR2(10),
  lmt_status_cd          VARCHAR2(10),
  cust_mgr_id            VARCHAR2(60),
  dept_id                VARCHAR2(60),
  bus_org_id             VARCHAR2(60),
  acct_instit_id         VARCHAR2(60),
  rgst_teller_id         VARCHAR2(60),
  recver_org_id          VARCHAR2(60),
  recver_trust_acct_num  VARCHAR2(60),
  recver_trust_acct_name VARCHAR2(500),
  recver_bank_no         VARCHAR2(90),
  recver_bank_name       VARCHAR2(500),
  payer_org_id           VARCHAR2(60),
  payer_trust_acct_num   VARCHAR2(60),
  payer_trust_acct_name  VARCHAR2(500),
  payer_bank_no          VARCHAR2(90),
  payer_bank_name        VARCHAR2(500),
  stl_status_cd          VARCHAR2(10),
  bill_num               VARCHAR2(90),
  bus_dt                 DATE,
  batch_no_code          VARCHAR2(90),
  ctr_nt_id              VARCHAR2(60),
  job_cd                 VARCHAR2(10),
  bill_sub_intrv_id      VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
