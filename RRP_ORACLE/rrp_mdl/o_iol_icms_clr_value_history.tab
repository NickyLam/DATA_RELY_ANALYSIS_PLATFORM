create table RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY
(
  serialno            VARCHAR2(32),
  clrid               VARCHAR2(32),
  evalmode            VARCHAR2(6),
  evaldate            DATE,
  curreny             VARCHAR2(10),
  rate                NUMBER(18,10),
  outevalexpdate      DATE,
  outevaldeptcode     VARCHAR2(300),
  outevalmethod       VARCHAR2(100),
  outevalflag         VARCHAR2(3),
  outevalamt1         NUMBER(20,2),
  outevaldate         DATE,
  outevalamt          NUMBER(20,2),
  evalamt             NUMBER(20,2),
  evalamt2            NUMBER(20,2),
  businessinsid       VARCHAR2(30),
  confmamt            NUMBER(20,2),
  condate             DATE,
  firstoutevalamt     NUMBER(20,2),
  firstevalamt        NUMBER(20,2),
  firstconfmamt       NUMBER(20,2),
  startbusinessinsid  VARCHAR2(30),
  verecoginition      VARCHAR2(6),
  outevalstatus       VARCHAR2(6),
  outevalextcustcname VARCHAR2(120),
  slflag              VARCHAR2(3),
  isaccurateprice     VARCHAR2(3),
  migtflag            VARCHAR2(80),
  autooutevalamt      NUMBER(20,2),
  autooutevalamt2     NUMBER(20,2),
  outevaldeptcode2    VARCHAR2(300),
  outevalamt2         NUMBER(20,2),
  outevaldate2        DATE,
  outevalflag2        VARCHAR2(3),
  outevalstartdate2   DATE,
  outevalexpdate2     DATE,
  confmdeptcode       VARCHAR2(300),
  calculateflag       VARCHAR2(3),
  accoutingamt        NUMBER(20,2),
  accoutingorgid      VARCHAR2(30),
  outevalstartdate    DATE,
  isvaluechange       VARCHAR2(2),
  slcaseid            VARCHAR2(64),
  fxtcaseid           VARCHAR2(64),
  start_dt            DATE,
  end_dt              DATE,
  id_mark             VARCHAR2(10),
  etl_timestamp       TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY
  is '押品价值历史信息表';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.serialno
  is '价值记录流水号';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.clrid
  is '押品编号';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.evalmode
  is '评估方式（01-外部评估、02-内部评估、03-内外部综合评估）';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.evaldate
  is '估值日期';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.curreny
  is '币种';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.rate
  is '汇率';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalexpdate
  is '外部评估价值估值到期日期';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevaldeptcode
  is '外部评估机构';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalmethod
  is '外部评估方法（01-指数法_外部指数、02-指数法_内部构建指数、03-市场法、04-收益法、05-重置成本法、06-工程进度法、07-非上市公司股权净资产比例法、08-直接引用法_金融质抵质押品、09-直接引用法_动产、10-直接引用法_房地产、11-直接引用法_询价、12-其他）';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalflag
  is '是否有外部预评估报告（0-否、1-是）';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalamt1
  is '外部预评估报告的评估价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevaldate
  is '外部正式评估报告评估日期';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalamt
  is '外部正式评估报告的评估价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.evalamt
  is '内部评估价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.evalamt2
  is '申请评估确认价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.businessinsid
  is '流程编号（我行确认价值对应的流程编号，如我行确认价值为自动重估得到，则该字段为空）';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.confmamt
  is '我行确认价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.condate
  is '评估认定日期';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.firstoutevalamt
  is '初评外部正式评估价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.firstevalamt
  is '初评内部评估价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.firstconfmamt
  is '初评我行确认价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.startbusinessinsid
  is '初评流程编号';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.verecoginition
  is '押品价值认定方式';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalstatus
  is '准入状态（01-未准入、02-已准入、03-黑名单、04-已退出、05-已取消）';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalextcustcname
  is '外部评估机构名称';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.slflag
  is '是否世联评估';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.isaccurateprice
  is '是否精准价(1是【按照楼盘id+楼栋id+房号编码+面积，世联返回的价格】 0否【世联返回均价】';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.migtflag
  is '迁移标识：rs rcr ilc upl mim';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.autooutevalamt
  is '世联评估价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.autooutevalamt2
  is '房讯通评估价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevaldeptcode2
  is '外部评估机构2';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalamt2
  is '外部正式评估报告的评估价值2';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevaldate2
  is '外部评估基准日2';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalflag2
  is '是否有外部评估报告2';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalstartdate2
  is '外部评估价值有效期起始日2';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalexpdate2
  is '外部评估价值有效期截止日2';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.confmdeptcode
  is '最终选定外部评估机构';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.calculateflag
  is '测算标识';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.accoutingamt
  is '记账价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.accoutingorgid
  is '记账机构';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.outevalstartdate
  is '外部评估价值有效期起始日';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.isvaluechange
  is '是否变更我行确认价值';
comment on column RRP_MDL.O_IOL_ICMS_CLR_VALUE_HISTORY.slcaseid
