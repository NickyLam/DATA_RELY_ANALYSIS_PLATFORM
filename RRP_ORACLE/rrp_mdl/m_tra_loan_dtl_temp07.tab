create table RRP_MDL.M_TRA_LOAN_DTL_TEMP07
(
  rcpt_id            VARCHAR2(100),
  out_acct_flow_num  VARCHAR2(200),
  oper_user_id       VARCHAR2(100),
  last_check_user_id VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_TRA_LOAN_DTL_TEMP07
  is '信贷交易流水表--放款流水登记和审核员工信息';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP07.rcpt_id
  is '借据号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP07.out_acct_flow_num
  is '出账流水号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP07.oper_user_id
  is '经办员工ID';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP07.last_check_user_id
  is '授权员工ID';

