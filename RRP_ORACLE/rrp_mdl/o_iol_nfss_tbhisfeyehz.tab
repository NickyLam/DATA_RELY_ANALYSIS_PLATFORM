create table RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ
(
  sum_date        NUMBER(38),
  sum_flag        VARCHAR2(2),
  internal_branch VARCHAR2(18),
  client_type     VARCHAR2(2),
  prd_code        VARCHAR2(30),
  branch_no       VARCHAR2(24),
  ta_code         VARCHAR2(14),
  tot_vol         NUMBER(18,3),
  long_frozen_vol NUMBER(18,3),
  nav             NUMBER(18,8),
  client_num      NUMBER(38),
  prd_type        VARCHAR2(2),
  etl_dt          DATE,
  etl_timestamp   TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ
  is '份额余额汇总表';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.sum_date
  is '汇总日期';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.sum_flag
  is '汇总方式,0-按交易机构，1-按开户机构';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.internal_branch
  is '机构内码';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.client_type
  is '客户类型,1-个人客户，0-对公客户';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.prd_code
  is '产品代码';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.branch_no
  is '机构代码';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.ta_code
  is 'TA代码';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.tot_vol
  is '份额总数';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.long_frozen_vol
  is '长期冻结份额';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.nav
  is '产品净值';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.client_num
  is '有效户数';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.prd_type
  is '产品类别,0-基金，1-理财';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IOL_NFSS_TBHISFEYEHZ.etl_timestamp
  is 'ETL处理时间戳';

