create table RRP_MDL.O_IML_REF_TRAN_CODE_PARA
(
  tran_code               VARCHAR2(30),
  bus_cls_cd              VARCHAR2(30),
  a_calc_bal_stop_pay_flg VARCHAR2(10),
  revs_tran_code          VARCHAR2(30),
  tran_code_descb         VARCHAR2(500),
  cntpty_tran_code        VARCHAR2(30),
  a_calc_lmt_amt_flg      VARCHAR2(10),
  revs_flg                VARCHAR2(10),
  chn_id                  VARCHAR2(100),
  aval_bal_calc_type_cd   VARCHAR2(30),
  multi_revs_way_flg      VARCHAR2(10),
  cash_tran_flg           VARCHAR2(10),
  cor_tran_flg            VARCHAR2(10),
  tran_cls_cd             VARCHAR2(30),
  debit_crdt_flg          VARCHAR2(10),
  lp_id                   VARCHAR2(100),
  start_dt                DATE,
  end_dt                  DATE,
  id_mark                 VARCHAR2(10),
  src_table_name          VARCHAR2(100),
  job_cd                  VARCHAR2(10),
  etl_timestamp           TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_REF_TRAN_CODE_PARA
  is '交易码参数表';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.tran_code
  is '交易码';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.bus_cls_cd
  is '业务分类代码';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.a_calc_bal_stop_pay_flg
  is '重新计算余额止付标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.revs_tran_code
  is '冲正交易码';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.tran_code_descb
  is '交易码描述';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.cntpty_tran_code
  is '对方交易码';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.a_calc_lmt_amt_flg
  is '重新计算限制金额标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.revs_flg
  is '冲正标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.chn_id
  is '渠道编号';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.aval_bal_calc_type_cd
  is '可用余额计算类型代码';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.multi_revs_way_flg
  is '多种冲正方式标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.cash_tran_flg
  is '现金交易标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.cor_tran_flg
  is '更正交易标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.tran_cls_cd
  is '交易分类代码';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.debit_crdt_flg
  is '借贷标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.job_cd
  is '任务编码';
comment on column RRP_MDL.O_IML_REF_TRAN_CODE_PARA.etl_timestamp
  is 'etl处理时间戳';

