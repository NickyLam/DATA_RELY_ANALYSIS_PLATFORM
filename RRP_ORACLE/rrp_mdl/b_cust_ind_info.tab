comment on table RRP_MDL.B_CUST_IND_INFO
  is '个人客户信息';
comment on column RRP_MDL.B_CUST_IND_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.B_CUST_IND_INFO.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_CUST_IND_INFO.org_id
