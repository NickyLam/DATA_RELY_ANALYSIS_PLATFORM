create table RRP_MDL.O_IOL_ICMS_AP_REGISTER_PROGRAM
(
  serialno                      VARCHAR2(64),
  programno                     VARCHAR2(64),
  programname                   VARCHAR2(1000),
  customername                  VARCHAR2(100),
  handletype                    VARCHAR2(1000),
  businesssum                   NUMBER(24,6),
  balancesum                    NUMBER(24,6),
  receiveamonut                 NUMBER(24,6),
  oninterestsum                 NUMBER(24,6),
  outinterestsum                NUMBER(24,6),
  pecuniacreditasum             NUMBER(24,6),
  transferprice                 NUMBER(24,6),
  payreceiveamonut              NUMBER(24,6),
  paylowamonut                  NUMBER(24,6),
  paylowcost                    NUMBER(24,6),
  paysum                        NUMBER(24,6),
  payinterest                   NUMBER(24,6),
  transferway                   VARCHAR2(36),
  othertransferway              VARCHAR2(36),
  respinvestigationdate         DATE,
  respinvestigationorg          VARCHAR2(160),
  vendeename                    VARCHAR2(160),
  remark                        VARCHAR2(1000),
  inputuserid                   VARCHAR2(64),
  inputorgid                    VARCHAR2(64),
  inputdate                     DATE,
  updatedate                    DATE,
  updateuserid                  VARCHAR2(64),
  updateorgid                   VARCHAR2(64),
  litigationphasecost           NUMBER(24,6),
  cancelaccountcapbaldepos      NUMBER(24,6),
  cancelaccountcapinowebalance  NUMBER(24,6),
  cancelaccountcapoutowebalance NUMBER(24,6),
  summarize                     VARCHAR2(4000),
  riskassetlist                 VARCHAR2(2000),
  saveflag                      VARCHAR2(2),
  executestatus                 VARCHAR2(2),
  packagedate                   DATE,
  transferflag                  VARCHAR2(2),
  currency                      VARCHAR2(3),
  transferorg                   VARCHAR2(64),
  agentlegalfee                 NUMBER(24,6),
  repaymode                     VARCHAR2(4),
  downpayment                   NUMBER(24,6),
  onaccountno                   VARCHAR2(32),
  transcontractno               VARCHAR2(128),
  counterpartyacctname          VARCHAR2(200),
  counterpartyacct              VARCHAR2(32),
  openbankname                  VARCHAR2(128),
  openbankno                    VARCHAR2(32),
  counterpartyaccttype          VARCHAR2(20),
  transcontractstartdate        DATE,
  transcontractenddate          DATE,
  transtradplatform             VARCHAR2(20),
  transtradplatformcus          VARCHAR2(256),
  counterpartypaydate           DATE,
  isaddrec                      NUMBER(1),
  start_dt                      DATE,
  end_dt                        DATE,
  id_mark                       VARCHAR2(10),
  etl_timestamp                 TIMESTAMP(6),
  counterpartyacctcerttype      VARCHAR2(4),
  counterpartyacctcertid        VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_AP_REGISTER_PROGRAM
  is '单户资产登记方案表';
