create table RRP_MDL.B_LOAN_APP_INFO
(
  data_dt      CHAR(8) not null,
  lgl_rep_id   VARCHAR2(200),
  app_id       VARCHAR2(200) not null,
  org_id       VARCHAR2(200),
  cust_id      VARCHAR2(200),
  app_dt       CHAR(8),
  cur          CHAR(3),
  app_amt      NUMBER(30,2),
  aprv_amt     NUMBER(30,2),
  loan_biz_typ VARCHAR2(10),
  app_stat     VARCHAR2(10),
  dept_line    VARCHAR2(500),
  data_src     VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_LOAN_APP_INFO
  is '贷款申请信息';
comment on column RRP_MDL.B_LOAN_APP_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_APP_INFO.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_LOAN_APP_INFO.app_id
  is '申请编号';
comment on column RRP_MDL.B_LOAN_APP_INFO.org_id
  is '机构编号';
comment on column RRP_MDL.B_LOAN_APP_INFO.cust_id
  is '客户编号';
comment on column RRP_MDL.B_LOAN_APP_INFO.app_dt
  is '申请日期';
comment on column RRP_MDL.B_LOAN_APP_INFO.cur
  is '币种';
comment on column RRP_MDL.B_LOAN_APP_INFO.app_amt
  is '申请金额';
comment on column RRP_MDL.B_LOAN_APP_INFO.aprv_amt
  is '批准金额';
comment on column RRP_MDL.B_LOAN_APP_INFO.loan_biz_typ
  is '贷款业务类型';
comment on column RRP_MDL.B_LOAN_APP_INFO.app_stat
  is '申请状态';
comment on column RRP_MDL.B_LOAN_APP_INFO.dept_line
  is '部门条线';
comment on column RRP_MDL.B_LOAN_APP_INFO.data_src
  is '数据来源';
alter table RRP_MDL.B_LOAN_APP_INFO
  add constraint PK_B_LOAN_APP_INFO primary key (DATA_DT, APP_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

