create table RRP_MDL.TMP_CCH_RPT_CBRC_RESULT
(
  data_date VARCHAR2(10) not null,
  org_no    VARCHAR2(60) not null,
  currency  VARCHAR2(10) not null,
  index_no  VARCHAR2(60) not null,
  index_val NUMBER(36,6),
  rpt_no    VARCHAR2(40)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.TMP_CCH_RPT_CBRC_RESULT
  is '临时表';
comment on column RRP_MDL.TMP_CCH_RPT_CBRC_RESULT.data_date
  is '数据日期';
comment on column RRP_MDL.TMP_CCH_RPT_CBRC_RESULT.org_no
  is '机构编码';
comment on column RRP_MDL.TMP_CCH_RPT_CBRC_RESULT.currency
  is '币种';
comment on column RRP_MDL.TMP_CCH_RPT_CBRC_RESULT.index_no
  is '指标编码';
comment on column RRP_MDL.TMP_CCH_RPT_CBRC_RESULT.index_val
  is '指标值';
comment on column RRP_MDL.TMP_CCH_RPT_CBRC_RESULT.rpt_no
  is '未知';

