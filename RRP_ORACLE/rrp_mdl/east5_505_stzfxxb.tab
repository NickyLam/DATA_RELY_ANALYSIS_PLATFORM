  is '受托支付对象行名';
comment on column RRP_MDL.EAST5_505_STZFXXB.bbz
  is '备注';
comment on column RRP_MDL.EAST5_505_STZFXXB.cjrq
  is '采集日期';
comment on column RRP_MDL.EAST5_505_STZFXXB.dept_no
  is '部门编号';
comment on column RRP_MDL.EAST5_505_STZFXXB.src_sys_id
  is '来源系统ID';
comment on column RRP_MDL.EAST5_505_STZFXXB.issued_no
  is '填报机构';
comment on column RRP_MDL.EAST5_505_STZFXXB.org_no
  is '报送机构';
comment on column RRP_MDL.EAST5_505_STZFXXB.address
  is '归属地';
comment on column RRP_MDL.EAST5_505_STZFXXB.stzfdxhm_orig
  is '受托支付对象户名（脱敏前）';
comment on column RRP_MDL.EAST5_505_STZFXXB.stzfdxhm_oth
  is '户名是否自然人名称';
comment on column RRP_MDL.EAST5_505_STZFXXB.gsfzjg
  is '归属分支机构';
alter table RRP_MDL.EAST5_505_STZFXXB
  add constraint PK_EAST5_505_STZFXXB primary key (CJRQ, STZFRQ, XDJJH, STZFDXZH)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

