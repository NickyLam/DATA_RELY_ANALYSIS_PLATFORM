comment on table RRP_MDL.EAST5_505_STZFXXB
  is '受托支付信息表';
comment on column RRP_MDL.EAST5_505_STZFXXB.rid
  is '数据主键';
comment on column RRP_MDL.EAST5_505_STZFXXB.jrxkzh
  is '金融许可证号';
comment on column RRP_MDL.EAST5_505_STZFXXB.nbjgh
  is '内部机构号';
comment on column RRP_MDL.EAST5_505_STZFXXB.xdhth
  is '信贷合同号';
comment on column RRP_MDL.EAST5_505_STZFXXB.xdjjh
  is '信贷借据号';
comment on column RRP_MDL.EAST5_505_STZFXXB.bz
  is '币种';
comment on column RRP_MDL.EAST5_505_STZFXXB.dkje
  is '贷款金额';
