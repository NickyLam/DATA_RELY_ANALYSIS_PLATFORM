create table RRP_MDL.O_IML_PTY_CPES_MEM
(
  etl_dt                         DATE,
  party_id                       VARCHAR2(60),
  lp_id                          VARCHAR2(60),
  mem_id                         VARCHAR2(60),
  mem_cd                         VARCHAR2(60),
  mem_org_cd                     VARCHAR2(60),
  mem_org_id                     VARCHAR2(60),
  org_cate_cd                    VARCHAR2(10),
  org_lev_cd                     VARCHAR2(10),
  org_cn_fname                   VARCHAR2(750),
  org_en_fname                   VARCHAR2(375),
  org_cn_abbr                    VARCHAR2(375),
  org_en_abbr                    VARCHAR2(150),
  unify_soci_crdt_cd             VARCHAR2(30),
  dist_cd                        VARCHAR2(10),
  lp_lev_cd                      VARCHAR2(10),
  org_hibchy_cd                  VARCHAR2(10),
  prod_valid_dt                  DATE,
  prod_invalid_dt                DATE,
  org_status_cd                  VARCHAR2(10),
  org_intnal_acct_name           VARCHAR2(150),
  org_intnal_acct_num            VARCHAR2(90),
  tran_acct_num                  VARCHAR2(90),
  tran_acct_status_cd            VARCHAR2(10),
  trust_acct_num                 VARCHAR2(90),
  trust_acct_status_cd           VARCHAR2(10),
  cpes_cap_acct_num              VARCHAR2(90),
  cpes_cap_acct_status_cd        VARCHAR2(10),
  legal_rep_or_princ             VARCHAR2(375),
  wdraw_acct_lg_pay_sys_bank_no  VARCHAR2(90),
  wdraw_acct_name                VARCHAR2(375),
  wdraw_acct_num                 VARCHAR2(90),
  rgst_cap                       NUMBER(30,2),
  addr                           VARCHAR2(750),
  cotas                          VARCHAR2(150),
  phone                          VARCHAR2(90),
  fax                            VARCHAR2(90),
  zip_cd                         VARCHAR2(90),
  sys_prtcptr_bigamt_bank_no     VARCHAR2(90),
  sys_prtcptr_bigamt_bank_name   VARCHAR2(750),
  ele_bill_agent_bigamt_bank_no  VARCHAR2(90),
  ele_bill_agent_bigamt_acct_num VARCHAR2(90),
  udtake_org_cd                  VARCHAR2(10),
  create_dt                      DATE,
  update_dt                      DATE,
  id_mark                        VARCHAR2(10),
  job_cd                         VARCHAR2(10),
  src_table_name                 VARCHAR2(200),
  sys_prtcptr_bigamt_bank_name_a VARCHAR2(200),
  rank                           INTEGER
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_CPES_MEM
  is '票交所会员';
comment on column RRP_MDL.O_IML_PTY_CPES_MEM.etl_dt
