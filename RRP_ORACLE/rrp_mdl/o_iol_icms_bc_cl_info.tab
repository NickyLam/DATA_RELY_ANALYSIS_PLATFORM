create table RRP_MDL.O_IOL_ICMS_BC_CL_INFO
(
  serialno               VARCHAR2(64),
  lineclass              VARCHAR2(36),
  currencyrange          VARCHAR2(400),
  lngotimes              NUMBER(22),
  occupynominalsum       NUMBER(24,6),
  afterloanuserid        VARCHAR2(32),
  creditflowtype         VARCHAR2(20),
  creditarea             VARCHAR2(2),
  approvalsuggestion     VARCHAR2(32),
  useterm                DATE,
  freezeflag             VARCHAR2(1),
  bizlongestterm         NUMBER(22),
  occupyexposuresum      NUMBER(24,6),
  limitusecondition      VARCHAR2(4000),
  classifytype2          VARCHAR2(100),
  bizextendedterm        NUMBER(22),
  outclassifydate        VARCHAR2(10),
  termtype               VARCHAR2(36),
  availablenominalsum    NUMBER(24,6),
  afterloanorgid         VARCHAR2(32),
  outclassifyorg         VARCHAR2(200),
  investway              VARCHAR2(2),
  bizlowestfloatrate     NUMBER(24,8),
  guarantybailsubaccount VARCHAR2(5),
  isrz                   VARCHAR2(2),
  isgovernfinance        VARCHAR2(2),
  isgreenfinance         VARCHAR2(2),
  maxnominalamount       NUMBER(24,6),
  usewithoutcondition    VARCHAR2(2),
  businesstype2          VARCHAR2(32),
  fundsource             VARCHAR2(18),
  playtype               VARCHAR2(2),
  bizmostmortgagerate    NUMBER(15,8),
  bizbailinitialrate     NUMBER(24,8),
  availableexposuresum   NUMBER(24,6),
  syndicatetotalsum      NUMBER(24,6),
  isbeltroadfinance      VARCHAR2(2),
  migtflag               VARCHAR2(80),
  istrans                VARCHAR2(1),
  linecontrolmode        VARCHAR2(36),
  otherlimitflag         VARCHAR2(1),
  singlebizmostamount    NUMBER(24,6),
  exposuresum            NUMBER(24,6),
  putoutorgid            VARCHAR2(32),
  riskexposuresum        NUMBER(24,6),
  isquerycreditreport    VARCHAR2(10),
  onlineamount           NUMBER(24,6),
  isconsumerfinance      VARCHAR2(2),
  maxexposureamount      NUMBER(24,6),
  ispubliccredit         VARCHAR2(2),
  creditauthno           VARCHAR2(200),
  islikeloan             VARCHAR2(2),
  lowriskexposuresum     NUMBER(24,6),
  drtimes                NUMBER(22),
  guarantybailaccount    VARCHAR2(32),
  nominalsum             NUMBER(24,6),
  latestusedate          DATE,
  outclassifylevel       VARCHAR2(18),
  isestatefinance        VARCHAR2(2),
  noeffectreason         VARCHAR2(4),
  changetype             VARCHAR2(4),
  hxtyoperateorg         VARCHAR2(2),
  classifyresulteleven   VARCHAR2(18),
  iscreditincrement      VARCHAR2(4),
  hxtymainratelevel      VARCHAR2(4),
  mainlevelorg           VARCHAR2(400),
  mainleveldate          VARCHAR2(20),
  purpose                VARCHAR2(1000),
  investtarget           VARCHAR2(500),
  publicorg              VARCHAR2(2),
  approvepubsum          NUMBER(24,6),
  publishsum             NUMBER(24,6),
  issuername             VARCHAR2(120),
  issuerid               VARCHAR2(16),
  originalname           VARCHAR2(200),
  originalid             VARCHAR2(16),
  channelname            VARCHAR2(32),
  channelid              VARCHAR2(32),
  managename             VARCHAR2(200),
  manageid               VARCHAR2(16),
  ispenetrate            VARCHAR2(2),
  moneyindustryt         VARCHAR2(32),
  supplychain            VARCHAR2(1),
  islikelowrisk          VARCHAR2(2),
  focuslendtype          VARCHAR2(2),
  isinnovate             VARCHAR2(2),
  issupplychainfinance   VARCHAR2(2),
  lmttyp                 VARCHAR2(30),
  sqdkze                 NUMBER(18,2),
  isjoinlimits           VARCHAR2(2),
  otherlimitamount       NUMBER(24,6),
  iscollectionagency     VARCHAR2(2),
  islimit                VARCHAR2(2),
  start_dt               DATE,
  end_dt                 DATE,
  id_mark                VARCHAR2(10),
  etl_timestamp          TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
