create table RRP_MDL.O_IML_AGT_AP_REGISTER_INFO_H
(
  agt_id                       VARCHAR2(250),
  lp_id                        VARCHAR2(100),
  flow_num                     VARCHAR2(100),
  prop_id                      VARCHAR2(100),
  prop_name                    VARCHAR2(1000),
  cust_name                    VARCHAR2(500),
  disp_type_cd                 VARCHAR2(1000),
  cont_amt                     NUMBER(30,8),
  cont_bal                     NUMBER(30,8),
  fin_acct_recvbl              NUMBER(30,8),
  in_bs_int_bal                NUMBER(30,8),
  off_bs_int_bal               NUMBER(30,8),
  cred_rht_amt                 NUMBER(30,8),
  tran_amt                     NUMBER(30,8),
  seller_invstg_agent_org_name VARCHAR2(500),
  buyer_name                   VARCHAR2(500),
  suit_stage_law_fee_amt       NUMBER(30,8),
  ckwrf_asset_pric_bal         NUMBER(30,8),
  ckwrf_asset_inbsoverint_bal  NUMBER(30,8),
  ckwrf_asset_offbsoverint_bal NUMBER(30,8),
  prop_descb                   VARCHAR2(4000),
  risk_asset_comb              VARCHAR2(2000),
  exec_status_cd               VARCHAR2(30),
  pkg_dt                       DATE,
  tran_type_cd                 VARCHAR2(30),
  curr_cd                      VARCHAR2(30),
  modif_post_org_id            VARCHAR2(100),
  advc_suit_fee                NUMBER(30,8),
  pay_way_cd                   VARCHAR2(30),
  first_pay_amt                NUMBER(30,8),
  rgst_teller_id               VARCHAR2(100),
  rgst_org_id                  VARCHAR2(100),
  rgst_dt                      DATE,
  update_teller_id             VARCHAR2(100),
  update_org_id                VARCHAR2(100),
  up_date                      DATE,
  start_dt                     DATE,
  end_dt                       DATE,
  id_mark                      VARCHAR2(10),
  src_table_name               VARCHAR2(100),
  job_cd                       VARCHAR2(10),
  etl_timestamp                TIMESTAMP(6),
  tran_cont_id                 VARCHAR2(250),
  tran_cont_begin_dt           DATE,
  tran_cont_exp_dt             DATE,
  tran_tran_plat               VARCHAR2(30),
  tran_tran_plat_descb         VARCHAR2(500),
  cntpty_acct_id               VARCHAR2(100),
  cntpty_acct_name             VARCHAR2(500),
  cntpty_type_cd               VARCHAR2(30),
  cntpty_open_bank_num         VARCHAR2(60),
  cntpty_open_bank_name        VARCHAR2(500),
  cntpty_tran_acct_dt          DATE,
  input_flg                    VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_AP_REGISTER_INFO_H
  is '单户资产登记信息历史';
