  redem_int_rat                     NUMBER(18,8),
  currt_bal                         NUMBER(30,2),
  int_adj_bal                       NUMBER(30,2),
  td_acru_int                       NUMBER(30,2),
  currt_acru_int                    NUMBER(30,2),
  bus_type_cd                       VARCHAR2(10),
  asset_thd_cls_cd                  VARCHAR2(30),
  tran_dir_cd                       VARCHAR2(10),
  discnt_dt                         DATE,
  discnt_ps_unify_soci_crdt_cd_cert VARCHAR2(60),
  cntpty_id                         VARCHAR2(60),
  cntpty_name                       VARCHAR2(375),
  cntpty_bank_no                    VARCHAR2(90),
  cntpty_cate_cd                    VARCHAR2(10),
  cntpty_type_cd                    VARCHAR2(10),
  hxb_acpt_flg                      VARCHAR2(10),
  bill_src_cd                       VARCHAR2(10),
  sys_in_flg                        VARCHAR2(10),
  quot_way_cd                       VARCHAR2(10),
  stl_way_cd                        VARCHAR2(10),
  lock_flg                          VARCHAR2(10),
  hold_days                         NUMBER(18),
  defer_days                        NUMBER(18),
  valid_flg                         VARCHAR2(10),
