  bill_cont_id                      VARCHAR2(60),
  bill_prod_id                      VARCHAR2(60),
  bill_med_cd                       VARCHAR2(10),
  bill_kind_cd                      VARCHAR2(10),
  draw_dt                           DATE,
  exp_dt                            DATE,
  actl_exp_dt                       DATE,
  appl_dt                           DATE,
  bus_dt                            DATE,
  stl_dt                            DATE,
  repo_dt                           DATE,
  actl_repo_dt                      DATE,
  curr_cd                           VARCHAR2(10),
  fac_val_amt                       NUMBER(30,2),
  stl_amt                           NUMBER(30,2),
  repo_amt                          NUMBER(30,2),
  int_amt                           NUMBER(30,2),
  repo_int_amt                      NUMBER(30,2),
