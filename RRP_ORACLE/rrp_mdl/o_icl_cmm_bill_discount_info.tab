  lmt_status_cd                     VARCHAR2(10),
  cust_mgr_id                       VARCHAR2(60),
  dept_id                           VARCHAR2(60),
  bus_org_id                        VARCHAR2(60),
  acct_instit_id                    VARCHAR2(60),
  bf_cntpty_flg                     VARCHAR2(10),
  bf_cntpty_name                    VARCHAR2(375),
  bf_cntpty_type_cd                 VARCHAR2(10),
  job_cd                            VARCHAR2(10),
  discnt_ps_name                    VARCHAR2(375),
  src_tran_dir_cd                   VARCHAR2(32),
  spd_pl_subj_id                    VARCHAR2(100),
  int_income_subj_id                VARCHAR2(60),
  spd_pl                            NUMBER(30,2),
  cntpty_org_id                     VARCHAR2(60),
