create table RRP_MDL.O_IML_EVT_WLD_ACCT_ETY_TRAN
(
  evt_id              VARCHAR2(60),
  lp_id               VARCHAR2(60),
  ser_num             VARCHAR2(90),
  batch_doc_name      VARCHAR2(150),
  batch_dt            DATE,
  grouping_seq_num    VARCHAR2(90),
  evt_tran_code       VARCHAR2(45),
  core_tran_flow      VARCHAR2(90),
  tran_descb          VARCHAR2(375),
  perds               NUMBER(10),
  card_no             VARCHAR2(90),
  curr_cd             VARCHAR2(10),
  enter_acct_amt      NUMBER(30,2),
  debit_crdt_flg      VARCHAR2(10),
  enter_acct_way_cd   VARCHAR2(10),
  subrch_id           VARCHAR2(60),
  subj_id             VARCHAR2(60),
  loan_prod_id        VARCHAR2(60),
  crdt_plan_id        VARCHAR2(60),
  syn_id              VARCHAR2(60),
  bank_id             VARCHAR2(60),
  rb_w_flg            VARCHAR2(10),
  tran_ref_no         VARCHAR2(90),
  aging_group_cd      VARCHAR2(10),
  bal_compnt_group_cd VARCHAR2(10),
  etl_dt              DATE,
  src_table_name      VARCHAR2(100),
  job_cd              VARCHAR2(10),
  etl_timestamp       TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_WLD_ACCT_ETY_TRAN
