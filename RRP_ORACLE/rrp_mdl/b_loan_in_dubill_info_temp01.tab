  bill_no                    VARCHAR2(200),
  ori_purpose_cd_flg         VARCHAR2(5),
  bill_act_amt               NUMBER(30,2),
  cptl_use_loc_cd            CHAR(1),
  orig_cont_id               VARCHAR2(200),
  orig_disc_psn_id           VARCHAR2(200),
  entrust_purpose_cd         VARCHAR2(30),
  sub_loan_use_type          VARCHAR2(10),
  cncl_dt                    VARCHAR2(8)
)
