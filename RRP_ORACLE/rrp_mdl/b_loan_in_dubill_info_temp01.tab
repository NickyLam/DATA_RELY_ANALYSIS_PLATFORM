  lvl5_cl                    VARCHAR2(10),
  gua_mode                   VARCHAR2(10),
  loan_dir_rgn               VARCHAR2(10),
  loan_dir_idy               VARCHAR2(10),
  syn_loan_flg               CHAR(1),
  proj_loan_flg              CHAR(1),
  idy_stru_adj_typ           VARCHAR2(10),
  idy_trnst_upg_flg          CHAR(1),
  strtg_emer_idy_typ         VARCHAR2(10),
  bank_tax_coop_loan_flg     CHAR(1),
  agr_rel_loan_flg           CHAR(1),
  rl_est_loan_flg            CHAR(1),
  iall_loan_flg              CHAR(1),
  ov_sea_mrg_loan_flg        CHAR(1),
  grn_loan_useage_cl         VARCHAR2(10),
  ent_gua_loan_typ           VARCHAR2(10),
  campus_cnsmp_loan_flg      CHAR(1),
  lcl_govfinpltf_loan_flg    CHAR(1),
  land_thirdparty_loan_typ   VARCHAR2(10),
  farmer_thirdparty_loan_typ VARCHAR2(10),
  pov_alle_rec_flg           CHAR(1),
  loan_hdl_chan              VARCHAR2(10),
  net_loan_flg               CHAR(1),
  cr_crd_biz_od_typ          VARCHAR2(10),
  repy_mode                  VARCHAR2(10),
  loan_frm                   VARCHAR2(10),
  rcmb_loan_flg              CHAR(1),
  adj_bad_flg                CHAR(1),
  aldy_rcmb_flg              CHAR(1),
  cton_prd_loan_flg          CHAR(1),
  cash_trf_flg               CHAR(1),
  fst_loan_flg               CHAR(1),
  first_loan_flg             CHAR(1),
  pboc_grn_loan_flg          CHAR(1),
  cbrc_grn_loan_flg          CHAR(1),
  cnsmp_scn_loan_flg         CHAR(1),
  loan_finc_spt_mode         VARCHAR2(10),
  acurt_pov_alle_loan_flg    CHAR(1),
  rate_re_prc_dt             CHAR(8),
  rate_flt_freq              VARCHAR2(10),
  rate_typ                   VARCHAR2(10),
  ast_scrtz_prod_id          VARCHAR2(200),
  exec_rate                  NUMBER(20,6),
  base_rate                  NUMBER(20,6),
  rate_flt_val               NUMBER(20,6),
  prc_base_typ               VARCHAR2(10),
  tot_prd_num                INTEGER,
  curr_prd                   INTEGER,
  cum_debt_prd_num           INTEGER,
  cnu_debt_prd_num           INTEGER,
  extn_cnt                   INTEGER,
  dsbr_mode                  VARCHAR2(10),
  int_calc_mode              VARCHAR2(10),
  mrgn_pct                   NUMBER(18,4),
  mrgn_cur                   CHAR(3),
  mrgn                       NUMBER(30,2),
  mrgn_acc                   VARCHAR2(200),
  loan_ofr_no                VARCHAR2(30),
  accrd_int                  NUMBER(30,2),
  pro_impt                   NUMBER(30,2),
  com_pro                    NUMBER(30,2),
  spcl_pro                   NUMBER(30,2),
  esp_pro                    NUMBER(30,2),
  spcl_loan_flg              CHAR(1),
  orig_rcpt_no               VARCHAR2(200),
  fnd_pct                    NUMBER(18,4),
  etr_acc                    VARCHAR2(200),
  etr_acc_nm                 VARCHAR2(500),
  loan_etr_acc_open_bank_nm  VARCHAR2(500),
