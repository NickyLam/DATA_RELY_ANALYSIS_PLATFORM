comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_APPLY.operatedate
  is '经办时间';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_APPLY.updateuserid
  is '更新人';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_APPLY.updateorgid
  is '更新机构';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_APPLY.updatedate
