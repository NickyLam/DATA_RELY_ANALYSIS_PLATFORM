create table RRP_MDL.M_TRA_LOAN_DTL_TEMP04
(
  mem_org_cd                   VARCHAR2(60),
  mem_org_id                   VARCHAR2(60),
  org_cn_fname                 VARCHAR2(750),
  org_cn_abbr                  VARCHAR2(375),
  sys_prtcptr_bigamt_bank_no   VARCHAR2(60),
  dist_cd                      VARCHAR2(60),
  sys_prtcptr_bigamt_bank_name VARCHAR2(750),
  rank_rn                      NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
comment on table RRP_MDL.M_TRA_LOAN_DTL_TEMP04
  is '人行支付行号与行名映射关系';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.mem_org_cd
  is '会员机构代码';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.mem_org_id
  is '会员机构编号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.org_cn_fname
  is '机构中文全称';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.org_cn_abbr
  is '机构中文简称';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.sys_prtcptr_bigamt_bank_no
  is '系统参与者大额行号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.dist_cd
  is '行政区划代码';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.sys_prtcptr_bigamt_bank_name
  is '系统参与者大额行名';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP04.rank_rn
  is '序号';

