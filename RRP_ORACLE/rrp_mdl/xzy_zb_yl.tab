create table RRP_MDL.XZY_ZB_YL
(
  bb_id VARCHAR2(800),
  bb_nm VARCHAR2(800),
  zb_id VARCHAR2(800),
  yl_zb VARCHAR2(800)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

