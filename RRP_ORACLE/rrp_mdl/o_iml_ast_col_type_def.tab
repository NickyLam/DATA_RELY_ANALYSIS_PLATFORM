create table RRP_MDL.O_IML_AST_COL_TYPE_DEF
(
  etl_dt                DATE,
  col_type_cd           VARCHAR2(30),
  col_type_name         VARCHAR2(750),
  up_level_node_type_cd VARCHAR2(30),
  lev                   NUMBER(10),
  base_cate_flg         VARCHAR2(10),
  spcl_info_type_cd     VARCHAR2(250),
  keyw_a                VARCHAR2(750),
  effect_way_cd         VARCHAR2(10),
  col_descb             VARCHAR2(1500),
  status_descb          VARCHAR2(375),
  admit_cls             VARCHAR2(15),
  modif_dt              DATE,
  modif_org_id          VARCHAR2(60),
  data_type_cd          VARCHAR2(10),
  guar_admit_cls_cd     VARCHAR2(10),
  modif_emply_id        VARCHAR2(60),
  reval_freq_cd         VARCHAR2(10),
  higt_pm_rat           NUMBER(18,6),
  keyw_b                VARCHAR2(375),
  gen_cd                VARCHAR2(30),
  manu_idtfy_flg        VARCHAR2(10),
  tshold                NUMBER(18,6),
  strip_line_cd         VARCHAR2(10),
  ab_divd_cd            VARCHAR2(10),
  keyw_comb_use_flg     VARCHAR2(10),
  create_dt             DATE,
  update_dt             DATE,
  id_mark               VARCHAR2(10),
  job_cd                VARCHAR2(10),
  src_table_name        VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AST_COL_TYPE_DEF
  is '押品类型定义表';
comment on column RRP_MDL.O_IML_AST_COL_TYPE_DEF.etl_dt
