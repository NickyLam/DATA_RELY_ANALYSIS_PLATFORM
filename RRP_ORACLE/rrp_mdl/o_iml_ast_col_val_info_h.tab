comment on column RRP_MDL.O_IML_AST_COL_VAL_INFO_H.ext_pa_estim_val
  is '外部初评评估价值';
comment on column RRP_MDL.O_IML_AST_COL_VAL_INFO_H.intnal_pa_estim_val
  is '内部初评评估价值';
comment on column RRP_MDL.O_IML_AST_COL_VAL_INFO_H.hxb_pa_cfm_val
  is '我行初评确认价值';
comment on column RRP_MDL.O_IML_AST_COL_VAL_INFO_H.pa_flow_id
  is '初评流程编号';
comment on column RRP_MDL.O_IML_AST_COL_VAL_INFO_H.evltion_status_cd
