create table RRP_MDL.T_COM_RRP_CRRS_CRRS_PAPER
(
  rid           VARCHAR2(100) not null,
  executives_id VARCHAR2(100) not null,
  paper_type    VARCHAR2(20) not null,
  paper_code    VARCHAR2(100) not null,
  customer_type CHAR(1),
  data_dt       VARCHAR2(40) not null,
  issued_no     VARCHAR2(100),
  rpt_org_no    VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;

