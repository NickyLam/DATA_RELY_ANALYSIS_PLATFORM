create table RRP_MDL.O_IML_FIN_ACCTI_SUBJ_RELA_H
(
  sob_id         VARCHAR2(100),
  lp_id          VARCHAR2(100),
  accti_id       VARCHAR2(100),
  amt_type_cd    VARCHAR2(30),
  subj_id        VARCHAR2(100),
  bus_type_cd    VARCHAR2(30),
  effect_dt      DATE,
  invalid_dt     DATE,
  subj_name      VARCHAR2(500),
  status_cd      VARCHAR2(30),
  subj_descb     VARCHAR2(500),
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10),
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10),
  etl_timestamp  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_FIN_ACCTI_SUBJ_RELA_H
  is '核算科目关系历史';
comment on column RRP_MDL.O_IML_FIN_ACCTI_SUBJ_RELA_H.sob_id
  is '账套编号';
