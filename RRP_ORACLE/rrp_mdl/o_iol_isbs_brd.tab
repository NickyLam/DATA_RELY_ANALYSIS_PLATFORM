create table RRP_MDL.O_IOL_ISBS_BRD
(
  inr           VARCHAR2(12),
  ownref        VARCHAR2(24),
  nam           VARCHAR2(60),
  ownusr        VARCHAR2(12),
  credat        DATE,
  opndat        DATE,
  clsdat        DATE,
  pnttyp        VARCHAR2(9),
  pntinr        VARCHAR2(12),
  predat        DATE,
  shpdat        DATE,
  spddat        DATE,
  totdat        DATE,
  advdat        DATE,
  matdat        DATE,
  rcvdat        DATE,
  disdat        DATE,
  docflg        VARCHAR2(2),
  rejflg        VARCHAR2(2),
  approvcod     VARCHAR2(2),
  relgodflg     VARCHAR2(2),
  relgoddat     DATE,
  trpdocnum     VARCHAR2(60),
  frepayflg     VARCHAR2(2),
  ver           VARCHAR2(6),
  advtyp        VARCHAR2(5),
  reltyp        VARCHAR2(3),
  expdat        DATE,
  rtoaplflg     VARCHAR2(2),
  trpdoctyp     VARCHAR2(38),
  tradat        DATE,
  tramod        VARCHAR2(30),
  mattxtflg     VARCHAR2(2),
  dscinsflg     VARCHAR2(2),
  docprbrol     VARCHAR2(5),
  docsta        VARCHAR2(2),
  igndisflg     VARCHAR2(2),
  totcur        VARCHAR2(5),
  totamt        NUMBER(18,3),
  payrol        VARCHAR2(5),
  acpnowflg     VARCHAR2(2),
  orddat        DATE,
  advdocflg     VARCHAR2(2),
  etyextkey     VARCHAR2(12),
  bchkeyinr     VARCHAR2(12),
  branchinr     VARCHAR2(12),
  ngrcod        VARCHAR2(9),
  sgdinr        VARCHAR2(12),
  blnum         VARCHAR2(30),
  shgref        VARCHAR2(24),
  fincod        VARCHAR2(30),
  fintyp        VARCHAR2(11),
  nraflg        VARCHAR2(2),
  qsqdbh        VARCHAR2(5),
  invnum        VARCHAR2(45),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10),
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ISBS_BRD
  is '进口信用证下单据业务信息(存放短字节内容)';
comment on column RRP_MDL.O_IOL_ISBS_BRD.inr
  is '进口单据INR号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.ownref
  is '来单参考号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.nam
  is '来单名称';
comment on column RRP_MDL.O_IOL_ISBS_BRD.ownusr
  is '负责人';
comment on column RRP_MDL.O_IOL_ISBS_BRD.credat
  is '寄单日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.opndat
  is '开证日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.clsdat
  is '结束日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.pnttyp
  is '父类类型';
comment on column RRP_MDL.O_IOL_ISBS_BRD.pntinr
  is '父类交易INR号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.predat
  is '寄单行寄单日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.shpdat
  is '最迟装运日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.spddat
  is '过期日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.totdat
  is '总天数';
comment on column RRP_MDL.O_IOL_ISBS_BRD.advdat
  is '通知日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.matdat
  is '效期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.rcvdat
  is '提单收到日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.disdat
  is '不符点通知日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.docflg
  is '到单标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.rejflg
  is '拒付标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.approvcod
  is '是否批准';
comment on column RRP_MDL.O_IOL_ISBS_BRD.relgodflg
  is '货物授权标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.relgoddat
  is '授权日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.trpdocnum
  is '传送单据数目';
comment on column RRP_MDL.O_IOL_ISBS_BRD.frepayflg
  is '免付款交单标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.ver
  is '版本号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.advtyp
  is '接收的的通知类型';
comment on column RRP_MDL.O_IOL_ISBS_BRD.reltyp
  is '授权类型';
comment on column RRP_MDL.O_IOL_ISBS_BRD.expdat
  is '提货担保开立日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.rtoaplflg
  is '货物授权申请人标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.trpdoctyp
  is '提单类型';
comment on column RRP_MDL.O_IOL_ISBS_BRD.tradat
  is '提单日期';
comment on column RRP_MDL.O_IOL_ISBS_BRD.tramod
  is '运输类型';
comment on column RRP_MDL.O_IOL_ISBS_BRD.mattxtflg
  is '多期限标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.dscinsflg
  is '单据差异标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.docprbrol
  is '提交角色';
comment on column RRP_MDL.O_IOL_ISBS_BRD.docsta
  is '单据类型';
comment on column RRP_MDL.O_IOL_ISBS_BRD.igndisflg
  is '忽略不符点标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.totcur
  is '付款总金额币种';
comment on column RRP_MDL.O_IOL_ISBS_BRD.totamt
  is '付款总金额';
comment on column RRP_MDL.O_IOL_ISBS_BRD.payrol
  is '付款人';
comment on column RRP_MDL.O_IOL_ISBS_BRD.acpnowflg
