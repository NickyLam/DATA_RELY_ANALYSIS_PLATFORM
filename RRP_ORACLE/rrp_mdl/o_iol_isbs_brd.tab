comment on column RRP_MDL.O_IOL_ISBS_BRD.etyextkey
  is '实体组';
comment on column RRP_MDL.O_IOL_ISBS_BRD.bchkeyinr
  is '经办机构号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.branchinr
