comment on column RRP_MDL.O_IOL_ISBS_BRD.ngrcod
  is '货物代码';
comment on column RRP_MDL.O_IOL_ISBS_BRD.sgdinr
  is '提货担保inr';
comment on column RRP_MDL.O_IOL_ISBS_BRD.blnum
  is '提单号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.shgref
  is '提货担保参考号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.fincod
  is '借据号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.fintyp
  is '业务品种';
comment on column RRP_MDL.O_IOL_ISBS_BRD.nraflg
  is 'NRA付款标志';
comment on column RRP_MDL.O_IOL_ISBS_BRD.qsqdbh
  is '清算渠道';
comment on column RRP_MDL.O_IOL_ISBS_BRD.invnum
  is '发票号';
comment on column RRP_MDL.O_IOL_ISBS_BRD.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_ISBS_BRD.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_ISBS_BRD.id_mark
