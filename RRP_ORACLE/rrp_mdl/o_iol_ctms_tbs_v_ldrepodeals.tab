create table RRP_MDL.O_IOL_CTMS_TBS_V_LDREPODEALS
(
  deal_id              NUMBER,
  deal_tablename       VARCHAR2(17),
  aspclient_id         NUMBER,
  bondscode            VARCHAR2(510),
  bondsname            VARCHAR2(4000),
  serial_number        VARCHAR2(23),
  trade_date           NUMBER(8),
  value_date           NUMBER(8),
  maturity_date        NUMBER(8),
  buyorsell            VARCHAR2(2),
  face_amount          VARCHAR2(510),
  repo_rate            VARCHAR2(384),
  amount               NUMBER(17,2),
  maturity_amount      NUMBER(17,2),
  fee                  NUMBER(17,2),
  tax_amt              NUMBER(17,2),
  broker_amt           NUMBER(17,2),
  interest             NUMBER(17,2),
  portfolio_id         NUMBER(5),
  portfolio_name       VARCHAR2(120),
  keepfolder_id        NUMBER,
  keepfolder_shortname VARCHAR2(75),
  cptys_short_name     VARCHAR2(192),
  cptys_id             NUMBER,
  settle_type          VARCHAR2(30),
  settle_type2         VARCHAR2(30),
  dealer_id            NUMBER(5),
  dealer_name          VARCHAR2(30),
  ref_number           VARCHAR2(48),
  cfets_from           VARCHAR2(2),
  lastmodified         TIMESTAMP(6),
  datasymbol_id        NUMBER,
  trade_rate           NUMBER,
  repo_days            NUMBER,
  ldrepodeals_id_grand NUMBER,
  repo_id              VARCHAR2(24),
  counterparty_type    VARCHAR2(15),
  clearing_type        VARCHAR2(2),
  repo_method          VARCHAR2(2),
  contract_no          VARCHAR2(24),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6),
  dn_dealer            VARCHAR2(900),
  trade_time           DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_CTMS_TBS_V_LDREPODEALS
