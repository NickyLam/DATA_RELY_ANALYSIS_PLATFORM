create table RRP_MDL.O_IOL_ATMS_DEV_BASE_INFO
(
  no                  VARCHAR2(30),
  ip                  VARCHAR2(30),
  org_no              VARCHAR2(30),
  away_flag           VARCHAR2(2),
  dev_catalog         VARCHAR2(5),
  dev_vendor          VARCHAR2(5),
  dev_type            VARCHAR2(5),
  work_type           VARCHAR2(2),
  status              VARCHAR2(2),
  dev_service         VARCHAR2(40),
  terminal_no         VARCHAR2(30),
  serial              VARCHAR2(60),
  address             VARCHAR2(120),
  buy_date            VARCHAR2(15),
  install_date        VARCHAR2(15),
  start_date          VARCHAR2(15),
  stop_date           VARCHAR2(15),
  open_time           VARCHAR2(15),
  close_time          VARCHAR2(15),
  expire_date         VARCHAR2(15),
  patrol_period       VARCHAR2(20),
  area_no             VARCHAR2(15),
  x                   VARCHAR2(20),
  y                   VARCHAR2(20),
  cashbox_limit       VARCHAR2(75),
  os                  VARCHAR2(75),
  atmc_soft           VARCHAR2(75),
  anti_virus_soft     VARCHAR2(75),
  sp                  VARCHAR2(75),
  virtual_teller_no   VARCHAR2(15),
  care_level          VARCHAR2(2),
  last_pm_date        VARCHAR2(15),
  expire_pm_date      VARCHAR2(15),
  locate_no           VARCHAR2(15),
  note1               VARCHAR2(45),
  note2               VARCHAR2(45),
  note3               VARCHAR2(45),
  note4               VARCHAR2(45),
  note5               VARCHAR2(45),
  carrier             VARCHAR2(30),
  money_org           VARCHAR2(30),
  dev_status          VARCHAR2(2),
  environment         VARCHAR2(384),
  address_code        VARCHAR2(23),
  cash_type           VARCHAR2(2),
  setup_type          VARCHAR2(2),
  net_type            VARCHAR2(2),
  operate_status      VARCHAR2(2),
  registration_status VARCHAR2(2),
  comm_packet         VARCHAR2(20),
  zip_type            VARCHAR2(2),
  dek_encoded         VARCHAR2(150),
  atmp_area           VARCHAR2(15),
  selfbanktype        VARCHAR2(2),
  arm_type            NUMBER(22),
  pref_no             VARCHAR2(6),
  country_no          VARCHAR2(9),
  postcode            VARCHAR2(9),
  contact             VARCHAR2(2),
  acpt_ins_id_cd      VARCHAR2(12),
  invstr_ins_id_cd    VARCHAR2(12),
  maintn_ins_id_cd    VARCHAR2(12),
  term_publicize_chnl VARCHAR2(150),
  socket              VARCHAR2(150),
  frn_acpt_tp         VARCHAR2(3),
  scan_code           VARCHAR2(3),
  magn_read_in        VARCHAR2(3),
  no_card             VARCHAR2(3),
  cont_ic_in          VARCHAR2(3),
  contless_ic_in      VARCHAR2(3),
  term_tran_fun       VARCHAR2(150),
  last_statue         VARCHAR2(2),
  is_export           NUMBER(22),
  deploy_area_no      VARCHAR2(3),
  deploy_area_name    VARCHAR2(150),
  terminal_status     VARCHAR2(3),
  start_dt            DATE,
  end_dt              DATE,
  id_mark             VARCHAR2(10),
  etl_timestamp       TIMESTAMP(6),
  comments            VARCHAR2(12),
  dac                 VARCHAR2(12)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
