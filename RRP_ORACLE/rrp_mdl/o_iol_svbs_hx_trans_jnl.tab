create table RRP_MDL.O_IOL_SVBS_HX_TRANS_JNL
(
  access_jnl_no     VARCHAR2(48),
  trans_code        VARCHAR2(48),
  trans_channel     VARCHAR2(24),
  cust_no           VARCHAR2(24),
  cust_name         VARCHAR2(48),
  id_type           VARCHAR2(12),
  id_no             VARCHAR2(48),
  card_type         VARCHAR2(2),
  card_no           VARCHAR2(48),
  client_id         VARCHAR2(24),
  branch_id         VARCHAR2(24),
  auth_flag         VARCHAR2(2),
  auth_result       VARCHAR2(2),
  author_id         VARCHAR2(24),
  cur_step          VARCHAR2(3),
  trans_time        TIMESTAMP(6),
  update_time       TIMESTAMP(6),
  trans_status      VARCHAR2(3),
  trans_msg         VARCHAR2(96),
  create_user       VARCHAR2(48),
  update_user       VARCHAR2(48),
  session_id        VARCHAR2(48),
  session_id2       VARCHAR2(48),
  session_id3       VARCHAR2(48),
  session_id4       VARCHAR2(48),
  session_id5       VARCHAR2(48),
  session_id6       VARCHAR2(48),
  session_id7       VARCHAR2(48),
  session_id8       VARCHAR2(48),
  session_id9       VARCHAR2(48),
  trans_address     VARCHAR2(384),
  task_state        VARCHAR2(2),
  longitude         VARCHAR2(96),
  latitude          VARCHAR2(96),
  trans_city        VARCHAR2(384),
  trans_city_code   VARCHAR2(48),
  connect_type      VARCHAR2(2),
  refuse_info       VARCHAR2(3000),
  refuse_detail     VARCHAR2(4000),
  trans_node_status VARCHAR2(8),
  is_risk_record    VARCHAR2(8),
  start_dt          DATE,
  end_dt            DATE,
  id_mark           VARCHAR2(10),
  etl_timestamp     TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_SVBS_HX_TRANS_JNL
  is '交易流水表';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRANS_JNL.access_jnl_no
