create table RRP_MDL.ADD_SDIS_JYBL_INFO
(
  cjrq    VARCHAR2(10),
  tbbm    VARCHAR2(30),
  jyzs    VARCHAR2(10),
  jytgl   VARCHAR2(10),
  byzd1   VARCHAR2(10),
  byzd2   VARCHAR2(10),
  byzd3   VARCHAR2(10),
  org_no  VARCHAR2(30),
  data_dt VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.ADD_SDIS_JYBL_INFO
  is '校验补录表';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.cjrq
  is '采集日期';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.tbbm
  is '填报部门';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.jyzs
  is '校验总数';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.jytgl
  is '校验通过率';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.byzd1
  is '备用字段1';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.byzd2
  is '备用字段2';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.byzd3
  is '备用字段3';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.org_no
  is '填报机构';
comment on column RRP_MDL.ADD_SDIS_JYBL_INFO.data_dt
  is '数据日期';

