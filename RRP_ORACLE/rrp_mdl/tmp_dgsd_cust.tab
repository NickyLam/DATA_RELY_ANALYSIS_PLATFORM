create table RRP_MDL.TMP_DGSD_CUST
(
  cust_id  VARCHAR2(60),
  distr_dt DATE
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.TMP_DGSD_CUST
  is '对公客户首次放款日期临时表';
comment on column RRP_MDL.TMP_DGSD_CUST.cust_id
  is '客户编号';
comment on column RRP_MDL.TMP_DGSD_CUST.distr_dt
  is '放款日期';

