create table RRP_MDL.U8_SOURCE
(
  owner         VARCHAR2(128),
  name          VARCHAR2(128),
  type          VARCHAR2(12),
  line          NUMBER,
  text          VARCHAR2(4000),
  origin_con_id NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

