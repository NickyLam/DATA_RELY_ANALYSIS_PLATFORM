comment on column RRP_MDL.O_IOL_NCBS_CIF_CHANNEL_CONTROL.end_date_time
  is '失效时间';
comment on column RRP_MDL.O_IOL_NCBS_CIF_CHANNEL_CONTROL.oper_narrative
  is '操作备注';
comment on column RRP_MDL.O_IOL_NCBS_CIF_CHANNEL_CONTROL.start_timestamp
