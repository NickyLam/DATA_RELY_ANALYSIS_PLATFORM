comment on column RRP_MDL.O_IOL_NCBS_CIF_CHANNEL_CONTROL.out_sign_user_id
  is '解约柜员';
comment on column RRP_MDL.O_IOL_NCBS_CIF_CHANNEL_CONTROL.unlost_time
