  is '卡类型';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.limited_amount
  is '限额';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.is_limiteo
  is '是否限额';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.default_card
  is '是否默认卡';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.business_type
  is '业务类型';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.financial_institution_code
  is '开户银行金融机构编码';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.last_updated_stamp
