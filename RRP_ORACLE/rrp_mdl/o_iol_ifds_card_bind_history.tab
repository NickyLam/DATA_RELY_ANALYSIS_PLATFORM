create table RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY
(
  tran_seq_no                VARCHAR2(60),
  billing_account_id         VARCHAR2(30),
  card_no                    VARCHAR2(60),
  card_name                  VARCHAR2(383),
  customer_no                VARCHAR2(30),
  card_type_id               VARCHAR2(30),
  other_bank_flag            VARCHAR2(20),
  bank_offices_no            VARCHAR2(30),
  bind_date                  TIMESTAMP(6),
  operate_time               TIMESTAMP(6),
  status_id                  VARCHAR2(30),
  amount                     NUMBER(18,2),
  simp_pay_flag              VARCHAR2(20),
  bank_number                VARCHAR2(30),
  bank_name                  VARCHAR2(383),
  third_party_id             VARCHAR2(60),
  third_party_name           VARCHAR2(383),
  channel                    VARCHAR2(30),
  cancel_date                TIMESTAMP(6),
  account_type               VARCHAR2(30),
  card_flag                  VARCHAR2(30),
  limited_amount             VARCHAR2(30),
  is_limiteo                 VARCHAR2(20),
  default_card               VARCHAR2(30),
  business_type              VARCHAR2(12),
  financial_institution_code VARCHAR2(60),
  last_updated_stamp         TIMESTAMP(6),
  last_updated_tx_stamp      TIMESTAMP(6),
  created_stamp              TIMESTAMP(6),
  created_tx_stamp           TIMESTAMP(6),
  etl_dt                     DATE,
  etl_timestamp              TIMESTAMP(6)
)
partition by list (ETL_DT)
(
  partition PARTITION_19000101 values (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20240630 values (TO_DATE(' 2024-06-30 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20250930 values (TO_DATE(' 2025-09-30 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY
  is '绑卡历史';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.tran_seq_no
  is '交易流水';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.billing_account_id
  is 'E账户编号';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.card_no
  is '卡号';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.card_name
  is '户名';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.customer_no
  is '客户号';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.card_type_id
  is '卡类型';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.other_bank_flag
  is '本他行标志';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.bank_offices_no
  is '绑卡开户网点';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.bind_date
  is '绑定时间';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.operate_time
  is '操作时间';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.status_id
  is '状态';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.amount
  is '预绑金额';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.simp_pay_flag
  is '是否快捷支付';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.bank_number
  is '归属行';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.bank_name
  is '行名';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.third_party_id
  is '商户号';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.third_party_name
  is '商户名称';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.channel
  is '通道';
comment on column RRP_MDL.O_IOL_IFDS_CARD_BIND_HISTORY.cancel_date
