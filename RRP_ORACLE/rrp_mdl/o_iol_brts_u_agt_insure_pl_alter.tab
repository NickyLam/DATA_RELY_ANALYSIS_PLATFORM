  insrt_cert_no       VARCHAR2(100),
  term_no             NUMBER(5),
  revoke_dt           VARCHAR2(10),
  end_dt              VARCHAR2(10),
  pay_end_dt          VARCHAR2(10),
  begin_dt            VARCHAR2(10),
  flag                NUMBER(5),
  channel             VARCHAR2(20),
  charge_rate         NUMBER(18,4),
  charge              NUMBER(18,4),
  ta_short_name       VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
