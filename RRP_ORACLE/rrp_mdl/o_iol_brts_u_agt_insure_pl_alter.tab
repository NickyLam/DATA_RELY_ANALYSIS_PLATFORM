  bank_acct_id        VARCHAR2(100),
  tran_status_cd      VARCHAR2(30),
  holder_name         VARCHAR2(100),
  holder_cert_type_cd VARCHAR2(30),
  holder_cert_no      VARCHAR2(100),
  rela_type_cd        VARCHAR2(30),
  insrt_name          VARCHAR2(100),
