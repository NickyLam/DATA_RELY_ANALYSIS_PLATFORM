comment on column RRP_MDL.O_IOL_ISBS_FEE0104.charge_to_base_acct_no
  is '收取账号';
comment on column RRP_MDL.O_IOL_ISBS_FEE0104.charge_to_acct_seq_no
  is '收取账号序号';
comment on column RRP_MDL.O_IOL_ISBS_FEE0104.withdrawal_type
