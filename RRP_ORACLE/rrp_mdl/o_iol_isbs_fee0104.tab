comment on column RRP_MDL.O_IOL_ISBS_FEE0104.effect_date
  is '生效日期';
comment on column RRP_MDL.O_IOL_ISBS_FEE0104.amort_start
  is '摊销起始日期';
comment on column RRP_MDL.O_IOL_ISBS_FEE0104.amort_end
