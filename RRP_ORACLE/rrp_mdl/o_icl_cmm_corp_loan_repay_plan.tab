create table RRP_MDL.O_ICL_CMM_CORP_LOAN_REPAY_PLAN
(
  etl_dt                    DATE,
  lp_id                     VARCHAR2(60),
  dubil_id                  VARCHAR2(100),
  acct_id                   VARCHAR2(60),
  cust_id                   VARCHAR2(60),
  tot_perds                 NUMBER(10),
  repay_perds               NUMBER(10),
  repay_sub_perds           VARCHAR2(150),
  value_dt                  DATE,
  repaybl_dt                DATE,
  exec_status_flg           VARCHAR2(10),
  ovdue_flg                 VARCHAR2(10),
  irr_repay_plan_flg        VARCHAR2(10),
  repay_flg                 VARCHAR2(10),
  is_int_set_flg            VARCHAR2(10),
  repay_cate_cd             VARCHAR2(10),
  repay_way_cd              VARCHAR2(10),
  curr_cd                   VARCHAR2(10),
  exec_int_rat              NUMBER(18,8),
  acru_nomal_pric           NUMBER(30,2),
  curr_issue_recvbl_pric    NUMBER(30,2),
  curr_issue_int_recvbl     NUMBER(30,2),
  curr_issue_recvbl_fee     NUMBER(30,2),
  curr_issue_int_sub_amt    NUMBER(30,2),
  payoff_dt                 DATE,
  curr_issue_pric_ovdue_dt  DATE,
  curr_issue_int_ovdue_dt   DATE,
  curr_issue_ovdue_days     NUMBER(10),
  curr_issue_ovdue_pric     NUMBER(30,2),
  curr_issue_ovdue_int      NUMBER(30,2),
  curr_issue_ovdue_comp_int NUMBER(30,2),
  curr_issue_over_int_bal   NUMBER(30,2),
  curr_issue_pnlt_bal       NUMBER(30,2),
  curr_issue_idle_bal       NUMBER(30,2),
  curr_issue_bad_debt_bal   NUMBER(30,2),
  int_ovdue_days            NUMBER(10),
  pric_bal                  NUMBER(30,2),
  curr_issue_recvbl_amt     NUMBER(30,2),
  job_cd                    VARCHAR2(10),
  repay_amt_type_cd         VARCHAR2(10),
  pd_h_ovdue_flg            VARCHAR2(10),
  curr_doc_bal              NUMBER(30,2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_CORP_LOAN_REPAY_PLAN
