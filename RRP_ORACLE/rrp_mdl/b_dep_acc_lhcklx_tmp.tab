create table RRP_MDL.B_DEP_ACC_LHCKLX_TMP
(
  dep_acct_id          VARCHAR2(60),
  dep_prod_sub_acct_id VARCHAR2(10),
  cainbl               NUMBER(20,2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.B_DEP_ACC_LHCKLX_TMP.dep_acct_id
  is '存款账户编号';
comment on column RRP_MDL.B_DEP_ACC_LHCKLX_TMP.dep_prod_sub_acct_id
  is '存款子户编号';
comment on column RRP_MDL.B_DEP_ACC_LHCKLX_TMP.cainbl
  is '累计计提金额(当日)';

