create table RRP_MDL.JRJGLX_MAP
(
  org_type     VARCHAR2(300),
  org_type_map VARCHAR2(300)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.JRJGLX_MAP
  is '金融机构类型映射表';
comment on column RRP_MDL.JRJGLX_MAP.org_type
  is '机构类型';
comment on column RRP_MDL.JRJGLX_MAP.org_type_map
  is '机构类型映射';

