create table RRP_MDL.O_IOL_IBMS_TTRD_BOOKKEEPING_ENTRY
(
  entry_id            VARCHAR2(45),
  tsk_id              VARCHAR2(45),
  entry_date          VARCHAR2(15),
  flow_id             VARCHAR2(45),
  chg_id              VARCHAR2(45),
  inst_id             NUMBER(16),
  bkkpg_org_id        VARCHAR2(45),
  subj_org_id         VARCHAR2(45),
  subj_code           VARCHAR2(150),
  subj_sub_code       VARCHAR2(150),
  inner_acct_sn       VARCHAR2(45),
  core_acct_code      VARCHAR2(45),
  step                VARCHAR2(30),
  debit_credit_flag   VARCHAR2(2),
  red_blue_flag       VARCHAR2(2),
  pending_cancel_flag VARCHAR2(2),
  currency            VARCHAR2(5),
  value               NUMBER(31,2),
  state               VARCHAR2(2),
  is_sending_core     VARCHAR2(2),
  secu_acct_id        VARCHAR2(45),
  cash_acct_id        VARCHAR2(45),
  update_time         VARCHAR2(29),
  estd_or_real        VARCHAR2(2),
  memo                VARCHAR2(300),
  core_acct_name      VARCHAR2(300),
  grp_flow_id         VARCHAR2(45),
  acctg_obj_id        VARCHAR2(45),
  chg_type            VARCHAR2(30),
  detail_flag         VARCHAR2(2),
  src_type            VARCHAR2(30),
  send_state          VARCHAR2(2),
  is_manual           VARCHAR2(2),
  ext_secu_acct_id    VARCHAR2(30),
  ext_cash_acct_id    VARCHAR2(30),
  i9_flag             VARCHAR2(2),
  ext_i_code          VARCHAR2(120),
  ext_a_type          VARCHAR2(30),
  ext_m_type          VARCHAR2(30),
  ext_dim1            VARCHAR2(300),
  ext_dim2            VARCHAR2(300),
  ext_dim3            VARCHAR2(300),
  ext_dim4            VARCHAR2(300),
  ext_dim5            VARCHAR2(300),
  ext_dim6            VARCHAR2(300),
  ext_value1          VARCHAR2(45),
  ext_value2          VARCHAR2(45),
  ext_value3          VARCHAR2(300),
  tax_type            NUMBER(22),
  tax_value           NUMBER(31,8),
  debit_credit_flag_m VARCHAR2(2),
  red_blue_flag_m     VARCHAR2(2),
  etl_dt              DATE,
  etl_timestamp       TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IBMS_TTRD_BOOKKEEPING_ENTRY
