create table RRP_MDL.T_COM_RRP_CRRS_CRRS_GROUP_FFILIATED_GROUPS
(
  rid             VARCHAR2(100) not null,
  customer_code   VARCHAR2(100) not null,
  group_code      VARCHAR2(100),
  group_name      VARCHAR2(200),
  associated_type CHAR(1),
  customer_name   VARCHAR2(100),
  data_dt         VARCHAR2(40) not null,
  issued_no       VARCHAR2(100),
  rpt_org_no      VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;

