create table RRP_MDL.DIIS_POAD08_TM
(
  rid            VARCHAR2(100) not null,
  cust_seq       NUMBER(15),
  name           VARCHAR2(400),
  cust_id        VARCHAR2(100),
  uscc           VARCHAR2(100),
  obj_name       VARCHAR2(400),
  obj_id_type    VARCHAR2(4),
  obj_id_no      VARCHAR2(100),
  acct_seq       NUMBER(15),
  acct_no        VARCHAR2(64),
  corp_name      VARCHAR2(200),
  id_type        VARCHAR2(40),
  id_no          VARCHAR2(60),
  id_valid_dt    VARCHAR2(20),
  tel_no         VARCHAR2(60),
  addr           VARCHAR2(180),
  open_dt        VARCHAR2(20),
  due_dt         VARCHAR2(20),
  prin_amt       NUMBER(30,2),
  mgr_mat        NUMBER(30,2),
  mgr_rate       NUMBER(5,2),
  exp_amt        NUMBER(30,2),
  exp_rate       NUMBER(5,2),
  mgr_acct_no    VARCHAR2(64),
  acct_c_seq     NUMBER(15),
  cs_type        VARCHAR2(40),
  cs_no          VARCHAR2(400),
  cs_amt         NUMBER(30,2),
  cs_amt_tot     NUMBER(30,2),
  sur_amt        NUMBER(30,2),
  note           VARCHAR2(600),
  prin_amt_tot   NUMBER(30,2),
  mgr_acct_tot   NUMBER(30,2),
  mgr_cs_amt_tot NUMBER(30,2),
  sur_amt_tot    NUMBER(30,2),
  data_dt        VARCHAR2(20) not null,
  org_no         VARCHAR2(40),
  curr_cd        VARCHAR2(6),
  dept_no        VARCHAR2(60),
  issued_no      VARCHAR2(40),
  rpt_org_no     VARCHAR2(40),
  data_ources    VARCHAR2(4),
  data_modify    VARCHAR2(4),
  is_seq         VARCHAR2(2),
  subj_id        VARCHAR2(60),
  dubil_id       VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.DIIS_POAD08_TM
  is '信用证';
comment on column RRP_MDL.DIIS_POAD08_TM.rid
  is '数据主键';
comment on column RRP_MDL.DIIS_POAD08_TM.cust_seq
  is '存款人序号';
comment on column RRP_MDL.DIIS_POAD08_TM.name
  is '用户姓名';
comment on column RRP_MDL.DIIS_POAD08_TM.cust_id
  is '客户表主键';
comment on column RRP_MDL.DIIS_POAD08_TM.uscc
  is '统一社会信用代码';
comment on column RRP_MDL.DIIS_POAD08_TM.obj_name
  is '对象名称';
comment on column RRP_MDL.DIIS_POAD08_TM.obj_id_type
  is '法定代表人或单位负责人证件类型';
comment on column RRP_MDL.DIIS_POAD08_TM.obj_id_no
  is '法定代表人或单位负责人证件号码';
comment on column RRP_MDL.DIIS_POAD08_TM.acct_seq
  is '存款账户序号';
comment on column RRP_MDL.DIIS_POAD08_TM.acct_no
  is '账号';
comment on column RRP_MDL.DIIS_POAD08_TM.corp_name
  is '公司名称';
comment on column RRP_MDL.DIIS_POAD08_TM.id_type
  is '证件类型 [枚举: 数标]';
comment on column RRP_MDL.DIIS_POAD08_TM.id_no
  is '证件号码';
comment on column RRP_MDL.DIIS_POAD08_TM.id_valid_dt
  is '客户证件有效期限';
comment on column RRP_MDL.DIIS_POAD08_TM.tel_no
  is '联系电话';
comment on column RRP_MDL.DIIS_POAD08_TM.addr
  is '地址';
comment on column RRP_MDL.DIIS_POAD08_TM.open_dt
  is '起始日';
comment on column RRP_MDL.DIIS_POAD08_TM.due_dt
  is '补录到期日期';
comment on column RRP_MDL.DIIS_POAD08_TM.prin_amt
  is '交易本金，债券券面等';
comment on column RRP_MDL.DIIS_POAD08_TM.mgr_mat
  is '保证金金额';
comment on column RRP_MDL.DIIS_POAD08_TM.mgr_rate
  is '保证金比例';
comment on column RRP_MDL.DIIS_POAD08_TM.exp_amt
  is '到期金额';
comment on column RRP_MDL.DIIS_POAD08_TM.exp_rate
  is '敞口比例';
comment on column RRP_MDL.DIIS_POAD08_TM.mgr_acct_no
  is '保证金存款账号';
comment on column RRP_MDL.DIIS_POAD08_TM.acct_c_seq
  is '序号';
comment on column RRP_MDL.DIIS_POAD08_TM.cs_type
  is '抵质押物类型';
comment on column RRP_MDL.DIIS_POAD08_TM.cs_no
  is '抵质押物账号（抵质押合同号）';
comment on column RRP_MDL.DIIS_POAD08_TM.cs_amt
  is '抵质押物金额（估值）';
comment on column RRP_MDL.DIIS_POAD08_TM.cs_amt_tot
  is '抵质押物金额（估值）小计';
comment on column RRP_MDL.DIIS_POAD08_TM.sur_amt
  is '剩余未覆盖金额';
comment on column RRP_MDL.DIIS_POAD08_TM.note
  is '备注';
comment on column RRP_MDL.DIIS_POAD08_TM.prin_amt_tot
  is '票据金额合计';
comment on column RRP_MDL.DIIS_POAD08_TM.mgr_acct_tot
  is '资产净值（或资产估值）合计';
comment on column RRP_MDL.DIIS_POAD08_TM.mgr_cs_amt_tot
  is '抵质押物金额（估值）合计';
comment on column RRP_MDL.DIIS_POAD08_TM.sur_amt_tot
  is '剩余未覆盖金额合计';
comment on column RRP_MDL.DIIS_POAD08_TM.data_dt
  is '数据日期';
comment on column RRP_MDL.DIIS_POAD08_TM.org_no
  is '所属机构';
comment on column RRP_MDL.DIIS_POAD08_TM.curr_cd
  is '币种';
comment on column RRP_MDL.DIIS_POAD08_TM.dept_no
  is '部门编号';
comment on column RRP_MDL.DIIS_POAD08_TM.issued_no
  is '填报机构';
comment on column RRP_MDL.DIIS_POAD08_TM.rpt_org_no
  is '报送机构号';
comment on column RRP_MDL.DIIS_POAD08_TM.data_ources
  is '数据来源';
comment on column RRP_MDL.DIIS_POAD08_TM.data_modify
  is '数据修改';
comment on column RRP_MDL.DIIS_POAD08_TM.is_seq
  is '是否合计项';
comment on column RRP_MDL.DIIS_POAD08_TM.subj_id
  is '科目编号';
comment on column RRP_MDL.DIIS_POAD08_TM.dubil_id
  is '借据编号';

