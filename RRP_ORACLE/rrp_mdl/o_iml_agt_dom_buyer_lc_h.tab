create table RRP_MDL.O_IML_AGT_DOM_BUYER_LC_H
(
  agt_id           VARCHAR2(250),
  lp_id            VARCHAR2(60),
  intnal_lc_id     VARCHAR2(100),
  lc_id            VARCHAR2(100),
  tran_descb       VARCHAR2(375),
  bus_teller_id    VARCHAR2(100),
  sys_rgst_dt      DATE,
  issue_dt         DATE,
  close_dt         DATE,
  close_type_cd    VARCHAR2(30),
  advise_bank_name VARCHAR2(375),
  final_modif_dt   DATE,
  modif_cnt        NUMBER(10),
  applit_name      VARCHAR2(375),
  applit_ref_id    VARCHAR2(100),
  pay_way_cd       VARCHAR2(30),
  benefc_name      VARCHAR2(375),
  fee_src_cd       VARCHAR2(30),
  cfm_way_cd       VARCHAR2(30),
  exp_dt           DATE,
  present_site     VARCHAR2(375),
  lc_type_cd       VARCHAR2(30),
  m_l_way_cd       VARCHAR2(30),
  m_l_cu_ratio     NUMBER(10),
  m_l_lower_ratio  NUMBER(10),
  shipment_dt      DATE,
  shipment_site    VARCHAR2(375),
  acpt_cnt         NUMBER(10),
  vp               NUMBER(10),
  belong_org_id    VARCHAR2(100),
  trast_org_id     VARCHAR2(100),
  issue_way_cd     VARCHAR2(30),
  dubil_id         VARCHAR2(100),
  traff_way_cd     VARCHAR2(30),
  lc_bal           NUMBER(18,3),
  open_way_cd      VARCHAR2(30),
  trade_type_cd    VARCHAR2(30),
  cfm_flg          VARCHAR2(10),
  pur_sale_cont_id VARCHAR2(250),
  nego_pay_flg_cd  VARCHAR2(30),
  cont_curr_cd     VARCHAR2(30),
  cont_amt         NUMBER(18,3),
  start_dt         DATE,
  end_dt           DATE,
  id_mark          VARCHAR2(10),
  src_table_name   VARCHAR2(100),
  job_cd           VARCHAR2(10),
  etl_timestamp    TIMESTAMP(6),
  prod_name        VARCHAR2(4000)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
