create table RRP_MDL.XZY_YSJ_2026_DB
(
  owner      VARCHAR2(100),
  table_name VARCHAR2(100),
  table_like VARCHAR2(100),
  table_key  VARCHAR2(100),
  comments   VARCHAR2(4000)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

