create table RRP_MDL.TMP_YZ
(
  id   VARCHAR2(63),
  name VARCHAR2(128),
  type VARCHAR2(23)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TMP_YZ.id
  is '主键ID';
comment on column RRP_MDL.TMP_YZ.name
  is '用户姓名';
comment on column RRP_MDL.TMP_YZ.type
  is '类型';

