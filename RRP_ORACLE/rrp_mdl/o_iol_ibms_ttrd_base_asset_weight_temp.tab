create table RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP
(
  id                 VARCHAR2(5),
  base_asset         VARCHAR2(150),
  weight             NUMBER(10,4),
  parent_id          VARCHAR2(5),
  style_level        VARCHAR2(2),
  check_level        VARCHAR2(2),
  is_readonly_weight VARCHAR2(2),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP
  is '基础资产权重录入(模板)';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.id
  is '主键';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.base_asset
  is '基础资产';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.weight
  is '权重';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.parent_id
  is '父id';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.style_level
  is '1-父级 2-子级';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.check_level
  is '1-控制子节点小于父节点  2-控制子节点相加为100';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.is_readonly_weight
  is '权重是否只读';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_BASE_ASSET_WEIGHT_TEMP.etl_timestamp
  is 'ETL处理时间戳';

