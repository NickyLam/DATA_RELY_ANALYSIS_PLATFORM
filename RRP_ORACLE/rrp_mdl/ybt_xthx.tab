create table RRP_MDL.YBT_XTHX
(
  data_dt              VARCHAR2(8),
  trccp_zdhj           NUMBER(10,2),
  trccp_xqzhl          NUMBER(10,2),
  trccp_ywysj          NUMBER(10,2),
  trccp_jytgl_all      NUMBER(10,2) default 100,
  trccp_jytgl_qjy      NUMBER(10,2) default 100,
  trccp_rpt_col        NUMBER(10) default 2224,
  trccp_zbkjwcj        NUMBER(10,2) default 100,
  yyglp_bsjd_jgsl      NUMBER(10),
  yyglp_bsjd_jgsl_t    NUMBER(10),
  yyglp_bsjd_tmsl      NUMBER(10),
  yyglp_bsjd_tmsl_t    NUMBER(10),
  yyglp_bsjd_jysl      NUMBER(10),
  yyglp_bsjd_jysl_t    NUMBER(10),
  yyglp_bsjd_tbsl      NUMBER(10),
  yyglp_bsjd_tbsl_t    NUMBER(10),
  yyglp_bsjd_bssl      NUMBER(10),
  yyglp_bsjd_bssl_t    NUMBER(10),
  yyglp_bsjd_zdzbjg    NUMBER(10),
  yyglp_bsjd_zdzbjg_t  NUMBER(10),
  yyglp_bsjd_wdmxb     NUMBER(10),
  yyglp_bsjd_wdmxb_t   NUMBER(10),
  yyglp_bsjd_wdhzb     NUMBER(10),
  yyglp_bsjd_wdhzb_t   NUMBER(10),
  yyglp_bsjd_to_1104   NUMBER(10),
  yyglp_bsjd_to_1104_t NUMBER(10),
  yyglp_bszc_tab       NUMBER(10) default 100,
  yyglp_bszc_col       NUMBER(10) default 2224,
  insert_time          TIMESTAMP(6) default SYSTIMESTAMP
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.YBT_XTHX
  is '一表通系统画像';
comment on column RRP_MDL.YBT_XTHX.data_dt
  is '数据日期';
comment on column RRP_MDL.YBT_XTHX.trccp_zdhj
  is '投入产出屏-自动化率';
comment on column RRP_MDL.YBT_XTHX.trccp_xqzhl
  is '投入产出屏-需求转化率';
comment on column RRP_MDL.YBT_XTHX.trccp_ywysj
  is '投入产出屏-业务用数率';
comment on column RRP_MDL.YBT_XTHX.trccp_jytgl_all
  is '投入产出屏-总校验通过率';
comment on column RRP_MDL.YBT_XTHX.trccp_jytgl_qjy
  is '投入产出屏-强校验通过率';
comment on column RRP_MDL.YBT_XTHX.trccp_rpt_col
  is '投入产出屏-报送字段数量';
comment on column RRP_MDL.YBT_XTHX.trccp_zbkjwcj
  is '投入产出屏-指标口径完成率';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_jgsl
  is '营运管理屏-报送进度-数据加工数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_jgsl_t
  is '营运管理屏-报送进度-数据加工总数';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_tmsl
  is '营运管理屏-报送进度-数据脱敏数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_tmsl_t
  is '营运管理屏-报送进度-数据脱敏总数';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_jysl
  is '营运管理屏-报送进度-数据校验数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_jysl_t
  is '营运管理屏-报送进度-数据校验总数';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_tbsl
  is '营运管理屏-报送进度-数据填报数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_tbsl_t
  is '营运管理屏-报送进度-数据填报总数';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_bssl
  is '营运管理屏-报送进度-数据报送数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_bssl_t
  is '营运管理屏-报送进度-数据报送总数';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_zdzbjg
  is '营运管理屏-报送进度-重点指标加工数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_zdzbjg_t
  is '营运管理屏-报送进度-重点指标加工总量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_wdmxb
  is '营运管理屏-报送进度-明细维度表加工数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_wdmxb_t
  is '营运管理屏-报送进度-明细维度表加工总数';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_wdhzb
  is '营运管理屏-报送进度-维度汇总表加工数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_wdhzb_t
  is '营运管理屏-报送进度-维度汇总表加工总数';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_to_1104
  is '营运管理屏-报送进度-转1104加工数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bsjd_to_1104_t
  is '营运管理屏-报送进度-转1104加工总量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bszc_tab
  is '营运管理屏-报送资产-表数量';
comment on column RRP_MDL.YBT_XTHX.yyglp_bszc_col
  is '营运管理屏-报送资产-字段数量';
comment on column RRP_MDL.YBT_XTHX.insert_time
  is '插入时间';

