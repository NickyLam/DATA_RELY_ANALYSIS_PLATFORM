  market_type_id       VARCHAR2(60),
  obj_id               VARCHAR2(60),
  asset_uniq_idf_id    VARCHAR2(100),
  prod_type_cd         VARCHAR2(30),
  tran_acct_b_id       VARCHAR2(60),
  tran_acct_b_name     VARCHAR2(250),
  acct_b_attr_cd       VARCHAR2(10),
  std_prod_id          VARCHAR2(60),
  asset_thd_cls_cd     VARCHAR2(30),
  curr_cd              VARCHAR2(10),
  tran_dir_cd          VARCHAR2(10),
  int_accr_base_cd     VARCHAR2(30),
  cntpty_cust_id       VARCHAR2(100),
  cntpty_id            VARCHAR2(60),
  cntpty_name          VARCHAR2(500),
  portf_id             VARCHAR2(60),
  portf_name           VARCHAR2(250),
  pric_subj_id         VARCHAR2(60),
  int_subj_id          VARCHAR2(100),
  tran_dt              DATE,
  value_dt             DATE,
  exp_dt               DATE,
  tran_amt             NUMBER(38,4),
  exp_stl_amt          NUMBER(38,4),
  debit_crdt_fee_rat   NUMBER(38,8),
  debit_crdt_days      NUMBER(22),
  inpwn_bond_comb      VARCHAR2(750),
  underly_bond_id      VARCHAR2(100),
  inpwn_cert_face_lmt  NUMBER(30,8),
  acru_int             NUMBER(30,8),
  int_recvbl           NUMBER(30,8),
  hold_pos             NUMBER(30,8),
  currt_bal            NUMBER(30,2),
  tran_id              VARCHAR2(100),
  tran_clear_acct_id   VARCHAR2(256),
  tran_clear_bank_no   VARCHAR2(256),
  tran_clear_bank_name VARCHAR2(500),
  job_cd               VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
