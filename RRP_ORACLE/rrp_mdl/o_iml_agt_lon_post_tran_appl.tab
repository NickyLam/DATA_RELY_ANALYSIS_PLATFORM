create table RRP_MDL.O_IML_AGT_LON_POST_TRAN_APPL
(
  appl_id                 VARCHAR2(100),
  lp_id                   VARCHAR2(100),
  tran_flow_num           VARCHAR2(100),
  rela_tran_flow_num      VARCHAR2(100),
  tran_cd                 VARCHAR2(30),
  tran_dt                 DATE,
  tran_amt                NUMBER(30,8),
  tran_status_cd          VARCHAR2(30),
  realtm_tran_flg         VARCHAR2(10),
  rolbk_flow_num          VARCHAR2(100),
  core_tran_ref_no        VARCHAR2(100),
  core_entry_flow_num     VARCHAR2(100),
  ova_flow_num            VARCHAR2(100),
  fft_tran_type_cd        VARCHAR2(30),
  grace_int_flg           VARCHAR2(10),
  grace_pric_flg          VARCHAR2(10),
  adv_repay_rs_cd         VARCHAR2(30),
  adv_repay_comnt         VARCHAR2(500),
  adv_repay_cap_src_comnt VARCHAR2(500),
  regroup_loan_flg        VARCHAR2(10),
  rela_obj_name           VARCHAR2(500),
  obj_id                  VARCHAR2(100),
  doc_type_name           VARCHAR2(500),
  doc_flow_num            VARCHAR2(100),
  rgst_org_id             VARCHAR2(100),
  rgst_teller_id          VARCHAR2(100),
  remark                  VARCHAR2(4000),
  other_comnt             VARCHAR2(4000),
  start_dt                DATE,
  end_dt                  DATE,
  id_mark                 VARCHAR2(10),
  src_table_name          VARCHAR2(100),
  job_cd                  VARCHAR2(10),
  etl_timestamp           TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_LON_POST_TRAN_APPL
