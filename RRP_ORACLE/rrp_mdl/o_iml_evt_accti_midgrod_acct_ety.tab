create table RRP_MDL.O_IML_EVT_ACCTI_MIDGROD_ACCT_ETY
(
  evt_id                VARCHAR2(100),
  sob_id                VARCHAR2(100),
  bus_sys_id            VARCHAR2(100),
  tran_dt               DATE,
  tran_flow_num         VARCHAR2(100),
  sumos_seq_num         VARCHAR2(60),
  sumos_id              VARCHAR2(100),
  tran_org_id           VARCHAR2(100),
  fin_org_id            VARCHAR2(100),
  subj_id               VARCHAR2(100),
  subj_name             VARCHAR2(500),
  batch_no              VARCHAR2(60),
  tran_tm               TIMESTAMP(6),
  curr_cd               VARCHAR2(30),
  off_bs_flg            VARCHAR2(10),
  cust_id               VARCHAR2(100),
  prod_id               VARCHAR2(100),
  acct_id               VARCHAR2(100),
  cash_trans_flg_cd     VARCHAR2(30),
  debit_crdt_dir_cd     VARCHAR2(30),
  tran_amt              NUMBER(30,2),
  tran_bal              NUMBER(30,2),
  memo_id               VARCHAR2(100),
  memo_descb            VARCHAR2(500),
  convt_exch_rat        NUMBER(18,8),
  user_id               VARCHAR2(100),
  sorc_sys_dt           DATE,
  sorc_sys_flow_num     VARCHAR2(100),
  src_sys_cd            VARCHAR2(30),
  src_tran_flow_seq_num VARCHAR2(60),
  chn_id                VARCHAR2(100),
  sellbl_prod_id        VARCHAR2(100),
  clear_status_cd       VARCHAR2(30),
  clear_flow_num        VARCHAR2(100),
  clear_dt              DATE,
  enter_acct_status_cd  VARCHAR2(30),
  src_sob_id            VARCHAR2(100),
  revs_status_cd        VARCHAR2(30),
  init_bus_dt           DATE,
  init_bus_flow_num     VARCHAR2(100),
  stand_mony_amt        NUMBER(30,2),
  aldy_sync_flg         VARCHAR2(10),
  ova_flow_num          VARCHAR2(100),
  etl_dt                DATE,
  src_table_name        VARCHAR2(100),
  job_cd                VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 0
    initrans 1
    maxtrans 255,
  partition PARTITION_20250930 values less than (TO_DATE(' 2025-10-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
