create table RRP_MDL.O_IML_PRD_INPWN_PROD_MGMT_INFO_H
(
  prod_pk         VARCHAR2(60),
  lp_id           VARCHAR2(60),
  fin_prod_id     VARCHAR2(100),
  pmo_type_descb  VARCHAR2(100),
  pmo_acct_num    VARCHAR2(500),
  pmo_evltion_amt NUMBER(38,8),
  value_dt        DATE,
  exp_dt          DATE,
  evltion_dt      DATE,
  create_tm       TIMESTAMP(6),
  update_tm       TIMESTAMP(6),
  start_dt        DATE,
  end_dt          DATE,
  id_mark         VARCHAR2(10),
  src_table_name  VARCHAR2(100),
  job_cd          VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PRD_INPWN_PROD_MGMT_INFO_H
  is '质押品管理信息历史';
