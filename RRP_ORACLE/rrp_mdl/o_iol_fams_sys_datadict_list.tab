  item_code     VARCHAR2(50),
  item_value    VARCHAR2(200),
  order_no      NUMBER(10),
  default_value VARCHAR2(50),
  create_user   VARCHAR2(20),
  create_dept   VARCHAR2(32),
  create_time   TIMESTAMP(6),
  update_user   VARCHAR2(20),
  update_time   TIMESTAMP(6),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_FAMS_SYS_DATADICT_LIST
