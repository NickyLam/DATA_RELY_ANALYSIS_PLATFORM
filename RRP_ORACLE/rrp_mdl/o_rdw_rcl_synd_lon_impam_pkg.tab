create table RRP_MDL.O_RDW_RCL_SYND_LON_IMPAM_PKG
(
  pkg_seq_num              VARCHAR2(90),
  cust_no                  VARCHAR2(90),
  normal_prin_subject_no   VARCHAR2(90),
  curr_int_rat_effect_dt   DATE,
  accrued_non_accrued_flg  VARCHAR2(15),
  currt_bal                NUMBER(30,2),
  next_int_rat_adj_dt      DATE,
  curr_cd                  VARCHAR2(15),
  curr_ovdue_flg           NUMBER(22),
  in_bs_int                NUMBER(30,2),
  exec_int_rate            NUMBER(38,8),
  tot_perds                NUMBER(10),
  distr_dt                 DATE,
  next_repay_dt            DATE,
  ovdue_int_rate           NUMBER(38,8),
  ovdue_days               NUMBER(22),
  ovdue_pric               NUMBER(30,2),
  base_int_rate            NUMBER(38,8),
  int_rat_flo_val          NUMBER(38,10),
  accts_org_no             VARCHAR2(90),
  ovdue_int                NUMBER(30,2),
  surp_perds               NUMBER(10),
  int_rat_float_way_cd     VARCHAR2(15),
  product_no               VARCHAR2(90),
  value_dt                 DATE,
  last_repay_dt            DATE,
  repay_freq_cd            VARCHAR2(15),
  pric_ovdue_flg           VARCHAR2(15),
  int_base_cd              VARCHAR2(15),
  repay_way_cd             VARCHAR2(15),
  mature_dt                DATE,
  int_accr_flg             VARCHAR2(15),
  comp_int_flg             VARCHAR2(15),
  int_ovdue_flg            VARCHAR2(15),
  level5_class_cd          VARCHAR2(15),
  distr_amt                NUMBER(30,2),
  nomal_pric               NUMBER(30,2),
  asset_three_cls_cd       VARCHAR2(45),
  int_repay_freq_cd        VARCHAR2(15),
  int_rat_adj_way_cd       VARCHAR2(15),
  dir_indus_cd             VARCHAR2(150),
  acm_recvbl_uncol_int_amt NUMBER(30,2),
  int_ovdue_days           NUMBER(10),
  recvbl_fee               NUMBER(30,2),
  td_acru_int              NUMBER(38,8),
  biz_breed_no             VARCHAR2(150),
  dubil_amt                NUMBER(30,2),
  adv_vat_amt              NUMBER(30,2),
  cred_rht_turn_flg        VARCHAR2(15),
  loan_type_cd             VARCHAR2(15),
  wrt_off_flg              VARCHAR2(10),
  cont_id                  VARCHAR2(100),
  guartor_name             VARCHAR2(500),
  open_acct_dt             DATE,
  comp_int_calc_way_cd     VARCHAR2(45),
  payoff_ind               VARCHAR2(15),
  int_rate_float_freq_cd   VARCHAR2(45),
  biz_strip_line_cd        VARCHAR2(45),
  repay_freq_val           NUMBER(22),
  int_repay_freq_val       NUMBER(22),
  wrt_off_pric             NUMBER(30,2),
  wrt_off_int              NUMBER(30,2),
  repay_prin               NUMBER(30,2),
  repay_int                NUMBER(30,2),
  bus_breed_cd             VARCHAR2(60),
  v_ccy_cd_before          VARCHAR2(15),
  v_dfc_ecl_cd             VARCHAR2(15),
  n_ecl                    NUMBER(26,5),
  n_ecl_before_dcf         NUMBER(26,5),
  n_ecl_before             NUMBER(26,5),
  tax_ecl                  NUMBER(30,2),
  n_ecl_dcf                NUMBER(26,5),
  tax_ecl_before           NUMBER(30,2),
  etl_dt                   DATE,
  guartor_cust_id          VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
