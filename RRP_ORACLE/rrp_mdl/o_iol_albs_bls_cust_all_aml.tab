create table RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML
(
  state             VARCHAR2(72),
  org_code          VARCHAR2(48),
  record_id         VARCHAR2(30),
  org_name          VARCHAR2(96),
  black_source_type VARCHAR2(2),
  customer_name     VARCHAR2(1500),
  detection_name    VARCHAR2(60),
  op_user_id        VARCHAR2(48),
  customer_no       VARCHAR2(48),
  identity_no       VARCHAR2(300),
  etl_dt            DATE,
  block_reason      VARCHAR2(375),
  input_type        VARCHAR2(3),
  customer_type     VARCHAR2(12),
  identity_type     VARCHAR2(12),
  crt_date          VARCHAR2(12),
  customer_address  VARCHAR2(360),
  id                VARCHAR2(48)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML
  is '黑名单系统供数给反洗钱系统黑名单表';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.state
  is '国家名称';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.org_code
  is '所属机构号';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.record_id
  is '黑名单ID（可通过该ID链接到黑名单系统查看记录的明细页面）  -也就是预警id';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.org_name
  is '所属机构名称';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.black_source_type
  is '黑名单类别:0-回溯检索客户黑名单,1-全球制裁名单,2-中国制裁名单';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.customer_name
  is '客户名称';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.detection_name
  is '侦测等级名称';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.op_user_id
  is '操作用户ID';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.customer_no
  is '客户号';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.identity_no
  is '证件号码';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.block_reason
  is '备注 也就是拦截原因';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.input_type
  is '决议类型 01-通用格式 09-道琼斯 20-OFAC 77-银行家年鉴';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.customer_type
  is '客户类型 00-对公 01-对私';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.identity_type
  is '证件类型 A-身份证 B-外国公民护照 C-户口簿（身份证号）...';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.crt_date
  is '检索日期：yyyymmdd';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.customer_address
  is '客户地址';
comment on column RRP_MDL.O_IOL_ALBS_BLS_CUST_ALL_AML.id
  is '主键ID';

