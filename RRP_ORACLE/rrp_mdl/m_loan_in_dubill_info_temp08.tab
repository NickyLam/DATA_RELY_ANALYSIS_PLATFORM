create table RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08
(
  dubil_num             VARCHAR2(2000),
  std_prod_id           VARCHAR2(2000),
  tran_dt               VARCHAR2(2000),
  tran_ref_no           VARCHAR2(2000),
  ncbs_reference        VARCHAR2(2000),
  channel_seq_no        VARCHAR2(2000),
  oth_real_base_acct_no VARCHAR2(2000),
  oth_real_tran_name    VARCHAR2(2000),
  contra_bank_code      VARCHAR2(2000),
  dfxh                  VARCHAR2(2000),
  contra_bank_name      VARCHAR2(2000),
  tran_amt              NUMBER(30,2),
  nbhzr_tran_amt        NUMBER(30,2),
  hkje                  NUMBER(30,2),
  rm                    NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08
  is '福费廷交易对手信息';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.dubil_num
  is '借据号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.std_prod_id
  is '标准产品编号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.tran_dt
  is '借据还款交易日期';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.tran_ref_no
  is '借据还款流水号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.ncbs_reference
  is '转入内部户流水号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.channel_seq_no
  is '转入内部户全局流水号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.oth_real_base_acct_no
  is '转入内部户账号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.oth_real_tran_name
  is '转入内部户账号户名';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.contra_bank_code
  is '转入内部户账号行号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.dfxh
  is '转入内部户账号人行支付行号';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.contra_bank_name
  is '转入内部户账号行名';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.tran_amt
  is '转入内部户金额';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.nbhzr_tran_amt
  is '转入内部户总金额';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.hkje
  is '福费廷还款金额';
comment on column RRP_MDL.M_LOAN_IN_DUBILL_INFO_TEMP08.rm
  is '序号';

