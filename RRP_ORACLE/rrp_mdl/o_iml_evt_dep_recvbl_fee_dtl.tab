create table RRP_MDL.O_IML_EVT_DEP_RECVBL_FEE_DTL
(
  etl_dt                 DATE,
  evt_id                 VARCHAR2(250),
  recvbl_fee_seq_num     VARCHAR2(60),
  lp_id                  VARCHAR2(100),
  bus_tran_dt            DATE,
  seq_num                VARCHAR2(60),
  cust_id                VARCHAR2(100),
  cust_type_cd           VARCHAR2(30),
  cust_acct_num          VARCHAR2(100),
  acct_name              VARCHAR2(500),
  open_acct_org_id       VARCHAR2(100),
  charge_acct_id         VARCHAR2(100),
  charge_acct_prod_id    VARCHAR2(100),
  charge_cust_acct_num   VARCHAR2(60),
  charge_acct_curr_cd    VARCHAR2(30),
  acct_id                VARCHAR2(100),
  effect_dt              DATE,
  last_charge_dt         DATE,
  tran_revs_dt           DATE,
  revs_org_id            VARCHAR2(100),
  core_tran_org_id       VARCHAR2(100),
  dep_vouch_cate_cd      VARCHAR2(30),
  vouch_id               VARCHAR2(250),
  vouch_sum_qtty         NUMBER(30),
  dep_agt_id             VARCHAR2(100),
  cntpty_bus_id          VARCHAR2(100),
  tran_ref_no            VARCHAR2(60),
  discnt_fee_amt         NUMBER(30,2),
  fee_type_id            VARCHAR2(100),
  fee_amt                NUMBER(30,2),
  init_fee_amt           NUMBER(30,2),
  next_charge_dt         DATE,
  tax                    NUMBER(30,2),
  init_recvbl_fee_amt    NUMBER(30,2),
  fee_price              NUMBER(30,2),
  charge_freq_cd         VARCHAR2(30),
  tax_rat                NUMBER(18,6),
  tax_category_cd        VARCHAR2(30),
  need_prft_cut_flg      VARCHAR2(10),
  tran_bank_prft_cut_amt NUMBER(30,2),
  fee_charge_way_cd      VARCHAR2(30),
  grace_flg              VARCHAR2(10),
  tran_revd_flg          VARCHAR2(10),
  fee_discnt_type_cd     VARCHAR2(30),
  tran_bank_ratio        NUMBER(18,6),
  charge_curr_cd         VARCHAR2(30),
  charge_sub_acct_num    VARCHAR2(60),
  charge_day             VARCHAR2(10),
  termnt_num             VARCHAR2(60),
  acct_bank_ratio        NUMBER(18,6),
  acct_bank_prft_cut_amt NUMBER(30,2),
  owe_fee_status_cd      VARCHAR2(30),
  prior_level            VARCHAR2(30),
  fee_discnt_rat         NUMBER(30,2),
  revs_auth_teller_id    VARCHAR2(100),
  revs_teller_id         VARCHAR2(100),
  tran_tm                TIMESTAMP(6),
  tran_teller_id         VARCHAR2(100),
  final_modif_dt         DATE,
  final_modif_teller_id  VARCHAR2(100),
  job_cd                 VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
