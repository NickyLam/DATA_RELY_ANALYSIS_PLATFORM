create table RRP_MDL.TMP_401_ZZKJQKMB_BWB1
(
  nbjgh  VARCHAR2(30) not null,
  kjkmbh VARCHAR2(60) not null,
  bz     VARCHAR2(3) not null,
  qcjfye NUMBER(20,2),
  qcdfye NUMBER(20,2),
  jffse  NUMBER(20,2),
  dffse  NUMBER(20,2),
  qmjfye NUMBER(20,2),
  qmdfye NUMBER(20,2),
  cjrq   VARCHAR2(8),
  bszq   VARCHAR2(20)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TMP_401_ZZKJQKMB_BWB1.nbjgh
  is '内部机构号';
comment on column RRP_MDL.TMP_401_ZZKJQKMB_BWB1.kjkmbh
  is '会计科目编号';
comment on column RRP_MDL.TMP_401_ZZKJQKMB_BWB1.bz
