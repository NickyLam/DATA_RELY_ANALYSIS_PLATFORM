comment on column RRP_MDL.TMP_401_ZZKJQKMB_BWB1.jffse
  is '临时表字段';
comment on column RRP_MDL.TMP_401_ZZKJQKMB_BWB1.dffse
  is '临时表字段';
comment on column RRP_MDL.TMP_401_ZZKJQKMB_BWB1.qmjfye
  is '期末借方余额';
comment on column RRP_MDL.TMP_401_ZZKJQKMB_BWB1.qmdfye
