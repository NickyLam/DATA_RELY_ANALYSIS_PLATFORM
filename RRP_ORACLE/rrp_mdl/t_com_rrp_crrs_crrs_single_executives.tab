create table RRP_MDL.T_COM_RRP_CRRS_CRRS_SINGLE_EXECUTIVES
(
  rid               VARCHAR2(100) not null,
  customer_code     VARCHAR2(60) not null,
  executives_id     VARCHAR2(100),
  person_type       VARCHAR2(20) not null,
  nationality_code  VARCHAR2(40),
  actual_controller CHAR(1),
  customer_name     VARCHAR2(100),
  update_dt         VARCHAR2(40),
  id_card_no        VARCHAR2(100),
  executives_name   VARCHAR2(200),
  data_dt           VARCHAR2(40) not null,
  issued_no         VARCHAR2(100),
  rpt_org_no        VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;

