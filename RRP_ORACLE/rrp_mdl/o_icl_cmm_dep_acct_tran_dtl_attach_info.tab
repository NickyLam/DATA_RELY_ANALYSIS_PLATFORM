create table RRP_MDL.O_ICL_CMM_DEP_ACCT_TRAN_DTL_ATTACH_INFO
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  tran_flow_num            VARCHAR2(60),
  tran_dt                  DATE,
  tran_timestamp           TIMESTAMP(6),
  acct_bill_flow_num       VARCHAR2(60),
  ova_flow_num             VARCHAR2(60),
  src_tran_flow_num        VARCHAR2(60),
  src_seq_no               VARCHAR2(100),
  cust_id                  VARCHAR2(60),
  cust_name                VARCHAR2(500),
  dep_sub_acct_id          VARCHAR2(60),
  cust_acct_id             VARCHAR2(60),
  sub_acct_id              VARCHAR2(60),
  tran_memo_descb          VARCHAR2(500),
  tran_kind_cd             VARCHAR2(30),
  debit_crdt_dir_cd        VARCHAR2(10),
  tran_org_id              VARCHAR2(60),
  cntpty_acct_id           VARCHAR2(60),
  cntpty_acct_name         VARCHAR2(1000),
  cntpty_acct_open_bank_cd VARCHAR2(60),
  cntpty_open_bank_name    VARCHAR2(1000),
  cntpty_subj_id           VARCHAR2(60),
  cntpty_subj_name         VARCHAR2(250),
  tran_curr_cd             VARCHAR2(10),
  tran_amt                 NUMBER(30,2),
  lev_tax_rebate_tran_flg  VARCHAR2(10),
  src_sys_id               VARCHAR2(10),
  tran_remark              VARCHAR2(1000),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 0
    initrans 1
    maxtrans 255,
  partition PARTITION_20250930 values less than (TO_DATE(' 2025-10-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.O_ICL_CMM_DEP_ACCT_TRAN_DTL_ATTACH_INFO
