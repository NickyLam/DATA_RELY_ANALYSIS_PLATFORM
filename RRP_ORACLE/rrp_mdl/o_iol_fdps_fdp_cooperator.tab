  old_req_account       VARCHAR2(360),
  ecif_account_id       VARCHAR2(360),
  cust_id_type          VARCHAR2(360),
  cust_id_no            VARCHAR2(360),
  cust_id_due_date      VARCHAR2(360),
  legal_person_name     VARCHAR2(360),
  legal_person_idtype   VARCHAR2(360),
  legal_person_idno     VARCHAR2(360),
  lpid_from_date        VARCHAR2(360),
  lpid_to_date          VARCHAR2(360),
  legal_person_telno    VARCHAR2(360),
  actor_name            VARCHAR2(1530),
  actor_id_type         VARCHAR2(360),
  actor_id_no           VARCHAR2(360),
  actorid_from_date     VARCHAR2(360),
  actorid_to_date       VARCHAR2(360),
  actor_mobile          VARCHAR2(360),
  licence_copy_url      VARCHAR2(4000),
  lp_front_copy_url     VARCHAR2(4000),
  lp_rear_copy_url      VARCHAR2(4000),
  actor_front_copy_url  VARCHAR2(4000),
  actor_rear_copy_url   VARCHAR2(4000),
  detail_address        VARCHAR2(1530),
  postal_code           VARCHAR2(360),
  contact_tel           VARCHAR2(360),
  clear_account         VARCHAR2(360),
  clear_account_name    VARCHAR2(1530),
  clear_org             VARCHAR2(360),
  clear_org_name        VARCHAR2(1530),
  mid_clear_account     VARCHAR2(1530),
  mid_account_name      VARCHAR2(1530),
  mid_clear_org         VARCHAR2(1530),
  mid_clear_org_name    VARCHAR2(1530),
  dep_clear_account     VARCHAR2(360),
  dep_account_name      VARCHAR2(1530),
  dep_clear_org         VARCHAR2(360),
  dep_clear_org_name    VARCHAR2(1530),
  cust_status           VARCHAR2(60),
  account_no            VARCHAR2(120),
  ext_name              VARCHAR2(1530),
  ext_value             VARCHAR2(1530),
  platform_code         VARCHAR2(1530),
  max_bind_cards        NUMBER(8),
  operator_id           VARCHAR2(1530),
  operator_dept_id      VARCHAR2(1530),
  checker_id            VARCHAR2(360),
  checker_dept_id       VARCHAR2(360),
  description           VARCHAR2(4000),
  last_updated_stamp    TIMESTAMP(6),
  last_updated_tx_stamp TIMESTAMP(6),
  created_stamp         TIMESTAMP(6),
  created_tx_stamp      TIMESTAMP(6),
  parent_merchant_sname VARCHAR2(1530),
  own_org_no            VARCHAR2(1530),
  dep_other_bank_flag   VARCHAR2(1530),
  settle_model          VARCHAR2(60),
  active_msm_model      VARCHAR2(60),
  ep_clear_ac           VARCHAR2(765),
  ep_clear_ac_name      VARCHAR2(765),
  ep_clear_org          VARCHAR2(765),
  ep_clear_org_name     VARCHAR2(765),
  ep_client_no          VARCHAR2(765),
  merchant_no           VARCHAR2(120),
  merchant_url          VARCHAR2(1530),
  recharge_url          VARCHAR2(1530),
  in_account_info       VARCHAR2(4000),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
compress;
