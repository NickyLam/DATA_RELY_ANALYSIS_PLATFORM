create table RRP_MDL.O_ICL_CMM_BILL_CENTER_INFO
(
  etl_dt                  DATE,
  lp_id                   VARCHAR2(60),
  bill_id                 VARCHAR2(60),
  bill_num                VARCHAR2(90),
  bill_sub_intrv_id       VARCHAR2(60),
  bill_med_cd             VARCHAR2(10),
  bill_type_cd            VARCHAR2(10),
  bill_pay_int_way_cd     VARCHAR2(30),
  draw_dt                 DATE,
  exp_dt                  DATE,
  distr_dt                DATE,
  acpt_dt                 DATE,
  cash_dt                 DATE,
  curr_cd                 VARCHAR2(10),
  fac_val_amt             NUMBER(30,2),
  cust_id                 VARCHAR2(60),
  cust_mgr_id             VARCHAR2(60),
  drawer_cust_id          VARCHAR2(60),
  drawer_name             VARCHAR2(500),
  drawer_acct_num         VARCHAR2(90),
  drawer_open_bank_no     VARCHAR2(90),
  drawer_open_bank_name   VARCHAR2(750),
  drawer_operr_id         VARCHAR2(60),
  drawer_type_cd          VARCHAR2(30),
  drawer_orgnz_cd         VARCHAR2(60),
  drawer_soci_crdt_cd     VARCHAR2(60),
  recver_name             VARCHAR2(375),
  recver_acct_num         VARCHAR2(90),
  recver_open_bank_no     VARCHAR2(90),
  recver_open_bank_name   VARCHAR2(750),
  pay_bank_bank_no        VARCHAR2(90),
  pay_bank_name           VARCHAR2(750),
  pay_org_id              VARCHAR2(60),
  pay_cfm_org_id          VARCHAR2(60),
  accptor_name            VARCHAR2(1000),
  accptor_acct_num        VARCHAR2(90),
  accptor_open_bank_no    VARCHAR2(90),
  accptor_open_bank_name  VARCHAR2(750),
  accptor_type_cd         VARCHAR2(30),
  acpt_org_id             VARCHAR2(60),
  accptor_soci_crdt_cd    VARCHAR2(60),
  holder_org_id           VARCHAR2(60),
  holder_org_name         VARCHAR2(750),
  endors_cnt              INTEGER,
  lock_flg                VARCHAR2(10),
  loss_flg                VARCHAR2(10),
  hxb_acpt_flg            VARCHAR2(10),
  pay_cfm_flg             VARCHAR2(10),
  payoff_flg              VARCHAR2(10),
  recs_flg                VARCHAR2(10),
  valet_coll_flg          VARCHAR2(10),
  risk_status_cd          VARCHAR2(10),
  bill_src_cd             VARCHAR2(10),
  bill_status_cd          VARCHAR2(10),
  ccution_status_cd       VARCHAR2(30),
  invtry_status_cd        VARCHAR2(30),
  ele_bill_status_cd      VARCHAR2(30),
  bill_proc_mdl_status_cd VARCHAR2(30),
  belong_org_id           VARCHAR2(60),
  receipt_flg             VARCHAR2(10),
  redcst_flg              VARCHAR2(10),
  data_src_cd             VARCHAR2(10),
  job_cd                  VARCHAR2(10),
  etl_timestamp           TIMESTAMP(6),
  recver_soci_crdt_cd     VARCHAR2(60),
  discnt_bank_org_id      VARCHAR2(60),
  discnt_ibank_no         VARCHAR2(60),
  discnt_bank_name        VARCHAR2(750)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
