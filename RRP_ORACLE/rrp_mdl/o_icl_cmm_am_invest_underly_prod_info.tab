create table RRP_MDL.O_ICL_CMM_AM_INVEST_UNDERLY_PROD_INFO
(
  etl_dt                      DATE,
  lp_id                       VARCHAR2(60),
  prod_id                     VARCHAR2(60),
  std_prod_id                 VARCHAR2(60),
  prod_cate_cd                VARCHAR2(60),
  prod_abbr                   VARCHAR2(250),
  prod_fname                  VARCHAR2(250),
  prft_mode_cd                VARCHAR2(60),
  coupon_breed_cd             VARCHAR2(60),
  fin_prod_id                 VARCHAR2(60),
  issue_price                 NUMBER(30,14),
  issue_size                  NUMBER(30,2),
  issue_curr_cd               VARCHAR2(60),
  overs_flg                   VARCHAR2(60),
  tran_site_cd                VARCHAR2(60),
  tran_caln_cd                VARCHAR2(60),
  issue_way_cd                VARCHAR2(60),
  csner_id                    VARCHAR2(60),
  trustee_id                  VARCHAR2(60),
  issuer_id                   VARCHAR2(60),
  mger_id                     VARCHAR2(60),
  finer_id                    VARCHAR2(60),
  issue_dt                    DATE,
  value_dt                    DATE,
  exp_dt                      DATE,
  prod_tenor                  NUMBER(10),
  actl_exp_dt                 DATE,
  subtn_flg                   VARCHAR2(60),
  subtn_claus                 VARCHAR2(1000),
  contn_weight_flg            VARCHAR2(60),
  brkevn_flg                  VARCHAR2(60),
  rgst_trust_org_cd           VARCHAR2(60),
  fin_inst_issue_flg          VARCHAR2(60),
  guartor_id                  VARCHAR2(60),
  purch_cfm_tenor             NUMBER(10),
  redem_cfm_tenor             NUMBER(10),
  sub_debt_flg                VARCHAR2(60),
  invest_char_type_cd         VARCHAR2(60),
  fac_val                     NUMBER(30,14),
  city_bond_flg               VARCHAR2(60),
  city_bond_lev_cd            VARCHAR2(60),
  asset_src_cd                VARCHAR2(60),
  distr_brch_id               VARCHAR2(100),
  clear_ped_cd                VARCHAR2(30),
  proj_dir_indus_categy_cd    VARCHAR2(60),
  proj_dir_indus_gen_cd       VARCHAR2(60),
  bank_int_prod_level2_cls_cd VARCHAR2(60),
  bank_int_prod_level3_cls_cd VARCHAR2(60),
  bank_int_prod_level4_cls_cd VARCHAR2(60),
  bank_int_prod_level5_cls_cd VARCHAR2(60),
  actl_crdt_main_id           VARCHAR2(500),
  ped_days                    VARCHAR2(60),
  am_plan_type_cd             VARCHAR2(60),
  int_rat_adj_way_cd          VARCHAR2(60),
  prod_bal                    NUMBER(30,2),
  prod_nv                     NUMBER(30,14),
  job_cd                      VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
