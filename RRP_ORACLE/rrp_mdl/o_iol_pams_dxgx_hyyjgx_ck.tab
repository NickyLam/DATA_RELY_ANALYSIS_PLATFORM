create table RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK
(
  tjrq          NUMBER(22),
  jxdxdh        NUMBER(22),
  khdxdh        NUMBER(22),
  fpjs          VARCHAR2(6),
  zlbl          NUMBER(19,5),
  gxhslx        VARCHAR2(3),
  gxzt          VARCHAR2(3),
  yylsh         NUMBER(22),
  yz            NUMBER(25,4),
  clbl          NUMBER(19,5),
  gxly          VARCHAR2(6),
  etl_dt        DATE,
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK
  is '对象关系-行员业绩关系-存款子账户';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.tjrq
  is '数据日期';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.jxdxdh
  is '绩效对象代号';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.khdxdh
  is '考核对象代号';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.fpjs
  is '分配角色';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.zlbl
  is '认领比例';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.gxhslx
  is '关系函数类型';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.gxzt
  is '关系状态';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.yylsh
  is '预约流水号';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.yz
  is '阈值';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.clbl
  is '存量比例';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.gxly
  is '关系来源';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IOL_PAMS_DXGX_HYYJGX_CK.etl_timestamp
  is 'ETL处理时间戳';

