create table RRP_MDL.O_IML_PTY_CAP_CNTPTY_INFO
(
  party_id               VARCHAR2(60),
  lp_id                  VARCHAR2(60),
  dept_id                VARCHAR2(60),
  cntpty_id              VARCHAR2(60),
  cntpty_abbr            VARCHAR2(750),
  cntpty_fname           VARCHAR2(750),
  cntpty_en_abbr         VARCHAR2(750),
  cntpty_en_name         VARCHAR2(750),
  elec_cert_name         VARCHAR2(150),
  elec_cert_id           VARCHAR2(60),
  elec_cert_flg          VARCHAR2(10),
  intnal_rating_level_cd VARCHAR2(10),
  cotas_name             VARCHAR2(150),
  tel_num                VARCHAR2(90),
  fax_num                VARCHAR2(90),
  issuer_flg             VARCHAR2(10),
  issuer_id              VARCHAR2(60),
  guartor_flg            VARCHAR2(10),
  guartor_id             VARCHAR2(60),
  fin_inst_flg           VARCHAR2(10),
  trust_org_flg          VARCHAR2(10),
  indus_type_cd          VARCHAR2(10),
  elec_ibank_no          VARCHAR2(90),
  pay_bk_bank_no         VARCHAR2(90),
  swift_id               VARCHAR2(30),
  cust_id                VARCHAR2(100),
  create_dt              DATE,
  update_dt              DATE,
  etl_dt                 DATE,
  id_mark                VARCHAR2(10),
  src_table_name         VARCHAR2(100),
  job_cd                 VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_CAP_CNTPTY_INFO
  is '资金交易对手信息表';
comment on column RRP_MDL.O_IML_PTY_CAP_CNTPTY_INFO.party_id
  is '当事人编号';
comment on column RRP_MDL.O_IML_PTY_CAP_CNTPTY_INFO.lp_id
