create table RRP_MDL.O_IOL_ICMS_CODE_LIBRARY
(
  etl_dt        DATE,
  codeno        VARCHAR2(64),
  itemno        VARCHAR2(64),
  inputuser     VARCHAR2(64),
  relativecode  VARCHAR2(4000),
  attribute6    VARCHAR2(1000),
  updatetime    VARCHAR2(64),
  sortno        VARCHAR2(64),
  isinuse       VARCHAR2(64),
  attribute8    VARCHAR2(1000),
  attribute3    VARCHAR2(1000),
  helptext      VARCHAR2(1000),
  updateuser    VARCHAR2(64),
  attribute9    VARCHAR2(1000),
  updateorg     VARCHAR2(64),
  itemdescribe  VARCHAR2(2000),
  bankno        VARCHAR2(64),
  itemattribute VARCHAR2(2000),
  updatedate    DATE,
  itemname      VARCHAR2(1000),
  remark        VARCHAR2(1000),
  inputorg      VARCHAR2(64),
  parentitemno  VARCHAR2(64),
  attribute1    VARCHAR2(2000),
  inputdate     DATE,
  attribute7    VARCHAR2(1000),
  inputtime     VARCHAR2(64),
  attribute2    VARCHAR2(1000),
  attribute5    VARCHAR2(1000),
  attribute4    VARCHAR2(1000),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
