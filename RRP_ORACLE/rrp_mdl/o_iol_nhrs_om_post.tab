comment on column RRP_MDL.O_IOL_NHRS_OM_POST.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_NHRS_OM_POST.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_NHRS_OM_POST.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IOL_NHRS_OM_POST.etl_timestamp
  is 'ETL处理时间戳';

