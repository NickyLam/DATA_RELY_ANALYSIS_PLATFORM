create table RRP_MDL.O_IOL_BDMS_HTES_DRAFT_INFO
(
  id                    VARCHAR2(60),
  draft_number          VARCHAR2(45),
  draft_attr            VARCHAR2(6),
  draft_type            VARCHAR2(6),
  remit_date            VARCHAR2(12),
  maturity_date         VARCHAR2(12),
  draft_amount          NUMBER(18,2),
  remitter_name         VARCHAR2(150),
  remitter_account      VARCHAR2(48),
  remitter_credit_no    VARCHAR2(48),
  remitter_brh_no       VARCHAR2(14),
  remitter_bank_no      VARCHAR2(18),
  remitter_bank_name    VARCHAR2(270),
  acceptor_name         VARCHAR2(150),
  acceptor_account      VARCHAR2(48),
  acceptor_credit_no    VARCHAR2(48),
  acceptor_brh_no       VARCHAR2(14),
  acceptor_bank_no      VARCHAR2(18),
  acceptor_bank_name    VARCHAR2(270),
  payee_name            VARCHAR2(150),
  payee_account         VARCHAR2(48),
  payee_credit_no       VARCHAR2(48),
  payee_brh_no          VARCHAR2(14),
  payee_bank_no         VARCHAR2(18),
  payee_bank_name       VARCHAR2(270),
  payer_brh_no          VARCHAR2(14),
  payer_bank_no         VARCHAR2(18),
  guarantee_brh_no      VARCHAR2(14),
  payer_confirm_brh_no  VARCHAR2(14),
  discount_brh_no       VARCHAR2(14),
  accept_gua_brh_no     VARCHAR2(14),
  disc_gua_brh_no       VARCHAR2(14),
  store_brh_no          VARCHAR2(14),
  flow_status           VARCHAR2(9),
  risk_status           VARCHAR2(6),
  store_status          VARCHAR2(6),
  status                VARCHAR2(6),
  org_flow_status       VARCHAR2(9),
  org_risk_status       VARCHAR2(6),
  org_status            VARCHAR2(6),
  org_store_status      VARCHAR2(6),
  last_upd_opr          VARCHAR2(45),
  last_upd_time         VARCHAR2(21),
  misc                  VARCHAR2(675),
  disc_date             VARCHAR2(12),
  emerg_flag            VARCHAR2(2),
  bp_no                 VARCHAR2(45),
  forehand_range        VARCHAR2(38),
  current_range         VARCHAR2(38),
  product_type          VARCHAR2(6),
  cd_range              VARCHAR2(38),
  standard_amt          NUMBER(18,2),
  draft_remark          VARCHAR2(675),
  draft_explain         VARCHAR2(675),
  cd_split              VARCHAR2(2),
  remitter_mem_no       VARCHAR2(9),
  remitter_dist_tp      VARCHAR2(6),
  remitter_brh_name     VARCHAR2(450),
  acceptor_mem_no       VARCHAR2(9),
  acceptor_dist_tp      VARCHAR2(6),
  acceptor_brh_name     VARCHAR2(450),
  payee_mem_no          VARCHAR2(9),
  payee_dist_tp         VARCHAR2(6),
  payee_brh_name        VARCHAR2(450),
  holder_mem_no         VARCHAR2(9),
  holder_name           VARCHAR2(675),
  holder_crt_no         VARCHAR2(48),
  holder_dist_tp        VARCHAR2(6),
  holder_acct_no        VARCHAR2(48),
  holder_bank_no        VARCHAR2(18),
  holder_bank_name      VARCHAR2(270),
  holder_brh_no         VARCHAR2(14),
  holder_brh_name       VARCHAR2(450),
  transfer_flag         VARCHAR2(6),
  consignment_code      VARCHAR2(6),
  owership_flag         VARCHAR2(3),
  payer_name            VARCHAR2(270),
  payer_account         VARCHAR2(48),
  payer_credit_no       VARCHAR2(48),
  payer_bank_name       VARCHAR2(270),
  payer_mem_no          VARCHAR2(9),
  payer_dist_tp         VARCHAR2(6),
  payer_brh_name        VARCHAR2(450),
  acceptor_acctname     VARCHAR2(675),
  remitter_acctname     VARCHAR2(675),
  payee_acctname        VARCHAR2(675),
  create_time           VARCHAR2(21),
  create_by             VARCHAR2(45),
  remitter_account_name VARCHAR2(225),
  acceptor_account_name VARCHAR2(225),
  payee_account_name    VARCHAR2(225),
  holder_acct_name      VARCHAR2(675),
  draft_pay_status      VARCHAR2(6),
  pay_no                VARCHAR2(53),
  settle_date           VARCHAR2(12),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6),
  migrate_flag          VARCHAR2(15)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
