create table RRP_MDL.O_ICL_CMM_POS_MERCHT_INFO
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  mercht_order_id          VARCHAR2(60),
  mercht_id                VARCHAR2(60),
  agency_id                VARCHAR2(60),
  mercht_name              VARCHAR2(500),
  mercht_fname             VARCHAR2(150),
  work_addr                VARCHAR2(750),
  open_acct_bank_name      VARCHAR2(150),
  open_acct_bank_id        VARCHAR2(60),
  acct_id                  VARCHAR2(60),
  acct_name                VARCHAR2(150),
  acct_type_cd             VARCHAR2(60),
  cotas_type_cd            VARCHAR2(60),
  cotas_name               VARCHAR2(150),
  cont_num                 VARCHAR2(90),
  cotas_e_mail             VARCHAR2(90),
  fax_num                  VARCHAR2(90),
  mercht_belong_rg_cd      VARCHAR2(60),
  mercht_mcc_code          VARCHAR2(60),
  mercht_mcc_descb         VARCHAR2(500),
  oper_co_corp_name        VARCHAR2(150),
  agency_abbr              VARCHAR2(100),
  agency_belong_brch_id    VARCHAR2(100),
  agency_bus_lics_id       VARCHAR2(60),
  agency_cotas_name        VARCHAR2(100),
  agency_cotas_addr        VARCHAR2(100),
  agency_enter_acct_chn_cd VARCHAR2(30),
  agency_status_cd         VARCHAR2(30),
  recv_bill_bank_id        VARCHAR2(60),
  mercht_status_cd         VARCHAR2(30),
  belong_org_id            VARCHAR2(60),
  cust_mgr_id              VARCHAR2(100),
  cust_mgr_name            VARCHAR2(150),
  flow_bank_apv_flow_id    VARCHAR2(60),
  flow_bank_apv_rest_cd    VARCHAR2(30),
  h5_flow_flg              VARCHAR2(30),
  dic_conc_mercht_flg      VARCHAR2(10),
  jh_mercht_flg            VARCHAR2(10),
  mercht_start_use_dt      DATE,
  job_cd                   VARCHAR2(10),
  mercht_sign_dt           DATE,
  mercht_revo_dt           DATE,
  dic_conc_co_status_cd    VARCHAR2(30),
  mercht_cust_id           VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
