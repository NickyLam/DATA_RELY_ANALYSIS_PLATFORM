create table RRP_MDL.O_IOL_SVBS_TL9_RESOURCEBASIC
(
  resourceid     VARCHAR2(192),
  parent         VARCHAR2(192),
  resourcename   VARCHAR2(192),
  accesscontrol  VARCHAR2(3),
  updatetime     DATE,
  createtime     DATE,
  recordstatus   VARCHAR2(3),
  resourcetypeid VARCHAR2(6),
  icon           VARCHAR2(384),
  catalog_id     VARCHAR2(24),
  specialflag    VARCHAR2(24),
  showflag       VARCHAR2(3),
  systemid       VARCHAR2(192),
  url            VARCHAR2(384),
  given_name     VARCHAR2(192),
  details        VARCHAR2(768),
  sort_no        NUMBER,
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10),
  etl_timestamp  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_SVBS_TL9_RESOURCEBASIC
  is '资源基础信息表';
comment on column RRP_MDL.O_IOL_SVBS_TL9_RESOURCEBASIC.resourceid
  is '资源ID';
comment on column RRP_MDL.O_IOL_SVBS_TL9_RESOURCEBASIC.parent
  is '父级资源ID';
