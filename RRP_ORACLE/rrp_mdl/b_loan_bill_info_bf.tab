create table RRP_MDL.B_LOAN_BILL_INFO_BF
(
  data_dt             CHAR(8) not null,
  lgl_rep_id          VARCHAR2(200) not null,
  org_id              VARCHAR2(200),
  subj_id             VARCHAR2(200),
  loan_cont_id        VARCHAR2(200) not null,
  bill_no             VARCHAR2(200) not null,
  bill_biz_typ        VARCHAR2(10),
  cur                 CHAR(3),
  bill_par_amt        NUMBER(30,2),
  bill_isu_dt         CHAR(8),
  bill_exp_dt         CHAR(8),
  drawer_id           VARCHAR2(200),
  drawer_nm           VARCHAR2(500),
  drawer_acc          VARCHAR2(200),
  drawer_open_bank_nm VARCHAR2(500),
  payee_nm            VARCHAR2(500),
  payee_acc           VARCHAR2(200),
  payee_open_bank_nm  VARCHAR2(500),
  bank_disc_flg       CHAR(1),
  bill_tra_bkgd       VARCHAR2(2000),
  comm_amt            NUMBER(30,2),
  oth_cost_cur        CHAR(3),
  oth_cost_amt        NUMBER(30,2),
  mrgn_pct            NUMBER(18,4),
  mrgn_cur            CHAR(3),
  mrgn                NUMBER(30,2),
  mrgn_acc            VARCHAR2(200),
  bill_stat           VARCHAR2(10),
  hdlr_no             VARCHAR2(30),
  dept_line           VARCHAR2(500),
  data_src            VARCHAR2(500),
  dubil_id            VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.B_LOAN_BILL_INFO_BF
  is '票据出票表';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.org_id
  is '银行编号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.subj_id
  is '科目编号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.loan_cont_id
  is '被担保合同编号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bill_no
  is '账单编号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bill_biz_typ
  is '票据业务类型';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.cur
  is '账号币种';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bill_par_amt
  is '票面金额';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bill_isu_dt
  is '票据出票日期';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bill_exp_dt
  is '票据到期日期';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.drawer_id
  is '出票人编号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.drawer_nm
  is '出票人名称';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.drawer_acc
  is '出票人账号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.drawer_open_bank_nm
  is '出票人开户行名称';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.payee_nm
  is '收款人名称';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.payee_acc
  is '收款人账号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.payee_open_bank_nm
  is '收款人开户行名称';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bank_disc_flg
  is '本行贴现标志';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bill_tra_bkgd
  is '票据交易背景';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.comm_amt
  is '手续费金额';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.oth_cost_cur
  is '其他费用币种';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.oth_cost_amt
  is '其他费用金额';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.mrgn_pct
  is '保证金比例:ED04AQ01';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.mrgn_cur
  is '保证金币种';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.mrgn
  is '保证金';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.mrgn_acc
  is '保证金账号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.bill_stat
  is '票据状态';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.hdlr_no
  is '经办人工号';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.dept_line
  is '部门条线';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.data_src
  is '数据来源（参见[字典:AML0045]）';
comment on column RRP_MDL.B_LOAN_BILL_INFO_BF.dubil_id
  is '借据编号';

