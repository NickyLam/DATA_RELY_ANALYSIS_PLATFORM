create table RRP_MDL.O_IOL_ILSS_WL_LOAN
(
  id               NUMBER(38),
  apply_id         NUMBER(38),
  apply_no         VARCHAR2(80),
  org_id           VARCHAR2(80),
  product_id       NUMBER(38),
  apply_amount     NUMBER(38,2),
  apply_time       DATE,
  bank_name        VARCHAR2(80),
  bank_card_no     VARCHAR2(80),
  loan_term        NUMBER(10),
  loan_rate        NUMBER(38,2),
  service_rate     NUMBER(38,2),
  service_fee      NUMBER(38,2),
  inst_fee_rate    NUMBER(38,2),
  inst_fee_amount  NUMBER(38,2),
  trans_amount     NUMBER(38,2),
  trans_time       DATE,
  operator         VARCHAR2(32),
  status           NUMBER(10),
  remark           VARCHAR2(1000),
  create_user      VARCHAR2(32),
  create_time      DATE,
  update_user      VARCHAR2(32),
  update_time      DATE,
  customer_id      NUMBER(38),
  bank_card_client VARCHAR2(32),
  bank_bind_phone  VARCHAR2(16),
  is_submit        NUMBER(22),
  card_type        VARCHAR2(1),
  fail_status      VARCHAR2(1),
  trans_seq_no     VARCHAR2(32),
  pay_order_id     VARCHAR2(32),
  loan_seq_no      VARCHAR2(32),
  global_seq_no    VARCHAR2(32),
  trans_status     VARCHAR2(20),
  hostcr_seq_no    VARCHAR2(32),
  hostdr_seq_no    VARCHAR2(32),
  pay_bank_name    VARCHAR2(80),
  pay_bank_card_no VARCHAR2(80),
  iou_no           VARCHAR2(80),
  trans_method     VARCHAR2(80),
  frozen_date      DATE,
  frozen_seq_no    VARCHAR2(32),
  direct_flg       NUMBER(1),
  appv_user_id     VARCHAR2(32),
  refinance_iou_no VARCHAR2(32),
  advice_id        NUMBER(18),
  pay_acct_no      VARCHAR2(32),
  loan_channel     VARCHAR2(10),
  start_dt         DATE,
  end_dt           DATE,
  id_mark          VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_ILSS_WL_LOAN
  is '贷款/放款';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.id
  is '主键ID';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.apply_id
  is '申请ID';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.apply_no
  is '贷款申请编号';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.org_id
  is '组织ID\N';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.product_id
  is '产品ID';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.apply_amount
  is '申请放款金额';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.apply_time
  is '申请放款时间';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.bank_name
  is '开户银行名称';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.bank_card_no
  is '开户卡号';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.loan_term
