comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.loan_rate
  is '贷款利率';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.service_rate
  is '服务利率';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.service_fee
  is '服务费用';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.inst_fee_rate
  is '分期手续费率';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.inst_fee_amount
  is '分期手续费固定金额';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.trans_amount
  is '放款金额';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.trans_time
  is '放款时间';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.operator
  is '经办人';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.status
  is '交易状态(0未放款1已放款2放款中,3待放款，4已拒绝，5人工审核)';
comment on column RRP_MDL.O_IOL_ILSS_WL_LOAN.remark
