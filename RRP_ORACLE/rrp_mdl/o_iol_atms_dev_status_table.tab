tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE
  is '设备模块状态表';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_no
  is '设备号';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_status
  is 'HEALTHY(正常) FATAL（故障）WARNING（警告）UNKNOWN（未知）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_tx_status
  is 'HEALTHY（正常）PARTSERVICE（部分服务）NOSERVICE（停止服务）UNKNOWN（未知）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_net_status
  is 'HEALTHY（正常）FATAL（故障，即离线）WARNING（警告）UNKNOW（未知）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_run_status
  is 'HEALTHY(正常) CLOSE（关机）MAINTAIN（维护）NETFATAL（P通讯故障）PARTSERVICE（部分服务）NOSERVICE（停止服务）STOP（停用）UNKNOWN（未知）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_cashbox_status
  is 'OK（充足）LOW（不足）EMPTY（缺炒）FULL（钞满）UNKNOWN（未知）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_mod_status
  is 'HEALTHY(正常) FATAL（故障） WARNING（警告） UNKNOWN（未知）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.dev_potential_fault
  is '设备是否存在潜在故障（未使用）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.status_last_time
  is '上次更新时间（yyyymmddhhmmss）';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.status_expire_time
  is '状态超时时间（yyyymmddhhmmss）';
