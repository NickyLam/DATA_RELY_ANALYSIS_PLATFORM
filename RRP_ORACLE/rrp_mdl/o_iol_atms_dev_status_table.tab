comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.cash_unit_type
  is 'P--Physical,L--Logical';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.status_info_type
  is '1--定时状态报文 2--强制发送状态报文';
comment on column RRP_MDL.O_IOL_ATMS_DEV_STATUS_TABLE.combin_unit_type
  is '0--按默认方式合并 1--按PUPosName合并 2--按DevCdmCUID合并 3--按PUPosName和DevCdmCUID合并';
