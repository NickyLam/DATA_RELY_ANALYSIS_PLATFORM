  cdm_cu_id                     VARCHAR2(100),
  cdm_pcu_id                    VARCHAR2(100),
  cdm_cu_note_value             VARCHAR2(100),
  cdm_cu_currency               VARCHAR2(100),
  cdm_cu_current_count          VARCHAR2(100),
