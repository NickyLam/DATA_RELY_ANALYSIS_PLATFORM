comment on column RRP_MDL.O_IML_AGT_IC_CARD_ELEC_CASH_ACCT_H.acct_name
  is '账户名称';
comment on column RRP_MDL.O_IML_AGT_IC_CARD_ELEC_CASH_ACCT_H.clos_acct_dt
