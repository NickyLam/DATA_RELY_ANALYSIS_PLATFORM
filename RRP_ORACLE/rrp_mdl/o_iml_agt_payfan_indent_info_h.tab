create table RRP_MDL.O_IML_AGT_PAYFAN_INDENT_INFO_H
(
  agt_id                   VARCHAR2(100),
  lp_id                    VARCHAR2(100),
  tran_flow_num            VARCHAR2(100),
  tran_dt                  DATE,
  payfan_chn_id            VARCHAR2(100),
  tran_code                VARCHAR2(60),
  curr_cd                  VARCHAR2(30),
  tran_type_cd             VARCHAR2(30),
  tran_status_cd           VARCHAR2(30),
  tran_amt                 NUMBER(30,2),
  batch_no                 VARCHAR2(60),
  batch_rgst_status_cd     VARCHAR2(30),
  tot                      NUMBER(10),
  sucs_tran_amt            NUMBER(30,2),
  sucs_tran_cnt            NUMBER(10),
  fail_tran_amt            NUMBER(30,2),
  fail_tran_cnt            NUMBER(10),
  chn_order_no             VARCHAR2(60),
  resp_code                VARCHAR2(30),
  resp_code_descb          VARCHAR2(2000),
  mercht_id                VARCHAR2(250),
  pay_acct_type_cd         VARCHAR2(30),
  pay_acct_id              VARCHAR2(100),
  pay_acct_name            VARCHAR2(500),
  intnal_acct_id           VARCHAR2(100),
  intnal_acct_name         VARCHAR2(500),
  recvbl_acct_id           VARCHAR2(100),
  recvbl_acct_name         VARCHAR2(500),
  recvbl_acct_type_cd      VARCHAR2(30),
  recvbl_bank_ibank_no     VARCHAR2(60),
  recvbl_bank_name         VARCHAR2(1000),
  cert_type_cd             VARCHAR2(30),
  cert_no                  VARCHAR2(100),
  mobile_no                VARCHAR2(60),
  postsc                   VARCHAR2(1000),
  ova_flow_num             VARCHAR2(100),
  core_flow_num            VARCHAR2(100),
  unionpay_mercht_order_no VARCHAR2(100),
  unionpay_tran_flow_num   VARCHAR2(100),
  unionpay_tran_dt         DATE,
  agt_corp_type_cd         VARCHAR2(30),
  agency_id                VARCHAR2(100),
  agt_corp_id              VARCHAR2(100),
  agt_corp_name            VARCHAR2(1000),
  api_sys_idf              VARCHAR2(100),
  teller_id                VARCHAR2(100),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
