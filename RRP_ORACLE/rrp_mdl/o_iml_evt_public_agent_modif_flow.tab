create table RRP_MDL.O_IML_EVT_PUBLIC_AGENT_MODIF_FLOW
(
  evt_id                     VARCHAR2(250),
  lp_id                      VARCHAR2(100),
  modif_flow_num             VARCHAR2(100),
  modif_dt                   DATE,
  unify_info_que_flow_num    VARCHAR2(100),
  init_tran_dt               DATE,
  init_tran_bus_flow_num     VARCHAR2(100),
  init_tran_ova_flow_num     VARCHAR2(100),
  blip_batch_no              VARCHAR2(500),
  agent_flg                  VARCHAR2(10),
  public_agent_type_cd       VARCHAR2(30),
  public_agent_name          VARCHAR2(500),
  agent_reason_descb         VARCHAR2(500),
  cert_type_cd               VARCHAR2(30),
  cert_no                    VARCHAR2(100),
  cont_num                   VARCHAR2(60),
  nation_cd                  VARCHAR2(30),
  gender_cd                  VARCHAR2(30),
  career_cd_one              VARCHAR2(30),
  career_descb_one           VARCHAR2(500),
  career_cd_two              VARCHAR2(30),
  career_descb_two           VARCHAR2(500),
  career_dtl_comnt           VARCHAR2(500),
  cont_addr_prov_cd          VARCHAR2(30),
  cont_addr_prov_name        VARCHAR2(500),
  cont_addr_city_cd          VARCHAR2(30),
  cont_addr_city_name        VARCHAR2(500),
  cont_addr_rg_cd            VARCHAR2(30),
  cont_addr_rg_name          VARCHAR2(500),
  cont_addr                  VARCHAR2(500),
  licen_issue_autho_addr     VARCHAR2(1000),
  cert_start_dt              DATE,
  cert_exp_dt                DATE,
  netw_vrfction_flow_num     VARCHAR2(100),
  netw_vrfction_rest_cd      VARCHAR2(30),
  netw_vrfction_rule_rest_cd VARCHAR2(30),
  face_recn_rest_cd          VARCHAR2(30),
  face_recn_score            VARCHAR2(10),
  etl_dt                     DATE,
  src_table_name             VARCHAR2(100),
  job_cd                     VARCHAR2(10),
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
