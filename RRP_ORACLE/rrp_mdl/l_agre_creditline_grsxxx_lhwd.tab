create table RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD
(
  data_date                 VARCHAR2(8),
  data_sourced              VARCHAR2(60),
  loan_num                  VARCHAR2(60),
  contract_num              VARCHAR2(60),
  bus_breed_id              VARCHAR2(60),
  bus_breed_name            VARCHAR2(500),
  cust_id                   VARCHAR2(60),
  cust_name                 VARCHAR2(100),
  drawdown_amt              NUMBER(30,2),
  loan_acct_bal             NUMBER(30,2),
  drawdown_dt               VARCHAR2(8),
  maturity_dt               VARCHAR2(8),
  pay_type                  VARCHAR2(60),
  loan_level10_cls_cd       VARCHAR2(60),
  od_days                   NUMBER(10),
  cust_mgr_id               VARCHAR2(60),
  org_num                   VARCHAR2(60),
  facility_num              VARCHAR2(60),
  ods_facility_num          VARCHAR2(60),
  used_facility_flg         VARCHAR2(1),
  facility_amt              NUMBER(30,2),
  ods_facility_amt          NUMBER(30,2),
  acct_typ                  VARCHAR2(20),
  contract_amt              NUMBER(30,2),
  contract_eff_dt           VARCHAR2(8),
  contract_orig_maturity_dt VARCHAR2(8),
  contract_sts              VARCHAR2(10),
  facility_start_dt         VARCHAR2(8),
  facility_end_dt           VARCHAR2(8),
  cyc_flg                   VARCHAR2(1),
  curr_cd                   VARCHAR2(3),
  org_num_sx                VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD
  is '零售系统授信信息表';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.data_date
  is '数据日期';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.data_sourced
  is '来源系统';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.loan_num
  is '贷款期数';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.contract_num
  is '业务合同号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.bus_breed_id
  is '业务品种编号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.bus_breed_name
  is '贷款业务品种';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.cust_id
  is '客户表主键';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.cust_name
  is '客户名称';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.drawdown_amt
  is '贷款发放金额';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.loan_acct_bal
  is '借据余额';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.drawdown_dt
  is '贷款发放日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.maturity_dt
  is '到期日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.pay_type
  is '支付方式';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.loan_level10_cls_cd
  is '贷款十级分类代码';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.od_days
  is '逾期天数';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.cust_mgr_id
  is '客户经理编号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.org_num
  is '所属机构';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.facility_num
  is '授信额度编号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.ods_facility_num
  is '源系统授信合同号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.used_facility_flg
  is '引用授信标志（是Y,否N）';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.facility_amt
  is '总授信额度_折人民币';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.ods_facility_amt
  is '源系统授信额度';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.acct_typ
  is '业务细类';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.contract_amt
  is '合同金额';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.contract_eff_dt
  is '业务合同生效日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.contract_orig_maturity_dt
  is '业务合同到期日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.contract_sts
  is '业务合同状态';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.facility_start_dt
  is '授信生效日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.facility_end_dt
  is '授信额度终止日期';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.cyc_flg
  is '循环额度标志';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX_LHWD.curr_cd
