create table RRP_MDL.O_IOL_WIND_COMPINTRODUCTION
(
  object_id             VARCHAR2(150),
  comp_id               VARCHAR2(60),
  comp_name             VARCHAR2(450),
  comp_sname            VARCHAR2(150),
  comp_name_eng         VARCHAR2(200),
  comp_snameeng         VARCHAR2(182),
  province              VARCHAR2(45),
  city                  VARCHAR2(75),
  address               VARCHAR2(750),
  office                VARCHAR2(600),
  zipcode               VARCHAR2(30),
  phone                 VARCHAR2(150),
  fax                   VARCHAR2(75),
  email                 VARCHAR2(300),
  website               VARCHAR2(300),
  registernumber        VARCHAR2(45),
  chairman              VARCHAR2(150),
  president             VARCHAR2(174),
  discloser             VARCHAR2(750),
  regcapital            NUMBER(20,4),
  currencycode          VARCHAR2(30),
  founddate             VARCHAR2(30),
  enddate               VARCHAR2(12),
  briefing              VARCHAR2(4000),
  comp_type             VARCHAR2(150),
  comp_property         VARCHAR2(150),
  country               VARCHAR2(45),
  businessscope         VARCHAR2(4000),
  company_type          VARCHAR2(30),
  s_info_totalemployees NUMBER(20),
  main_business         VARCHAR2(4000),
  opdate                DATE,
  opmode                VARCHAR2(2),
  social_credit_code    VARCHAR2(30),
  etl_dt                DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_WIND_COMPINTRODUCTION
  is '万德数据客户基本信息总表';
