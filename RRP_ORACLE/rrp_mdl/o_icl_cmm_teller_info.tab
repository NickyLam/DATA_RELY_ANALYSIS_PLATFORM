create table RRP_MDL.O_ICL_CMM_TELLER_INFO
(
  etl_dt                  DATE,
  lp_id                   VARCHAR2(60),
  teller_id               VARCHAR2(100),
  teller_name             VARCHAR2(500),
  teller_type_cd          VARCHAR2(30),
  teller_status_cd        VARCHAR2(30),
  teller_user_lev_cd      VARCHAR2(30),
  teller_prvlg_lev_cd     VARCHAR2(30),
  belong_org_id           VARCHAR2(100),
  jobs_cd                 VARCHAR2(100),
  jobs_cate               VARCHAR2(10),
  jobs_name               VARCHAR2(100),
  empyt_dt                DATE,
  cust_mgr_flg            VARCHAR2(10),
  enty_teller_flg         VARCHAR2(10),
  syn_teller_flg          VARCHAR2(10),
  super_teller_flg        VARCHAR2(100),
  acct_teller_flg         VARCHAR2(10),
  prvlg_mgmt_flg          VARCHAR2(10),
  director_mgmt_flg       VARCHAR2(10),
  crdt_cust_mgr_flg       VARCHAR2(10),
  wah_kepr_flg            VARCHAR2(10),
  auth_flg                VARCHAR2(10),
  auth_range              VARCHAR2(100),
  cors_moy_box_id         VARCHAR2(100),
  job_cd                  VARCHAR2(10),
  teller_type_subclass_cd VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_TELLER_INFO
  is '柜员信息';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.etl_dt
  is '数据日期';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.lp_id
  is '法人编号';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.teller_id
  is '柜员编号';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.teller_name
  is '柜员名称';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.teller_type_cd
  is '柜员类型代码';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.teller_status_cd
  is '柜员状态代码';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.teller_user_lev_cd
  is '柜员用户级别代码';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.teller_prvlg_lev_cd
  is '柜员权限级别代码';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.belong_org_id
  is '所属机构编号';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.jobs_cd
  is '岗位编号';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.jobs_cate
