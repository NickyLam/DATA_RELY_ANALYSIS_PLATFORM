comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.prvlg_mgmt_flg
  is '权限管理标志';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.director_mgmt_flg
  is '主管管理标志';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.crdt_cust_mgr_flg
