comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.jobs_name
  is '岗位名称';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.empyt_dt
  is '入职日期';
comment on column RRP_MDL.O_ICL_CMM_TELLER_INFO.cust_mgr_flg
