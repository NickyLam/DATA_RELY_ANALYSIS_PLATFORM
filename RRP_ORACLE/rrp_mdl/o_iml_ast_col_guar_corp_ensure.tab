create table RRP_MDL.O_IML_AST_COL_GUAR_CORP_ENSURE
(
  asset_id                      VARCHAR2(60),
  lp_id                         VARCHAR2(60),
  guartor_type_cd               VARCHAR2(10),
  guartor_id                    VARCHAR2(100),
  guartor_name                  VARCHAR2(100),
  guartor_orgnz_cd              VARCHAR2(100),
  guartor_nat_std_indus_cls_cd  VARCHAR2(100),
  guartor_net_asset_amt         NUMBER(30,2),
  guartor_econ_compnt_cd        VARCHAR2(10),
  guartor_guar_indep_cd         VARCHAR2(10),
  guartor_rgst_cd               VARCHAR2(100),
  guartor_rgst_ext_rating_cd    VARCHAR2(100),
  guartor_ext_rating_dt         DATE,
  guartor_ext_rating_rest_cd    VARCHAR2(100),
  guartor_intnal_rating_dt      DATE,
  guartor_intnal_rating_rest_cd VARCHAR2(100),
  guar_aim_cd                   VARCHAR2(10),
  stage_guar_flg                VARCHAR2(10),
  guar_corp_margin_amt          NUMBER(30,2),
  other_comnt                   VARCHAR2(4000),
  guar_tot_amt                  NUMBER(30,2),
  curr_cd                       VARCHAR2(10),
  resdnt_flg                    VARCHAR2(10),
  create_dt                     DATE,
  update_dt                     DATE,
  etl_dt                        DATE,
  id_mark                       VARCHAR2(10),
  src_table_name                VARCHAR2(100),
  job_cd                        VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AST_COL_GUAR_CORP_ENSURE
