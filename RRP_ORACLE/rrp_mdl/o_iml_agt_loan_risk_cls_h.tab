create table RRP_MDL.O_IML_AGT_LOAN_RISK_CLS_H
(
  risk_cls_id           VARCHAR2(100),
  rela_flow_num         VARCHAR2(100),
  agt_id                VARCHAR2(250),
  obj_id                VARCHAR2(100),
  obj_type_name         VARCHAR2(500),
  cust_id               VARCHAR2(100),
  cust_name             VARCHAR2(500),
  prod_id               VARCHAR2(100),
  curr_cd               VARCHAR2(30),
  loan_amt              NUMBER(30,2),
  loan_bal              NUMBER(30,2),
  loan_tenor_cd         VARCHAR2(30),
  cls_closing_dt        DATE,
  sys_cls_rest_cd       VARCHAR2(30),
  manu_cls_rest_cd      VARCHAR2(30),
  manu_cls_reason_descb VARCHAR2(1000),
  final_rest_cd         VARCHAR2(30),
  cls_way_cd            VARCHAR2(30),
  belong_strip_line_cd  VARCHAR2(30),
  cls_status_cd         VARCHAR2(30),
  low_risk_flg          VARCHAR2(10),
  curr_mon_happ_flg     VARCHAR2(10),
  remark                VARCHAR2(4000),
  oper_teller_id        VARCHAR2(100),
  oper_org_id           VARCHAR2(100),
  oper_dt               DATE,
  update_teller_id      VARCHAR2(100),
  update_org_id         VARCHAR2(100),
  modif_dt              DATE,
  lp_id                 VARCHAR2(100),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  src_table_name        VARCHAR2(100),
  job_cd                VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_LOAN_RISK_CLS_H
  is '贷款风险分类历史';
comment on column RRP_MDL.O_IML_AGT_LOAN_RISK_CLS_H.risk_cls_id
