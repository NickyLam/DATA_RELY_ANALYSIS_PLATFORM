comment on column RRP_MDL.O_IOL_ISBS_BDD.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_ISBS_BDD.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_ISBS_BDD.id_mark
