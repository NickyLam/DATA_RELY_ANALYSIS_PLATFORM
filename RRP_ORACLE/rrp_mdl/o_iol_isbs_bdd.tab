comment on column RRP_MDL.O_IOL_ISBS_BDD.invnum
  is '发票号';
comment on column RRP_MDL.O_IOL_ISBS_BDD.concur
  is '合同币种';
comment on column RRP_MDL.O_IOL_ISBS_BDD.conamt
  is '合同金额';
comment on column RRP_MDL.O_IOL_ISBS_BDD.comno
