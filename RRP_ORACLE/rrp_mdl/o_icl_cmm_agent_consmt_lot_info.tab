create table RRP_MDL.O_ICL_CMM_AGENT_CONSMT_LOT_INFO
(
  etl_dt              DATE,
  lp_id               VARCHAR2(60),
  ta_cd               VARCHAR2(10),
  prod_id             VARCHAR2(60),
  std_prod_id         VARCHAR2(500),
  tran_acct_id        VARCHAR2(60),
  consmt_bus_type_cd  VARCHAR2(10),
  cap_stl_acct_num    VARCHAR2(100),
  cust_id             VARCHAR2(60),
  cont_id             VARCHAR2(60),
  belong_org_id       VARCHAR2(100),
  bank_id             VARCHAR2(60),
  seller_id           VARCHAR2(60),
  ec_flg_cd           VARCHAR2(10),
  divd_way_cd         VARCHAR2(10),
  cust_type_cd        VARCHAR2(10),
  lot_type_cd         VARCHAR2(10),
  fir_subscr_dt       DATE,
  final_activ_acct_dt DATE,
  actl_value_dt       DATE,
  actl_exp_dt         DATE,
  divd_ratio          NUMBER(30,8),
  yld_rat             NUMBER(18,8),
  acm_prft            NUMBER(30,2),
  unpaid_prft         NUMBER(30,2),
  froz_unpaid_prft    NUMBER(30,2),
  curr_issue_prft     NUMBER(30,8),
  td_prft             NUMBER(30,2),
  tran_froz_lot       NUMBER(30,2),
  lonterm_froz_lot    NUMBER(30,2),
  loc_froz_lot        NUMBER(30,2),
  ld_tot_lot          NUMBER(30,2),
  uncfm_prod_amt      NUMBER(30,2),
  redem_amt           NUMBER(30,2),
  buy_cost            NUMBER(30,2),
  tot_lot             NUMBER(30,2),
  nv                  NUMBER(18,8),
  curr_bal            NUMBER(30,8),
  ear_d_bal           NUMBER(30,8),
  ear_m_bal           NUMBER(30,8),
  ear_s_bal           NUMBER(30,8),
  ear_y_bal           NUMBER(30,8),
  y_acm_bal           NUMBER(30,8),
  s_acm_bal           NUMBER(30,8),
  m_acm_bal           NUMBER(30,8),
  y_avg_bal           NUMBER(30,8),
  q_avg_bal           NUMBER(30,8),
  m_avg_bal           NUMBER(30,8),
  job_cd              VARCHAR2(10),
  etl_timestamp       TIMESTAMP(6)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20230430 values less than (TO_DATE(' 2023-05-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
