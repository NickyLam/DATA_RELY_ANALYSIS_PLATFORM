create table RRP_MDL.T_COM_RRP_IMAS_ETL_LOG
(
  p_date      VARCHAR2(8),
  system      VARCHAR2(30),
  proc_name   VARCHAR2(30),
  starttime   DATE,
  endtime     DATE,
  step        NUMBER(22),
  step_desc   VARCHAR2(500),
  sqlcount    NUMBER(22),
  return_code VARCHAR2(30),
  sqlmsg      VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

