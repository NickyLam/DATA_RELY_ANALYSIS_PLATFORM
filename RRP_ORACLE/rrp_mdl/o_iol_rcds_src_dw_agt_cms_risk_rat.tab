create table RRP_MDL.O_IOL_RCDS_SRC_DW_AGT_CMS_RISK_RAT
(
  etl_dt                    DATE,
  loan_acct_id              VARCHAR2(90),
  etl_dt_ora                DATE,
  blng_pty_id               VARCHAR2(90),
  risk_rat_categ_cd         VARCHAR2(2),
  risk_rat_resu_cd          VARCHAR2(3),
  rat_dt                    DATE,
  rat_org_id                VARCHAR2(45),
  rat_oper_emply_id         VARCHAR2(45),
  auto_rat_flg              VARCHAR2(2),
  aprv_emply_num            VARCHAR2(45),
  auth_emply_num            VARCHAR2(45),
  adj_emply_num             VARCHAR2(30),
  loan_fifth_modal_chg_rsns VARCHAR2(600),
  data_src_cd               VARCHAR2(6),
  del_flg                   VARCHAR2(2),
  job_cd                    VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_RCDS_SRC_DW_AGT_CMS_RISK_RAT
  is '数仓_信贷风险评级';
comment on column RRP_MDL.O_IOL_RCDS_SRC_DW_AGT_CMS_RISK_RAT.etl_dt
