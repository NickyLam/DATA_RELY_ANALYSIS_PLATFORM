create table RRP_MDL.O_IOL_CTMS_TBS_V_IAMDEALS
(
  deal_id              NUMBER,
  deal_tablename       VARCHAR2(12),
  aspclient_id         NUMBER,
  serial_number        VARCHAR2(23),
  trade_date           NUMBER(8),
  value_date           NUMBER(8),
  maturity_date        NUMBER(8),
  buyorsell            VARCHAR2(2),
  repo_rate            NUMBER(30,6),
  amount               NUMBER(17,2),
  maturity_amount      NUMBER(17,2),
  fee                  NUMBER(17,2),
  tax_amt              NUMBER(17,2),
  broker_amt           NUMBER(17,2),
  interest             NUMBER(17,2),
  portfolio_id         NUMBER(5),
  portfolio_name       VARCHAR2(120),
  keepfolder_id        NUMBER,
  keepfolder_shortname VARCHAR2(75),
  cptys_short_name     VARCHAR2(192),
  cptys_id             NUMBER,
  dealer_id            NUMBER(5),
  dealer_name          VARCHAR2(30),
  ref_number           VARCHAR2(48),
  cfets_from           VARCHAR2(2),
  lastmodified         TIMESTAMP(6),
  datasymbol_id        NUMBER,
  repo_days            NUMBER,
  iamdeals_id_grand    NUMBER,
  note                 VARCHAR2(4000),
  counterparty_type    VARCHAR2(15),
  repo_id              VARCHAR2(24),
  dn_dealer            VARCHAR2(900),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6),
  trade_time           DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_CTMS_TBS_V_IAMDEALS
  is '拆借交易';
comment on column RRP_MDL.O_IOL_CTMS_TBS_V_IAMDEALS.deal_id
  is '引用表ID';
