comment on column RRP_MDL.EAST5_803_XYKSXQKB.gsfzjg
  is '归属分支机构';
alter table RRP_MDL.EAST5_803_XYKSXQKB
  add primary key (CJRQ, RID, KHTYBH, XYKZH)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

