create table RRP_MDL.TZJ_ZB_RELA
(
  mk       VARCHAR2(200),
  bbbh     VARCHAR2(200),
  qtzbbh   VARCHAR2(200),
  htzbbh   VARCHAR2(200),
  zbmc     VARCHAR2(500),
  ccgc     VARCHAR2(200),
  shbjqszb VARCHAR2(20)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

