create table RRP_MDL.O_ICL_CMM_AGENT_CONSMT_PROD_INFO
(
  etl_dt                         DATE,
  lp_id                          VARCHAR2(60),
  prod_id                        VARCHAR2(60),
  std_prod_id                    VARCHAR2(60),
  prod_name                      VARCHAR2(375),
  prod_fname                     VARCHAR2(375),
  prod_tepla_id                  VARCHAR2(250),
  prod_tepla_comnt               VARCHAR2(1000),
  ta_cd                          VARCHAR2(10),
  consmt_bus_type_cd             VARCHAR2(10),
  prod_type_cd                   VARCHAR2(10),
  prod_sclass_cd                 VARCHAR2(10),
  issuer_id                      VARCHAR2(100),
  issuer_name                    VARCHAR2(375),
  trustee_id                     VARCHAR2(60),
  trustee_name                   VARCHAR2(250),
  mger_id                        VARCHAR2(60),
  mger_name                      VARCHAR2(375),
  fund_mgr                       VARCHAR2(3000),
  dept_id                        VARCHAR2(500),
  org_id                         VARCHAR2(60),
  coll_start_dt                  DATE,
  coll_end_dt                    DATE,
  found_dt                       DATE,
  end_dt                         DATE,
  value_dt                       DATE,
  int_closing_dt                 DATE,
  next_open_start_dt             DATE,
  next_open_end_dt               DATE,
  prft_exp_dt                    DATE,
  actl_found_dt                  DATE,
  sp_acct_id                     VARCHAR2(60),
  redem_acct_id                  VARCHAR2(60),
  comm_fee_assign_acct_id        VARCHAR2(60),
  mgmt_fee_assign_acct_id        VARCHAR2(60),
  allow_chn_group_id             VARCHAR2(60),
  allow_cust_group_id            VARCHAR2(60),
  sell_rg_ctrl_flg               VARCHAR2(10),
  lmt_ctrl_flg                   VARCHAR2(10),
  ped_open_flg                   VARCHAR2(10),
  allow_divd_way_cd              VARCHAR2(10),
  deflt_divd_way_cd              VARCHAR2(10),
  prft_embody_way_cd             VARCHAR2(10),
  prft_type_cd                   VARCHAR2(10),
  charge_type_cd                 VARCHAR2(10),
  prod_attr_cd                   VARCHAR2(10),
  risk_level_cd                  VARCHAR2(10),
  estim_level_cd                 VARCHAR2(10),
  prod_status_cd                 VARCHAR2(10),
  tran_flg_cd                    VARCHAR2(10),
  tard_way_cd                    VARCHAR2(10),
  ec_flg_cd                      VARCHAR2(10),
  prft_curr_cd                   VARCHAR2(10),
  curr_cd                        VARCHAR2(10),
  supt_buy_way_cd                VARCHAR2(30),
  ctrl_flg_info                  VARCHAR2(1000),
  bta_ctrl_flg_info              VARCHAR2(250),
  issue_price                    NUMBER(18,8),
  expe_yld_rat                   NUMBER(18,8),
  lowt_coll_amt                  NUMBER(30,2),
  higt_coll_amt                  NUMBER(30,2),
  lowt_coll_lot                  NUMBER(30,2),
  higt_coll_lot                  NUMBER(30,2),
  actl_coll_amt                  NUMBER(30,2),
  curr_coll_size                 NUMBER(30,2),
  indv_fir_lowt_invest_amt       NUMBER(30,2),
  acvmnt_base                    NUMBER(30,2),
  ped_days                       NUMBER(10),
  nv_days                        NUMBER(10),
  curr_tot_lot                   NUMBER(30,2),
  curr_acm_nv                    NUMBER(38,8),
  nv                             NUMBER(18,8),
  nv_dt                          DATE,
  fac_val                        NUMBER(18,8),
  sale_fee_rat                   NUMBER(18,8),
  diff_price_fee_rat             NUMBER(18,8),
  insure_prod_proj_type_cd       VARCHAR2(10),
  dir_insure_cd                  VARCHAR2(60),
  insure_return_days             NUMBER(10),
  redem_cap_avl_days             NUMBER(22),
  job_cd                         VARCHAR2(10),
  etl_timestamp                  TIMESTAMP(6),
  provi_for_aged_target_fund_flg VARCHAR2(10)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20230701 values less than (TO_DATE(' 2023-07-02 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
