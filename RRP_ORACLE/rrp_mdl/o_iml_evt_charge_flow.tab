create table RRP_MDL.O_IML_EVT_CHARGE_FLOW
(
  etl_dt                          DATE,
  evt_id                          VARCHAR2(250),
  lp_id                           VARCHAR2(100),
  charge_seq_num                  VARCHAR2(60),
  tran_dt                         DATE,
  flow_num                        VARCHAR2(100),
  tran_seq_num                    VARCHAR2(60),
  dep_agt_id                      VARCHAR2(100),
  cust_acct_num                   VARCHAR2(60),
  curr_cd                         VARCHAR2(30),
  sub_acct_num                    VARCHAR2(60),
  prod_id                         VARCHAR2(100),
  dep_vouch_cate_cd               VARCHAR2(30),
  vouch_begin_num                 VARCHAR2(60),
  vouch_sum_qtty                  NUMBER(30),
  cust_id                         VARCHAR2(100),
  cust_type_cd                    VARCHAR2(30),
  open_acct_org_id                VARCHAR2(100),
  acct_flg_idf                    VARCHAR2(60),
  acct_id                         VARCHAR2(100),
  effect_dt                       DATE,
  revs_org_id                     VARCHAR2(100),
  tran_cd                         VARCHAR2(30),
  tran_org_id                     VARCHAR2(100),
  ova_flow_num                    VARCHAR2(100),
  tran_ref_no                     VARCHAR2(60),
  tran_bank_ratio                 NUMBER(18,6),
  init_recvbl_fee_amt             NUMBER(30,2),
  fee_charge_way_cd               VARCHAR2(30),
  comm_fee_coll_way_cd            VARCHAR2(30),
  fee_type_id                     VARCHAR2(100),
  acct_dmic_charge_curr_cd        VARCHAR2(30),
  acct_dmic_fee_amt               NUMBER(30,2),
  fee_discnt_rat                  NUMBER(30,2),
  fee_discnt_type_cd              VARCHAR2(30),
  recvbl_fee_seq_num              VARCHAR2(60),
  acct_bank_prft_cut_amt          NUMBER(30,2),
  init_fee_amt                    NUMBER(30,2),
  discnt_fee_amt                  NUMBER(30,2),
  tran_bank_prft_cut_amt          NUMBER(30,2),
  tax                             NUMBER(30,2),
  fee_price                       NUMBER(30,2),
  tax_rat                         NUMBER(18,6),
  tax_category_cd                 VARCHAR2(30),
  amort_tm_type_cd                VARCHAR2(30),
  amort_tenor_type_cd             VARCHAR2(30),
  amort_day                       VARCHAR2(10),
  amort_mon                       VARCHAR2(10),
  amort_flg                       VARCHAR2(10),
  prft_cut_flg                    VARCHAR2(10),
  post_flg                        VARCHAR2(10),
  tran_revd_flg                   VARCHAR2(10),
  tran_acct_serv_fee_revs_seq_num VARCHAR2(60),
  revs_auth_teller                VARCHAR2(100),
  revs_teller                     VARCHAR2(100),
  org_tran_seq_num                VARCHAR2(60),
  end_day_onl_cd                  VARCHAR2(30),
  termnt_num                      VARCHAR2(60),
  acct_bank_ratio                 NUMBER(18,6),
  cntpty_cust_acct_num            VARCHAR2(100),
  cntpty_name                     VARCHAR2(500),
  core_flow_num                   VARCHAR2(100),
  tran_tm                         TIMESTAMP(6),
  tran_teller_id                  VARCHAR2(100),
  amort_closing_dt                DATE,
  bus_flow_num                    VARCHAR2(100),
  amort_begin_dt                  DATE,
  job_cd                          VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_CHARGE_FLOW
  is '收费流水';
comment on column RRP_MDL.O_IML_EVT_CHARGE_FLOW.etl_dt
