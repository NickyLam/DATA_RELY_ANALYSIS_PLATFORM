comment on column RRP_MDL.O_ICL_CMM_CUST_SIGN_PROD_INFO.sign_prod_status_cd
  is '签约产品状态代码';
comment on column RRP_MDL.O_ICL_CMM_CUST_SIGN_PROD_INFO.sign_dt
