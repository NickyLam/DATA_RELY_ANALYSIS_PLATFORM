comment on column RRP_MDL.O_ICL_CMM_CUST_SIGN_PROD_INFO.rels_org_id
  is '解约机构编号';
comment on column RRP_MDL.O_ICL_CMM_CUST_SIGN_PROD_INFO.rels_teller_id
