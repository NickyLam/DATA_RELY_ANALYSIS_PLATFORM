create table RRP_MDL.B_FIN_INST_BOND_INFO
(
  data_dt              CHAR(8) not null,
  lgl_rep_id           VARCHAR2(200),
  org_id               VARCHAR2(200),
  bond_id              VARCHAR2(200) not null,
  prod_nm              VARCHAR2(500),
  prod_cl              VARCHAR2(10),
  fin_debt_sub_cl      VARCHAR2(10),
  isu_subj_bio_flg     CHAR(1),
  isu_subj_rtg         VARCHAR2(10),
  isu_land_ctry_cd     VARCHAR2(200),
  isu_side_fin_org_typ VARCHAR2(10),
  bond_rtg             VARCHAR2(10),
  term                 INTEGER,
  cur                  CHAR(3),
  bill_par_amt         NUMBER(30,2),
  bill_par_int_rate    NUMBER(20,6),
  coupon_typ           VARCHAR2(10),
  rate_flt_std         VARCHAR2(10),
  isu_dt               CHAR(8),
  val_dt               CHAR(8),
  exp_dt               CHAR(8),
  isu_prc              NUMBER(30,2),
  rctly_ases_prc       NUMBER(30,2),
  ases_dt              CHAR(8),
  rctly_fair_val       NUMBER(30,2),
  rl_est_ent_isu_flg   CHAR(1),
  bond_rsk_cl          VARCHAR2(10),
  bond_isu_mode        VARCHAR2(10),
  subst_flg            CHAR(1),
  flt_rate_typ         VARCHAR2(10),
  ast_scrtz_typ        VARCHAR2(10),
  bond_isu_land        VARCHAR2(10),
  bond_typ_rsk         VARCHAR2(10),
  inr_rtg              VARCHAR2(10),
  bond_gen_ts_org      VARCHAR2(10),
  dept_line            VARCHAR2(500),
  data_src             VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_FIN_INST_BOND_INFO
  is '债券基础信息';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.org_id
  is '机构编号';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bond_id
  is '债券编号';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.prod_nm
  is '产品名称';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.prod_cl
  is '产品分类';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.fin_debt_sub_cl
  is '金融债细类';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.isu_subj_bio_flg
  is '发行主体境内境外标志';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.isu_subj_rtg
  is '发行主体评级';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.isu_land_ctry_cd
  is '发行地国家代码';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.isu_side_fin_org_typ
  is '发行方金融机构类型';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bond_rtg
  is '债券评级';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.term
  is '期限';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.cur
  is '币种';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bill_par_amt
  is '票面金额';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bill_par_int_rate
  is '票面利率';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.coupon_typ
  is '息票类型';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.rate_flt_std
  is '利率浮动标准';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.isu_dt
  is '发行日期';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.val_dt
  is '起息日期';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.exp_dt
  is '到期日期';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.isu_prc
  is '发行价格';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.rctly_ases_prc
  is '最近评估价格';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.ases_dt
  is '评估日期';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.rctly_fair_val
  is '最近公允价值';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.rl_est_ent_isu_flg
  is '房地产企业发行标志';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bond_rsk_cl
  is '债券风险分类';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bond_isu_mode
  is '债券发行方式';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.subst_flg
  is '用于置换标志';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.flt_rate_typ
  is '浮动利率类型';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.ast_scrtz_typ
  is '资产证券化类型';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bond_isu_land
  is '债券发行地';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bond_typ_rsk
  is '债券类型（客户风险）';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.inr_rtg
  is '内部评级';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.bond_gen_ts_org
  is '债券总托管机构';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.dept_line
  is '部门条线';
comment on column RRP_MDL.B_FIN_INST_BOND_INFO.data_src
  is '数据来源';
alter table RRP_MDL.B_FIN_INST_BOND_INFO
  add constraint PK_B_FIN_INST_BOND_INFO primary key (DATA_DT, BOND_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

