create table RRP_MDL.O_IML_AGT_AP_TRANSFER_INFO_H
(
  agt_id           VARCHAR2(250),
  lp_id            VARCHAR2(100),
  disp_prop_id     VARCHAR2(100),
  obj_id           VARCHAR2(100),
  obj_type_cd      VARCHAR2(30),
  prod_id          VARCHAR2(100),
  stl_acct_id      VARCHAR2(250),
  cust_id          VARCHAR2(100),
  cust_name        VARCHAR2(500),
  level5_cls_cd    VARCHAR2(250),
  curr_cd          VARCHAR2(30),
  distr_amt        NUMBER(30,8),
  loan_bal         NUMBER(30,8),
  recvbl_over_int  NUMBER(30,8),
  acru_comp_int    NUMBER(30,8),
  recvbl_pnlt      NUMBER(30,8),
  tran_amt         NUMBER(30,8),
  rgst_teller_id   VARCHAR2(100),
  rgst_org_id      VARCHAR2(100),
  rgst_dt          DATE,
  update_teller_id VARCHAR2(100),
  update_org_id    VARCHAR2(100),
  up_date          DATE,
  start_dt         DATE,
  end_dt           DATE,
  id_mark          VARCHAR2(10),
  src_table_name   VARCHAR2(100),
  job_cd           VARCHAR2(10),
  etl_timestamp    TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
comment on table RRP_MDL.O_IML_AGT_AP_TRANSFER_INFO_H
  is '资产转让债权信息历史';
comment on column RRP_MDL.O_IML_AGT_AP_TRANSFER_INFO_H.agt_id
  is '协议编号';
comment on column RRP_MDL.O_IML_AGT_AP_TRANSFER_INFO_H.lp_id
