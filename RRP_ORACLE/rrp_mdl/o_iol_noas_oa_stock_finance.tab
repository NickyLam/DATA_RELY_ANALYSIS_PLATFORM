create table RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE
(
  stock_finance_id        VARCHAR2(30),
  stock_info_id           VARCHAR2(30),
  a_particular_year       VARCHAR2(15),
  total_assets            VARCHAR2(90),
  gross_liability         VARCHAR2(90),
  net_asset               VARCHAR2(90),
  retained_profits        VARCHAR2(90),
  ratio_of_liabilities    VARCHAR2(90),
  balance_investment      VARCHAR2(90),
  balance_net_asset_ratio VARCHAR2(90),
  last_updated_stamp      TIMESTAMP(6),
  last_updated_tx_stamp   TIMESTAMP(6),
  created_stamp           TIMESTAMP(6),
  created_tx_stamp        TIMESTAMP(6),
  start_dt                DATE,
  end_dt                  DATE,
  id_mark                 VARCHAR2(10),
  etl_timestamp           TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE
  is '股东财务表';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.stock_info_id
  is '主键ID';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.total_assets
  is '资产总计';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.net_asset
  is '企业净资产';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.last_updated_stamp
  is '最后更新时间';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.last_updated_tx_stamp
  is '最后更新事务时间';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.created_stamp
  is '创建时间';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.created_tx_stamp
  is '创建交易时间';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IOL_NOAS_OA_STOCK_FINANCE.etl_timestamp
  is 'ETL处理时间戳';

