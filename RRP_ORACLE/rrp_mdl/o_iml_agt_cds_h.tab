create table RRP_MDL.O_IML_AGT_CDS_H
(
  agt_id                   VARCHAR2(250),
  lp_id                    VARCHAR2(100),
  precon_id                VARCHAR2(100),
  precon_rgst_dt           DATE,
  precon_open_acct_dt      DATE,
  precon_rgst_acct_type    VARCHAR2(30),
  precon_org               VARCHAR2(100),
  precon_curr_cd           VARCHAR2(30),
  precon_amt               NUMBER(30,2),
  pd_prod_precon_status_cd VARCHAR2(30),
  cust_id                  VARCHAR2(100),
  acct_id                  VARCHAR2(100),
  cust_acct_num            VARCHAR2(100),
  curr_cd                  VARCHAR2(30),
  sub_acct_num             VARCHAR2(60),
  prod_id                  VARCHAR2(100),
  comb_prod_id             VARCHAR2(250),
  acct_name                VARCHAR2(500),
  seq_num                  VARCHAR2(60),
  on_acct_seq_num          VARCHAR2(60),
  supp_on_acct_sub_seq_num VARCHAR2(60),
  tran_amt                 NUMBER(30,2),
  pd_cd                    VARCHAR2(30),
  pd_prod_cate_cd          VARCHAR2(30),
  pd_issue_amt             NUMBER(30,2),
  issue_year               VARCHAR2(60),
  issue_begin_dt           DATE,
  issue_termnt_dt          DATE,
  chn_id                   VARCHAR2(100),
  cntpty_acct_id           VARCHAR2(100),
  cntpty_cust_acct_num     VARCHAR2(100),
  cntpty_acct_curr_cd      VARCHAR2(30),
  cntpty_sub_acct_num      VARCHAR2(60),
  cntpty_prod_id           VARCHAR2(100),
  lmt_id                   VARCHAR2(100),
  vouch_no                 VARCHAR2(60),
  auto_payoff_flg          VARCHAR2(10),
  bank_int_int_rat         NUMBER(18,8),
  exec_int_rat             NUMBER(18,8),
  float_int_rat            NUMBER(18,8),
  int_rat_type_cd          VARCHAR2(30),
  int_rat_adj_way_cd       VARCHAR2(30),
  int_set_day              NUMBER(10),
  int_set_freq_cd          VARCHAR2(30),
  accrd_freq_pay_int_flg   VARCHAR2(10),
  next_int_set_dt          DATE,
  tran_ref_no              VARCHAR2(60),
  teller_id                VARCHAR2(100),
  acct_status_cd           VARCHAR2(30),
  redem_dt                 DATE,
  expect_redem_int         NUMBER(30,2),
  inpwn_flg                VARCHAR2(10),
  wdraw_way_cd             VARCHAR2(30),
  acct_attr_cd             VARCHAR2(30),
  cntpty_acct_name         VARCHAR2(500),
  potd_acct_id             VARCHAR2(100),
  cds_int_accr_way_cd      VARCHAR2(30),
  subscr_acct_id           VARCHAR2(100),
  col_int_acct_id          VARCHAR2(100),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6),
  del_dt                   DATE,
  fail_rs_descb            VARCHAR2(2000),
  memo                     VARCHAR2(2000),
  del_auth_teller_id       VARCHAR2(100),
  del_teller_id            VARCHAR2(100),
  revo_dt                  DATE,
  dep_char_cd              VARCHAR2(30)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_CDS_H
  is '大额存单历史';
comment on column RRP_MDL.O_IML_AGT_CDS_H.agt_id
