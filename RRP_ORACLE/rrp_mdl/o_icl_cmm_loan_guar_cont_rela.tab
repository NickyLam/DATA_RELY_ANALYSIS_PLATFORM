comment on column RRP_MDL.O_ICL_CMM_LOAN_GUAR_CONT_RELA.guar_curr_cd
  is '担保币种代码';
comment on column RRP_MDL.O_ICL_CMM_LOAN_GUAR_CONT_RELA.src_sys_cd
