create table RRP_MDL.O_IOL_ABSS_CODE_LIBRARY
(
  codeno        VARCHAR2(48),
  itemno        VARCHAR2(48),
  itemname      VARCHAR2(375),
  bankno        VARCHAR2(48),
  sortno        VARCHAR2(48),
  isinuse       VARCHAR2(27),
  itemdescribe  VARCHAR2(1200),
  itemattribute VARCHAR2(1200),
  relativecode  VARCHAR2(2400),
  attribute1    VARCHAR2(1200),
  attribute2    VARCHAR2(375),
  attribute3    VARCHAR2(375),
  attribute4    VARCHAR2(375),
  attribute5    VARCHAR2(375),
  attribute6    VARCHAR2(375),
  attribute7    VARCHAR2(375),
  attribute8    VARCHAR2(375),
  inputuser     VARCHAR2(48),
  inputorg      VARCHAR2(48),
  inputtime     VARCHAR2(30),
  updateuser    VARCHAR2(48),
  updatetime    VARCHAR2(30),
  remark        VARCHAR2(375),
  helptext      VARCHAR2(375),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10),
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ABSS_CODE_LIBRARY
  is '资产证券化管理系统代码表';
comment on column RRP_MDL.O_IOL_ABSS_CODE_LIBRARY.codeno
  is '代码编号';
