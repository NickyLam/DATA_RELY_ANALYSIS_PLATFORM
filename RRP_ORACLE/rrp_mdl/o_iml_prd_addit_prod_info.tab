create table RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO
(
  prod_id                   VARCHAR2(100),
  lp_id                     VARCHAR2(60),
  ta_cd                     VARCHAR2(30),
  main_prod_id              VARCHAR2(100),
  addit_prod_name           VARCHAR2(750),
  insu_comp_addit_prod_id   VARCHAR2(100),
  permium_calc_corp_type_cd VARCHAR2(30),
  create_dt                 DATE,
  update_dt                 DATE,
  etl_dt                    DATE,
  id_mark                   VARCHAR2(10),
  src_table_name            VARCHAR2(100),
  job_cd                    VARCHAR2(10),
  etl_timestamp             TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO
  is '附加险产品信息';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.prod_id
  is '产品编号';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.ta_cd
  is 'TA代码';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.main_prod_id
  is '主险产品编号';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.addit_prod_name
  is '附加险产品名称';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.insu_comp_addit_prod_id
  is '保险公司附加险产品编号';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.permium_calc_corp_type_cd
  is '保费计算单位类型代码';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.create_dt
  is '创建日期';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.update_dt
  is '更新日期';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.job_cd
  is '任务编码';
comment on column RRP_MDL.O_IML_PRD_ADDIT_PROD_INFO.etl_timestamp
  is 'ETL处理时间戳';

