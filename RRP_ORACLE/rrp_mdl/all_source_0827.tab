create table RRP_MDL.ALL_SOURCE_0827
(
  f_tab VARCHAR2(128),
  name  VARCHAR2(128),
  type  VARCHAR2(128),
  owner VARCHAR2(128),
  text  VARCHAR2(4000)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

