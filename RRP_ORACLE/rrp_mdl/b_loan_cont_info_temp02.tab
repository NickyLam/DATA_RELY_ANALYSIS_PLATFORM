create table RRP_MDL.B_LOAN_CONT_INFO_TEMP02
(
  data_dt            CHAR(8) not null,
  lgl_rep_id         VARCHAR2(200),
  cont_id            VARCHAR2(200) not null,
  cont_nm            VARCHAR2(500),
  prim_cont_id       VARCHAR2(200),
  cust_id            VARCHAR2(200),
  org_id             VARCHAR2(200),
  app_id             VARCHAR2(200),
  crdt_lmt_id        VARCHAR2(200),
  loan_prod_typ      VARCHAR2(10),
  loan_prod_nm       VARCHAR2(500),
  cur                CHAR(3),
  cont_amt           NUMBER(30,2),
  cont_start_dt      CHAR(8),
  cont_exp_dt        CHAR(8),
  gua_mode1          VARCHAR2(10),
  gua_mode2          VARCHAR2(10),
  cust_mgr_no        VARCHAR2(30),
  loan_useage        VARCHAR2(2000),
  dir_rgn_area_cd    VARCHAR2(10),
  dir_idy            VARCHAR2(10),
  fin_loan_rel_lc_no VARCHAR2(200),
  cont_sign_dt       CHAR(8),
  coop_agrt_id       VARCHAR2(200),
  cust_data_auth_id  VARCHAR2(200),
  grant_eff_dt       CHAR(8),
  grant_end_dt       CHAR(8),
  pnr_resp_amt       NUMBER(30,2),
  app_psn_tel        VARCHAR2(30),
  cont_stat          VARCHAR2(10),
  dept_line          VARCHAR2(500),
  data_src           VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.B_LOAN_CONT_INFO_TEMP02
  is '贷款合同信息';
comment on column RRP_MDL.B_LOAN_CONT_INFO_TEMP02.data_dt
