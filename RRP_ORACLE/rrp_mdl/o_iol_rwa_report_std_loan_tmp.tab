comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.portfoliotypedesc
  is '填报项目';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.rwbandid
