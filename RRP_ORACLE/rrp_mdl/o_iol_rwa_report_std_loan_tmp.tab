comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.rating_cd
  is '发行人注册国评级';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.ccp_type_cd
  is '交易对手类型代码';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.assettype_id
  is '资产类型ID';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.subject_cd
  is '科目代码';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.interest_receive_subject_cd
  is '应收利息科目代码';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.accrual_class_subject_cd
  is '应计科目代码';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.interest_adjust_subject_cd
  is '利息调整科目代码';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.fairvalue_changes_subject_cd
  is '公允价值变动科目代码';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.provision_single_subject_cd
  is '准备金科目代码';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.ccy_name
  is '币种名称';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.asset_balance
  is '资产余额（本币）';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.asset_balance_hcurr
  is '资产余额(本币）';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.receivable_int
  is '应收利息本币';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.accrued_int
  is '应计利息本币';
comment on column RRP_MDL.O_IOL_RWA_REPORT_STD_LOAN_TMP.int_adj
