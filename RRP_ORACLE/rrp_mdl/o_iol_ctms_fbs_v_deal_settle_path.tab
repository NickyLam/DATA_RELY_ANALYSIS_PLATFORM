  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_FBS_V_DEAL_SETTLE_PATH.cp_pay
  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_FBS_V_DEAL_SETTLE_PATH.system_name
  is '未知';
comment on column RRP_MDL.O_IOL_CTMS_FBS_V_DEAL_SETTLE_PATH.is_from_pack
  is '未知';
