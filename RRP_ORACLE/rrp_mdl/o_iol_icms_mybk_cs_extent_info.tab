create table RRP_MDL.O_IOL_ICMS_MYBK_CS_EXTENT_INFO
(
  serno                   VARCHAR2(32),
  registeraddressarea     VARCHAR2(150),
  statusid                VARCHAR2(30),
  sex                     VARCHAR2(2),
  city                    VARCHAR2(60),
  registerno              VARCHAR2(64),
  orgcode                 VARCHAR2(64),
  managebegindate         VARCHAR2(64),
  opendate                VARCHAR2(64),
  economictype            VARCHAR2(128),
  registeraddressareacode VARCHAR2(64),
  area                    VARCHAR2(60),
  companytype             VARCHAR2(128),
  registerdate            VARCHAR2(32),
  industryname            VARCHAR2(256),
  nationality             VARCHAR2(6),
  registeraddress         VARCHAR2(512),
  registerdepartment      VARCHAR2(150),
  migtflag                VARCHAR2(80),
  busdatareqdate          VARCHAR2(64),
  businfoexistflag        VARCHAR2(8),
  fundcurrency            VARCHAR2(64),
  companyinfoname         VARCHAR2(300),
  tradecode               VARCHAR2(64),
  managerange             VARCHAR2(4000),
  mobile                  VARCHAR2(32),
  certvalidenddate        VARCHAR2(128),
  statusdesc              VARCHAR2(500),
  certvalidstartdate      VARCHAR2(20),
  manageenddate           VARCHAR2(64),
  targetjyflag1           VARCHAR2(256),
  applyno                 VARCHAR2(64),
  companyinfolawer        VARCHAR2(75),
  registerfund            NUMBER(18,2),
  address                 VARCHAR2(600),
  prov                    VARCHAR2(30),
  notexistreason          VARCHAR2(500),
  lastcheckyear           VARCHAR2(64),
  indivocc                VARCHAR2(128),
  etl_dt                  DATE,
  etl_timestamp           TIMESTAMP(6),
  isestimatemode          VARCHAR2(8)
)
partition by list (ETL_DT)
(
  partition PARTITION_19000101 values (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20240630 values (TO_DATE(' 2024-06-30 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20240629 values (TO_DATE(' 2024-06-29 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20240531 values (TO_DATE(' 2024-05-31 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.O_IOL_ICMS_MYBK_CS_EXTENT_INFO
