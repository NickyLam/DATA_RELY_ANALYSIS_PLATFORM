  jgdh          VARCHAR2(15),
  kmh           VARCHAR2(30),
  khrq          NUMBER(22),
  xhrq          NUMBER(22),
  cpdm          VARCHAR2(30),
  cplb          VARCHAR2(3),
  cpmc          VARCHAR2(150),
  mjksr         NUMBER(22),
  mjjsr         NUMBER(22),
  nll           NUMBER(15,7),
  zhye          NUMBER(25,4),
  zhbs          VARCHAR2(2),
