  accept_ps_name               VARCHAR2(500),
  inv_id                       VARCHAR2(100),
  enter_id                     VARCHAR2(100),
  distr_cond_impt_flg          VARCHAR2(10),
  trade_fin_rela_curr_cd_one   VARCHAR2(30),
  trade_fin_rela_curr_cd_two   VARCHAR2(30),
  trade_fin_rela_curr_cd_three VARCHAR2(30),
  log_bnft_bank_name           VARCHAR2(500),
  fft_acpt_bank_no             VARCHAR2(100),
  accptor_open_bank_no         VARCHAR2(60),
  fft_cfm_bank_bank_no         VARCHAR2(100),
  buyer_pay_int_amt            NUMBER(30,2),
  redem_flg                    VARCHAR2(10),
  trade_fin_bus_id_one         VARCHAR2(100),
  trade_fin_bus_id_two         VARCHAR2(100),
  era_pay_bank_name            VARCHAR2(500),
  log_type_cd                  VARCHAR2(30),
  trade_fin_tenor_type_cd_one  VARCHAR2(30),
  trade_fin_tenor_type_cd_two  VARCHAR2(30),
  accptor_open_bank_name       VARCHAR2(500),
  stl_acct_open_bank_name      VARCHAR2(500),
  stl_acct_cust_name           VARCHAR2(500),
  buyer_pay_int_acct_id        VARCHAR2(100),
  fin_log_flg                  VARCHAR2(10),
  enter_open_bank_name         VARCHAR2(500),
  enter_cust_name              VARCHAR2(500),
  payfan_pric_repay_way_cd     VARCHAR2(30),
