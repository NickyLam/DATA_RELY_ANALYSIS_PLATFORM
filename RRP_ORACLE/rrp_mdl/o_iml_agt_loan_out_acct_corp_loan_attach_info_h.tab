  start_dt                     DATE,
  end_dt                       DATE,
  id_mark                      VARCHAR2(10),
  src_table_name               VARCHAR2(100),
  job_cd                       VARCHAR2(10),
  etl_timestamp                TIMESTAMP(6),
  file_int_flg                 VARCHAR2(10),
  comm_fee                     NUMBER(20,2),
  lc_benefc                    VARCHAR2(100),
  fix_int_rat_flg              VARCHAR2(30),
