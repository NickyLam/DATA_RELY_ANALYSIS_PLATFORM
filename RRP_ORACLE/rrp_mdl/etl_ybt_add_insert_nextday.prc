SELECT COUNT(1) INTO V_COUNT_T FROM RRP_MDL.ADD_SDIS_T_6_15_INFO WHERE DATA_DT = TO_CHAR(TO_DATE(V_P_DATE,'YYYYMMDD')-1,'YYYYMMDD');
IF V_COUNT_T = 0 THEN
INSERT INTO RRP_MDL.ADD_SDIS_T_6_15_INFO(F150001,F150007,F150011,F150015,ORG_NO,DATA_DT)
SELECT F150001,F150007,F150011,F150015,ORG_NO,V_P_DATE AS DATA_DT
FROM RRP_MDL.ADD_SDIS_T_6_15_INFO
WHERE DATA_DT = (SELECT MAX(DATA_DT) FROM RRP_MDL.ADD_SDIS_T_6_15_INFO);
ELSE
INSERT INTO RRP_MDL.ADD_SDIS_T_6_15_INFO(F150001,F150007,F150011,F150015,ORG_NO,DATA_DT)
SELECT F150001,F150007,F150011,F150015,ORG_NO,V_P_DATE AS DATA_DT
FROM RRP_MDL.ADD_SDIS_T_6_15_INFO
WHERE DATA_DT=TO_CHAR(TO_DATE(V_P_DATE,'YYYYMMDD')-1,'YYYYMMDD');
END IF;

  V_SQLCOUNT := SQL%ROWCOUNT;
  V_SQLMSG   := '返回值：[' || SQLCODE || '],描述信息：' || SQLERRM;
  O_ERRCODE  := '0';
  V_ENDTIME  := SYSDATE;
  COMMIT;
  ETL_YUSYS_LOG(V_P_DATE,V_SYSTEM,V_PROC_NAME,V_STARTTIME,V_ENDTIME,V_STEP,V_STEP_DESC,V_SQLCOUNT,O_ERRCODE,'');  
  


---------------------------SELECT * FROM RRP_MDL.ADD_SDIS_1104JY_INFO;--

  V_STEP      := V_STEP + 1;
  V_STEP_DESC := '插入ADD_SDIS_1104JY_INFO数据';
  V_STARTTIME := SYSDATE;

--删除当天脏数据，不支持重跑
--DELETE FROM RRP_MDL.ADD_SDIS_1104JY_INFO WHERE DATA_DT = V_P_DATE;

SELECT COUNT(1) INTO V_COUNT_T FROM RRP_MDL.ADD_SDIS_1104JY_INFO WHERE DATA_DT = TO_CHAR(TO_DATE(V_P_DATE,'YYYYMMDD')-1,'YYYYMMDD');
IF V_COUNT_T = 0 THEN
INSERT INTO RRP_MDL.ADD_SDIS_1104JY_INFO(RPT_ID,RPT_DT,ORG_NO,DATA_DT)
SELECT RPT_ID,RPT_DT,'00000V1' AS ORG_NO,V_P_DATE AS DATA_DT
FROM RRP_MDL.ADD_SDIS_1104JY_INFO
WHERE DATA_DT = (SELECT MAX(DATA_DT) FROM RRP_MDL.ADD_SDIS_1104JY_INFO);
ELSE
INSERT INTO RRP_MDL.ADD_SDIS_1104JY_INFO(RPT_ID,RPT_DT,ORG_NO,DATA_DT)
SELECT RPT_ID,RPT_DT,'00000V1' AS ORG_NO,V_P_DATE AS DATA_DT
FROM RRP_MDL.ADD_SDIS_1104JY_INFO
WHERE DATA_DT=TO_CHAR(TO_DATE(V_P_DATE,'YYYYMMDD')-1,'YYYYMMDD');
END IF;

  V_SQLCOUNT := SQL%ROWCOUNT;
  V_SQLMSG   := '返回值：[' || SQLCODE || '],描述信息：' || SQLERRM;
  O_ERRCODE  := '0';
  V_ENDTIME  := SYSDATE;
  COMMIT;
  ETL_YUSYS_LOG(V_P_DATE,V_SYSTEM,V_PROC_NAME,V_STARTTIME,V_ENDTIME,V_STEP,V_STEP_DESC,V_SQLCOUNT,O_ERRCODE,''); 
  
    
  
  -- STEP4：跑批结束 --
  V_STEP := V_STEP +1;
  V_STEP_DESC := '跑批结束';
  V_STARTTIME := SYSDATE;
  INSERT INTO RRP_MDL.ETL_STATE(ETL_DATE,PROC_NAME,END_TIME)
       VALUES (V_P_DATE,V_PROC_NAME,TO_CHAR(SYSTIMESTAMP,'YYYYMMDD HH24:MI:SS'));
  V_SQLCOUNT := SQL%ROWCOUNT;
  V_SQLMSG := '返回值：['||SQLCODE||'],描述信息：'||SQLERRM;
  V_ENDTIME := SYSDATE;
  COMMIT;
  ETL_YUSYS_LOG(V_P_DATE,V_SYSTEM,V_PROC_NAME,V_STARTTIME,V_ENDTIME,V_STEP,V_STEP_DESC,V_SQLCOUNT,O_ERRCODE,V_SQLMSG);

  -- 异常处理 --
  EXCEPTION
    WHEN OTHERS THEN
      V_SQLMSG := '返回值：['||SQLCODE||'],描述信息：'||SQLERRM;
      O_ERRCODE := '1';
      V_ENDTIME := SYSDATE;
      ROLLBACK;
  ETL_YUSYS_LOG(V_P_DATE,V_SYSTEM,V_PROC_NAME,V_STARTTIME,V_ENDTIME,V_STEP,V_STEP_DESC,V_SQLCOUNT,O_ERRCODE,V_SQLMSG);

END ETL_YBT_ADD_INSERT_NEXTDAY;
/

