CREATE OR REPLACE PROCEDURE RRP_MDL.ETL_YBT_ADD_INSERT_NEXTDAY(I_P_DATE IN INTEGER,O_ERRCODE OUT VARCHAR2)
  /**************************************************************************
  *  程序名称：ETL_YBT_ADD_INSERT_NEXTDAY
  *  功能描述：将一表通6张补录表插到下一天为前端应用继承使用
  *  目标表  ：一表通6张补录表
  *  来源表  ：一表通6张补录表
  *  配置表  ：不涉及
  *  创建日期：20251213
  *  开发人员：WYX
  *  修改情况：序号  修改日期  修改人   修改原因
  ***************************************************************************/
AS
 -- 定义变量 --
 V_P_DATE    VARCHAR2(8);                          -- 跑批数据日期
 V_SYSTEM    VARCHAR2(30) := '监管报送';           -- 来源系统
 V_PROC_NAME VARCHAR2(30) := 'ETL_YBT_ADD_INSERT_NEXTDAY';   -- 程序名称
 V_STARTTIME DATE;                                 -- 处理开始时间
 V_ENDTIME   DATE;                                 -- 处理结束时间
 V_STEP      INTEGER := 0;                         -- 处理步骤
 V_STEP_DESC VARCHAR2(500);                        -- 步骤描述
 V_SQLCOUNT  INTEGER;                              -- 记录数
 V_SQLMSG    VARCHAR2(500);                        -- SQL执行描述信息
 V_COUNT_T   NUMBER;

BEGIN
  -- 获取跑批日期 --
  V_P_DATE := TO_CHAR(I_P_DATE);

  -- STEP1：跑批开始 --
  V_STEP := 1;
  V_STEP_DESC := '跑批开始';
  V_STARTTIME := SYSDATE;
  V_SQLCOUNT := SQL%ROWCOUNT;
  V_SQLMSG := '返回值：['||SQLCODE||'],描述信息：'||SQLERRM;
  O_ERRCODE := '0';
  V_ENDTIME := SYSDATE;
  COMMIT;
  ETL_YUSYS_LOG(V_P_DATE,V_SYSTEM,V_PROC_NAME,V_STARTTIME,V_ENDTIME,V_STEP,V_STEP_DESC,V_SQLCOUNT,O_ERRCODE,V_SQLMSG);


  -- STEP3：程序业务逻辑处理主体部分 --

-----------------------------SELECT * FROM RRP_MDL.ADD_SDIS_T_3_5_INFO;
  V_STEP      := V_STEP + 1;
  V_STEP_DESC := '插入ADD_SDIS_T_3_5_INFO数据';
  V_STARTTIME := SYSDATE;

--删除当天脏数据，不支持重跑
--DELETE FROM RRP_MDL.ADD_SDIS_T_3_5_INFO WHERE DATA_DT = V_P_DATE;COMMIT;

SELECT COUNT(1) INTO V_COUNT_T FROM RRP_MDL.ADD_SDIS_T_3_5_INFO WHERE DATA_DT = TO_CHAR(TO_DATE(V_P_DATE,'YYYYMMDD')-1,'YYYYMMDD');
IF V_COUNT_T = 0 THEN
INSERT INTO RRP_MDL.ADD_SDIS_T_3_5_INFO(RID, GXID, JTID, JGID, GLJTID, GLGXLX, GXZT, ADDRESS, CJRQ, DEPT_NO, ORG_NO, RPT_ORG_NO, DATA_DT )
SELECT RID, GXID, JTID, JGID, GLJTID, GLGXLX, GXZT, ADDRESS, CJRQ, DEPT_NO, ORG_NO, RPT_ORG_NO,V_P_DATE AS DATA_DT
FROM RRP_MDL.ADD_SDIS_T_3_5_INFO
WHERE DATA_DT = (SELECT MAX(DATA_DT) FROM RRP_MDL.ADD_SDIS_T_3_5_INFO);
ELSE
INSERT INTO RRP_MDL.ADD_SDIS_T_3_5_INFO(RID, GXID, JTID, JGID, GLJTID, GLGXLX, GXZT, ADDRESS, CJRQ, DEPT_NO, ORG_NO, RPT_ORG_NO, DATA_DT )
SELECT RID, GXID, JTID, JGID, GLJTID, GLGXLX, GXZT, ADDRESS, CJRQ, DEPT_NO, ORG_NO, RPT_ORG_NO,V_P_DATE AS DATA_DT
FROM RRP_MDL.ADD_SDIS_T_3_5_INFO
WHERE DATA_DT=TO_CHAR(TO_DATE(V_P_DATE,'YYYYMMDD')-1,'YYYYMMDD');
END IF;

  V_SQLCOUNT := SQL%ROWCOUNT;
  V_SQLMSG   := '返回值：[' || SQLCODE || '],描述信息：' || SQLERRM;
  O_ERRCODE  := '0';
  V_ENDTIME  := SYSDATE;
  COMMIT;
  ETL_YUSYS_LOG(V_P_DATE,V_SYSTEM,V_PROC_NAME,V_STARTTIME,V_ENDTIME,V_STEP,V_STEP_DESC,V_SQLCOUNT,O_ERRCODE,'');

