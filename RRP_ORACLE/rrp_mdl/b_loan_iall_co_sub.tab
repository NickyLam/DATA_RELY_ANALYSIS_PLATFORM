create table RRP_MDL.B_LOAN_IALL_CO_SUB
(
  data_dt           CHAR(8) not null,
  lgl_rep_id        VARCHAR2(200),
  org_id            VARCHAR2(200),
  coop_co_id        VARCHAR2(200),
  co_nm             VARCHAR2(500),
  estb_dt           CHAR(8),
  subs_flg          CHAR(1),
  emp_num           INTEGER,
  loc_area_cd       VARCHAR2(10),
  act_pay_cptl      NUMBER(30,2),
  bank_shr_pct      NUMBER(18,4),
  ent_grow_up_stage VARCHAR2(10),
  dept_line         VARCHAR2(500),
  data_src          VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_LOAN_IALL_CO_SUB
  is '投贷联动合作公司信息子表';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.org_id
  is '机构编号';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.coop_co_id
  is '合作公司编号';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.co_nm
  is '公司名称';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.estb_dt
  is '设立日期';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.subs_flg
  is '子公司标志';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.emp_num
  is '从业人数';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.loc_area_cd
  is '所在地行政区划代码';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.act_pay_cptl
  is '实缴资本';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.bank_shr_pct
  is '银行股份占比';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.ent_grow_up_stage
  is '企业成长阶段';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.B_LOAN_IALL_CO_SUB.data_src
  is '数据来源';
alter table RRP_MDL.B_LOAN_IALL_CO_SUB
  add constraint PK_B_LOAN_IALL_CO_SUB primary key (DATA_DT)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

