comment on column RRP_MDL.O_IOL_TBMS_T_CORP_INFO.companyno
  is '企业联系人';
comment on column RRP_MDL.O_IOL_TBMS_T_CORP_INFO.authorgid
  is '认证（签约）机构';
comment on column RRP_MDL.O_IOL_TBMS_T_CORP_INFO.authtime
  is '认证（签约）时间';
comment on column RRP_MDL.O_IOL_TBMS_T_CORP_INFO.authorgcode
  is '认证(签约)机构编号';
comment on column RRP_MDL.O_IOL_TBMS_T_CORP_INFO.operusercode
