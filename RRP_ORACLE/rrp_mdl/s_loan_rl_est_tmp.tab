create table RRP_MDL.S_LOAN_RL_EST_TMP
(
  data_dt               CHAR(8),
  lgl_rep_id            VARCHAR2(200),
  org_id                VARCHAR2(200),
  cur                   CHAR(3),
  loan_bal              NUMBER(30,2),
  int_adj               NUMBER(18,4),
  cust_id               VARCHAR2(200),
  corp_cust_typ         VARCHAR2(10),
  rl_est_loan_typ       VARCHAR2(10),
  afp_typ               VARCHAR2(10),
  lvl5_cl               VARCHAR2(10),
  extn_flg              CHAR(1),
  ovd_flg               CHAR(1),
  ovd_days              INTEGER,
  prin_ovd_amt          NUMBER(30,2),
  rate_typ              VARCHAR2(10),
  ocg_rate              NUMBER(18,4),
  act_rate              NUMBER(20,6),
  cptl_fnd              NUMBER(30,2),
  lpr                   NUMBER(20,6),
  ltv                   NUMBER(18,4),
  dsr                   NUMBER(18,4),
  hse_num               INTEGER,
  hse_bldg_area         NUMBER(30,2),
  opr_pty_loan_flg      CHAR(1),
  hse_pty_mtg_flg       CHAR(1),
  dsbr_amt              NUMBER(30,2),
  dsbr_dt               CHAR(8),
  ind_hse_loan_typ      VARCHAR2(10),
  scrtz_flg             CHAR(1),
  main_gua_mode         VARCHAR2(10),
  orig_exp_dt           CHAR(8),
  norm_repy_amt         NUMBER(30,2),
  part_adv_repy_amt     NUMBER(30,2),
  full_adv_repy_amt     NUMBER(30,2),
  scrtz_amt             NUMBER(30,2),
  loan_cncl_amt         NUMBER(30,2),
  mon_sold_ind_hse_loan NUMBER(30,2),
  trf_in_loan_flg       CHAR(1),
  dept_line             VARCHAR2(500),
  data_src              VARCHAR2(500),
  hse_typ               VARCHAR2(10),
  rcpt_id               VARCHAR2(60),
  loan_act_dstr_dt      CHAR(8),
  gua_mode              VARCHAR2(10),
  aldy_repy_term        INTEGER,
  aldy_have_hse_num     INTEGER,
  cptl_fnd_rate         NUMBER(30,2),
  prin_ovd_amt_s67      NUMBER(30,2),
  proj_tot_invest       NUMBER(30,2),
  bank_idnt_prc_val     NUMBER(30,2),
  mon_pty_chgs          NUMBER(30,2),
  house_first_pay_amt   NUMBER(30,6),
  house_tot_price       NUMBER(30,6),
  fixed_int_mark        VARCHAR2(10),
  prc_base_typ          VARCHAR2(10),
  house_lease_type      VARCHAR2(50),
  apply_sys             VARCHAR2(100),
  approve_amt           NUMBER(20,2),
  mtg_loan_flg          VARCHAR2(100),
  loan_appl_flow_num    VARCHAR2(100),
  approve_dt            VARCHAR2(8),
  term_acm_mon          NUMBER(30,2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.data_dt
  is '数据日期';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.org_id
  is '银行编号';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.cur
  is '账号币种';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.loan_bal
  is '贷款余额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.int_adj
  is '利息调增金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.cust_id
  is '客户表主键';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.corp_cust_typ
  is '对公客户类型';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.rl_est_loan_typ
  is '房地产贷款类型';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.afp_typ
  is '保障性安居工程类型';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.lvl5_cl
  is '五级分类代码';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.extn_flg
  is '展期标志';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.ovd_flg
  is '逾期标志';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.ovd_days
  is '逾期天数';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.prin_ovd_amt
  is '本金逾期金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.rate_typ
  is '利率类型';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.ocg_rate
  is '按利率';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.act_rate
  is '实际利率';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.cptl_fnd
  is '资本金';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.lpr
  is 'LPR利率';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.ltv
  is '未知';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.dsr
  is 'DSR';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.hse_num
  is '住房套数';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.hse_bldg_area
  is '房屋建筑面积';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.opr_pty_loan_flg
  is '经营性物业贷款标志';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.hse_pty_mtg_flg
  is '房产抵押标志';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.dsbr_amt
  is '放款金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.dsbr_dt
  is '贷款借据发放日';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.ind_hse_loan_typ
  is '个人住房贷款类型';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.scrtz_flg
  is '证券化标志';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.main_gua_mode
  is '担保方式';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.orig_exp_dt
  is '原始到期日期';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.norm_repy_amt
  is '正常还款金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.part_adv_repy_amt
  is '部分提前还款金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.full_adv_repy_amt
  is '全额提前还款金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.scrtz_amt
  is '证券化金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.loan_cncl_amt
  is '贷款核销金额';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.mon_sold_ind_hse_loan
  is '当月售出个人住房贷款(卖断式)';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.trf_in_loan_flg
  is '转入贷款标志';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.dept_line
  is '部门条线';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.data_src
  is '数据来源（参见[字典:AML0045]）';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.hse_typ
  is '房屋类型';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.rcpt_id
  is '借据编号';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.loan_act_dstr_dt
  is '放款日期';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.gua_mode
  is '担保方式';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.aldy_repy_term
  is '已还款期限';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.aldy_have_hse_num
  is '已有住房套数';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.cptl_fnd_rate
  is '资本金比例';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.prin_ovd_amt_s67
  is '统计逾期金额_S67';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.proj_tot_invest
  is '项目总投资';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.bank_idnt_prc_val
  is '押品最新估值';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.mon_pty_chgs
  is '月物业费';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.house_first_pay_amt
