comment on column RRP_MDL.S_LOAN_RL_EST_TMP.loan_appl_flow_num
  is '贷款申请流水号';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.approve_dt
  is '终审时间';
comment on column RRP_MDL.S_LOAN_RL_EST_TMP.term_acm_mon
  is '期限积（月）';

