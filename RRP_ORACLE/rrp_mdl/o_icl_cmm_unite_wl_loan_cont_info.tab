  exec_int_rat                         NUMBER(18,8),
  cont_bal                             NUMBER(30,8),
  cont_amt                             NUMBER(30,8),
  distr_amt                            NUMBER(30,8),
  tenor                                VARCHAR2(60),
  begin_dt                             DATE,
  exp_dt                               DATE,
  sign_dt                              DATE,
  distr_dt                             DATE,
  termnt_dt                            DATE,
  spec_repay_day                       DATE,
  operr_id                             VARCHAR2(100),
  oper_org_id                          VARCHAR2(100),
  oper_dt                              DATE,
  rgstrat_id                           VARCHAR2(100),
  rgst_org_id                          VARCHAR2(100),
  rgst_dt                              DATE,
  update_id                            VARCHAR2(100),
  update_org_id                        VARCHAR2(100),
  update_dt                            DATE,
  job_cd                               VARCHAR2(10),
  etl_timestamp                        TIMESTAMP(6),
  adv_man_indu_flg                     VARCHAR2(10),
  green_crdt_fin_flg                   VARCHAR2(10),
  cty_lmt_indus_flg                    VARCHAR2(10),
  high_tech_serv_loan_flg              VARCHAR2(10),
  sci_tech_inovt_corp_flg              VARCHAR2(10),
  sci_tech_corp_flg                    VARCHAR2(10),
  high_new_tech_corp_flg               VARCHAR2(10),
  spe_soph_unq_new_med_side_enter_flg  VARCHAR2(10),
  spe_soph_unq_new_lte_gnt_corp_flg    VARCHAR2(10),
  provi_for_aged_property_flg          VARCHAR2(10),
  indu_corp_tech_rem_ugd_flg           VARCHAR2(30),
  three_old_tf_or_city_update_proj_flg VARCHAR2(30),
  br_build_ifin_flg                    VARCHAR2(10),
  sup_chain_fin_bus_flg                VARCHAR2(60),
  buid_bus_guar_loan_flg               VARCHAR2(10),
  county_loan_flg                      VARCHAR2(10),
  overs_loan_flg                       VARCHAR2(10),
  ppp_proj_flg                         VARCHAR2(10),
  cul_property_flg                     VARCHAR2(10),
  high_tech_property_flg               VARCHAR2(10),
  new_distr_flg                        VARCHAR2(10),
  agclt_flg                            VARCHAR2(10),
  seed_loan_flg                        VARCHAR2(10),
  proj_fin_flg                         VARCHAR2(10),
  lmt_or_encrge_indus_cd               VARCHAR2(10),
  sup_chain_fin_bus_prod_cls_cd        VARCHAR2(10),
  guar_proj_loan_type_cd               VARCHAR2(10),
  buid_bus_guar_loan_type_cd           VARCHAR2(30),
  estate_loan_type_cd                  VARCHAR2(10),
  strate_new_indus_type_cd             VARCHAR2(30),
  digit_econ_core_type_cd              VARCHAR2(30),
  agclt_loan_main_type_cd              VARCHAR2(30),
  agclt_loan_dir_cd                    VARCHAR2(30),
  dir_indus_cd                         VARCHAR2(30),
  loan_fin_supt_way_cd                 VARCHAR2(60),
  surp_indus_cd                        VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
