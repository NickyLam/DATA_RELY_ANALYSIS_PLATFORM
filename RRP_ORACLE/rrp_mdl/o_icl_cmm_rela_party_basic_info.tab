create table RRP_MDL.O_ICL_CMM_RELA_PARTY_BASIC_INFO
(
  etl_dt                           DATE,
  lp_id                            VARCHAR2(60),
  party_id                         VARCHAR2(100),
  party_name                       VARCHAR2(500),
  party_type_cd                    VARCHAR2(60),
  party_cert_type_cd_1             VARCHAR2(60),
  party_cert_id_1                  VARCHAR2(100),
  party_cert_type_cd_2             VARCHAR2(60),
  party_cert_id_2                  VARCHAR2(60),
  party_belong_org_id              VARCHAR2(60),
  party_belong_dept_id             VARCHAR2(100),
  party_kins_rela_cd               VARCHAR2(30),
  party_org_cd                     VARCHAR2(60),
  party_belong_corp_name           VARCHAR2(150),
  party_post_name                  VARCHAR2(150),
  party_ghb_post_name              VARCHAR2(1000),
  party_share_ratio                VARCHAR2(150),
  party_dom_overs_flg              VARCHAR2(10),
  rela_type_cd                     VARCHAR2(4000),
  rela_status_cd                   VARCHAR2(30),
  rela_effect_dt                   DATE,
  rela_invalid_dt                  DATE,
  rela_party_id                    VARCHAR2(100),
  rela_party_name                  VARCHAR2(1000),
  rela_party_cert_type_cd_1        VARCHAR2(60),
  rela_party_cert_id_1             VARCHAR2(100),
  rela_party_cert_type_cd_2        VARCHAR2(60),
  rela_party_cert_id_2             VARCHAR2(60),
  rela_party_belong_org_id         VARCHAR2(60),
  rela_party_belong_dept_id        VARCHAR2(60),
  rela_party_kins_rela_cd          VARCHAR2(30),
  rela_party_org_cd                VARCHAR2(60),
  rela_party_belong_corp_name      VARCHAR2(1000),
  rela_party_post_name             VARCHAR2(1000),
  rela_party_ghb_post_name         VARCHAR2(1000),
  rela_party_share_ratio           VARCHAR2(150),
  rela_party_dom_overs_flg         VARCHAR2(10),
  shard_or_rela_party_type_cd      VARCHAR2(60),
  shard_or_rela_party_bl_induty_cd VARCHAR2(60),
  shard_or_rela_party_rgst_addr    VARCHAR2(2000),
  shard_or_rela_party_rela_type_cd VARCHAR2(300),
  job_cd                           VARCHAR2(10),
  party_east_econ_type_cd          VARCHAR2(10),
  party_east_non_info              VARCHAR2(10),
  rela_east_econ_type_cd           VARCHAR2(10),
  rela_east_non_info               VARCHAR2(10),
  party_status_cd                  VARCHAR2(30),
  party_effect_dt                  DATE,
  party_invalid_dt                 DATE,
  rela_party_status_cd             VARCHAR2(30),
  rela_party_effect_dt             DATE,
  rela_party_invalid_dt            DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
