create table RRP_MDL.T_COM_RRP_CRRS_CRRS_GROUP_EXECUTIVES
(
  rid              VARCHAR2(100) not null,
  customer_code    VARCHAR2(100) not null,
  executives_id    VARCHAR2(100) not null,
  executives_name  VARCHAR2(100) not null,
  person_type      VARCHAR2(20) not null,
  nationality_code VARCHAR2(40),
  control_flag     CHAR(1),
  customer_name    VARCHAR2(100) not null,
  update_dt        VARCHAR2(40),
  id_card_no       VARCHAR2(100),
  data_dt          VARCHAR2(40) not null,
  issued_no        VARCHAR2(100),
  rpt_org_no       VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;

