create table RRP_MDL.O_IOL_ICMS_WLD_IQP_LOAN_APP
(
  serialno            VARCHAR2(32),
  seqno               VARCHAR2(60),
  transcode           VARCHAR2(10),
  producttype         VARCHAR2(20),
  wldversion          VARCHAR2(10),
  wldtimestamp        VARCHAR2(13),
  bankno              VARCHAR2(10),
  papporderid         VARCHAR2(60),
  bizscene            VARCHAR2(40),
  iscustdataqueryauth VARCHAR2(1),
  isneedtdouterdata   VARCHAR2(1),
  isneedgaouterdata   VARCHAR2(1),
  isneedhfouterdata   VARCHAR2(1),
  isneedyeouterdata   VARCHAR2(1),
  isneedxxouterdata   VARCHAR2(1),
  isneedouterlimit    VARCHAR2(1),
  isneedouterlist     VARCHAR2(1),
  idtype              VARCHAR2(4),
  idno                VARCHAR2(30),
  certtype            VARCHAR2(4),
  customername        VARCHAR2(80),
  genderno            VARCHAR2(6),
  nation              VARCHAR2(20),
  validbegintime      VARCHAR2(20),
  validendtime        VARCHAR2(20),
  profession          VARCHAR2(20),
  address             VARCHAR2(500),
  phone               VARCHAR2(20),
  ishaslandline       VARCHAR2(1),
  limitpurpose        VARCHAR2(12),
  firstchecklimit     NUMBER(24,6),
  callbackcode        VARCHAR2(10),
  inputuserid         VARCHAR2(32),
  inputorgid          VARCHAR2(32),
  inputdate           VARCHAR2(20),
  customerid          VARCHAR2(32),
  openflag            VARCHAR2(1),
  informflag          VARCHAR2(1),
  riskpapporderid     VARCHAR2(50),
  risktdouterdata     VARCHAR2(20),
  riskgaouterdata     VARCHAR2(20),
  riskhfouterdata     VARCHAR2(20),
  riskyeouterdata     VARCHAR2(20),
  riskxxouterdata     VARCHAR2(20),
  risknegative        VARCHAR2(20),
  riskrelational      VARCHAR2(20),
  riskotherrule       VARCHAR2(20),
  riskisoverlimithat  VARCHAR2(20),
  riskouterlimit      VARCHAR2(20),
  approvestatus       VARCHAR2(20),
  remark              VARCHAR2(510),
  operateorgid        VARCHAR2(32),
  start_dt            DATE,
  end_dt              DATE,
  id_mark             VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
