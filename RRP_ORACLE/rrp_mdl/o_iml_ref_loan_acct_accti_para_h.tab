create table RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H
(
  accti_cd         VARCHAR2(30),
  accti_type_cd    VARCHAR2(10),
  accti_org_lev_cd VARCHAR2(10),
  bus_id_cd        VARCHAR2(30),
  start_dt         DATE,
  end_dt           DATE,
  id_mark          VARCHAR2(10),
  src_table_name   VARCHAR2(100),
  job_cd           VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H
  is '贷款账户核算账户参数历史';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.accti_cd
  is '会计核算代码REF_ACCTI_CODE_H';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.accti_type_cd
  is '核算类型代码CD1320';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.accti_org_lev_cd
  is '核算机构级别代码CD1542';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.bus_id_cd
  is '业务编号代码';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.start_dt
  is '开始日期';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.end_dt
  is '结束日期';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.id_mark
  is '删除标识';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_REF_LOAN_ACCT_ACCTI_PARA_H.job_cd
  is '任务代码';

