create table RRP_MDL.O_IOL_BDMS_CPES_RECOVERY_HAND_AGREEPAY
(
  id                             VARCHAR2(60),
  buss_flag                      VARCHAR2(3),
  product_no                     VARCHAR2(12),
  draft_id                       VARCHAR2(60),
  hand_apply_id                  VARCHAR2(60),
  pub_apply_id                   VARCHAR2(60),
  recovery_type                  VARCHAR2(6),
  draft_number                   VARCHAR2(45),
  cd_range                       VARCHAR2(38),
  draft_amount                   NUMBER(18,2),
  recovery_buss_type             VARCHAR2(6),
  recovery_name                  VARCHAR2(675),
  recovery_cert_no               VARCHAR2(48),
  recovery_dist_tp               VARCHAR2(6),
  recovery_account               VARCHAR2(48),
  recovery_brh_no                VARCHAR2(14),
  recovery_bank_no               VARCHAR2(18),
  recovery_notice_date           VARCHAR2(12),
  recovery_notice_misc           VARCHAR2(675),
  recovery_backmisc              VARCHAR2(675),
  recovery_sign_date             VARCHAR2(12),
  recovery_sign_mk               VARCHAR2(6),
  recovery_sign_misc             VARCHAR2(675),
  berecovered_buss_type          VARCHAR2(6),
  berecovered_name               VARCHAR2(675),
  berecovered_cert_no            VARCHAR2(48),
  berecovered_dist_tp            VARCHAR2(6),
  berecovered_account            VARCHAR2(48),
  berecovered_brh_no             VARCHAR2(14),
  berecovered_agree_date         VARCHAR2(12),
  berecovered_agree_misc         VARCHAR2(675),
  berecovered_agree_number       NUMBER(12),
  berecovered_settle_account     VARCHAR2(48),
  berecovered_settle_bank_no     VARCHAR2(18),
  berecovered_backmisc           VARCHAR2(675),
  settle_type                    VARCHAR2(6),
  clear_type                     VARCHAR2(6),
  settle_date                    VARCHAR2(12),
  deal_status                    VARCHAR2(3),
  settle_status                  VARCHAR2(6),
  account_status                 VARCHAR2(3),
  err_code                       VARCHAR2(14),
  err_msg                        VARCHAR2(1200),
  branch_no                      VARCHAR2(15),
  belong_brh_no                  VARCHAR2(14),
  top_branch_no                  VARCHAR2(15),
  create_opr                     VARCHAR2(15),
  last_upd_opr                   VARCHAR2(45),
  last_upd_time                  VARCHAR2(21),
  recovery_mem_no                VARCHAR2(9),
  berecovered_mem_no             VARCHAR2(9),
  recovery_range                 VARCHAR2(38),
  recovery_amount                NUMBER(18,2),
  recovery_account_name          VARCHAR2(675),
  recovery_settle_account_name   VARCHAR2(675),
  recovery_settle_account        VARCHAR2(48),
  recovery_settle_brh_no         VARCHAR2(14),
  recovery_bt_no                 VARCHAR2(675),
  berecovered_account_name       VARCHAR2(675),
  berecovered_settle_account_nam VARCHAR2(675),
  berecovered_settle_brh_no      VARCHAR2(14),
  berecovered_bt_no              VARCHAR2(675),
  settle_amount                  NUMBER(18,2),
  etl_dt                         DATE,
  etl_timestamp                  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
