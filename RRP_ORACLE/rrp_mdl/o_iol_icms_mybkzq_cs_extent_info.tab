create table RRP_MDL.O_IOL_ICMS_MYBKZQ_CS_EXTENT_INFO
(
  serialno                           VARCHAR2(32),
  applyno                            VARCHAR2(64),
  businessscene                      VARCHAR2(64),
  businesstag                        VARCHAR2(64),
  mobile                             VARCHAR2(64),
  address                            VARCHAR2(1024),
  prov                               VARCHAR2(32),
  city                               VARCHAR2(64),
  area                               VARCHAR2(64),
  certvalidenddate                   VARCHAR2(128),
  busdatareqdate                     VARCHAR2(64),
  businfoexistflag                   VARCHAR2(8),
  notexistreason                     VARCHAR2(64),
  companyinfoname                    VARCHAR2(1024),
  companyinfolawer                   VARCHAR2(64),
  companyinforegisterno              VARCHAR2(64),
  companyinforegisterdate            VARCHAR2(32),
  companyinforegisteraddress         VARCHAR2(1024),
  companyinforegisteraddressareacode VARCHAR2(64),
  companyinforegisteraddressarea     VARCHAR2(128),
  companyinforegisterfund            VARCHAR2(64),
  companyinfofundcurrency            VARCHAR2(64),
  companyinfotradecode               VARCHAR2(64),
  companyinfomanagerange             VARCHAR2(4000),
  companyinfoorgcode                 VARCHAR2(64),
  companyinforegisterdepartment      VARCHAR2(128),
  companyinfostatusid                VARCHAR2(8),
  companyinfostatusdesc              VARCHAR2(512),
  companyinfolastcheckyear           VARCHAR2(64),
  companyinfomanagebegindate         VARCHAR2(64),
  companyinfomanageenddate           VARCHAR2(64),
  companyinfoopendate                VARCHAR2(64),
  companyinfocompanytype             VARCHAR2(128),
  companyinfoeconomictype            VARCHAR2(128),
  targetjyflag1                      VARCHAR2(256),
  industryname                       VARCHAR2(512),
  custipid                           VARCHAR2(64),
  custiproleid                       VARCHAR2(64),
  sex                                VARCHAR2(2),
  transmode                          VARCHAR2(64),
  etl_dt                             DATE,
  etl_timestamp                      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_MYBKZQ_CS_EXTENT_INFO
