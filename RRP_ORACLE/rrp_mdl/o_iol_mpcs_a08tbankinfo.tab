create table RRP_MDL.O_IOL_MPCS_A08TBANKINFO
(
  bkcd          VARCHAR2(21),
  bkstatus      VARCHAR2(2),
  banktype      VARCHAR2(3),
  bkctgycd      VARCHAR2(5),
  drctbkcd      VARCHAR2(21),
  bkname        VARCHAR2(180),
  bksname       VARCHAR2(180),
  lglprsn       VARCHAR2(21),
  hghptcpt      VARCHAR2(105),
  brbkcd        VARCHAR2(21),
  chrgbkcd      VARCHAR2(21),
  ndcd          VARCHAR2(6),
  citycd        VARCHAR2(9),
  sgn           VARCHAR2(15),
  tel           VARCHAR2(150),
  chngnb        VARCHAR2(12),
  fctvdt        VARCHAR2(12),
  ifctvdt       VARCHAR2(12),
  acctbkcdinf   VARCHAR2(21),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10),
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_MPCS_A08TBANKINFO
  is '中台机构信息表';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.bkcd
  is '参与机构行号';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.bkstatus
  is '参与机构状态 1 有效 2已撤销';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.banktype
  is '参与机构类别 01-直接参与人行 02-直接参与国库 03-EIS转换中心  04-直接参与商业银行  05-开户特许直接参与者  06-开户特许间接参与者 07-间接参与 08-无户特许直接参与者(债券)';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.bkctgycd
  is '行别代码';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.drctbkcd
  is '所属直参行号';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.bkname
  is '参与机构全称';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.bksname
  is '参与机构简称';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.lglprsn
  is '所属法人';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.hghptcpt
  is '本行上级参与机构 多个上级参与者之间以“；”分隔，上级参与者列表排列顺序是从左至右，按照参与者级别由高到低依次填写';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.brbkcd
  is '承接行行号';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.chrgbkcd
  is '管辖人行行号';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.ndcd
  is '所属CCPC';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.citycd
  is '所在城市代码';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.sgn
  is '加入业务系统标识 排列顺序按从左到右位为大额、小额、网银，其它位数保留。位数字含义：0：未加入 1：加入';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.tel
  is '电话/电挂';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.chngnb
  is '变更期数';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.fctvdt
  is '生效日期';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.ifctvdt
  is '失效日期';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.acctbkcdinf
  is '入账行行号信息';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IOL_MPCS_A08TBANKINFO.etl_timestamp
  is 'ETL处理时间戳';

