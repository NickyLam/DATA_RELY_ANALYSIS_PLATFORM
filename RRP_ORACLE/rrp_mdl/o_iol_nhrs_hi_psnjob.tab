create table RRP_MDL.O_IOL_NHRS_HI_PSNJOB
(
  assgid         NUMBER(38),
  begindate      VARCHAR2(15),
  clerkcode      VARCHAR2(75),
  creationtime   VARCHAR2(29),
  creator        VARCHAR2(30),
  dataoriginflag NUMBER(38),
  deposemode     VARCHAR2(30),
  dr             NUMBER(10),
  enddate        VARCHAR2(15),
  endflag        VARCHAR2(2),
  ismainjob      VARCHAR2(2),
  jobmode        VARCHAR2(30),
  lastflag       VARCHAR2(2),
  memo           VARCHAR2(2304),
  modifiedtime   VARCHAR2(29),
  modifier       VARCHAR2(30),
  occupation     VARCHAR2(30),
  oribillpk      VARCHAR2(30),
  oribilltype    VARCHAR2(30),
  pk_dept        VARCHAR2(30),
  pk_dept_v      VARCHAR2(30),
  pk_group       VARCHAR2(30),
  pk_hrgroup     VARCHAR2(30),
  pk_hrorg       VARCHAR2(30),
  pk_job         VARCHAR2(30),
  pk_job_type    VARCHAR2(30),
  pk_jobgrade    VARCHAR2(30),
  pk_jobrank     VARCHAR2(30),
  pk_org         VARCHAR2(30),
  pk_org_v       VARCHAR2(30),
  pk_post        VARCHAR2(30),
  pk_postseries  VARCHAR2(30),
  pk_psncl       VARCHAR2(30),
  pk_psndoc      VARCHAR2(30),
  pk_psnjob      VARCHAR2(30),
  pk_psnorg      VARCHAR2(30),
  poststat       VARCHAR2(2),
  psntype        NUMBER(38),
  recordnum      NUMBER(38),
  series         VARCHAR2(30),
  showorder      NUMBER(38),
  trial_flag     VARCHAR2(2),
  trial_type     NUMBER(38),
  trnsevent      NUMBER(38),
  trnsreason     VARCHAR2(30),
  trnstype       VARCHAR2(30),
  ts             VARCHAR2(29),
  worktype       VARCHAR2(30),
  jobglbdef1     VARCHAR2(192),
  jobglbdef2     VARCHAR2(30),
  jobglbdef3     VARCHAR2(30),
  jobglbdef4     VARCHAR2(30),
  jobglbdef5     VARCHAR2(30),
  jobglbdef6     VARCHAR2(30),
  jobglbdef9     VARCHAR2(192),
  jobglbdef7     VARCHAR2(30),
  jobglbdef8     VARCHAR2(192),
  jobglbdef10    VARCHAR2(30),
  jobglbdef11    VARCHAR2(15),
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10),
  etl_timestamp  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
