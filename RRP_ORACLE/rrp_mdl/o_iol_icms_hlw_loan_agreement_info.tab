create table RRP_MDL.O_IOL_ICMS_HLW_LOAN_AGREEMENT_INFO
(
  serialno                 VARCHAR2(32),
  productid                VARCHAR2(200),
  productname              VARCHAR2(1000),
  belongorgid              VARCHAR2(1000),
  agreementno              VARCHAR2(200),
  ismainagreement          VARCHAR2(10),
  mainagreementno          VARCHAR2(200),
  cooperatename            VARCHAR2(200),
  cooperatecerttype        VARCHAR2(10),
  cooperatecertid          VARCHAR2(64),
  cooperatetype            VARCHAR2(10),
  cooperatemethod          VARCHAR2(200),
  providecreditmodel       VARCHAR2(200),
  cooperateregisteraddress VARCHAR2(500),
  startdate                VARCHAR2(20),
  maturitydate             VARCHAR2(20),
  actualmaturitydate       VARCHAR2(20),
  limitflag                VARCHAR2(10),
  cooperatestatus          VARCHAR2(10),
  operationtype            VARCHAR2(6),
  oldserialno              VARCHAR2(32),
  datastatus               VARCHAR2(32),
  approvestatus            VARCHAR2(64),
  inputuserid              VARCHAR2(16),
  inputorgid               VARCHAR2(16),
  inputdate                DATE,
  updateuserid             VARCHAR2(16),
  updateorgid              VARCHAR2(16),
  updatedate               DATE,
  investmentprop           NUMBER(24,6),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_HLW_LOAN_AGREEMENT_INFO
  is '互联网贷款产品合作协议信息表';
