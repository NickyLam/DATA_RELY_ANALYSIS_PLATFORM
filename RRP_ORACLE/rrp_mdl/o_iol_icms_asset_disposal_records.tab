  is '抵债资产编号';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS.debtrepayassetname
  is '抵债资产名称';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS.accountno
  is '账户';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS.accountname
