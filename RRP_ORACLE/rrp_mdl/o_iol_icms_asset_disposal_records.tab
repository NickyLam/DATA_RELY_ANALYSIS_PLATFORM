  is '账户币种';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS.transactionamt
  is '交易价格';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS.accountrodtype
