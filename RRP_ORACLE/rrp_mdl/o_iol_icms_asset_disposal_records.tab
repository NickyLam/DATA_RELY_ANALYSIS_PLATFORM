create table RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS
(
  serialno              VARCHAR2(64),
  relativeserialno      VARCHAR2(64),
  debtrepayassetid      VARCHAR2(64),
  debtrepayassetname    VARCHAR2(200),
  accountno             VARCHAR2(100),
  accountname           VARCHAR2(200),
  subacctnum            VARCHAR2(60),
  accountcurrency       VARCHAR2(10),
  transactionamt        NUMBER(24,6),
  accountrodtype        VARCHAR2(64),
  handletype            VARCHAR2(48),
  handledate            DATE,
  handlebalance         NUMBER(24,6),
  handledesc            VARCHAR2(3000),
  handlenum             VARCHAR2(32),
  approvestatus         VARCHAR2(64),
  inputuserid           VARCHAR2(64),
  inputorgid            VARCHAR2(64),
  inputdate             DATE,
  operateuserid         VARCHAR2(64),
  operateorgid          VARCHAR2(64),
  operatedate           DATE,
  updateuserid          VARCHAR2(64),
  updateorgid           VARCHAR2(64),
  updatedate            DATE,
  relativeapplyserialno VARCHAR2(64),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS
  is '抵债资产处置申请记录表';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS.serialno
  is '流水号';
comment on column RRP_MDL.O_IOL_ICMS_ASSET_DISPOSAL_RECORDS.relativeserialno
  is '关联流水号';
