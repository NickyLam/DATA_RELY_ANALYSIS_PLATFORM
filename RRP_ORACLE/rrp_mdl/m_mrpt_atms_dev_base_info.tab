create table RRP_MDL.M_MRPT_ATMS_DEV_BASE_INFO
(
  data_dt             VARCHAR2(8),
  no                  VARCHAR2(30),
  ip                  VARCHAR2(30),
  org_no              VARCHAR2(30),
  away_flag           VARCHAR2(8),
  dev_catalog         NUMBER,
  dev_vendor          NUMBER,
  dev_type            NUMBER,
  work_type           NUMBER,
  status              NUMBER,
  dev_service         NUMBER,
  terminal_no         VARCHAR2(30),
  serial              VARCHAR2(60),
  address             VARCHAR2(120),
  buy_date            VARCHAR2(15),
