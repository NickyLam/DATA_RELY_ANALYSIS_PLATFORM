  close_time          VARCHAR2(15),
  expire_date         VARCHAR2(15),
  patrol_period       NUMBER,
  area_no             VARCHAR2(15),
  x                   NUMBER(20,10),
  y                   NUMBER(20,10),
  cashbox_limit       VARCHAR2(75),
  os                  VARCHAR2(75),
  atmc_soft           VARCHAR2(75),
  anti_virus_soft     VARCHAR2(75),
  sp                  VARCHAR2(75),
  virtual_teller_no   VARCHAR2(15),
  care_level          VARCHAR2(2),
  last_pm_date        VARCHAR2(15),
  expire_pm_date      VARCHAR2(15),
  locate_no           VARCHAR2(15),
  note1               VARCHAR2(45),
  note2               VARCHAR2(45),
  note3               VARCHAR2(45),
  note4               VARCHAR2(45),
  note5               VARCHAR2(45),
  carrier             VARCHAR2(30),
  money_org           VARCHAR2(30),
  dev_status          NUMBER,
  environment         VARCHAR2(384),
  address_code        VARCHAR2(23),
  cash_type           NUMBER,
  setup_type          NUMBER,
  net_type            VARCHAR2(2),
  operate_status      NUMBER,
  registration_status NUMBER,
  comm_packet         NUMBER,
  zip_type            NUMBER,
  dek_encoded         VARCHAR2(150),
  atmp_area           VARCHAR2(15),
  selfbanktype        NUMBER,
  arm_type            NUMBER,
  pref_no             VARCHAR2(6),
  country_no          VARCHAR2(9),
  postcode            VARCHAR2(9),
  contact             VARCHAR2(2),
  acpt_ins_id_cd      VARCHAR2(12),
  invstr_ins_id_cd    VARCHAR2(12),
  maintn_ins_id_cd    VARCHAR2(12),
  term_publicize_chnl VARCHAR2(150),
  socket              VARCHAR2(150),
