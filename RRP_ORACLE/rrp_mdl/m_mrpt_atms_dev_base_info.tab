  magn_read_in        VARCHAR2(3),
  no_card             VARCHAR2(3),
  cont_ic_in          VARCHAR2(3),
  contless_ic_in      VARCHAR2(3),
  term_tran_fun       VARCHAR2(150),
  last_statue         VARCHAR2(2),
