create table RRP_MDL.O_IOL_ABSS_FLOW_TASK
(
  serialno         VARCHAR2(48),
  objectno         VARCHAR2(48),
  objecttype       VARCHAR2(60),
  relativeserialno VARCHAR2(48),
  flowno           VARCHAR2(48),
  flowname         VARCHAR2(120),
  phaseno          VARCHAR2(48),
  phasename        VARCHAR2(120),
  phasetype        VARCHAR2(27),
  applytype        VARCHAR2(60),
  userid           VARCHAR2(48),
  username         VARCHAR2(120),
  orgid            VARCHAR2(48),
  orgname          VARCHAR2(120),
  begintime        VARCHAR2(30),
  endtime          VARCHAR2(30),
  phasechoice      VARCHAR2(120),
  phaseaction      VARCHAR2(750),
  phaseopinion     VARCHAR2(4000),
  phaseopinion1    VARCHAR2(375),
  phaseopinion2    VARCHAR2(375),
  phaseopinion3    VARCHAR2(375),
  phaseopinion4    VARCHAR2(375),
  checklistresult  VARCHAR2(120),
  autodecision     VARCHAR2(120),
  riskscanresult   VARCHAR2(120),
  standardtime1    VARCHAR2(48),
  standardtime2    VARCHAR2(48),
  costlob          VARCHAR2(48),
  clientx          NUMBER,
  clienty          NUMBER,
  width            NUMBER,
  heigth           NUMBER,
  groupinfo        VARCHAR2(1500),
  processinstno    VARCHAR2(48),
  processtaskno    VARCHAR2(48),
  relativeobjectno VARCHAR2(48),
  flowstate        VARCHAR2(120),
  forkstate        VARCHAR2(9),
  version          VARCHAR2(15),
  baseflowno       VARCHAR2(48),
  taskstate        VARCHAR2(9),
  forkno           VARCHAR2(30),
  allforkno        VARCHAR2(120),
  parentflowno     VARCHAR2(96),
  assignedtaskno   VARCHAR2(480),
  relanoticeno     VARCHAR2(60),
  start_dt         DATE,
  end_dt           DATE,
  id_mark          VARCHAR2(10),
  etl_timestamp    TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ABSS_FLOW_TASK
  is '流程阶段数据';
