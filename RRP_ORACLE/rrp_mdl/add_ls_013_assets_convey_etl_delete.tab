create table RRP_MDL.ADD_LS_013_ASSETS_CONVEY_ETL_DELETE
(
  datainput_id   VARCHAR2(32) not null,
  data_date      VARCHAR2(10),
  acct_org_num   VARCHAR2(20),
  jywym          VARCHAR2(200),
  khwym          VARCHAR2(30),
  khmc           VARCHAR2(200),
  cplx           VARCHAR2(30),
  cpmc           VARCHAR2(100),
  zqzrrq         VARCHAR2(10),
  zrfslb         VARCHAR2(50),
  dybj           NUMBER(20,6),
  czqwjfl        VARCHAR2(10),
  sfzzg          VARCHAR2(10),
  ssje           NUMBER(20,6),
  dzhhxje        NUMBER(20,6),
  dzhzrhsxj      NUMBER(20,6),
  zrshqtdj       NUMBER(20,6),
  zcje           NUMBER(20,6),
  zczrjypt       VARCHAR2(50),
  zczrdjpt       VARCHAR2(50),
  zjjydslb       VARCHAR2(50),
  sys_source     VARCHAR2(100),
  sfsc           VARCHAR2(10),
  jydslb         VARCHAR2(100),
  sys_data_date  VARCHAR2(20) not null,
  sys_data_case  VARCHAR2(32) not null,
  sys_operator   VARCHAR2(256),
  sys_oper_org   VARCHAR2(32) not null,
  sys_oper_date  VARCHAR2(20),
  sys_data_state VARCHAR2(10),
  sys_order_no   NUMBER(19),
  error_mark     VARCHAR2(2),
  flow_node_id   VARCHAR2(32),
  comments       VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.ADD_LS_013_ASSETS_CONVEY_ETL_DELETE
  is '补录表-零售-资产转让模型-应用';
comment on column RRP_MDL.ADD_LS_013_ASSETS_CONVEY_ETL_DELETE.datainput_id
