create table RRP_MDL.CONFIG_ETL_FREQ
(
  proc_name VARCHAR2(150),
  freq_typ  VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.CONFIG_ETL_FREQ
  is '跑批频率';
comment on column RRP_MDL.CONFIG_ETL_FREQ.proc_name
  is '程序名称';
comment on column RRP_MDL.CONFIG_ETL_FREQ.freq_typ
  is '频率类型';

