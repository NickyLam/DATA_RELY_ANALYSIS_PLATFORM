create table RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT
(
  evt_id            VARCHAR2(250),
  lp_id             VARCHAR2(100),
  dubil_id          VARCHAR2(100),
  input_dt          DATE,
  crdt_appl_id      VARCHAR2(100),
  chn_src           VARCHAR2(100),
  cfm_dt            DATE,
  tot_soc_amt       NUMBER(30,2),
  guar_soc_amt      NUMBER(30,2),
  pa_insure_soc_amt NUMBER(30,2),
  gr_insure_soc_amt NUMBER(30,2),
  stud_loan_prod_id VARCHAR2(100),
  remark            VARCHAR2(1000),
  start_dt          DATE,
  end_dt            DATE,
  id_mark           VARCHAR2(10),
  src_table_name    VARCHAR2(100),
  job_cd            VARCHAR2(10),
  etl_timestamp     TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT
  is '平安普惠理赔确认事件';
comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.evt_id
  is '事件编号';
comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.dubil_id
  is '借据编号';
comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.input_dt
  is '录入日期';
comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.crdt_appl_id
