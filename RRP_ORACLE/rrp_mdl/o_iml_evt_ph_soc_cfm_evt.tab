comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.cfm_dt
  is '确认日期';
comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.tot_soc_amt
  is '总理赔金额';
comment on column RRP_MDL.O_IML_EVT_PH_SOC_CFM_EVT.guar_soc_amt
