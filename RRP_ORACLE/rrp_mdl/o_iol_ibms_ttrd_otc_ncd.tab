create table RRP_MDL.O_IOL_IBMS_TTRD_OTC_NCD
(
  i_code                VARCHAR2(45),
  a_type                VARCHAR2(30),
  m_type                VARCHAR2(30),
  currency              VARCHAR2(5),
  q_type                VARCHAR2(3),
  b_name                VARCHAR2(150),
  p_type                VARCHAR2(45),
  p_class               VARCHAR2(90),
  b_coupon              NUMBER(12,6),
  ncdcount              NUMBER(31,4),
  b_issue_price         NUMBER(12,4),
  min_issue_price       NUMBER(12,4),
  max_issue_price       NUMBER(12,4),
  b_start_date          VARCHAR2(15),
  b_mtr_date            VARCHAR2(15),
  b_term                VARCHAR2(9),
  first_date            VARCHAR2(15),
  b_pay_freq            VARCHAR2(9),
  b_issue_mode          VARCHAR2(2),
  b_coupon_type         VARCHAR2(2),
  i_code_bench          VARCHAR2(45),
  a_type_bench          VARCHAR2(30),
  m_type_bench          VARCHAR2(30),
  settle_status         NUMBER,
  set_date              VARCHAR2(15),
  honour_date           VARCHAR2(15),
  b_issue_date          VARCHAR2(15),
  annual_rate           NUMBER(12,6),
  b_daycount            VARCHAR2(180),
  b_fst_pay_date        VARCHAR2(15),
  tender_type           NUMBER,
  min_rate              NUMBER(12,6),
  max_rate              NUMBER(12,6),
  b_actual_issue_amount NUMBER(31,4),
  intordid              VARCHAR2(45),
  issuer                VARCHAR2(383),
  issuerange            VARCHAR2(150),
  gradeinst             VARCHAR2(383),
  grade                 VARCHAR2(15),
  parvalue              NUMBER(12,6),
  issue_start_date      VARCHAR2(15),
  issue_mtr_date        VARCHAR2(15),
  max_bid_amount        NUMBER(31,4),
  min_bid_amount        NUMBER(31,4),
  singe_max_bid_amount  NUMBER(31,4),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
