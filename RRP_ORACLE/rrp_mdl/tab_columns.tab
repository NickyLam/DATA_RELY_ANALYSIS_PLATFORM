create table RRP_MDL.TAB_COLUMNS
(
  owner       VARCHAR2(128) not null,
  table_name  VARCHAR2(128) not null,
  column_name VARCHAR2(128) not null,
  column_id   NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

