create table RRP_MDL.O_IOL_WIND_CBONDDESCRIPTION
(
  object_id                VARCHAR2(150),
  s_info_windcode          VARCHAR2(60),
  b_info_fullname          VARCHAR2(750),
  b_info_issuer            VARCHAR2(150),
  b_issue_announcement     VARCHAR2(12),
  b_issue_firstissue       VARCHAR2(12),
  b_issue_lastissue        VARCHAR2(12),
  b_issue_amountplan       NUMBER(24,8),
  b_issue_amountact        NUMBER(24,8),
  b_info_issueprice        NUMBER(20,4),
  b_info_par               NUMBER(20),
  b_info_couponrate        NUMBER(20,4),
  b_info_spread            NUMBER(20,4),
  b_info_carrydate         VARCHAR2(12),
  b_info_enddate           VARCHAR2(12),
  b_info_maturitydate      VARCHAR2(12),
  b_info_term_year_        NUMBER(20,4),
  b_info_term_day_         NUMBER(20,4),
  b_info_paymentdate       VARCHAR2(12),
  b_info_paymenttype       NUMBER(9),
  b_info_interestfrequency VARCHAR2(30),
  b_info_form              VARCHAR2(15),
  b_info_coupon            NUMBER(9),
  b_info_interesttype      NUMBER(9),
  b_info_act               NUMBER(20,4),
  b_issue_fee              NUMBER(20,4),
  b_redemption_feeration   NUMBER(20,4),
  b_info_taxrate           NUMBER(20,4),
  crncy_code               VARCHAR2(15),
  s_info_name              VARCHAR2(150),
  s_info_exchmarket        VARCHAR2(15),
  b_info_guarantor         VARCHAR2(150),
  b_info_guartype          NUMBER(9),
  b_info_listdate          VARCHAR2(12),
  b_info_yearsnumber       NUMBER(20),
  s_div_recorddate         VARCHAR2(12),
  b_info_codebyplacing     VARCHAR2(15),
  b_info_delistdate        VARCHAR2(12),
  b_info_issuetype         NUMBER(9),
  b_info_guarintroduction  VARCHAR2(1500),
  b_info_bgndbyplacing     VARCHAR2(12),
  b_info_enddbyplacing     VARCHAR2(12),
  b_info_amountbyplacing   NUMBER(20,4),
  b_info_underwritingcode  NUMBER(9),
  b_info_issuercode        VARCHAR2(150),
  b_info_formercode        VARCHAR2(60),
  b_info_coupontxt         VARCHAR2(3000),
  is_failure               NUMBER(5),
  is_crossmarket           NUMBER(5),
  b_info_coupondatetxt     VARCHAR2(3000),
  b_info_subordinateornot  NUMBER(5),
  b_tendrst_referyield     NUMBER(20,4),
  b_info_curpar            NUMBER(20,4),
  s_info_formerwindcode    VARCHAR2(60),
  is_corporate_bond        NUMBER(5),
  b_info_issuertype        VARCHAR2(150),
  b_info_specialbondtype   VARCHAR2(60),
  is_payadvanced           VARCHAR2(2),
  is_callable              VARCHAR2(2),
  is_chooseright           VARCHAR2(2),
  is_netprice              NUMBER(1),
  is_act_days              NUMBER(1),
  is_incbonds              NUMBER(5),
  issue_object             VARCHAR2(150),
  b_info_actualbenchmark   VARCHAR2(12),
  register_file_type_code  NUMBER(9),
  register_file_number     VARCHAR2(1500),
  list_ann_date            VARCHAR2(12),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
