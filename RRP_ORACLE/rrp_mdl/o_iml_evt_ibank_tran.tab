create table RRP_MDL.O_IML_EVT_IBANK_TRAN
(
  etl_dt                      DATE,
  evt_id                      VARCHAR2(60),
  lp_id                       VARCHAR2(60),
  tran_num                    VARCHAR2(90),
  entr_dt                     DATE,
  entr_tm                     VARCHAR2(15),
  cfm_dt                      DATE,
  cfm_tm                      VARCHAR2(15),
  intnal_tran_num             VARCHAR2(90),
  ext_tran_num                VARCHAR2(90),
  operr_name                  VARCHAR2(150),
  tran_type_id                VARCHAR2(60),
  ext_cap_acct_id             VARCHAR2(60),
  intnal_cap_acct_id          VARCHAR2(60),
  ext_secu_acct_id            VARCHAR2(60),
  intnal_secu_acct_id         VARCHAR2(60),
  cntpty_id                   VARCHAR2(60),
  pric_intnal_cap_acct_id     VARCHAR2(60),
  fin_instm_id                VARCHAR2(60),
  asset_type_id               VARCHAR2(60),
  tran_market_id              VARCHAR2(60),
  fin_instm_name              VARCHAR2(375),
  tran_qtty                   NUMBER(38,8),
  tran_price                  NUMBER(38,8),
  tran_amt                    NUMBER(38,8),
  tran_fee                    NUMBER(38,8),
  stl_dt                      DATE,
  tran_status_cd              VARCHAR2(10),
  stl_way_cd                  VARCHAR2(30),
  net_price_amt               NUMBER(30,8),
  int_recvbl                  NUMBER(30,8),
  quote_tran_num              VARCHAR2(90),
  ignore_flg                  VARCHAR2(10),
  tran_exec_market_id         VARCHAR2(60),
  agent_name                  VARCHAR2(150),
  cntpty_name                 VARCHAR2(300),
  evltion_net_price_brkb      NUMBER(18,6),
  tran_src_cd                 VARCHAR2(10),
  deal_qtty                   NUMBER(38,8),
  actl_recv_int               NUMBER(38,8),
  actl_recv_amt               NUMBER(38,8),
  dealer_name                 VARCHAR2(150),
  cntpty_zzd_acct_id          VARCHAR2(100),
  cntpty_open_bank_num        VARCHAR2(90),
  cntpty_acct_num             VARCHAR2(300),
  cntpty_open_bank_name       VARCHAR2(750),
  cntpty_acct_name            VARCHAR2(750),
  cbond_yld_rat               NUMBER(18,8),
  exp_yld_rat                 NUMBER(38,8),
  recvbl_uncol_int            NUMBER(38,8),
  operr_id                    VARCHAR2(60),
  checker_id                  VARCHAR2(60),
  recvbl_uncol_pric           NUMBER(38,8),
  actl_int                    NUMBER(38,8),
  actl_pric                   NUMBER(38,8),
  ref_type_cd                 VARCHAR2(10),
  recvbl_uncol_int_resv_flg   VARCHAR2(10),
  recvbl_uncol_pric_resv_flg  VARCHAR2(10),
  dealer_id                   VARCHAR2(60),
  tran_mode_cd                VARCHAR2(10),
  clear_mode_cd               VARCHAR2(10),
  apv_odd_no                  VARCHAR2(90),
  stl_status_cd               VARCHAR2(10),
  accti_tran_num              VARCHAR2(90),
  ftp_int_rat                 NUMBER(18,8),
  assoced_apv_odd_no          VARCHAR2(90),
  bi_valid_cont_id            VARCHAR2(100),
  data_src_cd                 VARCHAR2(10),
  nv_dt                       DATE,
  cntpty_swift_cd             VARCHAR2(60),
  splt_type_cd                VARCHAR2(10),
  parent_tran_num             VARCHAR2(90),
  main_tran_num               VARCHAR2(90),
  merge_tran_num              VARCHAR2(90),
  miro_tran_num               VARCHAR2(90),
  rela_tran_num               VARCHAR2(90),
  ex_yld_rat                  NUMBER(18,8),
  cust_mgr_name               VARCHAR2(300),
  cust_mgr_id                 VARCHAR2(60),
  camp_org_id                 VARCHAR2(60),
  redem_cfm_dt                DATE,
  tran_way_cd                 VARCHAR2(30),
  dlvy_dt                     DATE,
  cont_id                     VARCHAR2(90),
  cap_dir_descb               VARCHAR2(1500),
  final_dir_type_cd           VARCHAR2(10),
  rela_ser_num                VARCHAR2(150),
  level5_cls_cd               VARCHAR2(10),
  prod_char_cd                VARCHAR2(10),
  curr_lot                    NUMBER(38,8),
  unpay_turn_lot              NUMBER(38,8),
  input_dt                    DATE,
  dlvy_site_id                VARCHAR2(60),
  not_stl_comm_fee            NUMBER(38,8),
  int_accr_base_cd            VARCHAR2(30),
  contn_int_flg               VARCHAR2(10),
  rela_party_info             VARCHAR2(3000),
  redem_type_cd               VARCHAR2(10),
  std_prod_id                 VARCHAR2(60),
  ftp_id                      VARCHAR2(100),
  is_term                     VARCHAR2(15),
  term_start_day              DATE,
  term_end_day                DATE,
  bank_cap_acct_open_bank_num VARCHAR2(375),
  bank_cap_acct_id            VARCHAR2(250),
  th_ssn_redem_flg            VARCHAR2(10),
  plan_redem_dt               DATE,
  acct_b_cate_cd              VARCHAR2(16)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
