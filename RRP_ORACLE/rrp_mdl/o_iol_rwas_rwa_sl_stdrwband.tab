create table RRP_MDL.O_IOL_RWAS_RWA_SL_STDRWBAND
(
  stdrwbandid        NUMBER(9),
  reportid           NUMBER(9),
  stdrwbanddesc      NVARCHAR2(750),
  stdrwbandfloor     NUMBER(10,8),
  stdrwbandceiling   NUMBER(10,8),
  creationdate       DATE,
  lastupdatedate     DATE,
  stdrwbandgroupid   NUMBER(9),
  stdrwbandgroupdesc NVARCHAR2(750),
  stdrwbandlcldsc    NVARCHAR2(750),
  stdrwband          NUMBER(18,3),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_RWAS_RWA_SL_STDRWBAND
  is '权重等级表';
comment on column RRP_MDL.O_IOL_RWAS_RWA_SL_STDRWBAND.stdrwbandid
