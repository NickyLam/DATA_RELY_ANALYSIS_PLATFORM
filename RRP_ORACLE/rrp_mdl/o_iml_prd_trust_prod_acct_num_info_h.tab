create table RRP_MDL.O_IML_PRD_TRUST_PROD_ACCT_NUM_INFO_H
(
  ta_cd                        VARCHAR2(30),
  lp_id                        VARCHAR2(60),
  prod_id                      VARCHAR2(60),
  cap_veri_acct_open_bank_cd   VARCHAR2(60),
  rgst_rgst_acct_open_bank_cd  VARCHAR2(60),
  make_acct_bank_acct_num      VARCHAR2(90),
  keep_acct_bank_acct_num      VARCHAR2(90),
  coll_cap_vrfction_acct       VARCHAR2(90),
  coll_cap_vrfction_acct_name  VARCHAR2(375),
  trust_corp_prod_id           VARCHAR2(30),
  stl_type_cd                  VARCHAR2(10),
  trust_bank_name              VARCHAR2(150),
  trust_org_name               VARCHAR2(375),
  prod_name                    VARCHAR2(750),
  make_acct_bank_acct_num_name VARCHAR2(375),
  keep_acct_bank_acct_num_name VARCHAR2(375),
  resv_field_1                 VARCHAR2(750),
  resv_field_2                 VARCHAR2(750),
  start_dt                     DATE,
  end_dt                       DATE,
  id_mark                      VARCHAR2(10),
  src_table_name               VARCHAR2(100),
  job_cd                       VARCHAR2(10),
  etl_timestamp                TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
