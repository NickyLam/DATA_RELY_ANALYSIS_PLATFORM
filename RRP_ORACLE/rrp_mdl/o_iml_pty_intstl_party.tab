create table RRP_MDL.O_IML_PTY_INTSTL_PARTY
(
  party_id                 VARCHAR2(60),
  lp_id                    VARCHAR2(60),
  cust_id                  VARCHAR2(60),
  cust_name                VARCHAR2(375),
  cn_name                  VARCHAR2(375),
  intstl_cust_type_cd_comb VARCHAR2(30),
  hq_party_id              VARCHAR2(60),
  nation_crdt_level_cd     VARCHAR2(30),
  risk_level_cd            VARCHAR2(30),
  risk_cty_cd              VARCHAR2(30),
  trans_lang_cd            VARCHAR2(30),
  edit_id                  VARCHAR2(60),
  serv_level_cd            VARCHAR2(30),
  enty_group_id            VARCHAR2(60),
  orgnz_cd                 VARCHAR2(30),
  cert_type_cd             VARCHAR2(30),
  cert_no                  VARCHAR2(60),
  resdnt_type_cd           VARCHAR2(30),
  belong_org_id            VARCHAR2(60),
  tran_main_cd             VARCHAR2(30),
  src_party_id             VARCHAR2(60),
  cbec_flg                 VARCHAR2(10),
  create_dt                DATE,
  update_dt                DATE,
  etl_dt                   DATE,
  id_mark                  VARCHAR2(10),
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_INTSTL_PARTY
  is '国结当事人';
comment on column RRP_MDL.O_IML_PTY_INTSTL_PARTY.party_id
  is '当事人编号';
comment on column RRP_MDL.O_IML_PTY_INTSTL_PARTY.lp_id
