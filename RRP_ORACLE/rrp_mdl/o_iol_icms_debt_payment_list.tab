create table RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST
(
  serialno           VARCHAR2(64),
  relativeserialno   VARCHAR2(64),
  customerid         VARCHAR2(16),
  customername       VARCHAR2(200),
  debtrepayassetid   VARCHAR2(64),
  debtrepayassetname VARCHAR2(200),
  debtrepaysum       NUMBER(24,6),
  debtoffsetamount   NUMBER(24,6),
  receivedate        DATE,
  debtrepayassettype VARCHAR2(48),
  debtrepaymenttype  VARCHAR2(48),
  status             VARCHAR2(10),
  amount             NUMBER(38),
  stockcode          VARCHAR2(100),
  propertylocation   VARCHAR2(200),
  remark             VARCHAR2(3000),
  inputuserid        VARCHAR2(64),
  inputorgid         VARCHAR2(64),
  inputdate          DATE,
  operateuserid      VARCHAR2(64),
  operateorgid       VARCHAR2(64),
  operatedate        DATE,
  updateuserid       VARCHAR2(64),
  updateorgid        VARCHAR2(64),
  updatedate         DATE,
  putoutorgid        VARCHAR2(20),
  originaltaxfees    NUMBER(24,6),
  lastevaltime       DATE,
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST
  is '抵债资产信息表';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.serialno
  is '流水号';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.relativeserialno
  is '关联流水号';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.customerid
  is '客户编号';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.customername
  is '客户名称';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.debtrepayassetid
  is '抵债资产编号';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.debtrepayassetname
  is '抵债资产名称';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.debtrepaysum
  is '抵扣债权金额';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.debtoffsetamount
  is '抵债金额';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.receivedate
  is '抵债日期';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.debtrepayassettype
  is '抵债资产类型(code:DebtRepaymentType)';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.debtrepaymenttype
  is '抵债类型(code:DebtRepayAssetType)';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.status
  is '处理状态(code:CollectResult)';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.amount
  is '数量';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.stockcode
  is '股票代码/权证号';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.propertylocation
  is '房产位置';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.remark
  is '备注';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.inputuserid
  is '登记人';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.inputorgid
  is '登记机构';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.inputdate
  is '登记日期';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.operateuserid
  is '经办客户经理';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.operateorgid
  is '经办客户经理所属机构';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.operatedate
  is '经办时间';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.updateuserid
