comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.updateorgid
  is '更新机构';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.updatedate
  is '更新日期';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.putoutorgid
  is '账务机构';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.originaltaxfees
  is '原相关税费';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.lastevaltime
  is '估值日期';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_ICMS_DEBT_PAYMENT_LIST.end_dt
