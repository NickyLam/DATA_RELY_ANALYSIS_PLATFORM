create table RRP_MDL.O_IOL_RWAS_RPT_BOND_INVEST
(
  data_date                   DATE,
  loan_ref_no                 VARCHAR2(150),
  loan_ref_desc               VARCHAR2(600),
  contract_no                 VARCHAR2(150),
  src_system_id               VARCHAR2(30),
  accorg_no                   VARCHAR2(30),
  accorg_name                 VARCHAR2(383),
  five_class_cd               VARCHAR2(30),
  five_class_name             VARCHAR2(30),
  product_cd                  VARCHAR2(60),
  product_name                VARCHAR2(600),
  bis_product_type_cd         VARCHAR2(120),
  bis_product_type_name       VARCHAR2(300),
  bis_product_btype_cd        VARCHAR2(60),
  bis_product_btype_name      VARCHAR2(300),
  buss_type_cd                VARCHAR2(75),
  buss_type_name              VARCHAR2(300),
  start_date                  DATE,
  due_date                    DATE,
  orig_maturity               NUMBER(18,2),
  overdue_days                NUMBER(22),
  std_default_flag            VARCHAR2(15),
  book_type_id                VARCHAR2(15),
  book_type_name              VARCHAR2(30),
  on_off_id                   VARCHAR2(15),
  bis_ccy_cd                  VARCHAR2(15),
  bis_ccy_name                VARCHAR2(96),
  exchange_rate               NUMBER(18,8),
  subject_cd                  VARCHAR2(24),
  subject_name                VARCHAR2(300),
  pric_bal_origcurr           NUMBER(18,2),
  pric_bal                    NUMBER(18,2),
  asset_balance               NUMBER(18,2),
  accrued_subject_cd          VARCHAR2(24),
  accrued_subject_name        VARCHAR2(300),
