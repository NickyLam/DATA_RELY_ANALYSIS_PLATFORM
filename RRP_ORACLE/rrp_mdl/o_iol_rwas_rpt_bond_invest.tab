  receivable_subject_cd       VARCHAR2(24),
  receivable_subject_name     VARCHAR2(300),
  receivable_int              NUMBER(18,2),
  accrued_receiv_subject_cd   VARCHAR2(24),
  accrued_receiv_subject_name VARCHAR2(300),
  accrued_receiv_int          NUMBER(18,2),
  intadj_subject_cd           VARCHAR2(24),
  intadj_subject_name         VARCHAR2(300),
  int_adj                     NUMBER(18,2),
  fairchange_subject_cd       VARCHAR2(24),
  fairchange_subject_name     VARCHAR2(300),
  fairvalue_changes           NUMBER(18,2),
  depreamor_subject_cd        VARCHAR2(24),
  depreamor_subject_name      VARCHAR2(300),
  depre_amortizat             NUMBER(18,2),
  other_subject_cd            VARCHAR2(24),
  other_subject_name          VARCHAR2(300),
  other_amt                   NUMBER(18,2),
  provision_subject_cd        VARCHAR2(24),
  provision_subject_name      VARCHAR2(300),
  provision                   NUMBER(18,2),
  provesion_ratio             NUMBER(18,6),
  account_classification      VARCHAR2(15),
  cust_no                     VARCHAR2(150),
  cust_name                   VARCHAR2(384),
  ccp_type_cd                 VARCHAR2(60),
  ccp_type_name               VARCHAR2(300),
  ccp_btype_cd                VARCHAR2(60),
  ccp_btype_name              VARCHAR2(150),
  spe_lending_flag            VARCHAR2(15),
  spe_lending_type            VARCHAR2(150),
  bis_country_name            VARCHAR2(300),
  sov_sp_lt_rating_cd         VARCHAR2(30),
  cust_sp_lt_rating_cd        VARCHAR2(30),
  scra_rating                 VARCHAR2(15),
  int_trade_flag              VARCHAR2(3),
  solo_int_trade_flag         VARCHAR2(3),
  investment_cust_flag        VARCHAR2(15),
  ccy_mismatch_flag           VARCHAR2(3),
  accept_credit_self_flag     VARCHAR2(3),
  real_estate_type_cd         VARCHAR2(300),
  ltv                         NUMBER(18,6),
  accept_discount_self_flag   VARCHAR2(3),
  operation_pf_flag           VARCHAR2(3),
  cancel_flag                 VARCHAR2(3),
  off_asset_unmeasured_flag   VARCHAR2(3),
  unused_prl_tmeet_flag       VARCHAR2(3),
  ead_orig                    NUMBER(18,2),
  ccf                         NUMBER(18,6),
  ead_afterccf                NUMBER(18,2),
  ead_afterpro                NUMBER(18,2),
  rw                          NUMBER(18,6),
  crm_ccy_mis_flag            VARCHAR2(15),
  crm_amt_rmb                 NUMBER(18,2),
  crm_amt_split               NUMBER(18,2),
  crm_ccy_mis_coeff           NUMBER(18,6),
  crm_mat_mis_coeff           NUMBER(18,6),
  crm_floor_mis_coeff         NUMBER(18,6),
  crm_weighting_rw            NUMBER(18,6),
  rwa_ucovered                NUMBER(18,6),
  rwa_covered                 NUMBER(18,6),
  rwa                         NUMBER(18,2),
  c_item_e                    NUMBER(18,6),
  c_item_f                    NUMBER(18,6),
  c_item_g                    NUMBER(18,6),
  c_item_h                    NUMBER(18,6),
  c_item_i                    NUMBER(18,6),
  c_item_j                    NUMBER(18,6),
  c_item_k                    NUMBER(18,6),
  c_item_l                    NUMBER(18,6),
  c_item_m                    NUMBER(18,6),
  c_item_n                    NUMBER(18,6),
  c_item_o                    NUMBER(18,6),
  c_item_p                    NUMBER(18,6),
  c_item_q                    NUMBER(18,6),
  c_item_r                    NUMBER(18,6),
  c_item_s                    NUMBER(18,6),
  c_item_t                    NUMBER(18,6),
  c_item_u                    NUMBER(18,6),
  c_item_v                    NUMBER(18,6),
  c_item_w                    NUMBER(18,6),
  c_item_x                    NUMBER(18,6),
  c_item_y                    NUMBER(18,6),
  c_item_z                    NUMBER(18,6),
  report_no                   VARCHAR2(30),
  report_line_no              VARCHAR2(60),
  report_line_name            VARCHAR2(300),
  investment_vaild_flag       VARCHAR2(15),
  recognition_date            DATE,
  sec_no                      VARCHAR2(90),
  sec_name                    VARCHAR2(150),
  load_date                   VARCHAR2(30),
  final_weight                VARCHAR2(15),
  nvestment_rema_maturity     NUMBER(18),
  etl_dt                      DATE,
  etl_timestamp               TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
