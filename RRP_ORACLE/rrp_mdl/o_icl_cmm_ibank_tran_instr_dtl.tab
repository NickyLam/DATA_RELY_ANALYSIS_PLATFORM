create table RRP_MDL.O_ICL_CMM_IBANK_TRAN_INSTR_DTL
(
  etl_dt                      DATE,
  lp_id                       VARCHAR2(60),
  instr_seq_num               NUMBER(22),
  parent_instr_seq_num        NUMBER(22),
  ext_instr_seq_num           VARCHAR2(90),
  rela_cap_instr_seq_num      NUMBER(22),
  rela_vch_instr_seq_num      NUMBER(22),
  rela_main_instr_seq_num     NUMBER(22),
  actl_accti_main_seq_num     NUMBER(22),
  adj_entry_main_seq_num      NUMBER(22),
  intnal_tran_flow_num        VARCHAR2(60),
  obj_id                      VARCHAR2(60),
  instr_bus_type_cd           VARCHAR2(30),
  ext_secu_acct_id            VARCHAR2(60),
  intnal_secu_acct_id         VARCHAR2(60),
  intnal_cap_acct_id          VARCHAR2(60),
  parent_instm_market_type_id VARCHAR2(60),
  parent_instm_asset_type_id  VARCHAR2(60),
  parent_fin_instm_id         VARCHAR2(60),
  instr_type_cd               VARCHAR2(10),
  instr_status_cd             NUMBER(22),
  acpt_pay_instr_cd           VARCHAR2(10),
  tran_bus_type_cd            VARCHAR2(10),
  stl_way_cd                  VARCHAR2(20),
  stl_type_cd                 VARCHAR2(10),
  apv_status_cd               VARCHAR2(10),
  actl_rp_flg                 VARCHAR2(10),
  clear_flow_flg              VARCHAR2(10),
  surviv_term_flg             VARCHAR2(10),
  cntpty_id                   VARCHAR2(60),
  cntpty_name                 VARCHAR2(375),
  exec_market_id              VARCHAR2(60),
  memo_info                   VARCHAR2(750),
  theory_clear_dt             DATE,
  theory_stl_dt               DATE,
  actl_stl_dt                 DATE,
  tran_dt                     DATE,
  cfm_dt                      DATE,
  repay_dt                    DATE,
  final_mender_id             VARCHAR2(60),
  final_mender_name           VARCHAR2(150),
  checker_id                  VARCHAR2(60),
  operr_id                    VARCHAR2(60),
  operr_name                  VARCHAR2(150),
  curr_cd                     VARCHAR2(10),
  acru_int                    NUMBER(30,8),
  pric_bal                    NUMBER(30,8),
  recvbl_uncol_int            NUMBER(30,8),
  recvbl_uncol_pric           NUMBER(30,8),
  chg_qtty                    NUMBER(30,8),
  job_cd                      VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
