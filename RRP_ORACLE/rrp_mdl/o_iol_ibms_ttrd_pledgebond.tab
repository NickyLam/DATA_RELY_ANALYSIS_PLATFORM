create table RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND
(
  i_code           VARCHAR2(45),
  a_type           VARCHAR2(30),
  m_type           VARCHAR2(30),
  p_i_code         VARCHAR2(45),
  p_m_type         VARCHAR2(30),
  p_a_type         VARCHAR2(30),
  amount           NUMBER(20,3),
  discount         NUMBER(31,4),
  disamount        NUMBER(31,4),
  partytype        VARCHAR2(2),
  resertype        VARCHAR2(2),
  evalfullprice    NUMBER(10,4),
  volume           NUMBER(38,4),
  secu_acct_id     VARCHAR2(45),
  ext_secu_acct_id VARCHAR2(45),
  trade_grp_id     VARCHAR2(45),
  sort             NUMBER(22),
  si_id            NUMBER(16),
  sysordid         NUMBER(16),
  demo             VARCHAR2(1500),
  trd_alt_mark     VARCHAR2(3),
  etl_dt           DATE,
  etl_timestamp    TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND
  is '外币存款账户子表';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.i_code
  is '金融工具代码 关联交易表ttrd_otc_trade intordid字段 或关联审批表ttrd_otc_order  intordid字段';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.a_type
  is '资产类型';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.m_type
  is '市场类型 xshg: 上交所 xshe:深交所 x_cnffex;中金所 x_cnbd;银行间';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.p_i_code
  is '质押券金融工具';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.p_m_type
  is 'xshg: 上交所 xshe:深交所 x_cnffex;中金所 x_cnbd;银行间';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.p_a_type
  is '资产类型';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.amount
  is '质押券面额';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.discount
  is '折价率';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.disamount
  is '折价金额';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.partytype
  is '1-本方 ; 0-对手方';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.resertype
  is '1-质押券 ; 0-保证券';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.evalfullprice
  is '中债估值（全价）';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.volume
  is '余额数量变动';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.secu_acct_id
  is '内部证券账户id';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.ext_secu_acct_id
  is '外部证券账户id';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.trade_grp_id
  is '核算交易组合';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.sort
  is '排序序号';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.si_id
  is '预审批剩余券面总额';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.sysordid
  is '交易序号';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.demo
  is '备注';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.trd_alt_mark
  is '新旧交替标识 默认为0，新券1老券-1';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.etl_dt
  is 'etl处理日期';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_PLEDGEBOND.etl_timestamp
  is 'etl处理时间戳';

