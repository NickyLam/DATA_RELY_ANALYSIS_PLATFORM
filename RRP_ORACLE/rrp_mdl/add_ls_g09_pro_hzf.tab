create table RRP_MDL.ADD_LS_G09_PRO_HZF
(
  hzfs      VARCHAR2(30),
  cpmc      VARCHAR2(100),
  ywpzbh    VARCHAR2(60) not null,
  ywpzmc    VARCHAR2(100),
  ywlx      VARCHAR2(30),
  ywxt      VARCHAR2(100),
  hzjgmc    VARCHAR2(200),
  shxydm    VARCHAR2(60),
  hzjglb    VARCHAR2(30),
  tgfwlx    VARCHAR2(10),
  bhczbl    NUMBER(20,4),
  hzfczbl   NUMBER(20,4),
  sfzcjy    VARCHAR2(9),
  hzxz      VARCHAR2(60),
  dsfhzjgmc VARCHAR2(200),
  dsfshxydm VARCHAR2(60),
  dsfhzjglb VARCHAR2(30),
  dsftgfwlx VARCHAR2(10),
  dsfhzxz   VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.ADD_LS_G09_PRO_HZF
  is 'G09互联网贷款产品信息静态表';
