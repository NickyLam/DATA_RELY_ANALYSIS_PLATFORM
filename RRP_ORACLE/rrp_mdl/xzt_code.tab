create table RRP_MDL.XZT_CODE
(
  tar_class_code VARCHAR2(200),
  tar_class_name VARCHAR2(200),
  tar_value_code VARCHAR2(200),
  tar_value_name VARCHAR2(500),
  mod_flg        VARCHAR2(20),
  cn             NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

