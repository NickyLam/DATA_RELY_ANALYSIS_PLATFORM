create table RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY
(
  party_id       VARCHAR2(60),
  lp_id          VARCHAR2(60),
  cntpty_id      VARCHAR2(60),
  dept_id        VARCHAR2(60),
  cn_name        VARCHAR2(750),
  en_name        VARCHAR2(750),
  cn_abbr        VARCHAR2(750),
  en_abbr        VARCHAR2(750),
  fx_id          VARCHAR2(60),
  cust_id        VARCHAR2(100),
  create_dt      DATE,
  update_dt      DATE,
  etl_dt         DATE,
  id_mark        VARCHAR2(10),
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY
  is '外汇资金交易对手';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.party_id
  is '当事人编号';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.cntpty_id
  is '交易对手编号';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.dept_id
  is '部门编号';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.cn_name
  is '中文名称';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.en_name
  is '英文名称';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.cn_abbr
  is '中文简称';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.en_abbr
  is '英文简称';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.fx_id
  is '外汇编号';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.cust_id
  is '客户编号';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.create_dt
  is '创建日期';
comment on column RRP_MDL.O_IML_PTY_FX_CAP_CNTPTY.update_dt
