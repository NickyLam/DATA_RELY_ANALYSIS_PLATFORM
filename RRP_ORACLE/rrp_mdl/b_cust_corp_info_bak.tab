  opr_stat                  VARCHAR2(10),
  opr_stat_end_dt           CHAR(8),
  cust_stat                 VARCHAR2(10),
  dept_line                 VARCHAR2(500),
  data_src                  VARCHAR2(500),
  tech_ent_idtfy_dt         CHAR(8)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.B_CUST_CORP_INFO_BAK.data_dt
