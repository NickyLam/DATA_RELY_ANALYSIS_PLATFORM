  ent_scale                 VARCHAR2(10),
  ent_hldg_typ              VARCHAR2(10),
  rsdnt_flg                 CHAR(1),
  regd_land_ctry_cd         VARCHAR2(10),
  regd_land_area_cd         VARCHAR2(10),
  regd_addr                 VARCHAR2(500),
