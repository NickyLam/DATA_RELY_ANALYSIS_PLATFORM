  upd_wrk_addr_dt           CHAR(8),
  cust_blng_idy             VARCHAR2(10),
  grn_loan_idy_cl           VARCHAR2(10),
  mjr_env_safe_rsk_ent_cl   VARCHAR2(10),
  open_ebank_flg            CHAR(1),
  ent_close_flg             CHAR(1),
  ent_gua_sml_micro_ent_flg CHAR(1),
  fit_sml_micro_ent_flg     CHAR(1),
  cn_cptl_flg               CHAR(1),
  vil_city_flg              CHAR(1),
  family_farm_flg           CHAR(1),
  ent_grow_up_stage         VARCHAR2(10),
  spv_sub_cl                VARCHAR2(10),
  microfin_co_flg           CHAR(1),
  tech_mid_sml_ent_flg      CHAR(1),
  high_tech_ent_flg         CHAR(1),
  tech_ent_flg              CHAR(1),
  tech_inno_ent_flg         CHAR(1),
  ipo_co_flg                CHAR(1),
  big_rsk_exp_cust_flg      CHAR(1),
  rel_pty_flg               CHAR(1),
  grp_mbr_cust_flg          CHAR(1),
  opr_scope                 VARCHAR2(2000),
  estb_dt                   CHAR(8),
  tel                       VARCHAR2(30),
  regd_cptl                 NUMBER(30,2),
  regd_cptl_cur             CHAR(3),
  paid_in_cptl              NUMBER(30,2),
  paid_in_cptl_cur          CHAR(3),
  bsc_dep_acc               VARCHAR2(200),
  bsc_acc_open_bank_nm      VARCHAR2(500),
  bsc_acc_open_bank_id      VARCHAR2(200),
  emp_num                   INTEGER,
  rsk_warn_sgnl             VARCHAR2(200),
  foc_evt                   VARCHAR2(500),
  pd                        NUMBER(18,4),
  inr_rtg                   VARCHAR2(10),
  ext_rtg                   VARCHAR2(10),
  cust_cr_rtg_tot_grd       INTEGER,
  cust_crdt_rtg             INTEGER,
  first_estbl_crdt_rel_dt   CHAR(8),
