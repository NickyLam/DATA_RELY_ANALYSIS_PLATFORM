create table RRP_MDL.B_LOAN_TRF_SUB
(
  data_dt                    CHAR(8) not null,
  lgl_rep_id                 VARCHAR2(200),
  rcpt_id                    VARCHAR2(200) not null,
  cont_id                    VARCHAR2(200),
  cntpr_cust_id              VARCHAR2(200),
  loan_trf_orig_val          NUMBER(30,2),
  loan_trf_agrt_amt          NUMBER(30,2),
  cntpr_sm_lgl_rep_flg       CHAR(1),
  trf_loan_orig_rcpt_dsbr_dt CHAR(8),
  dept_line                  VARCHAR2(500),
  data_src                   VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_LOAN_TRF_SUB
  is '贷款借据转入子表';
comment on column RRP_MDL.B_LOAN_TRF_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_TRF_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_LOAN_TRF_SUB.rcpt_id
  is '借据编号';
comment on column RRP_MDL.B_LOAN_TRF_SUB.cont_id
  is '合同编号';
comment on column RRP_MDL.B_LOAN_TRF_SUB.cntpr_cust_id
  is '交易对手客户编号';
comment on column RRP_MDL.B_LOAN_TRF_SUB.loan_trf_orig_val
  is '贷款转让原值';
comment on column RRP_MDL.B_LOAN_TRF_SUB.loan_trf_agrt_amt
  is '贷款转让协议金额';
comment on column RRP_MDL.B_LOAN_TRF_SUB.cntpr_sm_lgl_rep_flg
  is '交易对手同一法人标志';
comment on column RRP_MDL.B_LOAN_TRF_SUB.trf_loan_orig_rcpt_dsbr_dt
  is '转贷款原始借据放款日期';
comment on column RRP_MDL.B_LOAN_TRF_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.B_LOAN_TRF_SUB.data_src
  is '数据来源';
alter table RRP_MDL.B_LOAN_TRF_SUB
  add constraint PK_B_LOAN_TRF_SUB primary key (DATA_DT, RCPT_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

