create table RRP_MDL.B_OTH_FTP_CHG_INFO
(
  data_dt     CHAR(8) not null,
  lgl_rep_id  VARCHAR2(200),
  org_id      VARCHAR2(200) not null,
  ftp_biz_typ VARCHAR2(10) not null,
  term_typ    VARCHAR2(10),
  chg_dt      CHAR(8),
  ftp_prc     NUMBER(30,2),
  dept_line   VARCHAR2(500),
  data_src    VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_OTH_FTP_CHG_INFO
  is 'FTP定价变动明细信息表';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.org_id
  is '机构编号';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.ftp_biz_typ
  is 'FTP业务类型';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.term_typ
  is '期限类型';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.chg_dt
  is '变动日期';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.ftp_prc
  is 'FTP价格';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.dept_line
  is '部门条线';
comment on column RRP_MDL.B_OTH_FTP_CHG_INFO.data_src
  is '数据来源';
alter table RRP_MDL.B_OTH_FTP_CHG_INFO
  add constraint PK_B_OTH_FTP_CHG_INFO primary key (DATA_DT, ORG_ID, FTP_BIZ_TYP)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

