  is '决策单意见';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.aprv_psn_no
  is '审批人工号';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.crdt_emp_no
