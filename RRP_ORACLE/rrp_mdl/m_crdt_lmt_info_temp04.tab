comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.apv_flow_num
  is '批复金额';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.lmt_under_sellbl_prod_id
  is '可售产品';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.apv_amt
