comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.status_cd
  is '状态代码';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.crdt_apved_dt
  is '授信审批日期';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.cust_id_zt_flg
