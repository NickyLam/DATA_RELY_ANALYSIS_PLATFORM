comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.crdt_start_dt
  is '授信开始日期';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.crdt_exp_dt
  is '授信到期日期';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.crdt_biz_typ
  is '授信业务类型';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.cir_lmt_flg
  is '循环额度标志';
comment on column RRP_MDL.M_CRDT_LMT_INFO_TEMP04.temp_lmt_flg
