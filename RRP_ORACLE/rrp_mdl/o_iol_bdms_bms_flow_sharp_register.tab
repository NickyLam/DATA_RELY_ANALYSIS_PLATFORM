create table RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER
(
  id                  VARCHAR2(60),
  flow_sharp_id       VARCHAR2(60),
  cur_node_id         VARCHAR2(60),
  cur_app_route_flag  VARCHAR2(2),
  next_node_id        VARCHAR2(60),
  next_app_route_flag VARCHAR2(2),
  product_no          VARCHAR2(12),
  protocol_no         VARCHAR2(60),
  contract_id         VARCHAR2(60),
  table_type          VARCHAR2(3),
  status              VARCHAR2(2),
  last_operator_no    VARCHAR2(45),
  last_txn_date       TIMESTAMP(6),
  etl_dt              DATE,
  etl_timestamp       TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER
  is '流程节点登记表';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.id
  is '主键';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.flow_sharp_id
  is '流程id';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.cur_node_id
  is '当前节点id';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.cur_app_route_flag
  is '当前是否含审批路线';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.next_node_id
  is '下一节点id';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.next_app_route_flag
  is '当前是否含审批路线';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.product_no
  is '产品类型编码';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.protocol_no
  is '协议号';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.contract_id
  is '协议id';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.table_type
  is '表类型';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.status
  is '流程状态';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.last_operator_no
  is '最后操作员编号';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.last_txn_date
  is '最后操作日期';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IOL_BDMS_BMS_FLOW_SHARP_REGISTER.etl_timestamp
  is 'ETL处理时间戳';

