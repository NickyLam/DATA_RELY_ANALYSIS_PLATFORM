create table RRP_MDL.O_IOL_ICMS_LOAN_REBUILD_FLOW_TAB
(
  serialno        VARCHAR2(64),
  duebillserialno VARCHAR2(64),
  dealtyp         VARCHAR2(20),
  operasc         VARCHAR2(20),
  loanrebuildtype VARCHAR2(20),
  balance         NUMBER(24,6),
  classifyresult  VARCHAR2(10),
  dealdate        VARCHAR2(20),
  inputuserid     VARCHAR2(20),
  inputorgid      VARCHAR2(20),
  bizdate         VARCHAR2(20),
  etl_dt          DATE,
  etl_timestamp   TIMESTAMP(6)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 0
    initrans 1
    maxtrans 255,
  partition PARTITION_20240117 values less than (TO_DATE(' 2024-01-18 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
    storage
