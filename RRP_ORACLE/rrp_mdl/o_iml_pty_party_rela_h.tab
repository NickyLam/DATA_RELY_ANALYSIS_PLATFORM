create table RRP_MDL.O_IML_PTY_PARTY_RELA_H
(
  party_id           VARCHAR2(60),
  lp_id              VARCHAR2(60),
  party_rela_type_cd VARCHAR2(10),
  seq_num            VARCHAR2(60),
  rela_party_id      VARCHAR2(60),
  valid_flg          VARCHAR2(10),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_PARTY_RELA_H
  is '当事人关系历史';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.party_id
  is '当事人编号';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.party_rela_type_cd
  is '当事人关系类型代码';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.seq_num
  is '序号';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.rela_party_id
  is '关联当事人编号';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.valid_flg
  is '有效标志';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_PTY_PARTY_RELA_H.job_cd
  is '任务编码';

