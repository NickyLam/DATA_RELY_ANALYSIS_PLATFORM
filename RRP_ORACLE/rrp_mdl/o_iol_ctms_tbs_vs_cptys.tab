create table RRP_MDL.O_IOL_CTMS_TBS_VS_CPTYS
(
  cptys_id                 NUMBER,
  aspclient_id             NUMBER,
  cptys_shortname          VARCHAR2(384),
  cptys_name               VARCHAR2(384),
  cptys_name2              VARCHAR2(384),
  name_src                 VARCHAR2(30),
  key_src                  VARCHAR2(30),
  islink_src               VARCHAR2(2),
  lastmodified             TIMESTAMP(6),
  datasymbolconfig_id      NUMBER,
  label                    VARCHAR2(96),
  rating_level             NUMBER(2),
  field1                   VARCHAR2(150),
  field2                   VARCHAR2(150),
  field3                   VARCHAR2(150),
  counterparty_ename       VARCHAR2(384),
  counterparty_short_ename VARCHAR2(384),
  contact_name             VARCHAR2(90),
  telephone                VARCHAR2(30),
  fax                      VARCHAR2(30),
  is_issuer                VARCHAR2(2),
  is_bank                  VARCHAR2(2),
  is_guarantee             VARCHAR2(2),
  is_custody               VARCHAR2(2),
  customer_type_code       VARCHAR2(30),
  customer_type_name       VARCHAR2(90),
  parent                   NUMBER,
  ex_code                  VARCHAR2(96),
  ex_account               VARCHAR2(96),
  swift_code               VARCHAR2(96),
  ref_issuer_id            VARCHAR2(60),
  issuer_name              VARCHAR2(96),
  cfets_member_attr        VARCHAR2(384),
  master_short_cname       VARCHAR2(1500),
  master_cfets_id          VARCHAR2(150),
  master_cnty_seq          VARCHAR2(17),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_CTMS_TBS_VS_CPTYS
  is '交易对手视图';
