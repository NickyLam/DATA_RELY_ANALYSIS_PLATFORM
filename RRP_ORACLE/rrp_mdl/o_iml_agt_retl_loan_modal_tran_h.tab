create table RRP_MDL.O_IML_AGT_RETL_LOAN_MODAL_TRAN_H
(
  agt_id                    VARCHAR2(250),
  lp_id                     VARCHAR2(60),
  dtl_id                    VARCHAR2(60),
  dubil_id                  VARCHAR2(60),
  acct_id                   VARCHAR2(60),
  bus_org_id                VARCHAR2(60),
  curr_cd                   VARCHAR2(30),
  init_loan_modal_cd        VARCHAR2(30),
  loan_modal_cd             VARCHAR2(30),
  init_acru_non_acru_flg_cd VARCHAR2(30),
  acru_non_acru_flg_cd      VARCHAR2(30),
  nomal_pric_amt            NUMBER(30,2),
  ovdue_pric_amt            NUMBER(30,2),
  idle_pric_amt             NUMBER(30,2),
  bad_debt_pric_amt         NUMBER(30,2),
  recvbl_acru_int_amt       NUMBER(30,2),
  coll_acru_int_amt         NUMBER(30,2),
  recvbl_over_int_amt       NUMBER(30,2),
  coll_over_int_amt         NUMBER(30,2),
  recvbl_acru_pnlt_amt      NUMBER(30,2),
  coll_acru_pnlt_amt        NUMBER(30,2),
  recvbl_pnlt_amt           NUMBER(30,2),
  coll_pnlt_amt             NUMBER(30,2),
  acru_comp_int_amt         NUMBER(30,2),
  comp_int_amt              NUMBER(30,2),
  tran_dt                   DATE,
  tran_teller_id            VARCHAR2(60),
  tran_flow_num             VARCHAR2(60),
  tran_evt_cd               VARCHAR2(30),
  tran_evt_descb            VARCHAR2(250),
  tran_cd                   VARCHAR2(30),
  rec_status_cd             VARCHAR2(30),
  matn_teller_id            VARCHAR2(60),
  start_dt                  DATE,
  end_dt                    DATE,
  id_mark                   VARCHAR2(10),
  src_table_name            VARCHAR2(100),
  job_cd                    VARCHAR2(10),
  etl_timestamp             TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
comment on table RRP_MDL.O_IML_AGT_RETL_LOAN_MODAL_TRAN_H
