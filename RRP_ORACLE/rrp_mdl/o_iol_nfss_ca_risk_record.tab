create table RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD
(
  id                 VARCHAR2(75),
  customer_no        VARCHAR2(75),
  customer_name      VARCHAR2(150),
  client_type        VARCHAR2(3),
  txn_org_cd         VARCHAR2(30),
  phone              VARCHAR2(30),
  id_type            VARCHAR2(30),
  id_code            VARCHAR2(75),
  paper_id           VARCHAR2(75),
  score              NUMBER(18,2),
  risk_level         VARCHAR2(3),
  risk_time          VARCHAR2(75),
  channel            VARCHAR2(15),
  effective_date     DATE,
  blip_platf_file_id VARCHAR2(750),
  risk_months        VARCHAR2(15),
  etl_dt             DATE,
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD
  is '客户风险评估记录表';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.id
  is '主键ID';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.customer_no
  is '客户编号';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.customer_name
  is '客户名称';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.client_type
  is '客户类型';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.txn_org_cd
  is '客户所属机构';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.phone
  is '联系方式';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.id_type
  is '证件类型';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.id_code
  is '证件号码';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.paper_id
  is '关联问卷主键ID';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.score
  is '总分';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.risk_level
  is '风险等级';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.risk_time
  is '评级时间';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.channel
  is '评估渠道';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.effective_date
  is '有效期';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.blip_platf_file_id
  is '影像平台文件ID';
comment on column RRP_MDL.O_IOL_NFSS_CA_RISK_RECORD.risk_months
