  obj_type_cd                   VARCHAR2(100),
  tran_type_cd                  VARCHAR2(60),
  ths_tm_tran_pric_sum          NUMBER(30,8),
  ths_tm_tran_int_sum           NUMBER(30,8),
  ths_tm_comp_int_sum           NUMBER(30,8),
  ths_tm_pnlt_sum               NUMBER(30,8),
  ths_tm_tran_adv_fee_sum       NUMBER(30,8),
  oper_dt                       DATE,
  oper_belong_org_id            VARCHAR2(100),
  oper_teller_id                VARCHAR2(100),
  rela_flow_num                 VARCHAR2(100),
  ths_return_post_acct_recl_amt NUMBER(30,8),
  ths_return_bf_acct_recv_amt   NUMBER(30,8),
  ths_tm_return_amt             NUMBER(30,8),
  last_acm_return_amt           NUMBER(30,8),
  acm_return_amt                NUMBER(30,8),
  fst_return_amt                NUMBER(30,8),
  rtn_suit_fee_cosdetn          NUMBER(30,8),
  wrt_off_type_cd               VARCHAR2(60),
  acct_recvbl_acct_id           VARCHAR2(250),
  acct_recvbl_acct_name         VARCHAR2(500),
  acct_recvbl_amt               NUMBER(30,8),
  tran_plat_cd                  VARCHAR2(60),
  tran_cont_id                  VARCHAR2(500),
  tran_way_cd                   VARCHAR2(60),
  tran_price                    NUMBER(30,8),
  real_tran_cosdetn             NUMBER(30,8),
  tran_return_acct_id           VARCHAR2(250),
  tran_return_acct_name         VARCHAR2(500),
  inside_acct_open_org_id       VARCHAR2(250),
  rgst_dt                       DATE,
  rgst_belong_org_id            VARCHAR2(100),
  rgst_teller_id                VARCHAR2(100),
  update_teller_id              VARCHAR2(100),
  update_org_id                 VARCHAR2(100),
  remark                        VARCHAR2(4000),
  start_dt                      DATE,
  end_dt                        DATE,
  id_mark                       VARCHAR2(10),
  src_table_name                VARCHAR2(100),
  job_cd                        VARCHAR2(10),
  etl_timestamp                 TIMESTAMP(6),
  debt_asset_id                 VARCHAR2(100),
  debt_asset_name               VARCHAR2(500),
  debt_amt                      NUMBER(30,8),
  recv_dt                       DATE,
  debt_asset_type_cd            VARCHAR2(60),
  debt_type_cd                  VARCHAR2(60),
  disp_way_cd                   VARCHAR2(60),
  disp_amt                      NUMBER(30,8),
  disp_comnt                    VARCHAR2(4000),
  create_mon                    VARCHAR2(500),
  crdt_bal                      NUMBER(30,8),
  loss_amt                      NUMBER(30,8),
  cust_type_cd                  VARCHAR2(30),
  guar_way_cd                   VARCHAR2(30),
  guartor                       VARCHAR2(4000),
  mtg_descb                     VARCHAR2(4000),
  suit_prog                     VARCHAR2(4000),
  liqd_disp_prop                VARCHAR2(4000),
  latest_disp_prog              VARCHAR2(4000),
  next_work_plan                VARCHAR2(4000),
  exist_prob                    VARCHAR2(4000),
  deduct_stl_acct_id            VARCHAR2(250),
  deduct_stl_acct_bal           NUMBER(30,8),
  deduct_amt                    NUMBER(30,8),
  deduct_reason                 VARCHAR2(4000),
  on_acct_id                    VARCHAR2(100),
  trane_cert_type_cd            VARCHAR2(30),
  trane_cert_no                 VARCHAR2(100),
  trane_acct_id                 VARCHAR2(100),
  trane_bank_no                 VARCHAR2(100),
  trane_tran_acct_dt            DATE,
  prop_id                       VARCHAR2(100),
  sign_dt                       DATE,
  effect_dt                     DATE,
  agt_curr_cd                   VARCHAR2(30),
  agt_amt                       NUMBER(30,8),
  margin_amt                    NUMBER(30,8),
  margin_ratio                  NUMBER(30,8),
  margin_curr_cd                VARCHAR2(30),
  court_judge_id                VARCHAR2(250),
  inst_pay_flg                  VARCHAR2(10),
  int_full_amt_derate_flg       VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
