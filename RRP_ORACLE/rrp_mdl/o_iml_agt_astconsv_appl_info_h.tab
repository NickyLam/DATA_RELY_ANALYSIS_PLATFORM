create table RRP_MDL.O_IML_AGT_ASTCONSV_APPL_INFO_H
(
  appl_id                       VARCHAR2(100),
  lp_id                         VARCHAR2(100),
  appl_flow_num                 VARCHAR2(100),
  cust_id                       VARCHAR2(4000),
  cust_name                     VARCHAR2(4000),
