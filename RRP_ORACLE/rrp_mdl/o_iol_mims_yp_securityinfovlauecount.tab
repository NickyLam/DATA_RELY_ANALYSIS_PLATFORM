create table RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT
(
  businessinsid VARCHAR2(48),
  sccode        VARCHAR2(48),
  guartype      VARCHAR2(30),
  confmamt      NUMBER(20,2),
  confmcurrency VARCHAR2(5),
  state         VARCHAR2(3),
  busovetime    VARCHAR2(15),
  createuser    VARCHAR2(30),
  deptcode      VARCHAR2(30),
  etl_dt        DATE,
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT
  is '押品出入库台账流水表';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.businessinsid
  is '流程实例号';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.sccode
  is '押品编号';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.guartype
  is '押品类型';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.confmamt
  is '我行确认价值';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.confmcurrency
  is '我行确认价值币种';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.state
  is '出入库状态';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.busovetime
  is '出入库时间';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.createuser
  is '创建人';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.deptcode
  is '所属机构';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.etl_dt
  is 'etl处理日期';
comment on column RRP_MDL.O_IOL_MIMS_YP_SECURITYINFOVLAUECOUNT.etl_timestamp
  is 'etl处理时间戳';

