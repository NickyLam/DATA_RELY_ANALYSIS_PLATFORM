create table RRP_MDL.TMP_EAST5_401_ZZKJQKMB
(
  nbjgh  VARCHAR2(30),
  kjkmbh VARCHAR2(60),
  bz     VARCHAR2(3),
  jffse  NUMBER(20,2),
  dffse  NUMBER(20,2)
)
tablespace TBS_EAST_DATA
