  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TMP_EAST5_401_ZZKJQKMB.nbjgh
  is '内部机构号';
comment on column RRP_MDL.TMP_EAST5_401_ZZKJQKMB.kjkmbh
  is '会计科目编号';
comment on column RRP_MDL.TMP_EAST5_401_ZZKJQKMB.bz
