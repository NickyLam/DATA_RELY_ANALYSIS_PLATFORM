create table RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO
(
  channeldate                   DATE,
  chan_biz_seq_num              VARCHAR2(64),
  tx_seq_num                    VARCHAR2(33),
  orig_tx_seq_num               VARCHAR2(33),
  orig_core_tran_flow_num       VARCHAR2(33),
  blip_id                       VARCHAR2(255),
  isagent                       VARCHAR2(2),
  agent_person_name             VARCHAR2(200),
  agent_person_cert_type_cd     VARCHAR2(4),
  agent_person_cert_num         VARCHAR2(60),
  agent_person_tel_num          VARCHAR2(30),
  agent_person_nation_cd        VARCHAR2(3),
  agent_gender_cd               VARCHAR2(1),
  agent_career_typeone_code     VARCHAR2(10),
  agent_career_typeone          VARCHAR2(100),
  agent_career_typetwo_code     VARCHAR2(10),
  agent_career_typetwo          VARCHAR2(100),
  agent_career_cd               VARCHAR2(255),
  agent_person_provincecode     VARCHAR2(10),
  agent_person_province         VARCHAR2(100),
  agent_person_citycode         VARCHAR2(10),
  agent_person_city             VARCHAR2(100),
  agent_person_countycode       VARCHAR2(10),
  agent_person_county           VARCHAR2(100),
  agent_person_contact_adr      VARCHAR2(512),
  agent_person_auth_adr         VARCHAR2(512),
  agent_person_start_dt         VARCHAR2(8),
  agent_person_end_dt           VARCHAR2(8),
  agent_type                    VARCHAR2(1),
  agent_person_reason           VARCHAR2(256),
  agent_person_networkchk_serno VARCHAR2(36),
  agent_person_networkchk_ret   VARCHAR2(4),
  agent_person_faceident_res    VARCHAR2(8),
  agent_person_faceident_score  VARCHAR2(8),
  agent_person_handchk_ret      VARCHAR2(3),
  note1                         VARCHAR2(100),
  note2                         VARCHAR2(200),
  orig_channeldate              DATE,
  etl_dt                        DATE,
  etl_timestamp                 TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO
  is '代理人补录登记簿';
comment on column RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO.channeldate
  is '渠道日期';
comment on column RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO.chan_biz_seq_num
  is '渠道流水号';
comment on column RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO.tx_seq_num
  is '业务流水号';
comment on column RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO.orig_tx_seq_num
  is '原交易业务流水号（交易订单号）';
comment on column RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO.orig_core_tran_flow_num
  is '原交易全局流水号';
comment on column RRP_MDL.O_IOL_NIBS_IB_LOG_AGENTFILL_INFO.blip_id
  is '影像批次号';
