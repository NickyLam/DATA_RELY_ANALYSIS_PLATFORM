create table RRP_MDL.B_FIN_INST_ULYG_INFO
(
  data_dt            CHAR(8) not null,
  lgl_rep_id         VARCHAR2(200),
  org_id             VARCHAR2(200),
  ulyg_id            VARCHAR2(200) not null,
  ulyg_prod_cl       VARCHAR2(10),
  cur                CHAR(3),
  book_amt           NUMBER(30,2),
  rate               NUMBER(20,6),
  val_dt             CHAR(8),
  exp_dt             CHAR(8),
  acpt_org_typ       VARCHAR2(10),
  orig_bill_hldr_typ VARCHAR2(10),
  dept_line          VARCHAR2(500),
  data_src           VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_FIN_INST_ULYG_INFO
  is '标的物基础信息';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.org_id
  is '机构编号';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.ulyg_id
  is '标的物编号';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.ulyg_prod_cl
  is '标的产品分类';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.cur
  is '币种';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.book_amt
  is '账面金额';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.rate
  is '利率';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.val_dt
  is '起息日期';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.exp_dt
  is '到期日期';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.acpt_org_typ
  is '承兑机构类型';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.orig_bill_hldr_typ
  is '原始持票人类型';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.dept_line
  is '部门条线';
comment on column RRP_MDL.B_FIN_INST_ULYG_INFO.data_src
  is '数据来源';
alter table RRP_MDL.B_FIN_INST_ULYG_INFO
  add constraint PK_B_FIN_INST_ULYG_INFO primary key (DATA_DT, ULYG_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

