create table RRP_MDL.XZY_YSJBG_2
(
  owner      VARCHAR2(120),
  table_name VARCHAR2(120),
  col_name   VARCHAR2(120),
  comments   VARCHAR2(4000),
  new_ty     VARCHAR2(120)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

