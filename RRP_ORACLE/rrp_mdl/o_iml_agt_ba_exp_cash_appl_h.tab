create table RRP_MDL.O_IML_AGT_BA_EXP_CASH_APPL_H
(
  appl_id                  VARCHAR2(100),
  lp_id                    VARCHAR2(100),
  org_id                   VARCHAR2(100),
  bill_id                  VARCHAR2(100),
  vouch_id                 VARCHAR2(60),
  bill_curr_cd             VARCHAR2(30),
  bill_amt                 NUMBER(30,2),
  msg_appl_type_cd         VARCHAR2(30),
  appl_dt                  DATE,
  sugst_pay_curr_cd        VARCHAR2(30),
  cash_amt                 NUMBER(30,2),
  onl_clear_cd             VARCHAR2(30),
  vouch_qtty               NUMBER(10),
  sugst_payer_cate_cd      VARCHAR2(30),
  sugst_payer_orgnz_cd     VARCHAR2(100),
  sugst_payer_name         VARCHAR2(750),
  sugst_payer_acct_id      VARCHAR2(100),
  sugst_payer_open_bank_no VARCHAR2(90),
  cash_curr_cd             VARCHAR2(30),
  sugst_pay_appl_dt        DATE,
  refuse_pay_cd            VARCHAR2(30),
  apv_status_cd            VARCHAR2(30),
  recv_opinion_cd          VARCHAR2(30),
  send_out_recv_status_cd  VARCHAR2(30),
  entry_status_cd          VARCHAR2(30),
  entry_dt                 DATE,
  revo_dt                  DATE,
  pay_tran_num             VARCHAR2(90),
  spec_prmssn_prtcptr_id   VARCHAR2(100),
  pos_apv_status_cd        VARCHAR2(30),
  send_pos_flow_num        VARCHAR2(90),
  adv_solu_pay_flg         VARCHAR2(30),
  tran_tm                  VARCHAR2(30),
  tran_dt                  DATE,
  reply_teller_id          VARCHAR2(100),
  lt_id                    VARCHAR2(100),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
