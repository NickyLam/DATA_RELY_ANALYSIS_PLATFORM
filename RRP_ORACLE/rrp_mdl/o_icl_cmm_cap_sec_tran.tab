create table RRP_MDL.O_ICL_CMM_CAP_SEC_TRAN
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  bus_id                   VARCHAR2(60),
  dept_id                  VARCHAR2(60),
  tran_acct_b_id           VARCHAR2(60),
  tran_acct_b_name         VARCHAR2(250),
  acct_b_attr_cd           VARCHAR2(10),
  std_prod_id              VARCHAR2(60),
  cust_id                  VARCHAR2(100),
  tran_acct_id             VARCHAR2(250),
  tran_acct_open_bank_no   VARCHAR2(375),
  cntpty_acct_id           VARCHAR2(250),
  cntpty_acct_open_bank_no VARCHAR2(375),
  crdt_out_acct_flow_num   VARCHAR2(100),
  cntpty_id                VARCHAR2(60),
  cntpty_name              VARCHAR2(250),
  portf_id                 VARCHAR2(60),
  portf_name               VARCHAR2(250),
  asset_type_cd            VARCHAR2(10),
  asset_four_cls_cd        VARCHAR2(10),
  tran_dir_cd              VARCHAR2(10),
  tran_dt                  DATE,
  stl_dt                   DATE,
  curr_cd                  VARCHAR2(10),
  stl_amt                  NUMBER(30,2),
  bond_fac_val             NUMBER(30,2),
  tran_net_price           NUMBER(22,12),
  tran_full_price          NUMBER(22,12),
  exp_yld_rat              NUMBER(22,12),
  bond_id                  VARCHAR2(60),
  bond_name                VARCHAR2(250),
  bond_type_cd             VARCHAR2(10),
  acru_int                 NUMBER(30,2),
  tran_fee                 NUMBER(30,2),
  tran_tax                 NUMBER(30,2),
  tran_comm                NUMBER(30,2),
  dealer_id                VARCHAR2(60),
  dealer_name              VARCHAR2(250),
  tran_src_cd              VARCHAR2(10),
  tran_id                  VARCHAR2(60),
  remark                   VARCHAR2(500),
  job_cd                   VARCHAR2(10),
  entry_org_id             VARCHAR2(60),
  tran_clear_bank_name     VARCHAR2(384)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_CAP_SEC_TRAN
