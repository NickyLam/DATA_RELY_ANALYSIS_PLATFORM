create table RRP_MDL.RPT_REPORT_RESULT
(
  index_no    VARCHAR2(64) default '-',
  data_date   VARCHAR2(32) default '-',
  org_no      VARCHAR2(64) default '-',
  dim1        VARCHAR2(96) default '-' not null,
  dim2        VARCHAR2(96) default '-' not null,
  dim3        VARCHAR2(96) default '-' not null,
  dim4        VARCHAR2(96) default '-' not null,
  dim5        VARCHAR2(96) default '-' not null,
  dim6        VARCHAR2(96) default '-' not null,
  dim7        VARCHAR2(96) default '-' not null,
  dim8        VARCHAR2(96) default '-' not null,
  dim9        VARCHAR2(96) default '-' not null,
  dim10       VARCHAR2(96) default '-' not null,
  index_val   NUMBER(38,6),
  template_id VARCHAR2(64),
  currency    VARCHAR2(96) default '-'
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.RPT_REPORT_RESULT
  is '报表结果表';
comment on column RRP_MDL.RPT_REPORT_RESULT.index_no
  is '指标编码';
comment on column RRP_MDL.RPT_REPORT_RESULT.data_date
  is '数据日期';
comment on column RRP_MDL.RPT_REPORT_RESULT.org_no
  is '所属机构';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim1
  is '??1';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim2
  is 'DIM2';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim3
  is '??3';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim4
  is '??4';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim5
  is 'DIM5';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim6
  is '??6';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim7
  is '??7';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim8
  is '??8';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim9
  is '??9';
comment on column RRP_MDL.RPT_REPORT_RESULT.dim10
  is 'DIM10';
comment on column RRP_MDL.RPT_REPORT_RESULT.index_val
  is '???';
comment on column RRP_MDL.RPT_REPORT_RESULT.template_id
  is '模板';
comment on column RRP_MDL.RPT_REPORT_RESULT.currency
  is '币种';

