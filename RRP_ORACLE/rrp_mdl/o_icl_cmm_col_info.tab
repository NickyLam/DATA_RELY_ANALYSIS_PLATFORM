create table RRP_MDL.O_ICL_CMM_COL_INFO
(
  etl_dt                  DATE,
  lp_id                   VARCHAR2(60),
  col_id                  VARCHAR2(60),
  col_type_id             VARCHAR2(60),
  col_name                VARCHAR2(500),
  guar_way_cd             VARCHAR2(10),
  col_mgmt_id             VARCHAR2(60),
  org_id                  VARCHAR2(60),
  com_prot_flg            VARCHAR2(10),
  asset_obg_lot           NUMBER(18,6),
  guar_effect_way_cd      VARCHAR2(10),
  trast_insure_flg        VARCHAR2(10),
  rgst_trast_status_cd    VARCHAR2(10),
  insure_trast_status_cd  VARCHAR2(10),
  insto_status_cd         VARCHAR2(10),
  rela_status_cd          VARCHAR2(10),
  espec_status_cd         VARCHAR2(15),
  wt_md_cash_ability_cd   VARCHAR2(10),
  np_cash_ability_cd      VARCHAR2(10),
  obank_guar_flg          VARCHAR2(10),
  gcust_flg               VARCHAR2(10),
  estim_curr_cd           VARCHAR2(10),
  estim_val               NUMBER(30,2),
  estim_way_cd            VARCHAR2(10),
  estim_dt                DATE,
  hxb_cfm_val             NUMBER(30,2),
  estim_idtfy_dt          DATE,
  hxb_pa_cfm_val          NUMBER(30,2),
  save_hxb_flg            VARCHAR2(10),
  setup_dt                DATE,
  modif_emply_id          VARCHAR2(60),
  main_col_flg            VARCHAR2(10),
  belong_cust_id          VARCHAR2(100),
  insto_entry_org_id      VARCHAR2(100),
  insto_entry_val         NUMBER(30,2),
  insto_entry_curr_cd     VARCHAR2(10),
  exp_dt                  DATE,
  dep_rcpt_vouch_id       VARCHAR2(100),
  dep_rcpt_effect_dt      DATE,
  dep_rcpt_exp_dt         DATE,
  dep_rcpt_term           VARCHAR2(45),
  dep_rcpt_term_days      NUMBER(10),
  dep_rcpt_int_rat        NUMBER(18,6),
  dep_rcpt_curr_cd        VARCHAR2(10),
  dep_rcpt_aval_amt       NUMBER(30,2),
  dep_rcpt_acct_bal       NUMBER(30,2),
  estate_mon_prop_fee     NUMBER(30,2),
  estate_arch_area        NUMBER(30,2),
  hxb_dep_rcpt_flg        VARCHAR2(10),
  prop_ps_id              VARCHAR2(100),
  prop_ps_name            VARCHAR2(150),
  prior_comp_weight_qtty  NUMBER(30,8),
  estim_ps_name           VARCHAR2(300),
  estim_exp_dt            DATE,
  col_val                 NUMBER(30,2),
  mtged_val               NUMBER(30,2),
  right_rgst_dt           DATE,
  check_guar_dt           DATE,
  ctfer_name_1            VARCHAR2(150),
  ctfer_name_2            VARCHAR2(150),
  oper_org_id             VARCHAR2(100),
  rgst_org_name           VARCHAR2(375),
  enty_coll_dt            DATE,
  pm_rat                  NUMBER(18,6),
  higt_mtg_rat            NUMBER(18,6),
  col_estim_curr_cd       VARCHAR2(30),
  col_estim_val           NUMBER(30,2),
  col_store_addr          VARCHAR2(500),
  col_belong_type_cd      VARCHAR2(30),
  estim_org_name          VARCHAR2(300),
  estim_org_orgnz_cd      VARCHAR2(100),
  estim_org_rgst_org_name VARCHAR2(150),
  pledgor_name            VARCHAR2(300),
  pledgor_cert_type_cd    VARCHAR2(30),
  pledgor_cert_no         VARCHAR2(100),
  belong_cert_type        VARCHAR2(15),
  belong_cert_no          VARCHAR2(500),
  belong_rgst_org         VARCHAR2(150),
  wat_rgst_num            VARCHAR2(300),
  wat_name                VARCHAR2(500),
  rent_flg                VARCHAR2(10),
  guara_tentry            VARCHAR2(300),
  rent_begin_dt           DATE,
  rent_exp_dt             DATE,
  rent_situ_descb         VARCHAR2(300),
  rgst_exp_dt             DATE,
  rgst_tenor              VARCHAR2(15),
  rgstrat_id              VARCHAR2(100),
  insto_dt                DATE,
  remark                  VARCHAR2(4000),
  job_cd                  VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
