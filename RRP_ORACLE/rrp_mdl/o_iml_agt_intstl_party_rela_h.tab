create table RRP_MDL.O_IML_AGT_INTSTL_PARTY_RELA_H
(
  rela_id            VARCHAR2(100),
  lp_id              VARCHAR2(60),
  agt_id             VARCHAR2(250),
  src_agt_id         VARCHAR2(100),
  agt_type_cd        VARCHAR2(30),
  bus_table_name     VARCHAR2(150),
  role_type_cd       VARCHAR2(30),
  party_addr_rela_id VARCHAR2(60),
  party_id           VARCHAR2(100),
  addr_keyw          VARCHAR2(150),
  addr_desc          VARCHAR2(375),
  addr_ref_descb     VARCHAR2(375),
  party_name         VARCHAR2(150),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_INTSTL_PARTY_RELA_H
  is '国结业务当事人关系历史';
comment on column RRP_MDL.O_IML_AGT_INTSTL_PARTY_RELA_H.rela_id
  is '关系编号';
