create table RRP_MDL.O_IOL_CUST_TMP
(
  cust_id  VARCHAR2(60),
  dubil_id VARCHAR2(60),
  distr_dt DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.O_IOL_CUST_TMP.cust_id
  is '客户表主键';
comment on column RRP_MDL.O_IOL_CUST_TMP.dubil_id
  is '借据编号';
comment on column RRP_MDL.O_IOL_CUST_TMP.distr_dt
  is '放款日期';

