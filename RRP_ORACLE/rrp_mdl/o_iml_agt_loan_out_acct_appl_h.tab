  deflt_repay_day            NUMBER(22),
  ovdue_exec_int_rat         NUMBER(18,8),
  ovdue_int_rat_float_way_cd VARCHAR2(30),
  ovdue_int_rat_flo_val      NUMBER(18,6),
  oper_org_id                VARCHAR2(100),
  bus_oper_teller_id         VARCHAR2(100),
  oper_dt                    DATE,
  rgst_teller_id             VARCHAR2(100),
  rgst_org_id                VARCHAR2(100),
  rgst_dt                    DATE,
  update_teller_id           VARCHAR2(100),
  update_org_id              VARCHAR2(100),
  modif_dt                   DATE,
  lp_id                      VARCHAR2(100),
  text_cont_id               VARCHAR2(500),
  margin_acct_id             VARCHAR2(100),
  margin_tran_out_acct_id    VARCHAR2(100),
  margin_curr_cd             VARCHAR2(30),
  margin_ratio               NUMBER(18,6),
  margin_sub_acct_num        VARCHAR2(60),
  margin_amt                 NUMBER(30,2),
  dubil_id                   VARCHAR2(100),
  subj_id                    VARCHAR2(100),
  out_acct_org_id            VARCHAR2(100),
  loan_org_id                VARCHAR2(100),
  int_accr_way_cd            VARCHAR2(30),
  enter_open_acct_org_id     VARCHAR2(100),
  enter_name                 VARCHAR2(500),
  enter_sub_acct_num         VARCHAR2(60),
  comm_fee_collect_way_cd    VARCHAR2(30),
  comm_fee_deduct_acct_id    VARCHAR2(100),
  comm_fee_amort_flg         VARCHAR2(10),
  comm_fee_rat               NUMBER(18,6),
  comm_fee_amt               NUMBER(30,2),
  loan_usage_cd              VARCHAR2(30),
  entr_pay_amt               NUMBER(30,2),
  entr_pay_stop_pay_flow_num VARCHAR2(100),
  file_dt                    DATE,
  major_guar_way_cd          VARCHAR2(30),
  mon_tenor                  NUMBER(22),
  day_tenor                  NUMBER(22),
  tran_status_cd             VARCHAR2(30),
  tran_tm                    TIMESTAMP(6),
  core_tran_dt               DATE,
  core_tran_flow_num         VARCHAR2(100),
  stl_acct_name              VARCHAR2(500),
