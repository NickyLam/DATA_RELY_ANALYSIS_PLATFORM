create table RRP_MDL.TMP_DEF_CUST_ACCT
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  cust_acct_id             VARCHAR2(60),
  cust_id                  VARCHAR2(60),
  acct_status_cd           VARCHAR2(10),
  acct_drawdown_way_status VARCHAR2(10),
  clos_acct_dt             DATE,
  acct_belong_org_id       VARCHAR2(60),
  open_acct_dt             DATE,
  job_cd                   VARCHAR2(10),
  vouch_kind_cd            VARCHAR2(10),
  open_acct_teller_id      VARCHAR2(60),
  tran_chn_status_cd       VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.lp_id
  is '法人编号';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.cust_acct_id
  is '客户账户编号';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.cust_id
  is '客户表主键';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.acct_status_cd
  is '准贷记卡账户状态';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.acct_drawdown_way_status
  is '账户支取方式状态';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.clos_acct_dt
  is '客户销户日期';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.acct_belong_org_id
  is '账户所属机构号';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.open_acct_dt
  is '开户日期';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.job_cd
  is '任务代码';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.vouch_kind_cd
  is '凭证种类代码';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.open_acct_teller_id
  is '开户柜员编号';
comment on column RRP_MDL.TMP_DEF_CUST_ACCT.tran_chn_status_cd
  is '交易渠道状态代码';

