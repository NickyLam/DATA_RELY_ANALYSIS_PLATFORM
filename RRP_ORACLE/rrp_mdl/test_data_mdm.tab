create table RRP_MDL.TEST_DATA_MDM
(
  id         NUMBER,
  table_name VARCHAR2(300),
  count_num  VARCHAR2(300)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.TEST_DATA_MDM
  is '明细层表数据查询';
comment on column RRP_MDL.TEST_DATA_MDM.id
  is '主键ID';
comment on column RRP_MDL.TEST_DATA_MDM.table_name
  is '报送表名称';
comment on column RRP_MDL.TEST_DATA_MDM.count_num
  is '数量';

