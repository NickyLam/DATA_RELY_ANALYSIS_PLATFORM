create table RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL
(
  evt_id         VARCHAR2(60),
  lp_id          VARCHAR2(60),
  seq_num        VARCHAR2(250),
  rgst_dt        DATE,
  rgst_flow_num  VARCHAR2(60),
  charge_cd      VARCHAR2(10),
  charge_lev_cd  VARCHAR2(10),
  recvbl_amt     NUMBER(30,2),
  fee_bus_cd     VARCHAR2(30),
  fee_org_id     VARCHAR2(60),
  enter_acct_id  VARCHAR2(60),
  actl_recv_amt  NUMBER(30,2),
  dubil_id       VARCHAR2(100),
  discnt_amt     NUMBER(18,6),
  etl_dt         DATE,
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10),
  etl_timestamp  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL
  is '手续费流水明细';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.evt_id
  is '事件编号';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.seq_num
  is '序号';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.rgst_dt
  is '登记日期';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.rgst_flow_num
  is '登记流水号';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.charge_cd
  is '收费代码';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.charge_lev_cd
  is '收费级别代码';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.recvbl_amt
  is '应收金额';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.fee_bus_cd
  is '费用业务代码';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.fee_org_id
  is '费用机构编号';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.enter_acct_id
  is '入账账户编号';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.actl_recv_amt
  is '实收金额';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.dubil_id
  is '借据编号';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.discnt_amt
  is '折扣金额';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.etl_dt
  is 'etl处理日期';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.job_cd
  is '任务编码';
comment on column RRP_MDL.O_IML_EVT_COMM_FEE_FLOW_DTL.etl_timestamp
  is 'etl处理时间戳';

