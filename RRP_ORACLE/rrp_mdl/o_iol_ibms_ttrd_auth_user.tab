create table RRP_MDL.O_IOL_IBMS_TTRD_AUTH_USER
(
  user_id               NUMBER(19),
  user_name             VARCHAR2(150),
  i_id                  NUMBER(19),
  email                 VARCHAR2(192),
  tel_num               VARCHAR2(48),
  mobile_num            VARCHAR2(48),
  employee_card_no      VARCHAR2(96),
  full_chinese_spell    VARCHAR2(375),
  password              VARCHAR2(768),
  account               VARCHAR2(48),
  birth_day             VARCHAR2(15),
  flag                  NUMBER(5),
  status                NUMBER(5),
  head_chinese_spell    VARCHAR2(150),
  create_time           VARCHAR2(35),
  update_time           VARCHAR2(35),
  is_first_login        VARCHAR2(2),
  pwd_update_date       VARCHAR2(15),
  input_pwd_error_times NUMBER(2),
  password_history      VARCHAR2(768),
  state                 VARCHAR2(2),
  update_user           NUMBER(19),
  qq_number             VARCHAR2(48),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IBMS_TTRD_AUTH_USER
  is '用户表';
comment on column RRP_MDL.O_IOL_IBMS_TTRD_AUTH_USER.user_id
  is '未知';
