create table RRP_MDL.O_IML_EVT_ONL_BANK_TRAN_DTL
(
  evt_id                  VARCHAR2(250),
  lp_id                   VARCHAR2(60),
  tran_flow_num           VARCHAR2(100),
  whole_unify_cust_id     VARCHAR2(60),
  tran_dt                 DATE,
  tran_tm                 VARCHAR2(20),
  tran_code               VARCHAR2(100),
  tran_oper_type_cd       VARCHAR2(10),
  tran_return_code        VARCHAR2(100),
  fail_rs                 VARCHAR2(2000),
  tran_amt                NUMBER(30,2),
  curr_cd                 VARCHAR2(10),
  comm_fee                NUMBER(30,2),
  pay_acct_num            VARCHAR2(60),
  pay_acct_name           VARCHAR2(100),
  pay_acct_type_cd        VARCHAR2(10),
  recvbl_num              VARCHAR2(60),
  recvbl_num_name         VARCHAR2(200),
  recvbl_acct_type_cd     VARCHAR2(10),
  recver_bank_no          VARCHAR2(60),
  recver_bank_name        VARCHAR2(500),
  recver_prov_cd          VARCHAR2(60),
  recver_prov_name        VARCHAR2(100),
  recver_city_cd          VARCHAR2(60),
  recver_city_name        VARCHAR2(200),
  plan_fomult_tm          VARCHAR2(20),
  plan_type_cd            VARCHAR2(10),
  tran_freq_cd            VARCHAR2(10),
  next_exec_dt            DATE,
  precon_plan_status_cd   VARCHAR2(10),
  tm_or_ff_begin_dt       DATE,
  tm_or_ff_closing_dt     DATE,
  lmt_attr_cd             VARCHAR2(100),
  save_cert_way_cd        VARCHAR2(10),
  usage_comnt             VARCHAR2(200),
  onl_bank_tran_flow_num  VARCHAR2(100),
  recver_nickna           VARCHAR2(100),
  atm_equip_id            VARCHAR2(60),
  st_msg_advise_mobile_no VARCHAR2(60),
  brac_id                 VARCHAR2(60),
  brac_name               VARCHAR2(500),
  dept_cd                 VARCHAR2(10),
  tran_out_route_id       VARCHAR2(60),
  remit_way_id            VARCHAR2(60),
  remit_way_name          VARCHAR2(100),
  next_day_tran_out_flg   VARCHAR2(10),
  tran_mobile_no          VARCHAR2(60),
  crdt_card_repay_flg     VARCHAR2(10),
  user_seq_id             VARCHAR2(60),
  remark                  VARCHAR2(250),
  tran_order_no           VARCHAR2(60),
  chain_way_track_no      VARCHAR2(100),
  etl_dt                  DATE,
  src_table_name          VARCHAR2(100),
  job_cd                  VARCHAR2(10),
  etl_timestamp           TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
