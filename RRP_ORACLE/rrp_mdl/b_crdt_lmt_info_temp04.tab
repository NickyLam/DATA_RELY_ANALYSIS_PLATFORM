create table RRP_MDL.B_CRDT_LMT_INFO_TEMP04
(
  data_dt                     CHAR(8),
  lgl_rep_id                  VARCHAR2(200),
  prim_crdt_cont_id           VARCHAR2(200),
  crdt_cont_id                VARCHAR2(200) not null,
  crdt_cont_nm                VARCHAR2(500),
  cust_id                     VARCHAR2(200) not null,
  org_id                      VARCHAR2(200),
  crdt_lmt                    NUMBER(30,2),
  aldy_use_lmt                NUMBER(30,2),
  sur_crdt_lmt                NUMBER(30,2),
  exp_crdt_lmt                NUMBER(30,2),
  exp_aldy_use_lmt            NUMBER(30,2),
  exp_sur_lmt                 NUMBER(30,2),
  cur                         CHAR(3),
  crdt_subj_typ               VARCHAR2(10),
  eff_dt                      CHAR(8),
  crdt_stat                   VARCHAR2(10),
  crdt_app_dt                 CHAR(8),
  crdt_start_dt               CHAR(8),
  crdt_exp_dt                 CHAR(8),
  crdt_biz_typ                VARCHAR2(10),
  cir_lmt_flg                 CHAR(1),
  temp_lmt_flg                CHAR(1),
  crdt_subj_cl                VARCHAR2(10),
  bank_tax_coop_loan_crdt_flg CHAR(1),
  dsn_sht_opn                 VARCHAR2(2000),
  aprv_psn_no                 VARCHAR2(30),
  crdt_emp_no                 VARCHAR2(200),
  dept_line                   VARCHAR2(500),
  data_src                    VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.B_CRDT_LMT_INFO_TEMP04
  is '授信额度子表';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.data_dt
  is '数据日期';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.prim_crdt_cont_id
  is '主授信合同编号';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_cont_id
  is '授信合同编号';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_cont_nm
  is '授信合同名称';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.cust_id
  is '客户编号';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.org_id
  is '机构编号';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_lmt
  is '授信额度';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.aldy_use_lmt
  is '已用额度';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.sur_crdt_lmt
  is '剩余授信额度';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.exp_crdt_lmt
  is '敞口授信额度';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.exp_aldy_use_lmt
  is '敞口已用额度';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.exp_sur_lmt
  is '敞口剩余额度';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.cur
  is '币种';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_subj_typ
  is '授信主体类型';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.eff_dt
  is '生效日期';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_stat
  is '授信状态';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_app_dt
  is '授信申请日期';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_start_dt
  is '授信开始日期';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_exp_dt
  is '授信到期日期';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_biz_typ
  is '授信业务类型';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.cir_lmt_flg
  is '循环额度标志';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.temp_lmt_flg
  is '临时额度标志';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_subj_cl
  is '授信主体种类';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.bank_tax_coop_loan_crdt_flg
  is '银税合作贷款授信标志';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.dsn_sht_opn
  is '决策单意见';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.aprv_psn_no
  is '审批人工号';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.crdt_emp_no
  is '授信员工号';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.dept_line
  is '部门条线';
comment on column RRP_MDL.B_CRDT_LMT_INFO_TEMP04.data_src
  is '数据来源';

