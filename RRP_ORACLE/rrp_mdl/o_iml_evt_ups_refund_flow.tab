create table RRP_MDL.O_IML_EVT_UPS_REFUND_FLOW
(
  evt_id                VARCHAR2(250),
  lp_id                 VARCHAR2(100),
  batch_no              VARCHAR2(60),
  tran_flow_num         VARCHAR2(100),
  tran_type_cd          VARCHAR2(100),
  tran_curr_cd          VARCHAR2(30),
  tran_amt              NUMBER(30,2),
  tran_dt               TIMESTAMP(6),
  tran_status_cd        VARCHAR2(30),
  acpt_pay_instr_cd     VARCHAR2(30),
  recver_acct_org_id    VARCHAR2(100),
  recver_acct_id        VARCHAR2(100),
  recver_acct_name      VARCHAR2(1000),
  recver_acct_type_cd   VARCHAR2(30),
  send_org_id           VARCHAR2(100),
  refund_acct_org_id    VARCHAR2(100),
  refund_acct_id        VARCHAR2(100),
  refund_acct_type_cd   VARCHAR2(30),
  sign_agt_id           VARCHAR2(100),
  mercht_id             VARCHAR2(100),
  mercht_cate_cd        VARCHAR2(30),
  mercht_name           VARCHAR2(1000),
  level2_mercht_id      VARCHAR2(100),
  level2_mercht_cate_cd VARCHAR2(30),
  level2_mercht_name    VARCHAR2(1000),
  init_tran_flow_num    VARCHAR2(100),
  init_indent_id        VARCHAR2(100),
  init_tran_amt         NUMBER(30,2),
  init_tran_tm          TIMESTAMP(6),
  sys_flow_num          VARCHAR2(100),
  sys_type_cd           VARCHAR2(30),
  sys_tran_dt           DATE,
  sys_return_code       VARCHAR2(100),
  sys_return_comnt      VARCHAR2(1000),
  core_flow_num         VARCHAR2(100),
  core_tran_dt          DATE,
  core_tran_status_cd   VARCHAR2(30),
  aldy_tran_flg         VARCHAR2(10),
  aldy_adj_entry_flg    VARCHAR2(10),
  aldy_clear_flg        VARCHAR2(10),
  check_entry_status_cd VARCHAR2(30),
  clear_batch_no        VARCHAR2(60),
  clear_dt              DATE,
  plat_tran_flow_num    VARCHAR2(100),
  plat_tran_dt          DATE,
  plat_tran_tm          TIMESTAMP(6),
  out_plat_flow_num     VARCHAR2(100),
  out_ova_plat_flow_num VARCHAR2(100),
  open_acct_org_id      VARCHAR2(100),
  teller_id             VARCHAR2(100),
