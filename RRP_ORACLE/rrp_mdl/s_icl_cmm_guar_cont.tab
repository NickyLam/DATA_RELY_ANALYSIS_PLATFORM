create table RRP_MDL.S_ICL_CMM_GUAR_CONT
(
  etl_dt                           DATE,
  lp_id                            VARCHAR2(60),
  guar_cont_id                     VARCHAR2(100),
  guar_cont_type_cd                VARCHAR2(10),
  guar_way_cd                      VARCHAR2(10),
  guar_type_cls_cd                 VARCHAR2(10),
  guar_kind_cd                     VARCHAR2(10),
  status_cd                        VARCHAR2(10),
  sign_dt                          DATE,
  effect_dt                        DATE,
  exp_dt                           DATE,
  cust_id                          VARCHAR2(60),
  guartor_id                       VARCHAR2(60),
  guartor_name                     VARCHAR2(100),
  guartor_cert_type_cd             VARCHAR2(10),
  guartor_cert_no                  VARCHAR2(60),
  guartor_natnal_econ_dept_type_cd VARCHAR2(60),
  guartor_indus_type_cd            VARCHAR2(60),
  guartor_dist_cd                  VARCHAR2(60),
  guartor_corp_size_cd             VARCHAR2(60),
  brwer_rela_cd                    VARCHAR2(10),
  curr_cd                          VARCHAR2(10),
  guar_amt                         NUMBER(30,2),
  ocup_amt                         NUMBER(30,2),
  guar_start_dt                    DATE,
  guar_exp_dt                      DATE,
  guar_tenor                       NUMBER(10),
  pri_contr_id                     VARCHAR2(100),
  pri_contr_type_cd                VARCHAR2(10),
  ocup_guar_lmt_flg                VARCHAR2(10),
  guar_range_cd                    VARCHAR2(10),
  gcust_flg                        VARCHAR2(10),
  rev_guar_measure_flg             VARCHAR2(10),
  gover_fin_guar_corp_guar_flg     VARCHAR2(10),
  obg_id                           VARCHAR2(60),
  obg_name                         VARCHAR2(100),
  dir_guar_flg                     VARCHAR2(10),
  cust_mgr_id                      VARCHAR2(60),
  director_org_id                  VARCHAR2(60),
  acct_instit_id                   VARCHAR2(60),
  rgst_org_id                      VARCHAR2(60),
  rgstrat_id                       VARCHAR2(60),
  rgst_dt                          DATE,
  update_person_id                 VARCHAR2(60),
  update_dt                        DATE,
  guar_cont_name                   VARCHAR2(100),
  job_cd                           VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.S_ICL_CMM_GUAR_CONT
  is '担保合同';
comment on column RRP_MDL.S_ICL_CMM_GUAR_CONT.etl_dt
