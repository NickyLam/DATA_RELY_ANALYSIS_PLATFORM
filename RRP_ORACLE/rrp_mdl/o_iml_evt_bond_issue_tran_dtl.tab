create table RRP_MDL.O_IML_EVT_BOND_ISSUE_TRAN_DTL
(
  etl_dt                DATE,
  evt_id                VARCHAR2(250),
  lp_cd                 VARCHAR2(60),
  bus_id                VARCHAR2(100),
  bus_table_name        VARCHAR2(150),
  dept_id               VARCHAR2(100),
  bond_id               VARCHAR2(100),
  bond_name             VARCHAR2(150),
  bond_type_cd          VARCHAR2(30),
  tran_id               VARCHAR2(100),
  tran_dt               DATE,
  dlvy_dt               DATE,
  tran_dir_cd           VARCHAR2(30),
  tran_net_price        NUMBER(30,2),
  tran_full_price       NUMBER(30,2),
  exp_yld_rat           NUMBER(18,8),
  stl_amt               NUMBER(30,2),
  portf_id              VARCHAR2(100),
  portf_name            VARCHAR2(150),
  acct_b_id             VARCHAR2(100),
  acct_b_name           VARCHAR2(150),
  acct_b_attr_cd        VARCHAR2(30),
  asset_cls4_name       VARCHAR2(100),
  stl_way_cd            VARCHAR2(30),
  dealer_id             VARCHAR2(100),
  dealer_name           VARCHAR2(150),
  cert_face_tot         NUMBER(30,2),
  cfets_tran_flg        VARCHAR2(10),
  tran_src_cd           VARCHAR2(30),
  asset_type_cd         VARCHAR2(30),
  acpt_pay_cfm_modif_tm TIMESTAMP(6),
  issue_status_cd       VARCHAR2(30),
  job_cd                VARCHAR2(10),
  src_table_name        VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_BOND_ISSUE_TRAN_DTL
  is '债券发行交易明细';
