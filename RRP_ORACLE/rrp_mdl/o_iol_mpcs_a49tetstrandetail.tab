create table RRP_MDL.O_IOL_MPCS_A49TETSTRANDETAIL
(
  mqinseq            VARCHAR2(24),
  cleartype          VARCHAR2(15),
  cleardate          VARCHAR2(12),
  seqno              VARCHAR2(15),
  origcd             VARCHAR2(17),
  commitdate         VARCHAR2(12),
  origcdseqno        VARCHAR2(24),
  openbankno         VARCHAR2(21),
  sapbankno          VARCHAR2(21),
  trantype           VARCHAR2(3),
  payeracctno        VARCHAR2(53),
  taxiname           VARCHAR2(450),
  txpycd             VARCHAR2(30),
  txpyna             VARCHAR2(180),
  detailno           VARCHAR2(5),
  itemcd             VARCHAR2(18),
  itemnm             VARCHAR2(270),
  recvbankno         VARCHAR2(21),
  innerpayeracctno   VARCHAR2(53),
  innerpayeracctname VARCHAR2(450),
  payeeacctno        VARCHAR2(53),
  payeeacctname      VARCHAR2(450),
  amount             NUMBER(18,2),
  taxname            VARCHAR2(180),
  pinmuna            VARCHAR2(270),
  taxdate            VARCHAR2(26),
  addinfo            VARCHAR2(300),
  hostnbr            VARCHAR2(60),
  globalseqno        VARCHAR2(105),
  inserttime         VARCHAR2(21),
  magebrn            VARCHAR2(9),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_MPCS_A49TETSTRANDETAIL
  is '社保费明细表';
comment on column RRP_MDL.O_IOL_MPCS_A49TETSTRANDETAIL.mqinseq
  is '中台流水号';
comment on column RRP_MDL.O_IOL_MPCS_A49TETSTRANDETAIL.cleartype
