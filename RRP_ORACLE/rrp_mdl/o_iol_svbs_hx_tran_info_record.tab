create table RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD
(
  sessionid          VARCHAR2(75),
  billid             VARCHAR2(75),
  glob_seq_num       VARCHAR2(75),
  status             NUMBER,
  tran_code          VARCHAR2(200),
  channel_type       NUMBER,
  system_sign        VARCHAR2(512),
  qrcode             VARCHAR2(4000),
  create_date        DATE,
  update_date        DATE,
  delete_flag        NUMBER,
  notes              VARCHAR2(300),
  is_tts             VARCHAR2(2),
  is_asr             VARCHAR2(2),
  video_duration     NUMBER,
  video_duration_str VARCHAR2(150),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD
  is '交易状态记录表';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.sessionid
  is '会话ID';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.billid
  is '订单号';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.glob_seq_num
  is '全局流水号';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.status
  is '1-生成二维码，2-正在双录，4-完成双录，5-影像下载失败 6- 影像下载成功 7-影像上传失败 8-影像上传成功 9-通知关联系统失败 10-通知关联系统成功 11-双录完成通知外系统失败 12-双录完成通知外系统成功  13-异常中断';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.tran_code
  is '交易码';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.channel_type
  is '发起渠道 1-移动作业平台(PAD)，2-兴金融小程序，3-手机银行（安卓），4-手机银行（IOS），5-企业手机银行（安卓），6-企业手机银行（IOS）';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.system_sign
  is '系统标识';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.qrcode
  is '小程序二维码base64';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.create_date
  is '创建日期';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.update_date
  is '最后更新日期';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.delete_flag
  is '删除标识 0- 使用中 1-已删除';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.notes
  is '备注';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.is_tts
  is '是否开启语音播报， 0-关闭  1-开启';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.is_asr
  is '是否开启语音识别， 0-关闭  1-开启';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.video_duration
  is '视频时长，单位毫秒';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.video_duration_str
  is '视频时长字符串，格式00:00:00.00';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IOL_SVBS_HX_TRAN_INFO_RECORD.etl_timestamp
  is 'ETL处理时间戳';

