comment on column RRP_MDL.EAST5_705_DKWJXTBDB.jbgyh
  is '经办人工号';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.bbz
  is '备注';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.cjrq
  is '采集日期';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.issued_no
  is '填报机构';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.org_no
  is '报送机构';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.dept_no
  is '部门编号';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.src_sys_id
