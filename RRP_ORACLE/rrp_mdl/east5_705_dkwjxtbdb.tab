comment on table RRP_MDL.EAST5_705_DKWJXTBDB
  is '贷款五级形态变动表';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.jrxkzh
  is '金融许可证号';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.nbjgh
  is '内部机构号';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.yhjgmc
  is '银行机构名称';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.xdhth
  is '信贷合同号';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.xdjjh
  is '信贷借据号';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.khtybh
  is '客户统一编号';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.khmc
  is '客户名称';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.tzrq
  is '调整日期';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.ywjfl
  is '原五级分类';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.xwjfl
  is '新五级分类';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.bdyy
