comment on column RRP_MDL.EAST5_705_DKWJXTBDB.rid
  is '数据主键';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.khmc_orig
  is '客户名称（脱敏前）';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.khmc_oth
  is '客户是否个人客户';
comment on column RRP_MDL.EAST5_705_DKWJXTBDB.gsfzjg
  is '归属分支机构';
alter table RRP_MDL.EAST5_705_DKWJXTBDB
  add constraint PK_EAST5_705_DKWJXTBDB primary key (CJRQ, XDJJH, TZRQ)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

