create table RRP_MDL.UNLOAD_JOB_CONF_DEF
(
  job_no         VARCHAR2(100) not null,
  job_name       VARCHAR2(100) not null,
  sys_code       VARCHAR2(20) not null,
  sys_desc       VARCHAR2(500) not null,
  batch_num      VARCHAR2(200) not null,
  db_no          VARCHAR2(20) not null,
  db_ip          VARCHAR2(30) not null,
  db_port        VARCHAR2(20) not null,
  db_name        VARCHAR2(20) not null,
  db_username    VARCHAR2(50) not null,
  db_passwd      VARCHAR2(50) not null,
  filepath       VARCHAR2(100) not null,
  filename       VARCHAR2(100),
  schema_name    VARCHAR2(20) not null,
  tab_name       VARCHAR2(100) not null,
  table_desc     VARCHAR2(500),
  app_ful_flg    VARCHAR2(1) not null,
  filter_cond    VARCHAR2(1000),
  split_col_name VARCHAR2(4000),
  use_sql_str    VARCHAR2(4000),
  use_sql_flg    VARCHAR2(1),
  field_split    VARCHAR2(20) not null,
  record_split   VARCHAR2(20) not null,
  char_set       VARCHAR2(20) not null,
  dep_sql        VARCHAR2(4000),
  gzip_flag      CHAR(1),
  scan_sql       VARCHAR2(4000),
  bat_pre_flow   VARCHAR2(4000),
  bat_post_flow  VARCHAR2(4000),
  job_pre_flow   VARCHAR2(4000),
  job_post_flow  VARCHAR2(4000),
  unload_tab     CHAR(1),
  valid_flag     CHAR(1) not null,
  create_dt      DATE,
  update_dt      DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.UNLOAD_JOB_CONF_DEF
  is '卸数配置表';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.job_no
  is '作业编号';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.job_name
  is '作业名';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.sys_code
  is '系统编号';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.sys_desc
  is '系统描述';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.batch_num
  is '批次号';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.db_no
  is '系统数据库编号';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.db_ip
  is '数据库IP';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.db_port
  is '数据库端口号';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.db_name
  is '实例名称';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.db_username
  is '数据库用户名称';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.db_passwd
  is '数据库用户密码';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.filepath
  is '文件路径';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.filename
  is '文件名称，添加#ETL_DATE#到文件名';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.schema_name
  is 'SCHEMA名称';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.tab_name
  is '表名';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.table_desc
  is '表中文名';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.app_ful_flg
  is '增全量标识(I增量 A全量)';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.filter_cond
  is '过滤条件';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.split_col_name
  is '筛选字段';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.use_sql_str
  is '自定义sql';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.use_sql_flg
  is '是否自定义sql(1 是 0 否)';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.field_split
  is '字段分割符';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.record_split
  is '记录换行符';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.char_set
  is '字符集(UTF8,ZHS16GBK)';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.dep_sql
  is '依赖SQL标识';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.gzip_flag
  is '是否压缩';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.scan_sql
  is '批次前置作业判断条件';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.bat_pre_flow
  is '批次前置任务';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.bat_post_flow
  is '批次后置任务';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.job_pre_flow
  is '作业前置任务';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.job_post_flow
  is '作业后置任务';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.unload_tab
  is '是否卸表结构，0为否，1为是';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.valid_flag
  is '是否有效';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.create_dt
  is '创建时间';
comment on column RRP_MDL.UNLOAD_JOB_CONF_DEF.update_dt
  is '最后更新时间';

