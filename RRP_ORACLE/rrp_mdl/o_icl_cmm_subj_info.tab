create table RRP_MDL.O_ICL_CMM_SUBJ_INFO
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  subj_id                  VARCHAR2(60),
  subj_name                VARCHAR2(250),
  super_subj_id            VARCHAR2(60),
  super_subj_name          VARCHAR2(250),
  subj_lev_cd              VARCHAR2(30),
  subj_char_cd             VARCHAR2(10),
  subj_bal_dir_cd          VARCHAR2(10),
  subj_src_cls_cd          VARCHAR2(10),
  trdpty_ctrl_acct_type_cd VARCHAR2(10),
  dtl_subj_flg             VARCHAR2(10),
  in_out_tab_flg           VARCHAR2(10),
  allow_od_flg             VARCHAR2(10),
  allow_budget_flg         VARCHAR2(10),
  allow_post_flg           VARCHAR2(10),
  adj_flg                  VARCHAR2(10),
  subj_status_cd           VARCHAR2(10),
  effect_dt                DATE,
  invalid_dt               DATE,
  job_cd                   VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_SUBJ_INFO
  is '科目信息';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.etl_dt
  is '数据日期';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.lp_id
  is '法人编号';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.subj_id
  is '科目编号';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.subj_name
  is '科目名称';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.super_subj_id
  is '上级科目编号';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.super_subj_name
  is '上级科目名称';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.subj_lev_cd
  is '科目级别代码';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.subj_char_cd
  is '科目性质代码';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.subj_bal_dir_cd
  is '科目余额方向代码';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.subj_src_cls_cd
  is '科目来源分类代码';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.trdpty_ctrl_acct_type_cd
  is '第三方控制账户类型代码';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.dtl_subj_flg
  is '明细科目标志';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.in_out_tab_flg
  is '表内外标志';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.allow_od_flg
  is '允许透支标志';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.allow_budget_flg
  is '允许预算标志';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.allow_post_flg
  is '允许过账标志';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.adj_flg
  is '调节标志';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.subj_status_cd
  is '科目状态代码';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.effect_dt
  is '生效日期';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.invalid_dt
  is '失效日期';
comment on column RRP_MDL.O_ICL_CMM_SUBJ_INFO.job_cd
  is '任务代码';

