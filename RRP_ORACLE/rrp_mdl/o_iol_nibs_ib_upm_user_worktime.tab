create table RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME
(
  usernum             VARCHAR2(8),
  branchnum           VARCHAR2(10),
  logindatestr        VARCHAR2(8),
  logintime           DATE,
  logouttime          DATE,
  totaltimesecond     VARCHAR2(10),
  trantimesecond      VARCHAR2(10),
  leveltimesecond     VARCHAR2(10),
  onlineleisuresecond VARCHAR2(10),
  singoutfalg         VARCHAR2(2),
  userstatus          VARCHAR2(5),
  start_dt            DATE,
  end_dt              DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME
  is '柜员工作时长统计';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.usernum
  is '柜员号';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.branchnum
  is '机构号';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.logindatestr
  is '登入日期 yyyymmdd';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.logintime
  is '登入时间 yyyymmdd hhmmss';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.logouttime
  is '登出时间 yyyymmdd hhmmss';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.totaltimesecond
  is '总时长 秒';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.trantimesecond
  is '交易时长 秒';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.leveltimesecond
  is '离柜时长 秒';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.onlineleisuresecond
  is '在线空闲时长 秒';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.singoutfalg
  is '是否进行进行了日终签退 0-否 1-是';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.userstatus
  is '柜员在登陆状态|o-在线 l-离线';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_NIBS_IB_UPM_USER_WORKTIME.end_dt
  is '结束时间';

