comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.split_lmt_circl_flg
  is '切分额度可循环标志';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.split_lmt_effect_dt
  is '切分额度生效日期';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.split_lmt_end_dt
