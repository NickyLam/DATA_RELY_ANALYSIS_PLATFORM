create table RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT
(
  cust_no             VARCHAR2(90),
  lmt_no              VARCHAR2(90),
  curr_cd             VARCHAR2(15),
  appl_lmt            NUMBER(30,2),
  apprv_lmt_amt       NUMBER(30,2),
  used_lmt            NUMBER(30,2),
  usable_lmt          NUMBER(30,2),
  usexposure_lmt      NUMBER(30,2),
  exposure_lmt        NUMBER(30,2),
  bus_breed_cd        VARCHAR2(90),
  lmt_apprv_dt        VARCHAR2(30),
  lmt_mature_dt       VARCHAR2(30),
  lmt_circl_flg       VARCHAR2(15),
  lmt_valid_flg       VARCHAR2(15),
  group_crdt_flg      VARCHAR2(30),
  unsplit_lmt_amt     NUMBER(30,2),
  unsplit_access_amt  NUMBER(30,2),
  split_lmt_no        VARCHAR2(90),
  split_lmt_flg       VARCHAR2(15),
  split_lmt_amt       NUMBER(30,2),
  split_lmt_type_cd   VARCHAR2(15),
  split_lmt_circl_flg VARCHAR2(15),
  split_lmt_effect_dt DATE,
  split_lmt_end_dt    DATE,
  split_lmt_surp_amt  NUMBER(30,2),
  etl_dt              DATE,
  scp_bus_breed_id    VARCHAR2(90),
  scp_curr_cd         VARCHAR2(90)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT
  is 'R02_公司贷款额度';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.cust_no
  is '客户编号';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.lmt_no
  is '额度编号';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.curr_cd
  is '币种代码';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.appl_lmt
  is '申请额度';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.apprv_lmt_amt
  is '额度批复金额';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.used_lmt
  is '已占用额度';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.usable_lmt
  is '剩余额度';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.usexposure_lmt
  is '已用敞口';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.exposure_lmt
  is '敞口额度';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.bus_breed_cd
  is '业务品种代码';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.lmt_apprv_dt
  is '额度批准日期';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.lmt_mature_dt
  is '额度有效结束日期';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.lmt_circl_flg
  is '额度循环标志';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.lmt_valid_flg
  is '额度有效标志';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.group_crdt_flg
  is '集团授信标志';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.unsplit_lmt_amt
  is '未切分额度金额';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.unsplit_access_amt
  is '未切分且未签订业务合同金额';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.split_lmt_no
  is '切分额度编号';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.split_lmt_flg
  is '专项切分额度标志';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LON_LMT.split_lmt_amt
