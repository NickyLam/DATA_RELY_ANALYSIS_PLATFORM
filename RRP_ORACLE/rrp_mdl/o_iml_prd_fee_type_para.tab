comment on column RRP_MDL.O_IML_PRD_FEE_TYPE_PARA.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_PRD_FEE_TYPE_PARA.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_PRD_FEE_TYPE_PARA.id_mark
