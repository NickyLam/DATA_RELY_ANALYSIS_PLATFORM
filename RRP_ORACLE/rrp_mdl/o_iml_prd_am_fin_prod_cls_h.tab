create table RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H
(
  fin_prod_id                 VARCHAR2(100),
  lp_id                       VARCHAR2(60),
  brch_seq_num                VARCHAR2(100),
  bank_int_prod_level2_cls_cd VARCHAR2(30),
  bank_int_prod_level3_cls_cd VARCHAR2(30),
  bank_int_prod_level4_cls_cd VARCHAR2(30),
  bank_int_prod_level5_cls_cd VARCHAR2(30),
  std_prod_id                 VARCHAR2(60),
  start_dt                    DATE,
  end_dt                      DATE,
  id_mark                     VARCHAR2(10),
  src_table_name              VARCHAR2(100),
  job_cd                      VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H
  is '资管金融产品分类历史';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.fin_prod_id
  is '金融产品编号';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.brch_seq_num
  is '分支序号';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.bank_int_prod_level2_cls_cd
  is '行内产品二级分类代码';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.bank_int_prod_level3_cls_cd
  is '行内产品三级分类代码';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.bank_int_prod_level4_cls_cd
  is '行内产品四级分类代码';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.bank_int_prod_level5_cls_cd
  is '行内产品五级分类代码';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.std_prod_id
  is '标准产品编号';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.start_dt
  is '开始日期';
comment on column RRP_MDL.O_IML_PRD_AM_FIN_PROD_CLS_H.end_dt
