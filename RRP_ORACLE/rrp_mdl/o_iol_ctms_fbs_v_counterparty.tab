create table RRP_MDL.O_IOL_CTMS_FBS_V_COUNTERPARTY
(
  counterparty_seq            NUMBER,
  cus_number                  NUMBER(20),
  label                       VARCHAR2(96),
  counterparty_cname          VARCHAR2(384),
  counterparty_ename          VARCHAR2(384),
  contact_name                VARCHAR2(90),
  telephone                   VARCHAR2(30),
  fax                         VARCHAR2(30),
  update_user                 NUMBER(5),
  update_time                 DATE,
  is_issuer                   VARCHAR2(2),
  is_bank                     VARCHAR2(2),
  is_guarantee                VARCHAR2(2),
  is_custody                  VARCHAR2(2),
  customer_type               VARCHAR2(30),
  parent                      NUMBER,
  rating_level                NVARCHAR2(24),
  ex_code                     VARCHAR2(96),
  ex_account                  VARCHAR2(96),
  swift_code                  VARCHAR2(96),
  ref_issuer_id               VARCHAR2(60),
  cfets_member_id             VARCHAR2(60),
  counterparty_short_cname    VARCHAR2(384),
  counterparty_short_ename    VARCHAR2(384),
  cfets_fx_member_id          VARCHAR2(75),
  cfets_member_attr           VARCHAR2(2),
  counterparty_fx_short_ename VARCHAR2(384),
  interbanktype               VARCHAR2(96),
  overseas                    VARCHAR2(96),
  start_dt                    DATE,
  end_dt                      DATE,
  id_mark                     VARCHAR2(10),
  etl_timestamp               TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
