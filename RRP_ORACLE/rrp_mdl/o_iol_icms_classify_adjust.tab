create table RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST
(
  serialno             VARCHAR2(64),
  objecttype           VARCHAR2(64),
  productid            VARCHAR2(64),
  adjustdate           DATE,
  adjustapplyer        VARCHAR2(64),
  customername         VARCHAR2(200),
  adjustorgid          VARCHAR2(64),
  approvestatus        VARCHAR2(64),
  operatedate          DATE,
  inputdate            DATE,
  adjusttype           VARCHAR2(36),
  belongdept           VARCHAR2(64),
  inputuserid          VARCHAR2(64),
  updatedate           DATE,
  corporgid            VARCHAR2(64),
  objectno             VARCHAR2(64),
  operateorgid         VARCHAR2(64),
  customerid           VARCHAR2(16),
  adjustreason         VARCHAR2(1000),
  updateorgid          VARCHAR2(64),
  migtflag             VARCHAR2(80),
  adjustclassifyresult VARCHAR2(36),
  currclassifytype     VARCHAR2(36),
  updateuserid         VARCHAR2(64),
  adjustfinishdate     DATE,
  accountmonth         VARCHAR2(64),
  inputorgid           VARCHAR2(64),
  relativeserialno     VARCHAR2(64),
  operateuserid        VARCHAR2(64),
  currclassifyresult   VARCHAR2(64),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST
  is '风险分类调整';
comment on column RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST.serialno
  is '流水号';
comment on column RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST.objecttype
  is '对象类型对象类型(合同/借据)';
comment on column RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST.productid
  is '业务品种';
comment on column RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST.adjustdate
  is '调整申请日期';
comment on column RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST.adjustapplyer
  is '调整申请人';
comment on column RRP_MDL.O_IOL_ICMS_CLASSIFY_ADJUST.customername
