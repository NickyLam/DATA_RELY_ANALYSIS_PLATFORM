comment on column RRP_MDL.O_IOL_NIBS_IB_DEV_DEVICEMODEL_INFO.devcardbox
  is '卡箱个数';
comment on column RRP_MDL.O_IOL_NIBS_IB_DEV_DEVICEMODEL_INFO.creator
