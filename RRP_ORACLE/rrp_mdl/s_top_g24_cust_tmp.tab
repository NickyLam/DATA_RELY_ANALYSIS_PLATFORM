create table RRP_MDL.S_TOP_G24_CUST_TMP
(
  org_no  VARCHAR2(8),
  cust_id VARCHAR2(64)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.S_TOP_G24_CUST_TMP
  is 'G24最大百家客户临时表';
comment on column RRP_MDL.S_TOP_G24_CUST_TMP.org_no
  is '机构编号';
comment on column RRP_MDL.S_TOP_G24_CUST_TMP.cust_id
  is '客户号';

