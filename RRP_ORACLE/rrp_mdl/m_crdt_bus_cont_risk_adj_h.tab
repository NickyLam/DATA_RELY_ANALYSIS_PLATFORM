create table RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H
(
  agt_id                  VARCHAR2(60),
  lp_id                   VARCHAR2(60),
  flow_num                VARCHAR2(60),
  cust_id                 VARCHAR2(60),
  cust_name               VARCHAR2(150),
  bus_cont_id             VARCHAR2(60),
  bus_type_cd             VARCHAR2(30),
  bus_curr_cd             VARCHAR2(60),
  bal                     NUMBER(30,8),
  bf_adj_level5_cls_cd    VARCHAR2(30),
  a_adjust_level5_cls_cd  VARCHAR2(30),
  bf_adj_level11_cls_cd   VARCHAR2(30),
  a_adjust_level11_cls_cd VARCHAR2(30),
  adj_dt                  DATE,
  mg_prot_teller_id       VARCHAR2(30),
  mg_prot_org_id          VARCHAR2(30),
  rela_flow_id            VARCHAR2(60),
  rela_flow_type_cd       VARCHAR2(30),
  obj_type_cd             VARCHAR2(30),
  obj_descb               VARCHAR2(90),
  init_teller_id          VARCHAR2(30),
  etl_dt                  DATE,
  src_table_name          VARCHAR2(150),
  job_cd                  VARCHAR2(10),
  etl_timestamp           TIMESTAMP(6),
  data_dt                 CHAR(8),
  dubil_id                VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H
  is '信贷业务合同风险调整历史';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.agt_id
  is '协议编号';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.lp_id
  is '法人编号';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.flow_num
  is '流水号';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.cust_id
  is '客户编号';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.cust_name
  is '客户名称';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.bus_cont_id
  is '业务合同编号';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.bus_type_cd
  is '业务类型代码';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.bus_curr_cd
  is '业务币种代码';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.bal
