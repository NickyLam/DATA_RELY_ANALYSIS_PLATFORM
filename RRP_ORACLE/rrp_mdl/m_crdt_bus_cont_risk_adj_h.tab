comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.obj_type_cd
  is '对象类型代码';
comment on column RRP_MDL.M_CRDT_BUS_CONT_RISK_ADJ_H.obj_descb
