alter table RRP_MDL.B_GUA_COLL_INFO_YZI
  add constraint PK_B_GUA_COLL_INFO_YZI primary key (DATA_DT, COLL_ID, ORG_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

