create table RRP_MDL.B_GUA_COLL_INFO_YZI
(
  data_dt                 CHAR(8) not null,
  lgl_rep_id              VARCHAR2(200),
  coll_id                 VARCHAR2(200) not null,
  cust_id                 VARCHAR2(200),
  org_id                  VARCHAR2(200) not null,
  coll_typ                VARCHAR2(10),
  coll_nm                 VARCHAR2(500),
  cur                     CHAR(3),
  coll_orig_val           NUMBER(30,2),
  init_valt               NUMBER(30,2),
  bank_idnt_prc_val       NUMBER(30,2),
  aldy_mtg_val            NUMBER(30,2),
  ases_val                NUMBER(30,2),
  ases_dt                 CHAR(8),
  ases_org_nm             VARCHAR2(500),
  first_valt_dt           CHAR(8),
  valt_exp_dt             CHAR(8),
  regd_org_id             VARCHAR2(200),
  opr_org_id              VARCHAR2(200),
  coll_eff_dt             CHAR(8),
  coll_exp_dt             CHAR(8),
  plg_tkt_acc             VARCHAR2(200),
  plg_tkt_typ             VARCHAR2(10),
  plg_tkt_no              VARCHAR2(200),
  plg_tkt_amt             NUMBER(30,2),
  plg_tkt_isu_org_id      VARCHAR2(200),
  plg_tkt_estb_dt         CHAR(8),
  wrnt_regd_no            VARCHAR2(200),
  wrnt_nm                 VARCHAR2(500),
  wrnt_valid_exp_dt       CHAR(8),
  regd_valid_end_dt       CHAR(8),
  coll_cust_rsk_rtg_cl    VARCHAR2(10),
  dir_acq_flg             CHAR(1),
  qual_mtgn_flg           CHAR(1),
  re_mtg_plg_fin_coll_flg CHAR(1),
  regd_dt                 CHAR(8),
  mtrl_obj_coll_dt        CHAR(8),
  ases_mode               VARCHAR2(10),
  ases_method             VARCHAR2(10),
  valt_cyc                VARCHAR2(10),
  wrnt_regd_area          NUMBER(30,2),
  coll_owner_nm           VARCHAR2(500),
  coll_owner_crdl_typ     VARCHAR2(10),
  coll_owner_crdl_no      VARCHAR2(100),
  trd_coll_owner_flg      CHAR(1),
  coll_stat               VARCHAR2(10),
  dept_line               VARCHAR2(500),
  data_src                VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220228 values ('20220228')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_GUA_COLL_INFO_YZI
  is '抵质押物详细信息';
