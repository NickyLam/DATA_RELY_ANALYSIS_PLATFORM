create table RRP_MDL.O_ICL_CMM_ELEC_CHN_TRAN_DTL
(
  etl_dt                     DATE,
  lp_id                      VARCHAR2(60),
  tran_flow_num              VARCHAR2(200),
  ova_chn_flow_num           VARCHAR2(100),
  core_tran_flow_num         VARCHAR2(200),
  sorc_sys_flow_num          VARCHAR2(100),
  osb_tran_flow_num          VARCHAR2(200),
  rela_timing_task_id        VARCHAR2(200),
  chn_cd                     VARCHAR2(60),
  tran_dt                    DATE,
  tran_tm                    VARCHAR2(60),
  core_tran_dt               DATE,
  tran_type_code             VARCHAR2(250),
  tran_status_cd             VARCHAR2(10),
  tran_return_code           VARCHAR2(250),
  tran_acct_id               VARCHAR2(200),
  tran_acct_name             VARCHAR2(500),
  tran_amt                   NUMBER(30,4),
  curr_cd                    VARCHAR2(10),
  elec_chn_user_id           VARCHAR2(200),
  cust_id                    VARCHAR2(200),
  termn_ip_addr              VARCHAR2(500),
  tran_comm_fee              NUMBER(30,4),
  termn_mac_addr             VARCHAR2(500),
  termn_equip_model          VARCHAR2(200),
  termn_equip_id             VARCHAR2(200),
  cntpty_acct_id             VARCHAR2(60),
  cntpty_acct_name           VARCHAR2(500),
  cntpty_acct_open_bank_num  VARCHAR2(60),
  cntpty_acct_open_bank_name VARCHAR2(500),
  cntpty_acct_prov_cd        VARCHAR2(10),
  cntpty_acct_city_cd        VARCHAR2(10),
  memo_cd                    VARCHAR2(60),
  memo_descb                 VARCHAR2(500),
  tran_batch_no              VARCHAR2(60),
  tran_org_id                VARCHAR2(60),
  camp_emply_id              VARCHAR2(60),
  olbk_tran_src_cd           VARCHAR2(10),
  job_cd                     VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
