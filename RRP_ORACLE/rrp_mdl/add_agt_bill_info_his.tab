create table RRP_MDL.ADD_AGT_BILL_INFO_HIS
(
  vouch_id               VARCHAR2(100),
  bill_id                VARCHAR2(60),
  lp_id                  VARCHAR2(60),
  bill_num               VARCHAR2(60),
  role_src_cd            VARCHAR2(10),
  discnt_batch_id        VARCHAR2(60),
  pbc_tranbl_flg         VARCHAR2(10),
  hxb_acpt_flg           VARCHAR2(10),
  bill_med_cd            VARCHAR2(10),
  bill_type_cd           VARCHAR2(10),
  draw_dt                DATE,
  fac_val_exp_dt         DATE,
  drawer_cate_cd         VARCHAR2(10),
  drawer_orgnz_cd        VARCHAR2(30),
  drawer_name            VARCHAR2(150),
  drawer_acct_num        VARCHAR2(60),
  drawer_open_bank_num   VARCHAR2(60),
  accptor_open_bank_name VARCHAR2(250),
  drawer_open_bank_name  VARCHAR2(375),
  accptor_cate_cd        VARCHAR2(30),
  accptor_name           VARCHAR2(250),
  accptor_open_bank_num  VARCHAR2(60),
  accptor_acct_num       VARCHAR2(100),
  recver_name            VARCHAR2(375),
  recver_acct_num        VARCHAR2(60),
  recver_open_bank_num   VARCHAR2(60),
  recver_open_bank_name  VARCHAR2(375),
  bill_amt               NUMBER(30,2),
  bill_belong_org_id     VARCHAR2(60),
  bill_status_cd         VARCHAR2(30),
  loss_flg               VARCHAR2(10),
  final_modif_operr_id   VARCHAR2(60),
  final_modif_tm         TIMESTAMP(6),
  receipt_flg            VARCHAR2(10),
  redcst_flg             VARCHAR2(30),
  h_data_flg             VARCHAR2(100),
  create_dt              DATE,
  update_dt              DATE,
  etl_dt                 DATE,
  id_mark                VARCHAR2(10),
  src_table_name         VARCHAR2(100),
  job_cd                 VARCHAR2(10),
  etl_timestamp          TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.ADD_AGT_BILL_INFO_HIS
  is '历史票据信息';
comment on column RRP_MDL.ADD_AGT_BILL_INFO_HIS.vouch_id
  is '凭证编号';
