create table RRP_MDL.O_ICL_CMM_BILL_ACPT_INFO
(
  etl_dt                    DATE,
  lp_id                     VARCHAR2(60),
  bus_id                    VARCHAR2(60),
  batch_id                  VARCHAR2(60),
  bill_entry_id             VARCHAR2(60),
  bill_id                   VARCHAR2(60),
  bill_num                  VARCHAR2(90),
  bill_sub_intrv_id         VARCHAR2(60),
  cust_id                   VARCHAR2(60),
  bill_med_cd               VARCHAR2(10),
  bill_kind_cd              VARCHAR2(10),
  appl_dt                   DATE,
  recv_dt                   DATE,
  draw_dt                   DATE,
  exp_dt                    DATE,
  dir_indus_name            VARCHAR2(150),
  main_guar_way_cd          VARCHAR2(30),
  drawer_name               VARCHAR2(500),
  drawer_cate_cd            VARCHAR2(10),
  drawer_acct_num           VARCHAR2(100),
  drawer_open_bank_no       VARCHAR2(90),
  drawer_open_bank_name     VARCHAR2(500),
  accptor_name              VARCHAR2(500),
  accptor_acct_num          VARCHAR2(90),
  accptor_open_bank_no      VARCHAR2(90),
  accptor_open_bank_name    VARCHAR2(750),
  recver_cust_id            VARCHAR2(60),
  recver_name               VARCHAR2(500),
  recver_acct_num           VARCHAR2(90),
  recver_open_bank_no       VARCHAR2(90),
  recver_open_bank_name     VARCHAR2(750),
  repay_num                 VARCHAR2(100),
  entry_dt                  DATE,
  revo_dt                   DATE,
  bus_flow_num              VARCHAR2(60),
  margin_ratio              NUMBER(38,8),
  comm_fee_ratio            NUMBER(18,6),
  entry_status_cd           VARCHAR2(10),
  draw_status_cd            VARCHAR2(10),
  bill_acpt_status_cd       VARCHAR2(10),
  tranbl_flg                VARCHAR2(10),
  uncond_pay_flg            VARCHAR2(10),
  curr_cd                   VARCHAR2(10),
  fac_val_amt               NUMBER(30,2),
  payoff_flg                VARCHAR2(10),
  lmt_ocup_amt              NUMBER(30,2),
  lmt_ocup_status_cd        VARCHAR2(10),
  comm_fee                  NUMBER(18,2),
  todos                     NUMBER(18,2),
  acpt_fee                  NUMBER(30,2),
  mgmt_fee                  NUMBER(30,2),
  accptor_crdt_level_cd     VARCHAR2(10),
  accptor_rating_exp_dt     DATE,
  issue_org_id              VARCHAR2(60),
  enter_acct_org_id         VARCHAR2(60),
  cust_mgr_id               VARCHAR2(60),
  dept_id                   VARCHAR2(60),
  operr_id                  VARCHAR2(60),
  group_open_flg            VARCHAR2(10),
  group_name                VARCHAR2(500),
  group_id                  VARCHAR2(60),
  group_open_drawer_name    VARCHAR2(500),
  group_open_drawer_cust_no VARCHAR2(500),
  rela_party_que_rest_cd    VARCHAR2(30),
  job_cd                    VARCHAR2(10),
  etl_timestamp             TIMESTAMP(6),
  acpt_agt_batch_id         VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
