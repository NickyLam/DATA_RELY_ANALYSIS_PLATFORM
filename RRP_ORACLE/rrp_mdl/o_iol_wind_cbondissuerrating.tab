create table RRP_MDL.O_IOL_WIND_CBONDISSUERRATING
(
  object_id                  VARCHAR2(150),
  s_info_compname            VARCHAR2(150),
  ann_dt                     VARCHAR2(12),
  b_rate_style               VARCHAR2(150),
  b_info_creditrating        VARCHAR2(60),
  b_rate_ratingoutlook       NUMBER(9),
  b_info_creditratingagency  VARCHAR2(15),
  s_info_compcode            VARCHAR2(15),
  b_info_creditratingexplain VARCHAR2(1500),
  b_info_precreditrating     VARCHAR2(60),
  b_creditrating_change      VARCHAR2(15),
  b_info_issuerratetype      NUMBER(9),
  ann_dt2                    VARCHAR2(12),
  etl_dt                     DATE,
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_WIND_CBONDISSUERRATING
  is '中国债券发行主体信用评级表';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.object_id
  is '对象ID';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.s_info_compname
  is '公司名称';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.ann_dt
  is '公告日期';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.b_rate_style
  is '品种类别代码';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.b_info_creditrating
  is '信用评级';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.b_rate_ratingoutlook
  is '评级展望';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.b_info_creditratingagency
  is '评估机构代码';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.s_info_compcode
  is '公司ID';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.b_info_creditratingexplain
  is '信用评级说明';
comment on column RRP_MDL.O_IOL_WIND_CBONDISSUERRATING.b_info_precreditrating
