create table RRP_MDL.CONFIG_AREA
(
  new_area_cd       VARCHAR2(200),
  admin_plan_lvl    VARCHAR2(500),
  admin_plan_typ    VARCHAR2(500),
  lvl1_area         VARCHAR2(500),
  lvl2_area         VARCHAR2(500),
  lvl3_area         VARCHAR2(501),
  area_cd           VARCHAR2(200),
  cnty_dmn          VARCHAR2(15),
  poor_cnty         VARCHAR2(750),
  natl_revital_cnty VARCHAR2(750),
  farm_loc          VARCHAR2(500),
  bth_coor_dev_flg  VARCHAR2(10),
  yeb_flg           VARCHAR2(10),
  gba_flg           VARCHAR2(10),
  yrd_area_flg      VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.CONFIG_AREA
  is '中国行政区划2020-附录状态表';
comment on column RRP_MDL.CONFIG_AREA.new_area_cd
  is '新行政区划代码 匹配CONFIG_CODE表中最新的行政区划代码';
comment on column RRP_MDL.CONFIG_AREA.admin_plan_lvl
  is '行政规划级别';
comment on column RRP_MDL.CONFIG_AREA.admin_plan_typ
  is '行政规划类别';
comment on column RRP_MDL.CONFIG_AREA.lvl1_area
  is '一级行政区划';
comment on column RRP_MDL.CONFIG_AREA.lvl2_area
  is '二级行政区划';
comment on column RRP_MDL.CONFIG_AREA.lvl3_area
  is '三级行政区划';
comment on column RRP_MDL.CONFIG_AREA.area_cd
  is '行政区划代码 此部分为 中国行政区划2020版 行政区划 代码';
comment on column RRP_MDL.CONFIG_AREA.cnty_dmn
  is '县域';
comment on column RRP_MDL.CONFIG_AREA.poor_cnty
  is '贫困县';
comment on column RRP_MDL.CONFIG_AREA.natl_revital_cnty
  is '国家乡村振兴重点帮扶县';
comment on column RRP_MDL.CONFIG_AREA.farm_loc
  is '农户所在地';
comment on column RRP_MDL.CONFIG_AREA.bth_coor_dev_flg
  is '京津冀协同发展地区';
comment on column RRP_MDL.CONFIG_AREA.yeb_flg
  is '长江经济带地区';
comment on column RRP_MDL.CONFIG_AREA.gba_flg
  is '粤港澳大湾区';
comment on column RRP_MDL.CONFIG_AREA.yrd_area_flg
  is '长三角区域一体化地区';

