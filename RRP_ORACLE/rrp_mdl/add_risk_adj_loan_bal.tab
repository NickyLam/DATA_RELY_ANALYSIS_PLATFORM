create table RRP_MDL.ADD_RISK_ADJ_LOAN_BAL
(
  dubil_id VARCHAR2(100),
  cont_id  VARCHAR2(100),
  loan_bal NUMBER(20,2),
  adj_dt   CHAR(8),
  data_src VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.ADD_RISK_ADJ_LOAN_BAL
  is '利率补录';
comment on column RRP_MDL.ADD_RISK_ADJ_LOAN_BAL.dubil_id
  is '借据编号';
comment on column RRP_MDL.ADD_RISK_ADJ_LOAN_BAL.cont_id
  is '合同编号';
comment on column RRP_MDL.ADD_RISK_ADJ_LOAN_BAL.loan_bal
  is '贷款余额';
comment on column RRP_MDL.ADD_RISK_ADJ_LOAN_BAL.adj_dt
  is '调整日期';
comment on column RRP_MDL.ADD_RISK_ADJ_LOAN_BAL.data_src
  is '数据来源';

