create table RRP_MDL.XZY_XG
(
  scm        VARCHAR2(66),
  tab_name   VARCHAR2(400),
  tab_cn     VARCHAR2(800),
  tab_col    VARCHAR2(400),
  tab_col_cn VARCHAR2(2000),
  tab_chg    VARCHAR2(400)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

