  attr17               VARCHAR2(250),
  attr18               VARCHAR2(250),
  attr19               VARCHAR2(250),
  attr20               VARCHAR2(250),
  attr21               VARCHAR2(250),
  attr22               VARCHAR2(250),
  attr23               VARCHAR2(250),
  attr24               VARCHAR2(250),
  attr25               VARCHAR2(250),
  use_flg              VARCHAR2(10),
