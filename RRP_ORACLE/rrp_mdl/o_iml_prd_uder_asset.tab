create table RRP_MDL.O_IML_PRD_UDER_ASSET
(
  intnal_asset_id      VARCHAR2(100),
  lp_id                VARCHAR2(60),
  up_level_asset_id    VARCHAR2(100),
  fin_instm_id         VARCHAR2(100),
  asset_type_id        VARCHAR2(100),
  market_type_id       VARCHAR2(100),
  asset_id             VARCHAR2(100),
  asset_name           VARCHAR2(750),
  asset_cls_cd         VARCHAR2(30),
  asset_subdv_cd       VARCHAR2(30),
  invest_amt           NUMBER(30,8),
  invest_dt            DATE,
  value_dt             DATE,
  exp_dt               DATE,
  int_rat              NUMBER(18,8),
  pay_int_freq         VARCHAR2(30),
  fir_pay_int_dt       DATE,
  curr_cd              VARCHAR2(30),
  imp_dt               DATE,
  cntpty_id            VARCHAR2(100),
  uder_asset_status_cd VARCHAR2(30),
  ocup_crdt_flg        VARCHAR2(10),
  crdt_status_cd       VARCHAR2(30),
  crdt_main_id         VARCHAR2(100),
  crdt_wt              NUMBER(18,6),
  crdt_amt             NUMBER(30,8),
  checker_id           VARCHAR2(100),
  check_tm             TIMESTAMP(6),
  check_dt             DATE,
  invest_ratio         NUMBER(18,6),
  risk_wt              NUMBER(18,6),
  rating_rest_cd       VARCHAR2(30),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  src_table_name       VARCHAR2(100),
  job_cd               VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PRD_UDER_ASSET
  is '底层资产表';
comment on column RRP_MDL.O_IML_PRD_UDER_ASSET.intnal_asset_id
  is '内部资产编号';
