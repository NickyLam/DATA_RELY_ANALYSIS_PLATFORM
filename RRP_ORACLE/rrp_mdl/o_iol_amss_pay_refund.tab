create table RRP_MDL.O_IOL_AMSS_PAY_REFUND
(
  refund_no                  VARCHAR2(32),
  order_no                   VARCHAR2(32),
  mch_id                     NUMBER(11),
  total_fee                  NUMBER(11),
  refund_fee                 NUMBER(11),
  add_time                   TIMESTAMP(6),
  refund_state               NUMBER(4),
  order_state                NUMBER(4),
  trade_type                 VARCHAR2(32),
  trade_name                 VARCHAR2(64),
  refundid                   VARCHAR2(64),
  transaction_id             VARCHAR2(64),
  out_refund_no              VARCHAR2(32),
  out_trade_no               VARCHAR2(32),
  refund_channel             VARCHAR2(32),
  refund_user                VARCHAR2(32),
  update_version             NUMBER(11),
  mch_audit                  NUMBER(11),
  daemon_audit               NUMBER(11),
  refund_time                TIMESTAMP(6),
  refuse_reason              VARCHAR2(256),
  mch_refuse_reason          VARCHAR2(256),
  refund_source              NUMBER(1),
  mch_no                     VARCHAR2(32),
  mch_name                   VARCHAR2(64),
  fee_type                   VARCHAR2(6),
  group_id                   NUMBER(11),
  groupno                    VARCHAR2(32),
  center_id                  NUMBER(11),
  risk_ctr                   NUMBER(4),
  risk_info                  VARCHAR2(64),
  mch_audit_user             VARCHAR2(32),
  pt_audit_user              VARCHAR2(32),
  bank_no                    VARCHAR2(32),
  agentno                    VARCHAR2(32),
  deparno                    VARCHAR2(32),
  termtype                   VARCHAR2(16),
  termno                     VARCHAR2(32),
  operno                     VARCHAR2(32),
  shopno                     VARCHAR2(32),
  mch_review_time            TIMESTAMP(6),
  pt_review_time             TIMESTAMP(6),
  agentid                    VARCHAR2(32),
  group_no                   VARCHAR2(32),
  client_ip                  VARCHAR2(32),
  data_sign                  VARCHAR2(128),
  modify_time                TIMESTAMP(6),
  mdiscount                  NUMBER(11),
  union_id                   VARCHAR2(32),
  bank_type                  VARCHAR2(32),
  openid                     VARCHAR2(255),
  sub_openid                 VARCHAR2(255),
  fld_s1                     VARCHAR2(255),
  fld_s2                     VARCHAR2(255),
  fld_s3                     VARCHAR2(255),
  bs_discount                NUMBER(11),
  bs_discount_type           VARCHAR2(16),
  sign_agentno               VARCHAR2(32),
  fld_s4                     VARCHAR2(255),
  fld_s5                     VARCHAR2(255),
  fld_s6                     VARCHAR2(255),
  fld_s7                     VARCHAR2(255),
  fld_s8                     VARCHAR2(255),
  mch_discount_amount        NUMBER(13,2),
  plat_discount_amount       NUMBER(13,2),
  mch_rate_type              NUMBER(1),
  mch_rate                   NUMBER(11),
  cost_rate                  NUMBER(11),
  mch_theory_procedure_fee   NUMBER(13,2),
  mch_real_procedure_fee     NUMBER(13,2),
  mch_discount_fee           NUMBER(13,2),
  debit_card_brokerage_limit NUMBER(13,2),
  ori_mch_theory_fee         NUMBER(13,2),
  ori_mch_real_fee           NUMBER(13,2),
  calc_state                 NUMBER(1),
  api_provider               NUMBER(11),
  pay_center_id              VARCHAR2(32),
  quick_serial_no            VARCHAR2(256),
  acc_way_period             NUMBER(5),
  acct_dt                    VARCHAR2(32),
  start_dt                   DATE,
  end_dt                     DATE,
  id_mark                    VARCHAR2(10),
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_AMSS_PAY_REFUND
