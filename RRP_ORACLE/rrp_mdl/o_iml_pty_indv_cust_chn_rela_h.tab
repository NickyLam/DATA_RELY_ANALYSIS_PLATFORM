create table RRP_MDL.O_IML_PTY_INDV_CUST_CHN_RELA_H
(
  party_id                 VARCHAR2(100),
  belong_plat_cd           VARCHAR2(30),
  lp_id                    VARCHAR2(60),
  sign_chn_cd              VARCHAR2(30),
  user_seq_num             VARCHAR2(60),
  logon_acct_id            VARCHAR2(100),
  user_acct_status_cd      VARCHAR2(30),
  open_tm                  TIMESTAMP(6),
  clos_acct_tm             TIMESTAMP(6),
  onl_bank_pause_status_cd VARCHAR2(30),
  onl_bank_pause_end_tm    TIMESTAMP(6),
  onl_bank_pause_start_tm  TIMESTAMP(6),
  mbank_pause_status_cd    VARCHAR2(30),
  mbank_pause_start_tm     TIMESTAMP(6),
  mbank_pause_end_tm       TIMESTAMP(6),
  e_acct_sign_plat_cd      VARCHAR2(30),
  save_cert_way_cd         VARCHAR2(30),
  start_dt                 DATE,
  end_dt                   DATE,
  id_mark                  VARCHAR2(10),
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_INDV_CUST_CHN_RELA_H
  is '个人客户';
comment on column RRP_MDL.O_IML_PTY_INDV_CUST_CHN_RELA_H.party_id
