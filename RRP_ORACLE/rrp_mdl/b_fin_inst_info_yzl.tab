create table RRP_MDL.B_FIN_INST_INFO_YZL
(
  data_dt                  CHAR(8) not null,
  lgl_rep_id               VARCHAR2(200),
  org_id                   VARCHAR2(200),
  fin_inst_id              VARCHAR2(200) not null,
  fin_inst_nm              VARCHAR2(500),
  ast_typ                  VARCHAR2(10),
  cur                      CHAR(3),
  isu_prc                  NUMBER(30,2),
  isu_tot_scale            NUMBER(30,2),
  isu_org_nm               VARCHAR2(500),
  isu_org_id               VARCHAR2(200),
  isu_ctry_cd              VARCHAR2(200),
  isu_dt                   CHAR(8),
  exp_dt                   CHAR(8),
  rate_typ                 VARCHAR2(10),
  act_rate                 NUMBER(20,6),
  option_flg               CHAR(1),
  rctly_ases_prc           NUMBER(30,2),
  ases_prc_dt              CHAR(8),
  base_ast_id              VARCHAR2(200),
  base_ast_nm              VARCHAR2(500),
  base_ast_scale           NUMBER(30,2),
  base_ast_pct             NUMBER(18,4),
  base_ast_rtg             VARCHAR2(10),
  base_ast_rtg_org_nm      VARCHAR2(500),
  base_ast_cust_nm         VARCHAR2(500),
  base_ast_cust_ctry_cd    VARCHAR2(10),
  base_ast_cust_rtg        VARCHAR2(10),
  base_ast_cust_rtg_org_nm VARCHAR2(500),
  base_ast_cust_idy        VARCHAR2(10),
  fnl_dir_typ              VARCHAR2(10),
  fnl_dir_idy              VARCHAR2(10),
  dept_line                VARCHAR2(500),
  data_src                 VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20220228 values ('20220228')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_FIN_INST_INFO_YZL
  is '金融工具基础信息';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.data_dt
  is '数据日期';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.org_id
  is '机构编号';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.fin_inst_id
  is '金融工具编号';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.fin_inst_nm
  is '金融工具名称';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.ast_typ
  is '资产类型';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.cur
  is '币种';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.isu_prc
  is '发行价格';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.isu_tot_scale
  is '发行总规模';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.isu_org_nm
  is '发行机构名称';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.isu_org_id
  is '发行机构编码';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.isu_ctry_cd
  is '发行国家代码';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.isu_dt
