comment on column RRP_MDL.B_FIN_INST_INFO_YZL.data_src
  is '数据来源';
alter table RRP_MDL.B_FIN_INST_INFO_YZL
  add constraint PK_B_FIN_INST_INFO_YZL primary key (DATA_DT, FIN_INST_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

