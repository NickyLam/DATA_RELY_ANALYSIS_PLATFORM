comment on column RRP_MDL.B_FIN_INST_INFO_YZL.base_ast_rtg_org_nm
  is '基础资产评级机构';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.base_ast_cust_nm
  is '基础资产客户名称';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.base_ast_cust_ctry_cd
