comment on column RRP_MDL.B_FIN_INST_INFO_YZL.ases_prc_dt
  is '评估价格日期';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.base_ast_id
  is '基础资产编号';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.base_ast_nm
  is '基础资产名称';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.base_ast_scale
  is '基础资产规模';
comment on column RRP_MDL.B_FIN_INST_INFO_YZL.base_ast_pct
