create table RRP_MDL.O_IOL_CTMS_TBS_VS_ADDONPORTFOLIO
(
  addonportfolio_id     NUMBER,
  aspclient_id          NUMBER,
  owner_number          NUMBER,
  owner_code            VARCHAR2(192),
  owner_name            VARCHAR2(192),
  portfolio_id          NUMBER,
  portfolioname         VARCHAR2(120),
  keepfolder_id_default NUMBER,
  assettype_id_default  NUMBER,
  lastmodified          TIMESTAMP(6),
  datasymbol_id         NUMBER,
  buztype_id_default    NUMBER,
  status                VARCHAR2(2),
  nstd_id_default       NUMBER,
  pntt_type             VARCHAR2(2),
  asset_code            VARCHAR2(24),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_CTMS_TBS_VS_ADDONPORTFOLIO
