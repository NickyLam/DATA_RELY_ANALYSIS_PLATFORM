create table RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL
(
  evt_id             VARCHAR2(250),
  lp_id              VARCHAR2(60),
  tran_dt            DATE,
  tran_flow_num      VARCHAR2(150),
  batch_id           VARCHAR2(100),
  deduct_seq_num     VARCHAR2(90),
  acct_id            VARCHAR2(100),
  acct_name          VARCHAR2(150),
  amt                NUMBER(30,2),
  acct_num_resp_code VARCHAR2(45),
  acct_num_resp_info VARCHAR2(150),
  host_flow_num      VARCHAR2(150),
  host_tran_dt       DATE,
  host_return_code   VARCHAR2(45),
  host_return_info   VARCHAR2(1500),
  etl_dt             DATE,
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL
  is '代发代扣签约信息历史';
comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.evt_id
  is '事件编号';
comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.tran_dt
