comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.acct_name
  is '账户名称';
comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.amt
  is '金额';
comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.acct_num_resp_code
