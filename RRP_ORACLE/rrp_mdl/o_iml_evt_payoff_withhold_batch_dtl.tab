  is '批次编号';
comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.deduct_seq_num
  is '扣款序号';
comment on column RRP_MDL.O_IML_EVT_PAYOFF_WITHHOLD_BATCH_DTL.acct_id
