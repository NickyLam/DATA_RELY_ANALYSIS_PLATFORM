create table RRP_MDL.XZY_BYTE
(
  owner          VARCHAR2(512),
  segment_name   VARCHAR2(512),
  partition_name VARCHAR2(512),
  bytes          NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

