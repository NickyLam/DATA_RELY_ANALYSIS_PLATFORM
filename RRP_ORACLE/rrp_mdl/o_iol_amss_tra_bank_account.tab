create table RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT
(
  account_id             VARCHAR2(16),
  org_id                 VARCHAR2(32),
  account_code           VARCHAR2(128),
  bank_id                NUMBER(10),
  account_name           VARCHAR2(128),
  account_type           NUMBER(4),
  contact_line           VARCHAR2(64),
  remit_account_code     VARCHAR2(128),
  is_inline              NUMBER(1),
  bank_name              VARCHAR2(128),
  province               VARCHAR2(16),
  city                   VARCHAR2(16),
  id_card_type           NUMBER(4),
  id_card                VARCHAR2(128),
  address                VARCHAR2(512),
  tel                    VARCHAR2(64),
  examine_status         NUMBER(4),
  examine_time           TIMESTAMP(6),
  examine_status_remark  VARCHAR2(256),
  examine_emp            VARCHAR2(32),
  enabled                NUMBER(1),
  data_sign              VARCHAR2(128),
  data_source            NUMBER(4),
  fld_s1                 VARCHAR2(256),
  fld_s2                 VARCHAR2(256),
  fld_s3                 VARCHAR2(256),
  fld_n1                 NUMBER(10),
  fld_n2                 NUMBER(10),
  fld_n3                 NUMBER(10),
  fld_d1                 TIMESTAMP(6),
  create_user            NUMBER(10),
  create_emp             VARCHAR2(32),
  create_time            TIMESTAMP(6),
  update_time            TIMESTAMP(6),
  check_auth             NUMBER(4),
  e_account_code         VARCHAR2(64),
  account_en_name        VARCHAR2(64),
  account_expired_date   DATE,
  account_postcode       VARCHAR2(16),
  check_auth3            VARCHAR2(1),
  check_auth4            VARCHAR2(1),
  e_account_enabled      NUMBER(1),
  sft_merchant_id        VARCHAR2(32),
  fee_code               VARCHAR2(32),
  fee_code2              VARCHAR2(32),
  subject_account        VARCHAR2(32),
  unit_prop              VARCHAR2(4),
  new_account_code       VARCHAR2(64),
  account_properties     NUMBER(10),
  new_remit_account_code VARCHAR2(64),
  point_payment          NUMBER(1),
  points_offer           NUMBER(5),
  start_dt               DATE,
  end_dt                 DATE,
  id_mark                VARCHAR2(10),
  etl_timestamp          TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT
  is '银行结算账户表';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.account_id
  is '账户ID.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.org_id
  is '机构ID.对应渠道编号或商户编号';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.account_code
  is '银行卡号.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.bank_id
  is '开户银行.关联银行表( CMS_BANK )';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.account_name
  is '开户人.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.account_type
  is '帐户类型.1:企业 ;2:个人;5:内部户';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.contact_line
  is '联行号.网点号、联行号';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.remit_account_code
  is '汇出方银行卡号.兴业叫汇出方银行卡号，浦发叫现代支付号';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.is_inline
  is '是否行内账号.true:是，false:不是';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.bank_name
  is '开户支行名称.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.province
  is '开户支行所在省.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.city
  is '开户支行所在市.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.id_card_type
  is '持卡人证件类型.从系统类型表来';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.id_card
  is '持卡人证件号码.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.address
  is '持卡人地址.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.tel
  is '手机号码.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.examine_status
  is '审核状态.0:未审核;1:审核通过;2:审核不通过;3:需再次审核';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.examine_time
  is '审核时间.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.examine_status_remark
  is '审核备注.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.examine_emp
  is '审核人.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.enabled
  is '是否启用.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.data_sign
  is '数据签名.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.data_source
  is '数据来源.1:界面录入;2:基础资料导入导出:3:数据迁移';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.fld_s1
  is '结算账户的支出户名';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.fld_s2
  is '字符型保留字段2.';
comment on column RRP_MDL.O_IOL_AMSS_TRA_BANK_ACCOUNT.fld_s3
