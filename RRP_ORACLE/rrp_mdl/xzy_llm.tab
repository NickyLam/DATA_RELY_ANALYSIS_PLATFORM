create table RRP_MDL.XZY_LLM
(
  table_name VARCHAR2(400),
  table_n_cn VARCHAR2(400),
  table_zxd  VARCHAR2(400),
  table_bqsm VARCHAR2(400),
  col_name   VARCHAR2(400),
  col_cmt    VARCHAR2(400),
  col_zxd    VARCHAR2(400),
  col_bqsm   VARCHAR2(400)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

