create table RRP_MDL.M_TRA_LOAN_DTL_TEMP05
(
  rcpt_id       VARCHAR2(200),
  std_prod_id   VARCHAR2(100),
  tra_dr_cr_flg VARCHAR2(1),
  opp_acc       VARCHAR2(300),
  opp_acc_nm    VARCHAR2(750),
  opp_pbc_no    VARCHAR2(200),
  opp_bank_nm   VARCHAR2(750)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_TRA_LOAN_DTL_TEMP05
  is '贷款账户交易流水--对方账号信息';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP05.rcpt_id
  is '借据号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP05.std_prod_id
  is '标准产品编号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP05.tra_dr_cr_flg
  is '交易借贷标志';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP05.opp_acc
  is '对方账号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP05.opp_acc_nm
  is '对方户名';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP05.opp_pbc_no
  is '对方行号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP05.opp_bank_nm
  is '对方行名';

