create table RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR
(
  evt_id             VARCHAR2(100),
  lp_id              VARCHAR2(60),
  tran_dt            DATE,
  instr_flow_num     VARCHAR2(60),
  tran_flow_num      VARCHAR2(60),
  tran_org_id        VARCHAR2(60),
  tran_kind_cd       VARCHAR2(10),
  acct_id            VARCHAR2(60),
  accting_code       VARCHAR2(60),
  bal_compnt_type_cd VARCHAR2(10),
  bal_seq_num        VARCHAR2(60),
  tran_code          VARCHAR2(10),
  debit_crdt_dir_cd  VARCHAR2(10),
  curr_cd            VARCHAR2(10),
  tran_amt           NUMBER(30,2),
  erase_acct_flg     VARCHAR2(10),
  gl_post_flg        VARCHAR2(10),
  etl_dt             DATE,
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR
  is '对公贷款交易指令';
comment on column RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR.evt_id
  is '事件编号';
comment on column RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR.tran_dt
  is '交易日期';
comment on column RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR.instr_flow_num
