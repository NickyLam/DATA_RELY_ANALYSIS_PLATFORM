comment on column RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR.debit_crdt_dir_cd
  is '借贷方向代码';
comment on column RRP_MDL.O_IML_EVT_CORP_LOAN_TRAN_INSTR.curr_cd
