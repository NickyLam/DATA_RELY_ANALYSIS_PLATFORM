create table RRP_MDL.O_ICL_CMM_LOAN_PROD_INFO
(
  etl_dt                     DATE,
  lp_id                      VARCHAR2(60),
  prod_id                    VARCHAR2(100),
  prod_name                  VARCHAR2(200),
  super_prod_id              VARCHAR2(100),
  lmt_prod_flg               VARCHAR2(10),
  prod_status_cd             VARCHAR2(30),
  in_out_tab_attr_cd         VARCHAR2(30),
  prod_effect_dt             DATE,
  prod_invalid_dt            DATE,
  prod_edit_id               VARCHAR2(100),
  cust_type_comb_cd          VARCHAR2(3000),
  dom_overs_comb_cd          VARCHAR2(3000),
  curr_comb_cd               VARCHAR2(3000),
  repay_way_comb_cd          VARCHAR2(3000),
  guar_way_comb_cd           VARCHAR2(3000),
  acct_type_cd               VARCHAR2(100),
  discnt_loan_type_cd        VARCHAR2(30),
  repay_amt_ctrl_cd          VARCHAR2(30),
  bf_col_int_flg             VARCHAR2(10),
  lont_loan_tenor            VARCHAR2(10),
  shortest_loan_tenor        VARCHAR2(10),
  subtn_deduct_flg           VARCHAR2(10),
  auto_callbk_flg            VARCHAR2(10),
  circl_flg                  VARCHAR2(10),
  bar_flg                    VARCHAR2(10),
  int_accr_flg               VARCHAR2(10),
  comp_int_flg               VARCHAR2(10),
  pnlt_flg                   VARCHAR2(10),
  pnlt_comp_int_flg          VARCHAR2(10),
  comp_int_comp_int_flg      VARCHAR2(10),
  renew_flg                  VARCHAR2(10),
  max_renew_cnt              VARCHAR2(10),
  soterm_flg                 VARCHAR2(10),
  max_soterm_cnt             VARCHAR2(10),
  grace_period_corp_cd       VARCHAR2(30),
  grace_period               VARCHAR2(10),
  crdtc_grace_period         VARCHAR2(10),
  sig_distr_flg              VARCHAR2(10),
  sig_distr_amt_ctrl_flg     VARCHAR2(10),
  sig_distr_max_amt          VARCHAR2(30),
  sig_distr_min_amt          VARCHAR2(30),
  sel_sup_loan_flg           VARCHAR2(10),
  syn_loan_char_cd           VARCHAR2(30),
  int_rat_ped_cd             VARCHAR2(30),
  lowt_exec_int_rat          VARCHAR2(30),
  higt_exec_int_rat          VARCHAR2(30),
  ovdue_int_rat_float_way_cd VARCHAR2(30),
  ovdue_int_rat_float_ratio  VARCHAR2(30),
  job_cd                     VARCHAR2(10),
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_LOAN_PROD_INFO
  is '贷款产品信息';
comment on column RRP_MDL.O_ICL_CMM_LOAN_PROD_INFO.etl_dt
  is '数据日期';
