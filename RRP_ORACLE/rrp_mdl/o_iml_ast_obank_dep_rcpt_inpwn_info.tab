comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.pric_amt
  is '本金金额';
comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.curr_cd
