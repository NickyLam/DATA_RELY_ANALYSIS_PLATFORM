comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.ext_rating_rest_cd
  is '外部评级结果代码';
comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.effect_dt
