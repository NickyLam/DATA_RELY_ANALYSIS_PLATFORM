create table RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO
(
  asset_id           VARCHAR2(60),
  lp_id              VARCHAR2(60),
  vouch_id           VARCHAR2(100),
  aval_amt           NUMBER(30,2),
  bank_name          VARCHAR2(150),
  bank_rgst_cd       VARCHAR2(30),
  ext_rating_dt      DATE,
  ext_rating_rest_cd VARCHAR2(30),
  effect_dt          DATE,
  exp_dt             DATE,
  dep_term           NUMBER(30,2),
  int_rat            NUMBER(30,2),
  pric_amt           NUMBER(30,2),
  curr_cd            VARCHAR2(30),
  create_dt          DATE,
  update_dt          DATE,
  etl_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6),
  remark             VARCHAR2(4000)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO
  is '他行存单质押信息';
comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.asset_id
  is '资产编号';
comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.lp_id
