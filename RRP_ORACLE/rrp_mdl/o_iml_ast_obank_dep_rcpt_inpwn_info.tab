comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.exp_dt
  is '到期日期';
comment on column RRP_MDL.O_IML_AST_OBANK_DEP_RCPT_INPWN_INFO.dep_term
