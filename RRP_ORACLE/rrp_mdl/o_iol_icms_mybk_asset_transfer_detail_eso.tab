create table RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO
(
  contractno     VARCHAR2(64),
  termno         NUMBER(24,6),
  settledate     VARCHAR2(8),
  transtime      VARCHAR2(64),
  seqno          VARCHAR2(64),
  fundseqno      VARCHAR2(64),
  startdate      VARCHAR2(8),
  enddate        VARCHAR2(8),
  prinbal        NUMBER(24,6),
  intbal         NUMBER(24,6),
  ovdprinpnltbal NUMBER(24,6),
  ovdintpnltbal  NUMBER(24,6),
  opttype        VARCHAR2(8),
  fvtpltag       VARCHAR2(2),
  clearingamt    NUMBER(24,6),
  diffamt        NUMBER(24,6),
  status         VARCHAR2(10),
  accruedstatus  VARCHAR2(2),
  writeoff       VARCHAR2(2),
  opstorg        VARCHAR2(64),
  bsntype        VARCHAR2(64),
  regioncode     VARCHAR2(8),
  etl_dt         DATE,
  etl_timestamp  TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO
  is '网商贷资产转让明细文件中间表-债权直转';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.contractno
  is '平台贷款合同号';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.termno
  is '期次号';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.settledate
  is '业务日期';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.transtime
  is '交易时间';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.seqno
  is '资产转让业务流水号';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.fundseqno
  is '资金流水号';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.startdate
  is '分期开始日期';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.enddate
  is '分期结束日期';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.prinbal
  is '本金余额（单位分）';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.intbal
  is '利息余额（单位分）';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.ovdprinpnltbal
  is '逾期本金罚息余额（单位分）';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.ovdintpnltbal
  is '逾期利息罚息余额（单位分）';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.opttype
  is '操作类型';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.fvtpltag
  is '平价和折溢价转让为n，净值回购为y';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.clearingamt
  is '转让金额（单位分）';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.diffamt
  is '作价资产余额和转让金额之间的差价';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.status
  is '分期状态';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.accruedstatus
  is '应计非应计标识';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.writeoff
  is '核销标识';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.opstorg
  is '资产转让交易对手机构';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.bsntype
  is '产品业务类型';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.regioncode
  is '行政区划';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.etl_dt
  is 'etl处理日期';
comment on column RRP_MDL.O_IOL_ICMS_MYBK_ASSET_TRANSFER_DETAIL_ESO.etl_timestamp
  is 'etl处理时间戳';

