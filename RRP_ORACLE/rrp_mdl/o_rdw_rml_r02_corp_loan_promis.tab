create table RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS
(
  cust_id                      VARCHAR2(90),
  cust_name                    VARCHAR2(375),
  corp_size_cd                 VARCHAR2(15),
  indus_type_cd                VARCHAR2(15),
  belong_org                   VARCHAR2(90),
  lmt_cont_id                  VARCHAR2(90),
  lmt_prod_no                  VARCHAR2(375),
  curr_cd                      VARCHAR2(45),
  lmt_prod_oper_org            VARCHAR2(150),
  lmt_prod_mgmt_org            VARCHAR2(150),
  lmt_cont_amt                 NUMBER(30,8),
  group_crdt_cont_id           VARCHAR2(150),
  group_crdt_prod_no           VARCHAR2(90),
  group_crdt_lmt_cont_status   VARCHAR2(15),
  crdt_apv_id                  VARCHAR2(150),
  lmt_cont_status              VARCHAR2(15),
  lmt_cont_circl_flg           VARCHAR2(15),
  lmt_cont_froz_flg            VARCHAR2(15),
  cont_bal                     NUMBER(30,2),
  lmt_cont_start_dt            DATE,
  lmt_cont_exp_dt              DATE,
  bus_cont_start_dt            DATE,
  bus_cont_exp_dt              DATE,
  loan_level10_cls_cd          VARCHAR2(15),
  ovdue_days                   NUMBER(10),
  dir_indus_cd                 VARCHAR2(15),
  turn_crdt_flg                VARCHAR2(15),
  text_cont_id                 VARCHAR2(750),
  lmt_cont_nmal_aval_amt       NUMBER(30,8),
  sign_lmt_cont_promis_bal     NUMBER(30,8),
  not_sign_lmt_cont_promis_bal NUMBER(30,8),
  bus_cont_id                  VARCHAR2(90),
  bus_cont_prod_id             VARCHAR2(90),
  bus_cont_rgst_org            VARCHAR2(90),
  bus_cont_status              VARCHAR2(15),
  bus_cont_froz_flg            VARCHAR2(15),
  bus_cont_amt                 NUMBER(30,2),
  bus_cont_distr_amt           NUMBER(30,2),
  bus_cont_undistr_money_amt   NUMBER(30,2),
  bus_cont_bal_cny             NUMBER(30,2),
  etl_dt                       DATE,
  group_no                     VARCHAR2(15),
  fix_asset_loan_rtn_amt       NUMBER(30,8),
  bus_cont_curr_cd             VARCHAR2(45),
  fix_asset_loan_rtn_amt_cny   NUMBER(30,8)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS
  is '风险集市_R02_公司贷款承诺明细';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS.cust_id
  is '客户编号';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS.cust_name
  is '客户名称';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS.corp_size_cd
  is '企业规模代码';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS.indus_type_cd
  is '行业类型代码';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS.belong_org
  is '客户所属机构';
comment on column RRP_MDL.O_RDW_RML_R02_CORP_LOAN_PROMIS.lmt_cont_id
