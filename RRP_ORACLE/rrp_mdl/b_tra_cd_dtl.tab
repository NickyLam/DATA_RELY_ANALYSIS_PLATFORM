create table RRP_MDL.B_TRA_CD_DTL
(
  data_dt        CHAR(8) not null,
  lgl_rep_id     VARCHAR2(200),
  seq_no         VARCHAR2(200) not null,
  cust_id        VARCHAR2(200) not null,
  tra_typ        VARCHAR2(10),
  hdl_org_id     VARCHAR2(200),
  opp_acc        VARCHAR2(200),
  opp_acc_nm     VARCHAR2(500),
  opp_pbc_no     VARCHAR2(200),
  opp_bank_nm    VARCHAR2(500),
  tra_chan       VARCHAR2(10),
  cur            CHAR(3),
  acc_id         VARCHAR2(200) not null,
  tra_amt        NUMBER(30,2),
  occur_setl_typ VARCHAR2(10),
  dept_line      VARCHAR2(500),
  data_src       VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_TRA_CD_DTL
  is '存单业务交易流水';
comment on column RRP_MDL.B_TRA_CD_DTL.data_dt
  is '数据日期';
comment on column RRP_MDL.B_TRA_CD_DTL.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_TRA_CD_DTL.seq_no
  is '流水号';
comment on column RRP_MDL.B_TRA_CD_DTL.cust_id
  is '客户编号';
comment on column RRP_MDL.B_TRA_CD_DTL.tra_typ
  is '交易类型';
comment on column RRP_MDL.B_TRA_CD_DTL.hdl_org_id
  is '经办机构编号';
comment on column RRP_MDL.B_TRA_CD_DTL.opp_acc
  is '对方账号';
comment on column RRP_MDL.B_TRA_CD_DTL.opp_acc_nm
  is '对方户名';
comment on column RRP_MDL.B_TRA_CD_DTL.opp_pbc_no
  is '对方行号';
comment on column RRP_MDL.B_TRA_CD_DTL.opp_bank_nm
  is '对方行名';
comment on column RRP_MDL.B_TRA_CD_DTL.tra_chan
  is '交易渠道';
comment on column RRP_MDL.B_TRA_CD_DTL.cur
  is '币种';
comment on column RRP_MDL.B_TRA_CD_DTL.acc_id
  is '账户编号';
comment on column RRP_MDL.B_TRA_CD_DTL.tra_amt
  is '交易金额';
comment on column RRP_MDL.B_TRA_CD_DTL.occur_setl_typ
  is '发生结清类型';
comment on column RRP_MDL.B_TRA_CD_DTL.dept_line
  is '部门条线';
comment on column RRP_MDL.B_TRA_CD_DTL.data_src
  is '数据来源';
alter table RRP_MDL.B_TRA_CD_DTL
  add constraint PK_B_TRA_CD_DTL primary key (DATA_DT, SEQ_NO, CUST_ID, ACC_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

