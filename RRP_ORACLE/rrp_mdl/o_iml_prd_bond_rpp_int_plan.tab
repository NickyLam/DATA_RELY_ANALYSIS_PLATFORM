create table RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN
(
  bond_id            VARCHAR2(60),
  lp_id              VARCHAR2(60),
  seq_num            NUMBER(10),
  pay_dt             DATE,
  issuer_redem_dt    DATE,
  invtor_put_dt      DATE,
  int_amt            NUMBER(30,2),
  pric_amt           NUMBER(30,2),
  surp_pric_amt      NUMBER(30,2),
  issuer_redem_price NUMBER(30,2),
  invtor_put_price   NUMBER(30,2),
  create_dt          DATE,
  update_dt          DATE,
  etl_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN
  is '债券还本付息计划';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.bond_id
  is '债券编号';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.seq_num
  is '序号';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.pay_dt
  is '支付日期';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.issuer_redem_dt
  is '发行人赎回日期';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.invtor_put_dt
  is '投资人回售日期';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.int_amt
  is '利息金额';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.pric_amt
  is '本金金额';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.surp_pric_amt
  is '剩余本金金额';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.issuer_redem_price
  is '发行人赎回价格';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.invtor_put_price
  is '投资人回售价格';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.create_dt
  is '创建日期';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.update_dt
  is '更新日期';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_PRD_BOND_RPP_INT_PLAN.job_cd
