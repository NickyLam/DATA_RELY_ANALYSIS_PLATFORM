create index RRP_MDL.S_LOAN_IDX1 on RRP_MDL.S_LOAN (CUST_ID)
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  );

