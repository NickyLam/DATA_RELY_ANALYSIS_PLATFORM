comment on table RRP_MDL.S_LOAN
  is '贷款业务整合表';
comment on column RRP_MDL.S_LOAN.data_dt
  is '数据日期';
comment on column RRP_MDL.S_LOAN.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.S_LOAN.cont_id
  is '合同编号';
comment on column RRP_MDL.S_LOAN.rcpt_id
  is '借据编号';
comment on column RRP_MDL.S_LOAN.loan_biz_typ
  is '贷款业务类型';
comment on column RRP_MDL.S_LOAN.cust_id
  is '客户编号';
comment on column RRP_MDL.S_LOAN.cur
  is '币种';
comment on column RRP_MDL.S_LOAN.rcpt_stat
  is '借据状态';
comment on column RRP_MDL.S_LOAN.org_id
  is '机构编号';
comment on column RRP_MDL.S_LOAN.loan_act_dstr_dt
  is '贷款实际发放日期';
comment on column RRP_MDL.S_LOAN.loan_amt
  is '放款金额';
comment on column RRP_MDL.S_LOAN.loan_orig_exp_dt
  is '贷款原始到期日期';
comment on column RRP_MDL.S_LOAN.lvl5_cl
  is '五级分类';
comment on column RRP_MDL.S_LOAN.loan_term
  is '贷款期限';
comment on column RRP_MDL.S_LOAN.loan_dir_idy
  is '贷款投向行业';
comment on column RRP_MDL.S_LOAN.bio_loan_flg
  is '境内外贷款标志';
comment on column RRP_MDL.S_LOAN.loan_bal
  is '贷款余额';
comment on column RRP_MDL.S_LOAN.int_adj
  is '利息调整';
comment on column RRP_MDL.S_LOAN.fair_val_chg
  is '公允价值变动';
comment on column RRP_MDL.S_LOAN.extn_flg
  is '展期标志';
comment on column RRP_MDL.S_LOAN.rcmb_loan_flg
  is '重组贷款标志';
comment on column RRP_MDL.S_LOAN.ovd_prin_bal
  is '逾期本金余额';
comment on column RRP_MDL.S_LOAN.ovd_days
  is '逾期天数';
comment on column RRP_MDL.S_LOAN.idy_trnst_upg_flg
  is '工业转型升级标志';
comment on column RRP_MDL.S_LOAN.strtg_emer_idy_typ
  is '战略新兴产业类型';
comment on column RRP_MDL.S_LOAN.rl_est_loan_flg
  is '房地产贷款标志';
comment on column RRP_MDL.S_LOAN.agr_rel_loan_flg
  is '涉农贷款标志';
comment on column RRP_MDL.S_LOAN.spcl_loan_flg
  is '专项贷款标志';
comment on column RRP_MDL.S_LOAN.rate_typ
  is '利率类型';
comment on column RRP_MDL.S_LOAN.act_rate
  is '实际利率';
