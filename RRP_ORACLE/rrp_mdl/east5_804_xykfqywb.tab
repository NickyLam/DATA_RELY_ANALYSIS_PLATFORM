  bz          VARCHAR2(3),
  fqzed       NUMBER(20,2),
  kyfqed      NUMBER(20,2),
  fqje        NUMBER(20,2),
  fqqs        NUMBER(4),
  blfqrq      VARCHAR2(8) not null,
