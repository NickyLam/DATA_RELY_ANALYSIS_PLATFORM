  fqzrhm_orig VARCHAR2(450),
  gsfzjg      VARCHAR2(200)
)
partition by list (BLFQRQ)
(
  partition PARTITION_19000101 values ('19000101')
    tablespace USERS
    pctfree 10
    initrans 1
    maxtrans 255
);
