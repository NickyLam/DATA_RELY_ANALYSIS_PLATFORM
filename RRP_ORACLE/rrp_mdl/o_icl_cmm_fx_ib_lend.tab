create table RRP_MDL.O_ICL_CMM_FX_IB_LEND
(
  etl_dt               DATE,
  lp_id                VARCHAR2(60),
  bus_id               VARCHAR2(60),
  dept_id              VARCHAR2(60),
  entry_org_id         VARCHAR2(60),
  tran_acct_b_id       VARCHAR2(60),
  std_prod_id          VARCHAR2(60),
  cust_id              VARCHAR2(100),
  cntpty_id            VARCHAR2(60),
  cntpty_name          VARCHAR2(750),
  portf_id             VARCHAR2(60),
  portf_name           VARCHAR2(750),
  portf_class_name     VARCHAR2(250),
  inv_port_status_cd   VARCHAR2(10),
  subj_id              VARCHAR2(60),
  tran_aim_cd          VARCHAR2(10),
  tran_dir_cd          VARCHAR2(10),
  tran_mode_cd         VARCHAR2(10),
  clear_way_cd         VARCHAR2(10),
  ib_lend_type_cd      VARCHAR2(10),
  clear_org_cd         VARCHAR2(10),
  input_dt             DATE,
  tran_dt              DATE,
  value_dt             DATE,
  exp_dt               DATE,
  tenor                NUMBER(18),
  int_rat_adj_way_cd   VARCHAR2(10),
  int_accr_base_cd     VARCHAR2(10),
  int_rat_float_dir_cd VARCHAR2(10),
  int_rat_float_point  NUMBER(18,8),
  int_rat_tenor_cd     VARCHAR2(30),
  exec_int_rat         NUMBER(18,8),
  curr_cd              VARCHAR2(10),
  tran_amt             NUMBER(30,2),
  exp_amt              NUMBER(30,2),
  usd_tran_amt         NUMBER(30,12),
  acru_int             NUMBER(30,2),
  currt_bal            NUMBER(30,2),
  td_acru_int          NUMBER(30,2),
  currt_acru_int       NUMBER(30,2),
  pay_int_ped_cd       VARCHAR2(60),
  fir_pay_int_dt       DATE,
  pay_stub_proc_way_cd VARCHAR2(10),
  bag_status_cd        VARCHAR2(10),
  tran_src_cd          VARCHAR2(10),
  tran_site_cd         VARCHAR2(10),
  bag_id               VARCHAR2(60),
  tran_id              VARCHAR2(60),
  asset_thd_cls_cd     VARCHAR2(30),
  int_recvbl_subj_id   VARCHAR2(60),
  int_income_subj_id   VARCHAR2(60),
  int_rat_adj_freq_cd  VARCHAR2(60),
  base_rat             NUMBER(18,8),
  bond_id              VARCHAR2(60),
  bond_fac_val         NUMBER(30,2),
  bond_curr            VARCHAR2(15),
  inpwn_ratio          NUMBER(18,8),
  inpwn_way_cd         VARCHAR2(10),
  job_cd               VARCHAR2(10),
  dealer_acct_num      VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
