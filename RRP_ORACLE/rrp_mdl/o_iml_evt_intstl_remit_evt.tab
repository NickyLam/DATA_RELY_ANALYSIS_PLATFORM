create table RRP_MDL.O_IML_EVT_INTSTL_REMIT_EVT
(
  evt_id                        VARCHAR2(60),
  lp_id                         VARCHAR2(60),
  sorc_sys_id                   VARCHAR2(30),
  tran_descb                    VARCHAR2(90),
  recver_cust_id                VARCHAR2(30),
  recver_addr_name              VARCHAR2(150),
  recver_en_name                VARCHAR2(150),
  pay_bank_id                   VARCHAR2(30),
  pay_bank_addr_name            VARCHAR2(150),
  pay_bank_name                 VARCHAR2(150),
  remiter_cust_id               VARCHAR2(30),
  remiter_addr_name             VARCHAR2(150),
  remiter_name                  VARCHAR2(150),
  remit_bank_id                 VARCHAR2(30),
  remit_bank_addr_name          VARCHAR2(150),
  remit_bank_name               VARCHAR2(150),
  value_dt                      DATE,
  tran_start_tm                 DATE,
  tran_close_tm                 DATE,
  abmt_msg_fee_bear_way_cd      VARCHAR2(30),
  remit_oper_tm                 DATE,
  oper_user                     VARCHAR2(45),
  remit_out_msg_fee_bear_way_cd VARCHAR2(30),
  pay_type_cd                   VARCHAR2(30),
  clear_id                      VARCHAR2(60),
  abmt_comm_fee_curr_cd         VARCHAR2(30),
  abmt_comm_fee_amt             NUMBER(30,8),
  remit_cate_cd                 VARCHAR2(30),
  remit_way_cd                  VARCHAR2(30),
  pay_dt                        DATE,
  cust_type_cd                  VARCHAR2(30),
  soe_type_cd                   VARCHAR2(30),
  init_curr_cd                  VARCHAR2(30),
  remit_out_comm_fee_curr_cd    VARCHAR2(30),
  remit_out_comm_fee_amt        NUMBER(30,8),
  init_amt                      NUMBER(30,8),
  exch_rat                      NUMBER(30,8),
  sell_fx_type_cd               VARCHAR2(30),
  msg_type_cd                   VARCHAR2(30),
  belong_org_id                 VARCHAR2(30),
  oper_org_id                   VARCHAR2(30),
  remit_proc_type_cd            VARCHAR2(30),
  bal_pay_type_cd               VARCHAR2(30),
  remiter_acct_id               VARCHAR2(60),
  recver_acct_id                VARCHAR2(60),
  refund_flg                    VARCHAR2(10),
  nra_acct_flg                  VARCHAR2(10),
  clear_chn_cd                  VARCHAR2(30),
  cross_bor_cap_pool_flg        VARCHAR2(10),
  cap_pool_bus_type_cd          VARCHAR2(30),
  cap_pool_bus_pric             NUMBER(30,8),
  cap_pool_bus_int              NUMBER(30,8),
  entr_pay_id                   VARCHAR2(60),
  entr_pay_out_acct_dubil_id    VARCHAR2(30),
  gpi_remit_flg                 VARCHAR2(10),
  gpi_msg_feedback_status_cd    VARCHAR2(30),
  inquiry_flg                   VARCHAR2(10),
  deduct_acct_id                VARCHAR2(60),
  start_dt                      DATE,
  end_dt                        DATE,
  id_mark                       VARCHAR2(10),
  src_table_name                VARCHAR2(100),
  job_cd                        VARCHAR2(10),
  etl_timestamp                 TIMESTAMP(6),
  cbec_flg                      VARCHAR2(30)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
