create table RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H
(
  card_no        VARCHAR2(100),
  lp_id          VARCHAR2(60),
  acct_id        VARCHAR2(100),
  tran_dt        DATE,
  tran_flow_id   VARCHAR2(100),
  tran_tm        TIMESTAMP(6),
  operr_id       VARCHAR2(100),
  main_card_flg  VARCHAR2(10),
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10),
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H
  is '卡号与账号关系历史';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.card_no
  is '卡号';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.acct_id
  is '账户编号';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.tran_dt
  is '交易日期';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.tran_flow_id
  is '交易流水编号';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.tran_tm
  is '交易时间';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.operr_id
  is '操作员编号';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.main_card_flg
  is '主卡标志';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.start_dt
  is '开始日期';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.end_dt
  is '结束日期';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.id_mark
  is '删除标识';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_AGT_CARD_AND_ACCT_RELA_H.job_cd
  is '任务代码';

