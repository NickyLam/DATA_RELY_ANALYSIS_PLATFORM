comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.tran_market_name
  is '交易市场名称';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.surp_tenor
  is '剩余期限';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.recmd_flg
  is '推荐标志';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.full_price
  is '全价';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.net_price
