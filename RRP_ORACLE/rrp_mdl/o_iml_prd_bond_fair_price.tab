create table RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE
(
  bond_id            VARCHAR2(60),
  lp_id              VARCHAR2(60),
  price_dt           DATE,
  tran_market_name   VARCHAR2(100),
  surp_tenor         NUMBER(18),
  recmd_flg          VARCHAR2(10),
  full_price         NUMBER(30,8),
  net_price          NUMBER(30,8),
  exp_yld_rat        NUMBER(18,6),
  duran              NUMBER(18,10),
  coret_duran        NUMBER(18,10),
  valid_flg          VARCHAR2(10),
  acru_int           NUMBER(30,8),
  end_day_full_price NUMBER(30,8),
  estim_yld_rat      NUMBER(18,6),
  estim_coret_duran  NUMBER(18,6),
  estim_cvty         NUMBER(18,6),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE
  is '债券公允价格';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.bond_id
  is '债券编号';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.price_dt
