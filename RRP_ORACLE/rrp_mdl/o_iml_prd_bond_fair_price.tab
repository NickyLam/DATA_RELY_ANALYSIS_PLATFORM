comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.valid_flg
  is '有效标志';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.acru_int
  is '应计利息';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.end_day_full_price
  is '日终全价';
comment on column RRP_MDL.O_IML_PRD_BOND_FAIR_PRICE.estim_yld_rat
