create table RRP_MDL.TMP_B_GL_BAL1
(
  data_dt     CHAR(8) not null,
  lgl_rep_id  VARCHAR2(200),
  freq        VARCHAR2(10) not null,
  org_id      VARCHAR2(200) not null,
  cur         CHAR(3) not null,
  subj_id     VARCHAR2(200) not null,
  subj_nm     VARCHAR2(500),
  subj_lvl    INTEGER,
  subj_typ    VARCHAR2(10),
  bgn_dr_bal  NUMBER(30,2),
  bgn_cr_bal  NUMBER(30,2),
  curr_dr_amt NUMBER(30,2),
  curr_cr_amt NUMBER(30,2),
  end_dr_bal  NUMBER(30,2),
  end_cr_bal  NUMBER(30,2),
  dept_line   VARCHAR2(500),
  data_src    VARCHAR2(500),
  sub_level   VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TMP_B_GL_BAL1.data_dt
  is '数据日期';
comment on column RRP_MDL.TMP_B_GL_BAL1.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.TMP_B_GL_BAL1.freq
  is '频度';
comment on column RRP_MDL.TMP_B_GL_BAL1.org_id
  is '银行编号';
comment on column RRP_MDL.TMP_B_GL_BAL1.cur
  is '账号币种';
comment on column RRP_MDL.TMP_B_GL_BAL1.subj_id
  is '科目编号';
comment on column RRP_MDL.TMP_B_GL_BAL1.subj_nm
  is '核算科目名称';
comment on column RRP_MDL.TMP_B_GL_BAL1.subj_lvl
  is '科目级次';
comment on column RRP_MDL.TMP_B_GL_BAL1.subj_typ
  is '科目类别';
comment on column RRP_MDL.TMP_B_GL_BAL1.bgn_dr_bal
  is '期初借方余额';
comment on column RRP_MDL.TMP_B_GL_BAL1.bgn_cr_bal
  is '期初贷方余额';
comment on column RRP_MDL.TMP_B_GL_BAL1.curr_dr_amt
  is '本期借方发生额';
comment on column RRP_MDL.TMP_B_GL_BAL1.curr_cr_amt
  is '本期贷方发生额';
comment on column RRP_MDL.TMP_B_GL_BAL1.end_dr_bal
  is '期末借方余额';
comment on column RRP_MDL.TMP_B_GL_BAL1.end_cr_bal
  is '期末贷方余额';
comment on column RRP_MDL.TMP_B_GL_BAL1.dept_line
  is '部门条线';
comment on column RRP_MDL.TMP_B_GL_BAL1.data_src
  is '数据来源（参见[字典:AML0045]）';

