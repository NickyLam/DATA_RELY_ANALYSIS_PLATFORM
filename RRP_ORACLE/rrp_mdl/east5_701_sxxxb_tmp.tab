create table RRP_MDL.EAST5_701_SXXXB_TMP
(
  rid         VARCHAR2(50) not null,
  yhjgdm      VARCHAR2(30),
  jrxkzh      VARCHAR2(30),
  nbjgh       VARCHAR2(30),
  khtybh      VARCHAR2(70),
  khmc        VARCHAR2(450),
  khzjlb      VARCHAR2(60),
  khzjhm      VARCHAR2(70),
  sxxyh       VARCHAR2(60),
  sxxymc      VARCHAR2(450),
  edsqrq      VARCHAR2(8),
  sxztzl      VARCHAR2(60),
  sxzl        VARCHAR2(60),
  sxed        NUMBER(20,2),
  yyed        NUMBER(20,2),
  bz          VARCHAR2(3),
  sxksrq      VARCHAR2(8),
  sxdqrq      VARCHAR2(8),
  sxjcyj      VARCHAR2(3000),
  sprgh       VARCHAR2(30),
  jbrgh       VARCHAR2(30),
  sxzt        VARCHAR2(6),
  bbz         VARCHAR2(600),
  cjrq        VARCHAR2(8),
  dept_no     VARCHAR2(10),
  src_sys_id  VARCHAR2(10),
  issued_no   VARCHAR2(50),
  org_no      VARCHAR2(20),
  address     VARCHAR2(200),
  khmc_orig   VARCHAR2(400),
  khzjhm_orig VARCHAR2(70),
  khmc_oth    VARCHAR2(5),
  dkcpmc      VARCHAR2(100),
  gsfzjg      VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.rid
  is '数据主键';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.yhjgdm
  is '银行机构代码';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.jrxkzh
  is '金融许可证号';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.nbjgh
  is '内部机构号';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.khtybh
  is '客户统一编号';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.khmc
  is '客户名称';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.khzjlb
  is '客户证件类别';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.khzjhm
  is '客户证件号码';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxxyh
  is '授信协议号';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxxymc
  is '授信协议名称';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.edsqrq
  is '额度申请日期';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxztzl
  is '授信主体种类';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxzl
  is '授信种类';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxed
  is '报告日客户授信总额（元）';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.yyed
  is '已用额度';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.bz
  is '申请控制金额币种';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxksrq
  is '授信开始日期';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxdqrq
  is '授信到期日期';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxjcyj
  is '授信审批意见';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sprgh
  is '审批人工号';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.jbrgh
  is '经办人工号';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.sxzt
  is '授信状态';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.bbz
  is '备注';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.cjrq
  is '创建日期';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.dept_no
  is '部门编号';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.src_sys_id
  is '来源系统ID';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.issued_no
  is '填报机构';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.org_no
  is '所属机构';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.address
  is '用户地址';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.khmc_orig
  is '客户名称（脱敏前）';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.khzjhm_orig
  is '客户证件号码（脱敏前）';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.khmc_oth
  is '客户是否个人客户';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.dkcpmc
  is '贷款产品名称 只用来区分行内外产品';
comment on column RRP_MDL.EAST5_701_SXXXB_TMP.gsfzjg
  is '归属分支机构';

