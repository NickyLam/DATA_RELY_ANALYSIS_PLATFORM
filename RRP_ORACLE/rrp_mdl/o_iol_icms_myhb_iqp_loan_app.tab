  joininstcodes        VARCHAR2(64),
  nationalitynew       VARCHAR2(6),
  rulingir             NUMBER(16,9),
  agreementno          VARCHAR2(128),
  certcode             VARCHAR2(60),
  solvencyratings      VARCHAR2(2),
  invitestatus         VARCHAR2(1),
