  validdateendnew      VARCHAR2(10),
  telenew              VARCHAR2(18),
  approveprogress      VARCHAR2(3),
  cusname              VARCHAR2(200),
  authtext             VARCHAR2(256),
  consumingscore       VARCHAR2(20),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
