create table RRP_MDL.ADD_INDEX_MAP
(
  src_index_no VARCHAR2(200),
  tar_index_no VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.ADD_INDEX_MAP
  is '索引字典补录表';
comment on column RRP_MDL.ADD_INDEX_MAP.src_index_no
  is '源指标编号';
comment on column RRP_MDL.ADD_INDEX_MAP.tar_index_no
  is '目标指标编号';

