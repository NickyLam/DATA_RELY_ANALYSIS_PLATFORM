create table RRP_MDL.O_IOL_NCBS_FM_BRANCH
(
  area_code                    VARCHAR2(6),
  branch                       VARCHAR2(12),
  branch_name                  VARCHAR2(200),
  country                      VARCHAR2(3),
  profit_center                VARCHAR2(20),
  abnormal_open_control        VARCHAR2(1),
  auth_flag                    VARCHAR2(1),
  branch_short                 VARCHAR2(30),
  branch_status                VARCHAR2(1),
  branch_type                  VARCHAR2(1),
  cheque_issuing_branch_flag   VARCHAR2(1),
  city                         VARCHAR2(6),
  company                      VARCHAR2(20),
  default_teller_login         VARCHAR2(1),
  district                     VARCHAR2(10),
  eod_flag                     VARCHAR2(1),
  fta_code                     VARCHAR2(10),
  fta_flag                     VARCHAR2(1),
  fx_organ_code                VARCHAR2(12),
  index_str                    VARCHAR2(200),
  int_tax_levy                 VARCHAR2(1),
  ip_addr                      VARCHAR2(200),
  oper_max_level               VARCHAR2(5),
  pboc_fund_check_flag         VARCHAR2(1),
  postal_code                  VARCHAR2(10),
  state                        VARCHAR2(6),
  surtax_type                  VARCHAR2(30),
  tailbox_detach_flag          VARCHAR2(1),
  voucher_user_contral_flag    VARCHAR2(1),
  accounting_branch            VARCHAR2(12),
  libra_op_time                NUMBER(15),
  create_date                  DATE,
  end_date                     DATE,
  start_date                   DATE,
  tran_timestamp               VARCHAR2(26),
  attached_to                  VARCHAR2(12),
  base_ccy                     VARCHAR2(3),
  ccy_ctrl_branch              VARCHAR2(12),
  cny_business_unit            VARCHAR2(10),
  hierarchy_code               VARCHAR2(2),
  hkd_business_unit            VARCHAR2(10),
  internal_client              VARCHAR2(16),
  local_ccy                    VARCHAR2(3),
  sub_branch_code              VARCHAR2(12),
  tax_rpt_branch               VARCHAR2(12),
  tran_br_ind                  VARCHAR2(1),
  accounting_branch_flag       VARCHAR2(1),
  normal_close_time            VARCHAR2(8),
  normal_open_time             VARCHAR2(8),
  pboc_financing_no            VARCHAR2(30),
  branch_en_short              VARCHAR2(30),
  branch_head_phone            VARCHAR2(30),
  pboc_pay_branch_no           VARCHAR2(12),
  is_auto_create_internal_acct VARCHAR2(1),
  branch_en_name               VARCHAR2(200),
  pboc_area_code               VARCHAR2(50),
  branch_head_name             VARCHAR2(50),
  branch_close_date            DATE,
  branch_head_duty             VARCHAR2(50),
  swift_no                     VARCHAR2(50),
  cup_financing_no             VARCHAR2(50),
  pboc_acct_manage_sys_no      VARCHAR2(50),
  start_dt                     DATE,
  end_dt                       DATE,
  id_mark                      VARCHAR2(10),
  etl_timestamp                TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
