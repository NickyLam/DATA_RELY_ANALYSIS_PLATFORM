comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.grkhatjfl
  is '个人客户按统计分类';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.bxcdfylb
  is '本行承担费用类別';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.bxjmfylb
  is '本行减免费用类別';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.bnljcdhjmdxdxgfyje
  is '本年累计承担或减免的信贷相关费用金额（元）';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sfsc
  is '是否删除';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sys_data_date
  is '数据日期';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sys_data_case
  is '任务实例ID';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sys_operator
