comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sys_oper_org
  is '补录机构';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sys_oper_date
  is '操作日期';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sys_data_state
  is '数据状态:save(已保存),submit(已提交),reject(驳回),sucess(审核通过),refuse(已回退)';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.sys_order_no
  is '序号';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.error_mark
