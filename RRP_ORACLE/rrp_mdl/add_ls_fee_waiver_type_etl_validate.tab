create table RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE
(
  datainput_id       VARCHAR2(32) not null,
  data_date          VARCHAR2(10),
  acct_org_num       VARCHAR2(20),
  ywhtbh             VARCHAR2(30),
  khwym              VARCHAR2(30),
  khmc               VARCHAR2(60),
  tjywpz             VARCHAR2(60),
  grkhatjfl          VARCHAR2(60),
  bxcdfylb           VARCHAR2(60),
  bxjmfylb           VARCHAR2(60),
  bnljcdhjmdxdxgfyje NUMBER(20,6),
  sfsc               VARCHAR2(10),
  sys_data_date      VARCHAR2(20) not null,
  sys_data_case      VARCHAR2(32) not null,
  sys_operator       VARCHAR2(256),
  sys_oper_org       VARCHAR2(32) not null,
  sys_oper_date      VARCHAR2(20),
  sys_data_state     VARCHAR2(10),
  sys_order_no       NUMBER(19),
  error_mark         VARCHAR2(2),
  flow_node_id       VARCHAR2(32),
  comments           VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE
  is '补录表-零售-减免费用类别-应用';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.datainput_id
  is '数据录入时间';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.data_date
  is '数据日期';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.acct_org_num
  is '账务机构编号';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.ywhtbh
  is '业务合同编号';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.khwym
  is '客户唯一码';
comment on column RRP_MDL.ADD_LS_FEE_WAIVER_TYPE_ETL_VALIDATE.khmc
