create table RRP_MDL.XZY_PRO_INFO
(
  pro_id   VARCHAR2(800),
  pro_name VARCHAR2(800),
  pro_type VARCHAR2(120),
  tab_no   VARCHAR2(800)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

