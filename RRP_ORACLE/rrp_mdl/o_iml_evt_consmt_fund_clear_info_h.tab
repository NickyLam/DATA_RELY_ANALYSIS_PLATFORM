  clear_amt             NUMBER(30,2),
  froz_amt              NUMBER(30,2),
  host_tran_code        VARCHAR2(45),
  tran_org_id           VARCHAR2(100),
  cap_cate_cd           VARCHAR2(60),
  termn_id              VARCHAR2(100),
  bf_actl_enter_acct_dt DATE,
  lp_id                 VARCHAR2(60),
  init_clear_flow_num   VARCHAR2(150),
  tran_teller_id        VARCHAR2(100),
  intior_cd             VARCHAR2(30),
  finc_cust_id          VARCHAR2(100),
  tran_dt               DATE,
  job_cd                VARCHAR2(10),
  end_dt                DATE,
  actl_enter_acct_dt    DATE,
  clear_flow_num        VARCHAR2(150),
  unfrz_amt             NUMBER(30,2),
  id_mark               VARCHAR2(10),
  bus_cd                VARCHAR2(30),
  pric                  NUMBER(30,2),
  prod_acct_num         VARCHAR2(150),
  tran_chn_cd           VARCHAR2(30),
  evt_id                VARCHAR2(250),
  tran_cd               VARCHAR2(100),
  cfm_flow_num          VARCHAR2(150),
  clear_dt              DATE,
  bank_acct_id          VARCHAR2(100),
  pric_prft_flg         VARCHAR2(10),
  intfc_proc_flg_cd     VARCHAR2(30),
  ta_cd                 VARCHAR2(30),
  memo_comnt            VARCHAR2(375),
  tran_belong_org_id    VARCHAR2(100),
  curr_cd               VARCHAR2(30),
  prod_acct_type_cd     VARCHAR2(30),
  rela_flow_num         VARCHAR2(150),
  cust_id               VARCHAR2(100),
  bank_acct_type_cd     VARCHAR2(30),
  start_dt              DATE,
  src_table_name        VARCHAR2(100),
  bank_id               VARCHAR2(100),
  cfm_lot               NUMBER(30,3),
  prod_cd               VARCHAR2(100),
  return_code           VARCHAR2(45),
  cust_type_cd          VARCHAR2(30),
  host_dt               DATE,
  acct_dir_cd           VARCHAR2(30)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
