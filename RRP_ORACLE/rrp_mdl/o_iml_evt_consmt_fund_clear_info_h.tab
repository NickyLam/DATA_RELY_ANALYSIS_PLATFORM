create table RRP_MDL.O_IML_EVT_CONSMT_FUND_CLEAR_INFO_H
(
  ec_idf_cd             VARCHAR2(30),
  bal_chk_cfm_cd        VARCHAR2(30),
  return_info           VARCHAR2(750),
  host_flow_num         VARCHAR2(150),
