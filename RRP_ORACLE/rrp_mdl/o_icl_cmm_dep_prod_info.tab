create table RRP_MDL.O_ICL_CMM_DEP_PROD_INFO
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  prod_id                  VARCHAR2(60),
  prod_name                VARCHAR2(100),
  intnal_prod_id           VARCHAR2(60),
  accting_id               VARCHAR2(10),
  prod_cate_cd             VARCHAR2(10),
  sell_obj_cd              VARCHAR2(3000),
  dep_kind_cd              VARCHAR2(10),
  charge_evt_way_cd        VARCHAR2(10),
  supt_buy_way_cd          VARCHAR2(10),
  status_cd                VARCHAR2(10),
  curr_type_cd             VARCHAR2(3000),
  prod_modal_tran_flg      VARCHAR2(10),
  gl_sync_flg              VARCHAR2(10),
  precon_draw_flg          VARCHAR2(10),
  open_lmt_flg             VARCHAR2(10),
  rela_vouch_flg           VARCHAR2(10),
  allow_zero_bal_flg       VARCHAR2(10),
  redt_flg                 VARCHAR2(10),
  margin_dep_flg           VARCHAR2(10),
  allow_od_flg             VARCHAR2(10),
  emply_prod_flg           VARCHAR2(10),
  deriv_prod_flg           VARCHAR2(10),
  mpr_flg                  VARCHAR2(10),
  allow_redem_flg          VARCHAR2(10),
  allow_tran_flg           VARCHAR2(10),
  allow_spec_col_int_flg   VARCHAR2(10),
  allow_inpwn_flg          VARCHAR2(10),
  renew_dep_way_cd         VARCHAR2(10),
  allow_multi_subscr_flg   VARCHAR2(10),
  unexp_draw_way_cd        VARCHAR2(10),
  allow_tran_wdraw_flg     VARCHAR2(10),
  allow_wdraw_cnt          NUMBER(10),
  allow_wdraw_max_amt      NUMBER(30,2),
  base_rat_id              VARCHAR2(60),
  int_rat_file_type_cd     VARCHAR2(10),
  base_rat                 NUMBER(18,8),
  int_rat_flo_val          NUMBER(18,8),
  pay_int_freq             VARCHAR2(10),
  spread_int_rat           NUMBER(18,8),
  matn_teller_id           VARCHAR2(60),
  matn_org_id              VARCHAR2(500),
  effect_dt                DATE,
  invalid_dt               DATE,
  value_dt                 DATE,
  exp_dt                   DATE,
  stat_prod_subscr_lmt_flg VARCHAR2(10),
  value_way_cd             VARCHAR2(10),
  prod_issue_tot_uplmi     NUMBER(30,2),
  prod_issue_tot_lolmi     NUMBER(30,2),
  sell_begin_dt_tm         TIMESTAMP(6),
  sell_termnt_dt_tm        TIMESTAMP(6),
  apot_redem_dt            VARCHAR2(60),
  redem_int_rat_type       VARCHAR2(60),
  init_amt                 NUMBER(30,2),
  incremt_amt              NUMBER(30,2),
  min_retnd_amt            NUMBER(30,2),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6),
  pd_prod_cate_cd          VARCHAR2(30),
  pd_tenor_type_cd         VARCHAR2(30),
  dep_tenor                NUMBER(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_DEP_PROD_INFO
  is '存款产品信息';
