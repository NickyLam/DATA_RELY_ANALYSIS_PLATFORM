create table RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA
(
  etl_dt              DATE,
  lp_id               VARCHAR2(60),
  loan_cont_id        VARCHAR2(100),
  guar_cont_id        VARCHAR2(100),
  col_id              VARCHAR2(100),
  guar_way_cd         VARCHAR2(30),
  guar_curr_cd        VARCHAR2(10),
  guar_cont_status_cd VARCHAR2(30),
  guartor_cust_id     VARCHAR2(100),
  guartor_name        VARCHAR2(500),
  guar_effect_dt      DATE,
  guar_exp_dt         DATE,
  job_cd              VARCHAR2(10),
  etl_timestamp       TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA
  is '联合网贷贷款与担保合同关系';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.etl_dt
  is '数据日期';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.lp_id
  is '法人编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.loan_cont_id
  is '贷款合同编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.guar_cont_id
  is '担保合同编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.col_id
  is '押品编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.guar_way_cd
  is '担保方式代码';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.guar_curr_cd
  is '担保币种代码';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_LOAN_GUAR_CONT_RELA.guar_cont_status_cd
