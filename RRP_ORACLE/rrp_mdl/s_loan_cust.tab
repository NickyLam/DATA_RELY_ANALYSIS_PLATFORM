create table RRP_MDL.S_LOAN_CUST
(
  data_dt                   CHAR(8),
  org_id                    VARCHAR2(200),
  loan_id                   VARCHAR2(200),
  loan_typ                  VARCHAR2(10),
  cur                       CHAR(3),
  loan_bal                  NUMBER(30,2),
  loan_net_val              NUMBER(30,2),
  act_rate                  NUMBER(18,4),
  int_adj                   NUMBER(18,4),
  dsbr_amt                  NUMBER(30,2),
  cust_id                   VARCHAR2(200),
  dsbr_dt                   CHAR(8),
  orig_exp_dt               CHAR(8),
  cust_lrg_cl               VARCHAR2(10),
  corp_cust_typ             VARCHAR2(10),
  bio_flg                   CHAR(1),
  ent_close_flg             CHAR(1),
  rsdnt_flg                 CHAR(1),
  fin_org_typ               VARCHAR2(10),
  idy                       VARCHAR2(10),
  loan_dir                  VARCHAR2(10),
  loan_term                 VARCHAR2(10),
  ent_scale                 VARCHAR2(10),
  lvl5_cl                   VARCHAR2(10),
  main_gua_mode             VARCHAR2(10),
  loan_use_rgn_area_cd      VARCHAR2(10),
  lcl_fin_pltf_co_flg       CHAR(1),
  ent_hldg_typ              VARCHAR2(10),
  ovd_flg                   CHAR(1),
  ovd_days                  INTEGER,
  ovd_prin_amt              NUMBER(30,2),
  cust_crdt5m_flg           CHAR(1),
  sgl_crdt_amt              NUMBER(30,2),
  opr_cust_typ              VARCHAR2(10),
  extn_flg                  CHAR(1),
  acc_stat                  VARCHAR2(10),
  tech_innov_ent_flg        CHAR(1),
  ent_gua_sml_micro_ent_flg CHAR(1),
  disc_int_loan_flg         CHAR(1),
  ent_gua_loan_typ          VARCHAR2(10),
  disabled_flg              CHAR(1),
  farm_flg                  CHAR(1),
  rec_poor_flg              CHAR(1),
  family_farm_cust_flg      CHAR(1),
  low_incm_flg              CHAR(1),
  campus_cnsmp_loan_flg     CHAR(1),
  bank_tax_coop_loan_flg    CHAR(1),
  non_repy_prin_renew_flg   CHAR(1),
  pboc_ind_opr_loan_flg     CHAR(1),
  cbrc_flg                  CHAR(1),
  pboc_flg                  CHAR(1),
  pro_impt                  NUMBER(30,2),
  high_tech_idy_cl          VARCHAR2(10),
  dsr                       NUMBER(18,4),
  rcmb_loan_flg             CHAR(1),
  bgn_year_loan_lvl5_cl     VARCHAR2(10),
  dept_line                 VARCHAR2(500),
  data_src                  VARCHAR2(500),
  high_tech_ent_flg         VARCHAR2(200),
  tech_ent_flg              VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.S_LOAN_CUST
  is '贷款按客户整合表';
comment on column RRP_MDL.S_LOAN_CUST.data_dt
  is '数据日期';
comment on column RRP_MDL.S_LOAN_CUST.org_id
  is '机构编号';
comment on column RRP_MDL.S_LOAN_CUST.loan_id
  is '贷款编号';
comment on column RRP_MDL.S_LOAN_CUST.loan_typ
  is '贷款类型';
comment on column RRP_MDL.S_LOAN_CUST.cur
  is '币种';
comment on column RRP_MDL.S_LOAN_CUST.loan_bal
  is '贷款余额';
comment on column RRP_MDL.S_LOAN_CUST.loan_net_val
  is '贷款净值';
comment on column RRP_MDL.S_LOAN_CUST.act_rate
  is '实际利率';
comment on column RRP_MDL.S_LOAN_CUST.int_adj
  is '利息调整';
comment on column RRP_MDL.S_LOAN_CUST.dsbr_amt
  is '放款金额';
comment on column RRP_MDL.S_LOAN_CUST.cust_id
  is '客户编号';
comment on column RRP_MDL.S_LOAN_CUST.dsbr_dt
  is '放款日期';
comment on column RRP_MDL.S_LOAN_CUST.orig_exp_dt
  is '原始到期日期';
comment on column RRP_MDL.S_LOAN_CUST.cust_lrg_cl
  is '客户大类';
comment on column RRP_MDL.S_LOAN_CUST.corp_cust_typ
  is '对公客户类型';
comment on column RRP_MDL.S_LOAN_CUST.bio_flg
  is '境内外标志';
comment on column RRP_MDL.S_LOAN_CUST.ent_close_flg
  is '企业关停标志';
comment on column RRP_MDL.S_LOAN_CUST.rsdnt_flg
  is '居民标志';
comment on column RRP_MDL.S_LOAN_CUST.fin_org_typ
  is '金融机构类型';
comment on column RRP_MDL.S_LOAN_CUST.idy
  is '行业';
comment on column RRP_MDL.S_LOAN_CUST.loan_dir
  is '贷款投向';
comment on column RRP_MDL.S_LOAN_CUST.loan_term
  is '贷款期限';
comment on column RRP_MDL.S_LOAN_CUST.ent_scale
  is '企业规模';
comment on column RRP_MDL.S_LOAN_CUST.lvl5_cl
  is '五级分类';
comment on column RRP_MDL.S_LOAN_CUST.main_gua_mode
  is '主要担保方式';
comment on column RRP_MDL.S_LOAN_CUST.loan_use_rgn_area_cd
  is '贷款使用地区行政区划代码';
comment on column RRP_MDL.S_LOAN_CUST.lcl_fin_pltf_co_flg
  is '地方融资平台公司标志';
comment on column RRP_MDL.S_LOAN_CUST.ent_hldg_typ
  is '企业控股类型';
comment on column RRP_MDL.S_LOAN_CUST.ovd_flg
  is '逾期标志';
comment on column RRP_MDL.S_LOAN_CUST.ovd_days
  is '逾期天数';
comment on column RRP_MDL.S_LOAN_CUST.ovd_prin_amt
  is '逾期本金金额';
comment on column RRP_MDL.S_LOAN_CUST.cust_crdt5m_flg
  is '客户授信500万以上标志';
comment on column RRP_MDL.S_LOAN_CUST.sgl_crdt_amt
  is '单户授信金额';
comment on column RRP_MDL.S_LOAN_CUST.opr_cust_typ
  is '经营性客户类型';
comment on column RRP_MDL.S_LOAN_CUST.extn_flg
  is '展期标志';
comment on column RRP_MDL.S_LOAN_CUST.acc_stat
  is '账户状态';
comment on column RRP_MDL.S_LOAN_CUST.tech_innov_ent_flg
  is '科技创新型企业标志';
comment on column RRP_MDL.S_LOAN_CUST.ent_gua_sml_micro_ent_flg
  is '创业担保小微企业标志';
comment on column RRP_MDL.S_LOAN_CUST.disc_int_loan_flg
  is '贴息贷款标志';
comment on column RRP_MDL.S_LOAN_CUST.ent_gua_loan_typ
  is '创业担保贷款类型';
comment on column RRP_MDL.S_LOAN_CUST.disabled_flg
  is '残疾人标志';
comment on column RRP_MDL.S_LOAN_CUST.farm_flg
  is '农户标志';
comment on column RRP_MDL.S_LOAN_CUST.rec_poor_flg
  is '建档立卡贫困户标志';
comment on column RRP_MDL.S_LOAN_CUST.family_farm_cust_flg
  is '家庭农场客户标志';
comment on column RRP_MDL.S_LOAN_CUST.low_incm_flg
  is '低保户标志';
comment on column RRP_MDL.S_LOAN_CUST.campus_cnsmp_loan_flg
  is '校园消费贷款标志';
comment on column RRP_MDL.S_LOAN_CUST.bank_tax_coop_loan_flg
  is '银税合作贷款标志';
comment on column RRP_MDL.S_LOAN_CUST.non_repy_prin_renew_flg
  is '无还本续贷标志';
comment on column RRP_MDL.S_LOAN_CUST.pboc_ind_opr_loan_flg
  is 'PBOC个人经营性贷款标志';
comment on column RRP_MDL.S_LOAN_CUST.cbrc_flg
  is 'CBRC标志';
comment on column RRP_MDL.S_LOAN_CUST.pboc_flg
  is 'PBOC标志';
comment on column RRP_MDL.S_LOAN_CUST.pro_impt
  is '减值准备';
comment on column RRP_MDL.S_LOAN_CUST.high_tech_idy_cl
  is '高技术产业（制造业）分类';
comment on column RRP_MDL.S_LOAN_CUST.dsr
  is 'DSR';
comment on column RRP_MDL.S_LOAN_CUST.rcmb_loan_flg
  is '重组贷款标志';
comment on column RRP_MDL.S_LOAN_CUST.bgn_year_loan_lvl5_cl
