create table RRP_MDL.O_IOL_NCBS_RB_ACCT_EVENT_REGISTER
(
  acct_seq_no           VARCHAR2(5),
  amt_type              VARCHAR2(10),
  base_acct_no          VARCHAR2(64),
  business_unit         VARCHAR2(10),
  client_no             VARCHAR2(16),
  client_type           VARCHAR2(3),
  doc_type              VARCHAR2(10),
  int_type              VARCHAR2(5),
  internal_key          NUMBER(15),
  prod_type             VARCHAR2(12),
  profit_center         VARCHAR2(20),
  reference             VARCHAR2(50),
  user_id               VARCHAR2(8),
  voucher_no            VARCHAR2(50),
  term                  VARCHAR2(5),
  term_type             VARCHAR2(1),
  company               VARCHAR2(20),
  gl_posted_flag        VARCHAR2(1),
  int_cap_flag          VARCHAR2(1),
  movt_status           VARCHAR2(1),
  narrative             VARCHAR2(400),
  prefix                VARCHAR2(10),
  print_cnt             NUMBER(5),
  seq_no                VARCHAR2(50),
  seq_renew_rollover_no VARCHAR2(50),
  source_module         VARCHAR2(3),
  tax_type              VARCHAR2(2),
  tran_status           VARCHAR2(1),
  int_class             VARCHAR2(5),
  accounting_status     VARCHAR2(3),
  acct_open_date        DATE,
  last_cycle_date       DATE,
  maturity_date         DATE,
  reversal_date         DATE,
  tran_date             DATE,
  tran_timestamp        VARCHAR2(26),
  acct_branch           VARCHAR2(12),
  acct_ccy              VARCHAR2(3),
  acct_level_int_rate   NUMBER(15,8),
  actual_rate           NUMBER(15,8),
  calc_days             NUMBER(5),
  calc_int_amt          NUMBER(38,2),
  debt_int_rate         NUMBER(15,8),
  float_rate            NUMBER(15,8),
  gross_interest_amt    NUMBER(17,2),
  int_adj               NUMBER(17,2),
  int_adj_ctd           NUMBER(17,2),
  net_interest_amt      NUMBER(17,2),
  principal_amt         NUMBER(17,2),
  real_rate             NUMBER(15,8),
  spread_rate           NUMBER(15,8),
  tax_amt               NUMBER(17,2),
  tax_rate              NUMBER(15,8),
  tran_amt              NUMBER(17,2),
  tran_branch           VARCHAR2(12),
  reaccount_cd          VARCHAR2(20),
  bus_seq_no            VARCHAR2(33),
  calc_begin_date       DATE,
  year_basis            VARCHAR2(3),
  month_basis           VARCHAR2(3),
  etl_dt                DATE,
  etl_timestamp         TIMESTAMP(6)
)
partition by range (ETL_DT)
(
  partition PARTITION_19000101 values less than (TO_DATE(' 1900-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 0
    initrans 1
    maxtrans 255,
  partition PARTITION_20250930 values less than (TO_DATE(' 2025-10-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN'))
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
