  car_tot_price               NUMBER(30,2),
  carp_tot_price              NUMBER(30,2),
  indv_opering_loan_cls_cd    VARCHAR2(30),
  open_corp_stl_acct_flg      VARCHAR2(10),
  loc_strate_new_indus_cd     VARCHAR2(30),
  es_envi_prot_cls_cd         VARCHAR2(30),
  entr_loan_risk_cls_cd       VARCHAR2(30),
  entr_loan_dep_acct_id       VARCHAR2(250),
  entr_dep_curr_cd            VARCHAR2(30),
  entr_dep_amt                NUMBER(30,2),
  cap_src_descb               VARCHAR2(2000),
  entr_cond_descb             VARCHAR2(2000),
  indv_loan_comm_fee_rat      NUMBER(18,6),
  lp_id                       VARCHAR2(250),
