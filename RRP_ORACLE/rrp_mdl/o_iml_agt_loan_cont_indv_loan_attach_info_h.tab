  hxb_rela_party_flg          VARCHAR2(10),
  chn_id                      VARCHAR2(100),
  repay_card_type_cd          VARCHAR2(30),
  open_acct_bind_id_no        VARCHAR2(60),
  open_acct_bind_mobile_no    VARCHAR2(60),
  incre_crdt_mode_cd          VARCHAR2(60),
  acm_callbk_amt              NUMBER(30,2),
