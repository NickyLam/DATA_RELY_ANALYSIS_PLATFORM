  arch_corp_name              VARCHAR2(1000),
  csner_cust_id               VARCHAR2(500),
  expt_lmt_flg                VARCHAR2(10),
  repay_acct_id               VARCHAR2(100),
  repay_acct_name             VARCHAR2(500),
  deflt_repay_day             VARCHAR2(10),
  bar_flg                     VARCHAR2(10),
  hxb_open_supv_acct_flg      VARCHAR2(10),
