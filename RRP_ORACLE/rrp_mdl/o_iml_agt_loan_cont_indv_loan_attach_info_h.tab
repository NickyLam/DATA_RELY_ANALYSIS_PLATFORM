  seller_bear_repo_duty_flg   VARCHAR2(10),
  rela_agt_id                 VARCHAR2(250),
  insu_comp_name              VARCHAR2(1000),
  insure_cont_id              VARCHAR2(250),
  buy_estate_type_cd          VARCHAR2(30),
  buy_estate_area             NUMBER(30,2),
