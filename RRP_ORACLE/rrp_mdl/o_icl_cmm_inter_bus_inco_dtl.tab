create table RRP_MDL.O_ICL_CMM_INTER_BUS_INCO_DTL
(
  etl_dt              DATE,
  lp_id               VARCHAR2(60),
  acct_bill_flow_num  VARCHAR2(60),
  tran_flow_num       VARCHAR2(60),
  tran_dt             DATE,
  acct_dt             DATE,
  amort_flow_num      VARCHAR2(60),
  subj_id             VARCHAR2(60),
  std_prod_id         VARCHAR2(60),
  cust_id             VARCHAR2(60),
  bus_acct_id         VARCHAR2(60),
  intnal_acct_id      VARCHAR2(60),
  intnal_acct_name    VARCHAR2(100),
  intnal_main_acct_id VARCHAR2(60),
  tran_main_acct_id   VARCHAR2(60),
  tran_sub_acct_id    VARCHAR2(60),
  tran_chn_cd         VARCHAR2(10),
  bal_dir_cd          VARCHAR2(10),
  sorc_sys_cd         VARCHAR2(30),
  cust_mgr_id         VARCHAR2(60),
  charge_cd           VARCHAR2(60),
  charge_name         VARCHAR2(100),
  charge_cate_cd      VARCHAR2(10),
  amort_flg           VARCHAR2(10),
  debit_crdt_flg      VARCHAR2(10),
  erase_acct_flg      VARCHAR2(10),
  revs_flg            VARCHAR2(10),
  tran_org_id         VARCHAR2(60),
  acct_instit_id      VARCHAR2(60),
  curr_cd             VARCHAR2(10),
  tran_amt            NUMBER(30,2),
  recvbl_comm_fee_amt NUMBER(18,2),
  tran_remark_info    VARCHAR2(100),
  job_cd              VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_INTER_BUS_INCO_DTL
  is '中间业务收入明细';
comment on column RRP_MDL.O_ICL_CMM_INTER_BUS_INCO_DTL.etl_dt
