create table RRP_MDL.O_IOL_ICMS_CLR_PARAM
(
  clrtypeid             VARCHAR2(96),
  clrtypename           VARCHAR2(240),
  crmtype               VARCHAR2(54),
  maxltv                NUMBER(16,6),
  maxltvscenario        VARCHAR2(1500),
  isallowedmort         VARCHAR2(3),
  isallowedpledge       VARCHAR2(3),
  isallowedremort       VARCHAR2(3),
  isallowedremortinline VARCHAR2(3),
  isacceptnfstrepay     VARCHAR2(3),
  registagencytype      VARCHAR2(54),
  gntcerttype           VARCHAR2(54),
  atttemplate           VARCHAR2(96),
  infotab               VARCHAR2(96),
  iscurrmismatch        VARCHAR2(3),
  isneedinsurance       VARCHAR2(3),
  renewalterm           NUMBER(38),
  isneednotarizaiton    VARCHAR2(3),
  isneedrgst            VARCHAR2(3),
  isneedmonitoring      VARCHAR2(3),
  monitoringfrq         VARCHAR2(18),
  maxguaterm            NUMBER(38),
  maxguascenario        VARCHAR2(3000),
  evalperiod            NUMBER(38),
  issuitineval          VARCHAR2(3),
  issuitouteval         VARCHAR2(3),
  mainevalmethod        VARCHAR2(96),
  detailevalmodel       VARCHAR2(240),
  fastevalmodel         VARCHAR2(240),
  evalflow              VARCHAR2(96),
  appraiseatt           VARCHAR2(3000),
  reevalfrqunit         VARCHAR2(18),
  reevalfrq             NUMBER(38),
  isautoreeval          VARCHAR2(3),
  autoreevalmode        VARCHAR2(18),
  reevaldatedef         VARCHAR2(3000),
  extweight             NUMBER(16,6),
  inweight              NUMBER(16,6),
  isneedrightcert       VARCHAR2(3),
  issuitcombineeval     VARCHAR2(3),
  ismanualbatchreval    VARCHAR2(3),
  issysbatchreval       VARCHAR2(3),
  evalmodelmarket       VARCHAR2(240),
  evalmodelprofit       VARCHAR2(240),
  evalmodelcost         VARCHAR2(240),
  evalmodelquick        VARCHAR2(240),
  ishavewarrant         VARCHAR2(3),
  isneedin              VARCHAR2(3),
  isqualified           VARCHAR2(3),
  validcerttype         VARCHAR2(240),
  inputorgid            VARCHAR2(96),
  inputuserid           VARCHAR2(240),
  inputdate             TIMESTAMP(6),
  updateorgid           VARCHAR2(96),
  updateuserid          VARCHAR2(240),
  updatedate            TIMESTAMP(6),
  remark                VARCHAR2(1500),
  entrycriteria         VARCHAR2(4000),
  productlist           VARCHAR2(4000),
  clronlyscope          VARCHAR2(4000),
  maincerttype          VARCHAR2(90),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_CLR_PARAM
  is '押品分类参数';
comment on column RRP_MDL.O_IOL_ICMS_CLR_PARAM.clrtypeid
  is '押品类型编号';
comment on column RRP_MDL.O_IOL_ICMS_CLR_PARAM.clrtypename
  is '押品类型名称';
comment on column RRP_MDL.O_IOL_ICMS_CLR_PARAM.crmtype
  is '风险缓释工具类型';
comment on column RRP_MDL.O_IOL_ICMS_CLR_PARAM.maxltv
  is '最大抵质押率';
comment on column RRP_MDL.O_IOL_ICMS_CLR_PARAM.maxltvscenario
  is '最大抵质押率适用业务场景';
comment on column RRP_MDL.O_IOL_ICMS_CLR_PARAM.isallowedmort
  is '是否允许抵押';
comment on column RRP_MDL.O_IOL_ICMS_CLR_PARAM.isallowedpledge
  is '是否允许质押';
