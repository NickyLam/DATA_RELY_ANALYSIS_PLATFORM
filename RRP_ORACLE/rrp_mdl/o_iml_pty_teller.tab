create table RRP_MDL.O_IML_PTY_TELLER
(
  emply_id         VARCHAR2(60),
  party_id         VARCHAR2(60),
  lp_id            VARCHAR2(60),
  belong_org_id    VARCHAR2(60),
  teller_id        VARCHAR2(60),
  belong_dept_id   VARCHAR2(60),
  teller_status_cd VARCHAR2(10),
  create_dt        DATE,
  update_dt        DATE,
  etl_dt           DATE,
  id_mark          VARCHAR2(10),
  src_table_name   VARCHAR2(100),
  job_cd           VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_PTY_TELLER
  is '柜员';
comment on column RRP_MDL.O_IML_PTY_TELLER.emply_id
  is '员工编号';
comment on column RRP_MDL.O_IML_PTY_TELLER.party_id
  is '当事人编号';
comment on column RRP_MDL.O_IML_PTY_TELLER.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_PTY_TELLER.belong_org_id
  is '所属机构编号';
comment on column RRP_MDL.O_IML_PTY_TELLER.teller_id
  is '柜员编号';
comment on column RRP_MDL.O_IML_PTY_TELLER.belong_dept_id
  is '归属部门编号';
comment on column RRP_MDL.O_IML_PTY_TELLER.teller_status_cd
  is '柜员状态代码CD1515';
comment on column RRP_MDL.O_IML_PTY_TELLER.create_dt
  is '创建日期';
comment on column RRP_MDL.O_IML_PTY_TELLER.update_dt
  is '更新日期';
comment on column RRP_MDL.O_IML_PTY_TELLER.etl_dt
  is '数据日期';
comment on column RRP_MDL.O_IML_PTY_TELLER.id_mark
  is '删除标识';
comment on column RRP_MDL.O_IML_PTY_TELLER.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_PTY_TELLER.job_cd
  is '任务代码';

