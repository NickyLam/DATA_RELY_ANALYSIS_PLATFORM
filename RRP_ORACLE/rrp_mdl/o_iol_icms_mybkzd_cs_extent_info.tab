create table RRP_MDL.O_IOL_ICMS_MYBKZD_CS_EXTENT_INFO
(
  serialno                VARCHAR2(32),
  applyno                 VARCHAR2(64),
  mobile                  VARCHAR2(32),
  address                 VARCHAR2(1200),
  prov                    VARCHAR2(60),
  city                    VARCHAR2(120),
  area                    VARCHAR2(120),
  certvalidenddate        VARCHAR2(128),
  busdatareqdate          VARCHAR2(64),
  businfoexistflag        VARCHAR2(8),
  notexistreason          VARCHAR2(500),
  companyinfoname         VARCHAR2(600),
  companyinfolawer        VARCHAR2(150),
  registerno              VARCHAR2(64),
  registerdate            VARCHAR2(32),
  registeraddress         VARCHAR2(1024),
  registeraddressareacode VARCHAR2(64),
  registeraddressarea     VARCHAR2(300),
  registerfund            NUMBER(18,2),
  fundcurrency            VARCHAR2(64),
  tradecode               VARCHAR2(64),
  managerange             VARCHAR2(4000),
  orgcode                 VARCHAR2(64),
  registerdepartment      VARCHAR2(300),
  statusid                VARCHAR2(30),
  statusdesc              VARCHAR2(1000),
  lastcheckyear           VARCHAR2(64),
  managebegindate         VARCHAR2(64),
  manageenddate           VARCHAR2(64),
  opendate                VARCHAR2(64),
  companytype             VARCHAR2(256),
  economictype            VARCHAR2(256),
  targetjyflag1           VARCHAR2(256),
  industryname            VARCHAR2(256),
  certvalidstartdate      VARCHAR2(20),
  sex                     VARCHAR2(2),
  indivocc                VARCHAR2(256),
  nationality             VARCHAR2(6),
  businessscene           VARCHAR2(64),
  businesstag             VARCHAR2(64),
  pushreason              VARCHAR2(8),
  custverifytype          VARCHAR2(32),
  custverifyresult        VARCHAR2(8),
  custverifytime          VARCHAR2(24),
  customertag             VARCHAR2(32),
  employee_id             VARCHAR2(128),
  nation                  VARCHAR2(32),
  company_info_org_code   VARCHAR2(64),
  start_dt                DATE,
  end_dt                  DATE,
  id_mark                 VARCHAR2(10),
  etl_timestamp           TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_MYBKZD_CS_EXTENT_INFO
