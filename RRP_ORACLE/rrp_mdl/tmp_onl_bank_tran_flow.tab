create table RRP_MDL.TMP_ONL_BANK_TRAN_FLOW
(
  flow VARCHAR2(90)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.TMP_ONL_BANK_TRAN_FLOW
  is '网上银行交易正常流水临时表-手工报表专用';
comment on column RRP_MDL.TMP_ONL_BANK_TRAN_FLOW.flow
  is '流水号';

