create table RRP_MDL.ADD_DG_015_NATION_FOREIGN_ETL_VALIDATE
(
  datainput_id   VARCHAR2(32) not null,
  data_date      VARCHAR2(10),
  acct_org_num   VARCHAR2(20),
  jywym          VARCHAR2(200),
  zhwym          VARCHAR2(60),
  zwjgmc         VARCHAR2(60),
  ywlb           VARCHAR2(100),
  sfnbwd         VARCHAR2(10),
  dwdblb         VARCHAR2(60),
  ysqsrq         VARCHAR2(10),
  sfbnqy         VARCHAR2(10),
  sjdqrq         VARCHAR2(10),
  dwdbqye        NUMBER(20,6),
  dwdblyrq       VARCHAR2(10),
  sfbnly         VARCHAR2(10),
  dwdblye        NUMBER(20,6),
  dwdbdqsxje     NUMBER(20,6),
  dwdbqmye       NUMBER(20,6),
  ychdwdbdkje    NUMBER(20,6),
  dwdbqmdkye     NUMBER(20,6),
  sys_source     VARCHAR2(100),
  sys_data_date  VARCHAR2(20) not null,
  sys_data_case  VARCHAR2(32) not null,
  sys_operator   VARCHAR2(256),
  sys_oper_org   VARCHAR2(32) not null,
  sys_oper_date  VARCHAR2(20),
  sys_data_state VARCHAR2(10),
  sys_order_no   NUMBER(19),
  error_mark     VARCHAR2(2),
  flow_node_id   VARCHAR2(32),
  comments       VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.ADD_DG_015_NATION_FOREIGN_ETL_VALIDATE
  is '补录表-对公-国别-内保外贷模型-G51-应用';
comment on column RRP_MDL.ADD_DG_015_NATION_FOREIGN_ETL_VALIDATE.datainput_id
