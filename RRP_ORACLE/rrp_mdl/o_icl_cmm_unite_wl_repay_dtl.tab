create table RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL
(
  etl_dt                      DATE,
  lp_id                       VARCHAR2(60),
  dubil_id                    VARCHAR2(100),
  cust_id                     VARCHAR2(60),
  prod_id                     VARCHAR2(60),
  repay_acct_id               VARCHAR2(100),
  repay_flow_id               VARCHAR2(250),
  repay_dt                    DATE,
  intnal_carr_flg             VARCHAR2(10),
  wrt_off_flg                 VARCHAR2(10),
  adv_repay_flg               VARCHAR2(10),
  ovdue_repay_flg             VARCHAR2(10),
  acru_non_acru_cd            VARCHAR2(10),
  repay_type_cd               VARCHAR2(10),
  curr_cd                     VARCHAR2(10),
  curr_nomal_pric_bal         NUMBER(30,2),
  currt_repay_amt             NUMBER(30,2),
  currt_repay_pric            NUMBER(30,2),
  currt_repay_nomal_pric      NUMBER(30,2),
  currt_repay_ovdue_pric      NUMBER(30,2),
  curr_repay_int              NUMBER(30,2),
  currt_repay_nomal_int       NUMBER(30,2),
  currt_repay_ovdue_int       NUMBER(30,2),
  currt_repay_pnlt            NUMBER(30,2),
  currt_repay_ovdue_pric_pnlt NUMBER(30,2),
  currt_repay_ovdue_int_pnlt  NUMBER(30,2),
  currt_repay_fee             NUMBER(30,2),
  currt_repay_fee_rat         NUMBER(18,8),
  job_cd                      VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL
  is '联合网贷还款明细';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.etl_dt
  is '数据日期';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.lp_id
  is '法人编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.dubil_id
  is '借据编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.cust_id
  is '客户编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.prod_id
  is '产品编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.repay_acct_id
  is '还款账户编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.repay_flow_id
  is '还款流水编号';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.repay_dt
  is '还款日期';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.intnal_carr_flg
  is '内部结转标志';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.wrt_off_flg
  is '核销标志';
comment on column RRP_MDL.O_ICL_CMM_UNITE_WL_REPAY_DTL.adv_repay_flg
