  inst_cod                  VARCHAR2(10),
  prod_cd                   VARCHAR2(10),
  curr_code                 VARCHAR2(2),
  rmt_cash_flg              VARCHAR2(1),
  oa_bankno                 VARCHAR2(20),
  opec_bank_name            VARCHAR2(60),
  cust_actno                VARCHAR2(32),
  temp_acctno_ctfc          VARCHAR2(16),
  basic_acctno_license      VARCHAR2(16),
  trans_chgpflg             VARCHAR2(1),
  org_intc_date             VARCHAR2(8),
  org_end_date              VARCHAR2(8),
  combprod_cod              VARCHAR2(10),
  comb_acno                 VARCHAR2(32),
  acct_acno                 VARCHAR2(32),
  sys_acctno                VARCHAR2(32),
  sign_contract_fs_prod_cod VARCHAR2(10),
  safe_acctno_char          VARCHAR2(4),
  cnrt_code                 VARCHAR2(30),
  approve_cod               VARCHAR2(25),
  openup_flg                VARCHAR2(1),
  openup_opr_name           VARCHAR2(22),
  resv_lfield               VARCHAR2(200),
  rsv_fld                   VARCHAR2(16),
  resv_fld2                 VARCHAR2(200),
  resv_fld3                 VARCHAR2(200),
  resv_bal01                NUMBER(17,2),
  resv_bal02                NUMBER(17,2),
  appt_amt                  NUMBER(17,2),
  succ_cnt                  NUMBER(10),
  if_flag                   VARCHAR2(1),
  acct_fbal                 NUMBER(17,2),
  rsv_acfld                 VARCHAR2(50),
  rsv_adfld                 VARCHAR2(50),
  rsv_aefld                 VARCHAR2(50),
  rsv_affld                 VARCHAR2(50),
  resv_number               NUMBER(10),
  resv_date1                VARCHAR2(8),
  resv_date2                VARCHAR2(8),
  rmk_info                  VARCHAR2(128),
  mod_opr                   VARCHAR2(8),
  mod_unit                  VARCHAR2(10),
