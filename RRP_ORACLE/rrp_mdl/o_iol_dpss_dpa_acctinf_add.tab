  time_sign                 NUMBER(16),
  rec_sts                   VARCHAR2(1),
  start_dt                  DATE,
  end_dt                    DATE,
  id_mark                   VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_DPSS_DPA_ACCTINF_ADD
  is '负债账户补充资料登记表';
