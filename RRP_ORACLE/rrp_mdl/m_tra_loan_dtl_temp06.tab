create table RRP_MDL.M_TRA_LOAN_DTL_TEMP06
(
  tran_ref_no              VARCHAR2(200),
  tran_flow_num            VARCHAR2(200),
  acct_bill_flow_num       VARCHAR2(200),
  tran_amt                 NUMBER(30,2),
  cntpty_acct_id           VARCHAR2(200),
  cntpty_acct_name         VARCHAR2(500),
  cntpty_acct_open_bank_cd VARCHAR2(200),
  cntpty_open_bank_name    VARCHAR2(500),
  oth_real_base_acct_no    VARCHAR2(200),
  oth_real_tran_name       VARCHAR2(500),
  oth_real_tran_bank_code  VARCHAR2(200),
  oth_real_tran_bank_name  VARCHAR2(500),
  rank_num                 INTEGER
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
comment on table RRP_MDL.M_TRA_LOAN_DTL_TEMP06
  is '信贷交易流水表--交易对手信息';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.tran_ref_no
  is '信贷交易流水';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.tran_flow_num
  is '对应核心交易流水';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.acct_bill_flow_num
  is '对应核心交易流水账单号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.tran_amt
  is '核心交易金额';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.cntpty_acct_id
  is '交易对手账号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.cntpty_acct_name
  is '交易对手户名';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.cntpty_acct_open_bank_cd
  is '交易对手行号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.cntpty_open_bank_name
  is '交易对手行名';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.oth_real_base_acct_no
  is '登记簿交易对手账号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.oth_real_tran_name
  is '登记簿交易对手户名';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.oth_real_tran_bank_code
  is '登记簿交易对手行号';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.oth_real_tran_bank_name
  is '登记簿交易对手行名';
comment on column RRP_MDL.M_TRA_LOAN_DTL_TEMP06.rank_num
  is '序号';

