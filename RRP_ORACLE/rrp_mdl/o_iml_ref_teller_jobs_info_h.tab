create table RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H
(
  jobs_id        VARCHAR2(100),
  lp_id          VARCHAR2(60),
  jobs_name      VARCHAR2(500),
  jobs_aval_flg  VARCHAR2(10),
  jobs_type_cd   VARCHAR2(30),
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10),
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H
  is '柜员岗位信息历史';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.jobs_id
  is '岗位编号';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.jobs_name
  is '岗位名称';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.jobs_aval_flg
  is '岗位可用标志';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.jobs_type_cd
  is '岗位类型代码';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_REF_TELLER_JOBS_INFO_H.job_cd
  is '任务编码';

