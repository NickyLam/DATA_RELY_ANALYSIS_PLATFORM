create table RRP_MDL.O_IML_EVT_REPAY_FLOW
(
  evt_id                               VARCHAR2(250),
  callbk_id                            VARCHAR2(100),
  lp_id                                VARCHAR2(100),
  loan_num                             VARCHAR2(60),
  cust_id                              VARCHAR2(100),
  loan_repay_dt                        DATE,
  loan_repay_type_cd                   VARCHAR2(30),
  pay_cust_id                          VARCHAR2(100),
  curr_cd                              VARCHAR2(30),
  cny_exch_rat                         NUMBER(18,8),
  exch_way_cd                          VARCHAR2(30),
  callbk_pric                          NUMBER(30,2),
  bus_tran_dt                          DATE,
  callbk_prod_way_cd                   VARCHAR2(30),
  tran_ref_no                          VARCHAR2(60),
  tran_org_id                          VARCHAR2(100),
  repay_plan_modif_way_cd              VARCHAR2(30),
  adv_repay_fee_amt                    NUMBER(30,2),
  adv_repay_pric_amt                   NUMBER(30,2),
  loan_rs_cd                           VARCHAR2(30),
  tran_memo_descb                      VARCHAR2(500),
  tran_stl_flg                         VARCHAR2(10),
  tran_stl_dt                          DATE,
  acct_aldy_check_flg                  VARCHAR2(10),
  acct_check_dt                        DATE,
  revs_flg                             VARCHAR2(10),
  tran_revs_rs_descb                   VARCHAR2(500),
  sellout_flg                          VARCHAR2(10),
  evt_cate_id                          VARCHAR2(100),
  tran_cd                              VARCHAR2(30),
  adv_bf_repay_repay_plan_modif_way_cd VARCHAR2(30),
  adv_bf_repay_exp_dt                  DATE,
  nomal_repay_eh_issue_repay_amt       NUMBER(30,2),
  stl_teller_id                        VARCHAR2(100),
  acct_apv_teller_id                   VARCHAR2(100),
  ba_auth_teller_id                    VARCHAR2(100),
  tran_teller_id                       VARCHAR2(100),
  final_modif_dt                       DATE,
  tran_tm                              TIMESTAMP(6),
  repay_rstrct_cd                      VARCHAR2(30),
  check_entry_code                     VARCHAR2(60),
  etl_dt                               DATE,
  src_table_name                       VARCHAR2(100),
  job_cd                               VARCHAR2(10),
  etl_timestamp                        TIMESTAMP(6),
  callbk_rs                            VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_REPAY_FLOW
  is '还款流水';
comment on column RRP_MDL.O_IML_EVT_REPAY_FLOW.evt_id
