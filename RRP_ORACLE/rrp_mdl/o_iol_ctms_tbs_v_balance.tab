create table RRP_MDL.O_IOL_CTMS_TBS_V_BALANCE
(
  baretrade_id    NUMBER,
  baretradename   VARCHAR2(60),
  balance_id      NUMBER,
  alterbalance_id NUMBER,
  aspclient_id    NUMBER,
  keepfolder_id   NUMBER,
  settledate      NUMBER(8),
  assettype       VARCHAR2(30),
  buztype         VARCHAR2(30),
  majorassetcode  VARCHAR2(30),
  minorassetcode  VARCHAR2(30),
  holdposition    NUMBER,
  holdfaceamount  NUMBER,
  cleanpricecost  NUMBER,
  interestadjust  NUMBER,
  fairvaluealter  NUMBER,
  interestcost    NUMBER,
  dirtypricecost  NUMBER,
  impairment      NUMBER,
  priceearning    NUMBER,
  amortizeearning NUMBER,
  interestearning NUMBER,
  fairvalueincome NUMBER,
  impairmentlost  NUMBER,
  tradeexpense    NUMBER,
  realrate        NUMBER,
  valuedate       NUMBER(8),
  maturitydate    NUMBER(8),
  lastmodified    TIMESTAMP(6),
  occuramount     NUMBER,
  balance_id_prev NUMBER,
  rev_flag        VARCHAR2(2),
  reservevalue1   NUMBER,
  reservevalue2   NUMBER,
  chargeincome    NUMBER,
  chargeexpense   NUMBER,
  start_dt        DATE,
  end_dt          DATE,
  id_mark         VARCHAR2(10),
  etl_timestamp   TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_CTMS_TBS_V_BALANCE
