create table RRP_MDL.M_DICT_G09_HZF
(
  data_date    VARCHAR2(10),
  acct_org_num VARCHAR2(20),
  hzfwym       VARCHAR2(90),
  shxydm       VARCHAR2(45),
  hzfs         VARCHAR2(150),
  hzfmc        VARCHAR2(150),
  hlwdkytlb    VARCHAR2(75),
  hlwdkhzjglb  VARCHAR2(75),
  bhczbl       NUMBER(10,2),
  hzjgczbl     NUMBER(10,2),
  hzjgtgfwlx   VARCHAR2(15),
  zxlb         VARCHAR2(75),
  sys_source   VARCHAR2(100),
  ywpzbh       VARCHAR2(60),
  ywpzmc       VARCHAR2(100),
  tjye         NUMBER(20,6),
  sfsc         VARCHAR2(10),
  std_prod_id  VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_DICT_G09_HZF
  is 'G09合作方';
comment on column RRP_MDL.M_DICT_G09_HZF.data_date
  is '更新日期';
comment on column RRP_MDL.M_DICT_G09_HZF.acct_org_num
  is '账务机构编号';
comment on column RRP_MDL.M_DICT_G09_HZF.hzfwym
  is '合作方唯一码';
comment on column RRP_MDL.M_DICT_G09_HZF.shxydm
  is '社会信用代码';
comment on column RRP_MDL.M_DICT_G09_HZF.hzfs
  is '合作方式';
comment on column RRP_MDL.M_DICT_G09_HZF.hzfmc
  is '合作方名称';
comment on column RRP_MDL.M_DICT_G09_HZF.hlwdkytlb
  is '互联网贷款用途类别';
comment on column RRP_MDL.M_DICT_G09_HZF.hlwdkhzjglb
  is '互联网贷款合作机构类别';
comment on column RRP_MDL.M_DICT_G09_HZF.bhczbl
  is '本行出资比例';
comment on column RRP_MDL.M_DICT_G09_HZF.hzjgczbl
  is '合作机构出资比例';
comment on column RRP_MDL.M_DICT_G09_HZF.hzjgtgfwlx
  is '合作机构提供服务类型';
comment on column RRP_MDL.M_DICT_G09_HZF.zxlb
  is '增信类别';
comment on column RRP_MDL.M_DICT_G09_HZF.sys_source
  is '来源系统';
comment on column RRP_MDL.M_DICT_G09_HZF.ywpzbh
  is '业务品种编号';
comment on column RRP_MDL.M_DICT_G09_HZF.ywpzmc
  is '业务品种名称';
comment on column RRP_MDL.M_DICT_G09_HZF.tjye
  is '统计余额';
comment on column RRP_MDL.M_DICT_G09_HZF.sfsc
  is '是否删除';
comment on column RRP_MDL.M_DICT_G09_HZF.std_prod_id
  is '标准产品编号';

