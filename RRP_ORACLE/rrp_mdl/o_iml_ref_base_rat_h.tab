create table RRP_MDL.O_IML_REF_BASE_RAT_H
(
  lp_id          VARCHAR2(100),
  base_rat_id    VARCHAR2(100),
  curr_cd        VARCHAR2(30),
  effect_dt      DATE,
  base_rat       NUMBER(18,8),
  start_dt       DATE,
  end_dt         DATE,
  id_mark        VARCHAR2(10),
  src_table_name VARCHAR2(100),
  job_cd         VARCHAR2(10),
  etl_timestamp  TIMESTAMP(6),
  invalid_dt     DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_REF_BASE_RAT_H
  is '基准利率历史表';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.base_rat_id
  is '基准利率编号';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.curr_cd
  is '币种代码';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.effect_dt
  is '生效日期';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.base_rat
  is '基准利率';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.src_table_name
  is '源表名称';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.job_cd
  is '任务编码';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.etl_timestamp
  is 'etl处理时间戳';
comment on column RRP_MDL.O_IML_REF_BASE_RAT_H.invalid_dt
  is '失效日期';

