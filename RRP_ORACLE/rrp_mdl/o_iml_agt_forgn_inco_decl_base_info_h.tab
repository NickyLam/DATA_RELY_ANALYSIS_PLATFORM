create table RRP_MDL.O_IML_AGT_FORGN_INCO_DECL_BASE_INFO_H
(
  agt_id                     VARCHAR2(250),
  lp_id                      VARCHAR2(100),
  decl_id                    VARCHAR2(100),
  temp_decl_flow_num         VARCHAR2(100),
  init_enty_id               VARCHAR2(100),
  edit_id                    VARCHAR2(100),
  oper_type_cd               VARCHAR2(30),
  modif_rs_descb             VARCHAR2(750),
  decl_num                   VARCHAR2(60),
  recver_type_cd             VARCHAR2(30),
  indv_id_card_piece_no_code VARCHAR2(60),
  orgnz_id                   VARCHAR2(100),
  recver_name                VARCHAR2(750),
  payer_name                 VARCHAR2(750),
  rev_curr_cd                VARCHAR2(30),
  rev_amt                    NUMBER(30),
  soe_exch_rat               NUMBER(18,8),
  soe_amt                    NUMBER(30),
  cny_acct_id                VARCHAR2(100),
  spot_exch_amt              NUMBER(30),
  fx_acct_id                 VARCHAR2(100),
  other_amt                  NUMBER(30),
  other_acct_id              VARCHAR2(100),
  stl_way_cd                 VARCHAR2(30),
  bank_bus_id                VARCHAR2(100),
  dom_bank_deduct_curr_cd    VARCHAR2(30),
  dom_bank_deduct_amt        NUMBER(30),
  overs_bank_deduct_curr_cd  VARCHAR2(30),
  overs_bank_deduct_amt      NUMBER(30),
  start_dt                   DATE,
  end_dt                     DATE,
  id_mark                    VARCHAR2(10),
  src_table_name             VARCHAR2(100),
  job_cd                     VARCHAR2(10),
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
