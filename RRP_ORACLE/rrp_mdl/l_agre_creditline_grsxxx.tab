create table RRP_MDL.L_AGRE_CREDITLINE_GRSXXX
(
  data_date                 VARCHAR2(8),
  data_sourced              VARCHAR2(60),
  loan_num                  VARCHAR2(60),
  contract_num              VARCHAR2(60),
  bus_breed_id              VARCHAR2(60),
  bus_breed_name            VARCHAR2(500),
  cust_id                   VARCHAR2(60),
  cust_name                 VARCHAR2(100),
  drawdown_amt              NUMBER(30,2),
  loan_acct_bal             NUMBER(30,2),
  drawdown_dt               VARCHAR2(8),
  maturity_dt               VARCHAR2(8),
  pay_type                  VARCHAR2(60),
  loan_level10_cls_cd       VARCHAR2(60),
  od_days                   NUMBER(10),
  cust_mgr_id               VARCHAR2(60),
  org_num                   VARCHAR2(60),
  facility_num              VARCHAR2(60),
  ods_facility_num          VARCHAR2(60),
  used_facility_flg         VARCHAR2(1),
  facility_amt              NUMBER(30,2),
  ods_facility_amt          NUMBER(30,2),
  acct_typ                  VARCHAR2(20),
  contract_amt              NUMBER(30,2),
  contract_eff_dt           VARCHAR2(8),
  contract_orig_maturity_dt VARCHAR2(8),
  contract_sts              VARCHAR2(10),
  facility_start_dt         VARCHAR2(8),
  facility_end_dt           VARCHAR2(8),
  cyc_flg                   VARCHAR2(1),
  curr_cd                   VARCHAR2(3),
  org_num_sx                VARCHAR2(10)
)
partition by list (DATA_DATE)
(
  partition P19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition P20220930 values ('20220930')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_20220901 values ('20220901')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.L_AGRE_CREDITLINE_GRSXXX
  is '零售系统授信信息表';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.data_date
  is '数据日期';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.data_sourced
  is '来源系统';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.loan_num
  is '借据号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.contract_num
  is '业务合同号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.bus_breed_id
  is '业务品种编号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.bus_breed_name
  is '业务品种名称';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.cust_id
  is '客户号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.cust_name
  is '客户名称';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.drawdown_amt
  is '借据放款金额';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.loan_acct_bal
  is '借据余额';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.drawdown_dt
  is '借据放款日期';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.maturity_dt
  is '借据到期日期';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.pay_type
  is '还款方式';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.loan_level10_cls_cd
  is '十级分类';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.od_days
  is '逾期天数';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.cust_mgr_id
  is '客户经理号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.org_num
  is '机构号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.facility_num
  is '授信额度编号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.ods_facility_num
  is '源系统授信合同号';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.used_facility_flg
  is '引用授信标志（是Y,否N）';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.facility_amt
  is '授信额度';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.ods_facility_amt
  is '源系统授信额度';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.acct_typ
  is '贷款类型';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.contract_amt
  is '业务合同金额';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.contract_eff_dt
  is '业务合同生效日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.contract_orig_maturity_dt
  is '业务合同到期日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.contract_sts
  is '业务合同状态';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.facility_start_dt
  is '授信生效日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.facility_end_dt
  is '授信到期日';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.cyc_flg
  is '循环额度标志';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.curr_cd
  is '币种';
comment on column RRP_MDL.L_AGRE_CREDITLINE_GRSXXX.org_num_sx
  is '授信所属机构号';

