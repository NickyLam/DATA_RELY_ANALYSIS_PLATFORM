create table RRP_MDL.O_IML_EVT_WRT_GUAT_TRAN_FLOW
(
  evt_id                      VARCHAR2(250),
  tran_flow_num               VARCHAR2(100),
  lp_id                       VARCHAR2(100),
  cash_tran_seq_num           VARCHAR2(60),
  cr_acct_id                  VARCHAR2(100),
  cr_cust_acct_num            VARCHAR2(60),
  cr_acct_curr                VARCHAR2(30),
  cr_acct_sub_acct_num        VARCHAR2(60),
  cr_acct_prod_id             VARCHAR2(100),
  cr_bal_type_cd              VARCHAR2(30),
  cr_tran_seq_num             VARCHAR2(60),
  dr_acct_id                  VARCHAR2(100),
  dr_cust_acct_num            VARCHAR2(60),
  dr_acct_curr                VARCHAR2(30),
  dr_acct_sub_acct_num        VARCHAR2(60),
  dr_acct_prod_id             VARCHAR2(100),
  dr_bal_type_cd              VARCHAR2(30),
  dr_tran_seq_num             VARCHAR2(60),
  cust_id                     VARCHAR2(100),
  tran_cd                     VARCHAR2(30),
  tran_dt                     DATE,
  tran_org_id                 VARCHAR2(100),
  revs_dt                     DATE,
  revs_tran_cd                VARCHAR2(30),
  wrt_guat_tran_status_cd     VARCHAR2(30),
  bus_type_cd                 VARCHAR2(30),
  quot_type_cd                VARCHAR2(30),
  exch_rat_type_cd            VARCHAR2(30),
  buy_amt                     NUMBER(30,2),
  buy_curr_cd                 VARCHAR2(30),
  buyer_exch_rat              NUMBER(18,8),
  sell_curr                   VARCHAR2(30),
  sell_amt                    NUMBER(30,2),
  seller_exch_rat             NUMBER(18,8),
  exec_exch_rat               NUMBER(18,8),
  float_int_rat               NUMBER(18,8),
  base_quot_way_cd            VARCHAR2(30),
  base_exch_rat_type_cd       VARCHAR2(30),
  base_exch_rat               NUMBER(18,8),
  base_equvl_amt              NUMBER(30,2),
  cross_exch_rat              NUMBER(18,8),
  offset_cross_exch_rat       NUMBER(18,8),
  intnal_price                NUMBER(30,2),
  change_equvl_amt            NUMBER(30,2),
  change_amt                  NUMBER(30,2),
  change_base_int_rat         NUMBER(18,8),
  change_base_int_rat_type_cd VARCHAR2(30),
  change_int_rat              NUMBER(18,8),
  change_base_quot_way_cd     VARCHAR2(30),
  change_quot_way_cd          VARCHAR2(30),
  change_int_rat_type_cd      VARCHAR2(30),
  tran_ref_no                 VARCHAR2(60),
  follow_ref_no               VARCHAR2(60),
  chn_id                      VARCHAR2(100),
  bank_tran_seq_num           VARCHAR2(60),
  tran_descb                  VARCHAR2(500),
  src_module_type_cd          VARCHAR2(30),
  tran_termn_id               VARCHAR2(100),
  check_dt                    DATE,
  entry_dt                    DATE,
  check_teller_id             VARCHAR2(100),
  check_auth_teller_id        VARCHAR2(100),
  tran_auth_teller_id         VARCHAR2(100),
  revs_auth_teller_id         VARCHAR2(100),
  revs_teller_id              VARCHAR2(100),
  core_tran_teller_id         VARCHAR2(100),
  tran_tm                     TIMESTAMP(6),
  offset_status_cd            VARCHAR2(30),
  fcurr_hq_sys_in_suplm_amt   NUMBER(30,2),
  sys_in_offset_flow_num      VARCHAR2(100),
  tran_market_offset_flow_num VARCHAR2(100),
  etl_dt                      DATE,
  src_table_name              VARCHAR2(100),
  job_cd                      VARCHAR2(10),
  etl_timestamp               TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
