  rgst_dt                       DATE,
  rgst_belong_org_id            VARCHAR2(100),
  rgst_teller_id                VARCHAR2(100),
  update_teller_id              VARCHAR2(100),
  update_org_id                 VARCHAR2(100),
  remark                        VARCHAR2(4000),
  start_dt                      DATE,
  end_dt                        DATE,
  id_mark                       VARCHAR2(10),
  src_table_name                VARCHAR2(100),
  job_cd                        VARCHAR2(10),
  etl_timestamp                 TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
