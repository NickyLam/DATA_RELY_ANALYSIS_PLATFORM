create table RRP_MDL.O_IOL_UUSS_UUS_ORGAN
(
  organcodekey       VARCHAR2(18),
  organcode          VARCHAR2(18),
  zoneno             VARCHAR2(5),
  pbocfinancialcode  VARCHAR2(90),
  financialcode      VARCHAR2(18),
  swiftcode          VARCHAR2(45),
  bankcode           VARCHAR2(18),
  legal              VARCHAR2(6),
  businesslicense    VARCHAR2(27),
  organizationcode   VARCHAR2(14),
  taxid              VARCHAR2(23),
  organcnfullname    VARCHAR2(300),
  organcnshortname   VARCHAR2(150),
  organenfullname    VARCHAR2(150),
  organenshortname   VARCHAR2(150),
  organstatecode     VARCHAR2(2),
  organstatus        VARCHAR2(2),
  organfoundingdate  VARCHAR2(12),
  organclosedate     VARCHAR2(12),
  organtype          VARCHAR2(3),
  isst               VARCHAR2(2),
  ishs               VARCHAR2(2),
  isyy               VARCHAR2(2),
  isxz               VARCHAR2(2),
  iszw               VARCHAR2(2),
  organlevel         VARCHAR2(3),
  leafnoteflag       VARCHAR2(2),
  xzuporgancode      VARCHAR2(18),
  zwuporgancode      VARCHAR2(18),
  hsuporgancode      VARCHAR2(18),
  seque              VARCHAR2(5),
  postcode           VARCHAR2(9),
  country            VARCHAR2(5),
  province           VARCHAR2(9),
  city               VARCHAR2(9),
  county             VARCHAR2(9),
  address            VARCHAR2(600),
  email              VARCHAR2(75),
  url                VARCHAR2(75),
  countrycode        VARCHAR2(6),
  areacode           VARCHAR2(6),
  phone              VARCHAR2(45),
  subphone           VARCHAR2(9),
  servicephone       VARCHAR2(45),
  funorgan           VARCHAR2(18),
  fundep             VARCHAR2(18),
  orderno            VARCHAR2(18),
  financiallicnum    VARCHAR2(45),
  organsystem        VARCHAR2(383),
  cbrcfininsttid     VARCHAR2(90),
  unionfinancialcode VARCHAR2(21),
  workstarttm        VARCHAR2(9),
  workendtm          VARCHAR2(9),
  updatedate         VARCHAR2(12),
  heademplyid        VARCHAR2(12),
  isxnhs             VARCHAR2(2),
  rhregcode          VARCHAR2(15),
  blng_city_pbc      VARCHAR2(300),
  bankcodeperson     VARCHAR2(18),
  note1              VARCHAR2(300),
  note2              VARCHAR2(300),
  note3              VARCHAR2(300),
  note4              VARCHAR2(150),
  note5              VARCHAR2(150),
  note6              VARCHAR2(150),
  note7              VARCHAR2(150),
  note8              VARCHAR2(75),
  note9              VARCHAR2(75),
  note10             VARCHAR2(75),
  bbuporgancode      VARCHAR2(18),
  countyflag         VARCHAR2(3),
  technologyflag     VARCHAR2(3),
  specialflag        VARCHAR2(3),
  financeflag        VARCHAR2(3),
  freetradeflag      VARCHAR2(3),
  busitimedesc       VARCHAR2(4000),
  busiscopdesc       VARCHAR2(4000),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
