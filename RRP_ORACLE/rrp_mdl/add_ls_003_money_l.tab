create table RRP_MDL.ADD_LS_003_MONEY_L
(
  data_date    VARCHAR2(10),
  acct_org_num VARCHAR2(20),
  jywym        VARCHAR2(200),
  zhwym        VARCHAR2(90),
  khwym        VARCHAR2(90),
  khmc         VARCHAR2(150),
  dkywpzmc     VARCHAR2(150),
  tjye         NUMBER(20,4),
  ssgmjjhyxldm VARCHAR2(12),
  txgmjjxyxldm VARCHAR2(12)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.ADD_LS_003_MONEY_L
  is '零售-账务基表-补录表                 ';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.data_date
  is '数据日期';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.acct_org_num
  is '账务机构编号';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.jywym
  is '交易唯一码                ';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.zhwym
  is '账户唯一码                ';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.khwym
  is '客户唯一码';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.khmc
  is '客户名称';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.dkywpzmc
  is '贷款业务品种名称          ';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.tjye
  is '统计余额（元）            ';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.ssgmjjhyxldm
  is '所属国民经济行业小类代码  ';
comment on column RRP_MDL.ADD_LS_003_MONEY_L.txgmjjxyxldm
  is '投向国民经济行业小类代码  ';

