create table RRP_MDL.O_IOL_IFDS_BILL_FIN_ACC_ASSOC
(
  billing_account_id    VARCHAR2(20),
  fin_account_id        VARCHAR2(20),
  party_id              VARCHAR2(20),
  third_party_id        VARCHAR2(20),
  product_id            VARCHAR2(20),
  account_role_type_id  VARCHAR2(20),
  imprinted_name        VARCHAR2(20),
  from_date             TIMESTAMP(6),
  thru_date             TIMESTAMP(6),
  last_updated_stamp    TIMESTAMP(6),
  last_updated_tx_stamp TIMESTAMP(6),
  created_stamp         TIMESTAMP(6),
  created_tx_stamp      TIMESTAMP(6),
  account_no            VARCHAR2(20),
  medium_type_id        VARCHAR2(20),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_IFDS_BILL_FIN_ACC_ASSOC
  is 'E账户与产品账号关联表';
comment on column RRP_MDL.O_IOL_IFDS_BILL_FIN_ACC_ASSOC.billing_account_id
  is 'E账户编号';
