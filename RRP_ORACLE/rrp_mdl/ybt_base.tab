create table RRP_MDL.YBT_BASE
(
  proc_name VARCHAR2(128) not null,
  ref_table VARCHAR2(128),
  ref_proc  VARCHAR2(128)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

