create table RRP_MDL.EAST5_601_BNWYWDBHTB_TMP
(
  cont_id    VARCHAR2(200),
  act_end_dt CHAR(8),
  rowno      NUMBER
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.EAST5_601_BNWYWDBHTB_TMP.cont_id
  is '合同编号';
comment on column RRP_MDL.EAST5_601_BNWYWDBHTB_TMP.act_end_dt
  is '实际终止日期';
comment on column RRP_MDL.EAST5_601_BNWYWDBHTB_TMP.rowno
  is '行号';

