create table RRP_MDL.XZY_ORG
(
  org_id        VARCHAR2(200),
  org_aft       VARCHAR2(200),
  fin_permit_no VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

