create table RRP_MDL.O_ICL_CMM_CAP_BOND_DEBIT_CRDT
(
  etl_dt               DATE,
  lp_id                VARCHAR2(60),
  bus_id               VARCHAR2(60),
  dept_id              VARCHAR2(60),
  entry_org_id         VARCHAR2(60),
  tran_acct_b_id       VARCHAR2(60),
  tran_acct_b_name     VARCHAR2(250),
  std_prod_id          VARCHAR2(60),
  cust_id              VARCHAR2(100),
  cntpty_id            VARCHAR2(60),
  cntpty_name          VARCHAR2(250),
  portf_id             VARCHAR2(60),
  portf_name           VARCHAR2(150),
  subj_id              VARCHAR2(60),
  tran_dir_cd          VARCHAR2(10),
  tran_dt              DATE,
  value_dt             DATE,
  exp_dt               DATE,
  tran_amt             NUMBER(30,2),
  exp_stl_amt          NUMBER(30,2),
  curr_cd              VARCHAR2(10),
  debit_crdt_fee_rat   NUMBER(18,8),
  debit_crdt_days      NUMBER(18),
  bond_fac_val_comb    VARCHAR2(750),
  inpwn_bond_comb      VARCHAR2(750),
  underly_bond_id      VARCHAR2(60),
  acru_int             NUMBER(30,2),
  tm_bg_stl_way_cd     VARCHAR2(10),
  term_end_stl_way_cd  VARCHAR2(10),
  tran_fee             NUMBER(30,2),
  tran_tax             NUMBER(30,2),
  tran_comm            NUMBER(30,2),
  currt_bal            NUMBER(30,2),
  currt_acru_int       NUMBER(30,2),
  dealer_id            VARCHAR2(60),
  dealer_name          VARCHAR2(375),
  tran_id              VARCHAR2(60),
  tran_ref_no          VARCHAR2(90),
  tran_clear_acct_id   VARCHAR2(256),
  tran_clear_bank_no   VARCHAR2(384),
  asset_thd_cls_cd     VARCHAR2(30),
  job_cd               VARCHAR2(10),
  acct_b_attr_cd       VARCHAR2(10),
  tran_clear_bank_name VARCHAR2(500)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
