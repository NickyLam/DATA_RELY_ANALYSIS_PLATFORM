comment on column RRP_MDL.O_IOL_IFMS_TBINSUREREQ.curr_type
  is '币别[代码T003][参考CFG_T_CURRENCY_TYPE]';
comment on column RRP_MDL.O_IOL_IFMS_TBINSUREREQ.clear_status
