create table RRP_MDL.M_LOAN_TRF_INFO_TEMP03
(
  trf_cont_id            VARCHAR2(200),
  cntpr_nm               VARCHAR2(750),
  trf_cont_start_dt      VARCHAR2(8),
  trf_cont_exp_dt        VARCHAR2(8),
  cntpr_trf_acc          VARCHAR2(300),
  cntpr_trf_acc_nm       VARCHAR2(750),
  cntpr_trf_dt           VARCHAR2(8),
  cntpr_aldy_pay_amt     NUMBER(30,2),
  cntpr_trf_acc_bank_no  VARCHAR2(200),
  trf_cont_sign_dt       VARCHAR2(8),
  cntpr_trf_cert_type_cd VARCHAR2(100),
  cntpr_trf_cert_no      VARCHAR2(100),
  prop_id                VARCHAR2(100),
  cntpr_trf_end_dt       VARCHAR2(8)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_LOAN_TRF_INFO_TEMP03
  is '信贷资产转让信息业务补录信息';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.trf_cont_id
  is '转让合同号';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_nm
  is '交易对手名称';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.trf_cont_start_dt
  is '转让合同起始日期';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.trf_cont_exp_dt
  is '转让合同到期日期';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_trf_acc
  is '交易对手转账账号';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_trf_acc_nm
  is '交易对手转账账号开户行行名';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_trf_dt
  is '交易对手转账日期';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_aldy_pay_amt
  is '交易对手已支付金额';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_trf_acc_bank_no
  is '交易对手转账账号开户行行号';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.trf_cont_sign_dt
  is '转让合同签约日期';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_trf_cert_type_cd
  is '对手方证件类型代码';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_trf_cert_no
  is '对手方证件号码';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.prop_id
  is '方案编号';
comment on column RRP_MDL.M_LOAN_TRF_INFO_TEMP03.cntpr_trf_end_dt
  is '最终交易对手支付日期';

