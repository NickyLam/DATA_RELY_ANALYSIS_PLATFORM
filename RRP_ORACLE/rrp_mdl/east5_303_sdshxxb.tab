comment on column RRP_MDL.EAST5_303_SDSHXXB.qszhlx
  is '清算账号类型';
comment on column RRP_MDL.EAST5_303_SDSHXXB.qszhmc
  is '清算账户名称';
comment on column RRP_MDL.EAST5_303_SDSHXXB.qszhkhhmc
  is '清算账号开户行名称';
comment on column RRP_MDL.EAST5_303_SDSHXXB.qxrq
  is '起效日期';
comment on column RRP_MDL.EAST5_303_SDSHXXB.sxrq
  is '失效日期';
comment on column RRP_MDL.EAST5_303_SDSHXXB.shzt
  is '商户状态';
comment on column RRP_MDL.EAST5_303_SDSHXXB.bbz
  is '备注';
comment on column RRP_MDL.EAST5_303_SDSHXXB.cjrq
  is '采集日期';
comment on column RRP_MDL.EAST5_303_SDSHXXB.dept_no
  is '部门编号';
comment on column RRP_MDL.EAST5_303_SDSHXXB.src_sys_id
  is '来源系统ID';
comment on column RRP_MDL.EAST5_303_SDSHXXB.issued_no
  is '填报机构';
comment on column RRP_MDL.EAST5_303_SDSHXXB.org_no
  is '报送机构';
comment on column RRP_MDL.EAST5_303_SDSHXXB.address
  is '归属地';
comment on column RRP_MDL.EAST5_303_SDSHXXB.hqckzh
  is '存款账号';
comment on column RRP_MDL.EAST5_303_SDSHXXB.qszhmc_oth
  is '清算账户是否个人账户';
comment on column RRP_MDL.EAST5_303_SDSHXXB.qszhmc_orig
  is '清算账户名称（脱敏前）';
comment on column RRP_MDL.EAST5_303_SDSHXXB.gsfzjg
  is '归属分支机构';
alter table RRP_MDL.EAST5_303_SDSHXXB
  add primary key (CJRQ, RID, SHBH)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

