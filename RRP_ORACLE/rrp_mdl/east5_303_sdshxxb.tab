comment on table RRP_MDL.EAST5_303_SDSHXXB
  is '收单商户信息表';
comment on column RRP_MDL.EAST5_303_SDSHXXB.rid
  is '数据主键';
comment on column RRP_MDL.EAST5_303_SDSHXXB.jrxkzh
  is '金融许可证号';
comment on column RRP_MDL.EAST5_303_SDSHXXB.nbjgh
  is '内部机构号';
comment on column RRP_MDL.EAST5_303_SDSHXXB.shbh
  is '商户编号';
comment on column RRP_MDL.EAST5_303_SDSHXXB.shmc
  is '商户名称';
comment on column RRP_MDL.EAST5_303_SDSHXXB.sfpos
  is '是否POS商户';
comment on column RRP_MDL.EAST5_303_SDSHXXB.zdh
  is '终端号';
comment on column RRP_MDL.EAST5_303_SDSHXXB.shmccm
  is '商户MCC码';
comment on column RRP_MDL.EAST5_303_SDSHXXB.shmccmc
  is '商户MCC名称';
comment on column RRP_MDL.EAST5_303_SDSHXXB.shdq
  is '商户地区';
comment on column RRP_MDL.EAST5_303_SDSHXXB.qszh
