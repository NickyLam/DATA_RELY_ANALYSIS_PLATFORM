  bckmk_rcal_ratecod VARCHAR2(10),
  rate_level         NUMBER(13,2),
  rate_seqno         VARCHAR2(10),
  dep_term           VARCHAR2(6),
  against_flg        VARCHAR2(1),
  rate_float_kind    VARCHAR2(1),
  rate_float_value   NUMBER(11,7),
