  txn_date           VARCHAR2(8),
  txn_ctime          NUMBER(10),
  busi_inst          VARCHAR2(10),
  tl_seqno           VARCHAR2(16),
  mod_opr            VARCHAR2(8),
  mod_unit           VARCHAR2(10),
  mod_date           VARCHAR2(8),
  mod_time           NUMBER(10),
  time_sign          NUMBER(16),
  rec_sts            VARCHAR2(1),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_DPSS_DPR_ACTINTJNL
