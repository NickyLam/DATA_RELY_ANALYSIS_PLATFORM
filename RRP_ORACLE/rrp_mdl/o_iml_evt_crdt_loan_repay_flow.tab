create table RRP_MDL.O_IML_EVT_CRDT_LOAN_REPAY_FLOW
(
  evt_id                 VARCHAR2(250),
  lp_id                  VARCHAR2(100),
  repay_flow_num         VARCHAR2(100),
  dubil_id               VARCHAR2(100),
  tran_dt                DATE,
  cust_id                VARCHAR2(100),
  cust_name              VARCHAR2(500),
  cert_type_cd           VARCHAR2(30),
  cert_id                VARCHAR2(100),
  curr_cd                VARCHAR2(30),
  deduct_acct_num        VARCHAR2(100),
  repay_tran_flow_num    VARCHAR2(100),
  repay_type_cd          VARCHAR2(30),
  rpbl_amt               NUMBER(30,8),
  actl_repay_amt         NUMBER(30,8),
  paid_pric              NUMBER(30,8),
  paid_int               NUMBER(30,8),
  paid_pnlt              NUMBER(30,8),
  paid_comp_int          NUMBER(30,8),
  surp_pric              NUMBER(30,8),
  repay_perds            NUMBER(10),
  revs_flg               VARCHAR2(10),
  happ_rs_cd             VARCHAR2(30),
  callbk_id              VARCHAR2(250),
  core_flow_num          VARCHAR2(100),
  chn_id                 VARCHAR2(100),
  init_sys_id            VARCHAR2(100),
  remark                 VARCHAR2(2000),
  rgst_teller_id         VARCHAR2(100),
  rgst_org_id            VARCHAR2(100),
  rgst_dt                DATE,
  final_update_teller_id VARCHAR2(100),
  final_update_org_id    VARCHAR2(100),
  final_update_dt        DATE,
  start_dt               DATE,
  end_dt                 DATE,
  id_mark                VARCHAR2(10),
  src_table_name         VARCHAR2(100),
  job_cd                 VARCHAR2(10),
  etl_timestamp          TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IML_EVT_CRDT_LOAN_REPAY_FLOW
  is '信贷贷款还款流水';
