create table RRP_MDL.S26_CONFIG_CUST
(
  cust_id  VARCHAR2(200),
  province VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.S26_CONFIG_CUST
  is '过程临时表';
comment on column RRP_MDL.S26_CONFIG_CUST.cust_id
  is '客户号';
comment on column RRP_MDL.S26_CONFIG_CUST.province
  is '省份';

