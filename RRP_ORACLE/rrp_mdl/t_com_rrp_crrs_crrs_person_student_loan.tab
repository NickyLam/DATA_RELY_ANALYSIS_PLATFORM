create table RRP_MDL.T_COM_RRP_CRRS_CRRS_PERSON_STUDENT_LOAN
(
  rid                        VARCHAR2(100) not null,
  customer_code              VARCHAR2(100) not null,
  customer_name              VARCHAR2(100),
  school_name                VARCHAR2(200),
  school_address             VARCHAR2(500),
  school_administrative_code VARCHAR2(40),
  student_number             VARCHAR2(100),
  family_address             VARCHAR2(500),
  family_administrative_code VARCHAR2(40),
  student_loan_type          CHAR(1),
  loan_contract_number       VARCHAR2(100),
  data_dt                    VARCHAR2(40) not null,
  issued_no                  VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;

