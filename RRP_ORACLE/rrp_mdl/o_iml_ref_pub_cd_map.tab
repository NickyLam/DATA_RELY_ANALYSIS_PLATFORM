create table RRP_MDL.O_IML_REF_PUB_CD_MAP
(
  sorc_sys_cd              VARCHAR2(10),
  subj                     VARCHAR2(10),
  src_tab_en_name          VARCHAR2(100),
  src_tab_cn_name          VARCHAR2(100),
  src_field_en_name        VARCHAR2(100),
  src_field_cn_name        VARCHAR2(100),
  src_code_val             VARCHAR2(60),
  src_code_descb           VARCHAR2(1000),
  target_tab_en_name       VARCHAR2(100),
  target_tab_cn_name       VARCHAR2(100),
  target_tab_field_en_name VARCHAR2(100),
  target_tab_field_cn_name VARCHAR2(100),
  target_cd_tab_en_name    VARCHAR2(60),
  target_cd_tab_cn_name    VARCHAR2(250),
  target_cd_val            VARCHAR2(30),
  target_cd_descb          VARCHAR2(1000),
  remark                   VARCHAR2(100),
  etl_dt                   DATE,
  src_table_name           VARCHAR2(100),
  job_cd                   VARCHAR2(10),
  etl_timestamp            TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IML_REF_PUB_CD_MAP
  is '公共代码映射表';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.sorc_sys_cd
  is '源系统代码';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.subj
  is '科目';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.src_tab_en_name
  is '来源表中文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.src_tab_cn_name
  is '来源表英文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.src_field_en_name
  is '来源代码英文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.src_field_cn_name
  is '来源代码中文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.src_code_val
  is '来源码值';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.src_code_descb
  is '来源码值描述';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_tab_en_name
  is '目标表英文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_tab_cn_name
  is '目标表中文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_tab_field_en_name
  is '目标代码英文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_tab_field_cn_name
  is '目标代码中文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_cd_tab_en_name
  is '目标码值表英文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_cd_tab_cn_name
  is '目标码值表中文名';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_cd_val
  is '目标码值';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.target_cd_descb
  is '目标码值描述';
comment on column RRP_MDL.O_IML_REF_PUB_CD_MAP.remark
