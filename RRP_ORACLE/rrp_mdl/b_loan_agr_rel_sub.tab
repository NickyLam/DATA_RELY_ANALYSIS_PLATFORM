create table RRP_MDL.B_LOAN_AGR_REL_SUB
(
  data_dt                      CHAR(8) not null,
  lgl_rep_id                   VARCHAR2(200),
  org_id                       VARCHAR2(200),
  rcpt_id                      VARCHAR2(200) not null,
  agr_rel_loan_biz_typ         VARCHAR2(10),
  agr_cprsv_dvlp_loan_flg      CHAR(1),
  loan_char                    VARCHAR2(10),
  farmer_coop_loan_flg         CHAR(1),
  vil_three_rt_mtg_loan_cl     VARCHAR2(10),
  vil_colltv_econ_org_loan_flg CHAR(1),
  farm_loan_flg                CHAR(1),
  two_rt_loan_gua_mode         VARCHAR2(10),
  coll_val                     NUMBER(30,2),
  dept_line                    VARCHAR2(500),
  data_src                     VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_LOAN_AGR_REL_SUB
  is '涉农贷款子表';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.org_id
  is '机构编号';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.rcpt_id
  is '借据编号';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.agr_rel_loan_biz_typ
  is '涉农贷款业务类型';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.agr_cprsv_dvlp_loan_flg
  is '农业综合开发贷款标志';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.loan_char
  is '贷款性质';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.farmer_coop_loan_flg
  is '农民合作社贷款标志';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.vil_three_rt_mtg_loan_cl
  is '农村三权抵押贷款分类';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.vil_colltv_econ_org_loan_flg
  is '农村集体经济组织贷款标志';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.farm_loan_flg
  is '农户贷款标志';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.two_rt_loan_gua_mode
  is '两权贷款担保方式';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.coll_val
  is '押品价值';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.B_LOAN_AGR_REL_SUB.data_src
  is '数据来源';
alter table RRP_MDL.B_LOAN_AGR_REL_SUB
  add constraint PK_B_LOAN_AGR_REL_SUB primary key (DATA_DT, RCPT_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

