create table RRP_MDL.S_REGROUP_CL_CHANGE
(
  data_dt                 CHAR(8),
  rid                     VARCHAR2(70),
  cust_id                 VARCHAR2(200),
  cust_nm                 VARCHAR2(200),
  rcpt_id                 VARCHAR2(200),
  loan_std_prod_id        VARCHAR2(200),
  cur                     CHAR(3),
  loan_net_val_bf         NUMBER(30,2),
  loan_net_val            NUMBER(30,2),
  lvl5_cl_bf              VARCHAR2(10),
  lvl5_cl                 VARCHAR2(10),
  adj_dt                  CHAR(8),
  data_src                VARCHAR2(100),
  regroup_loan_flg_bf     VARCHAR2(100),
  regroup_loan_flg_af     VARCHAR2(100),
  regroup_loan_type_cd_bf VARCHAR2(100),
  regroup_loan_type_cd_af VARCHAR2(100)
)
partition by list (DATA_DT)
(
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.S_REGROUP_CL_CHANGE
  is '零售五级分类变动表';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.data_dt
  is '数据日期';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.rid
  is '流水号RID';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.cust_id
  is '客户号';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.cust_nm
  is '客户名称';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.rcpt_id
  is '借据号';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.loan_std_prod_id
  is '贷款产品编号';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.cur
  is '业务币种代码';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.loan_net_val_bf
  is '调整前余额';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.loan_net_val
  is '调整后余额';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.lvl5_cl_bf
  is '调整前五级分类代码';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.lvl5_cl
  is '调整后五级分类代码';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.adj_dt
  is '调整日期';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.data_src
  is '数据来源';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.regroup_loan_flg_bf
  is '重组贷款标志前';
comment on column RRP_MDL.S_REGROUP_CL_CHANGE.regroup_loan_flg_af
  is '重组贷款标志后';

