  bus_id                   VARCHAR2(60),
  comb_tran_num            VARCHAR2(90),
  obj_id                   VARCHAR2(60),
  prod_type_cd             VARCHAR2(30),
  asset_type_name          VARCHAR2(250),
  level5_cls_cd            VARCHAR2(10),
  acct_name                VARCHAR2(500),
  subj_id                  VARCHAR2(60),
  int_subj_id              VARCHAR2(100),
  int_adj_subj_id          VARCHAR2(100),
  tran_market_id           VARCHAR2(60),
  exchg_acct_id            VARCHAR2(60),
  cntpty_cust_id           VARCHAR2(60),
  cntpty_id                VARCHAR2(60),
  cntpty_name              VARCHAR2(375),
  cntpty_acct_num          VARCHAR2(300),
  cntpty_acct_name         VARCHAR2(750),
  cntpty_open_bank_num     VARCHAR2(90),
  cntpty_open_bank_name    VARCHAR2(750),
  cntpty_cls_descb         VARCHAR2(1000),
  cntpty_idf_code          VARCHAR2(150),
  cntpty_idf_code_type_cd  VARCHAR2(100),
  tran_type_cd             VARCHAR2(10),
  bank_flg                 VARCHAR2(10),
  cty_cd                   VARCHAR2(10),
  value_dt                 DATE,
  exp_dt                   DATE,
  cash_dt                  DATE,
  tenor_cd                 VARCHAR2(10),
  int_accr_base_cd         VARCHAR2(10),
  int_rat_adj_way_cd       VARCHAR2(10),
  base_rat_type_cd         VARCHAR2(10),
  int_rat_adj_freq_cd      VARCHAR2(10),
  apv_odd_no               VARCHAR2(90),
  curr_cd                  VARCHAR2(10),
  fac_val_amt              NUMBER(38,8),
  fac_val_int_rat          NUMBER(18,8),
  base_rat                 NUMBER(18,8),
  exec_int_rat             NUMBER(18,8),
  pay_int_ped_cd           VARCHAR2(10),
  auto_redt_flg            VARCHAR2(10),
  actl_bal                 NUMBER(30,8),
  pric_bal                 NUMBER(30,8),
  currt_bal                NUMBER(30,8),
  acru_int                 NUMBER(30,8),
  recvbl_uncol_pric        NUMBER(30,8),
  recvbl_uncol_int         NUMBER(30,8),
  last_update_dt           DATE,
  cap_type_cd              VARCHAR2(10),
  asset_four_cls_cd        VARCHAR2(10),
  asset_thd_cls_cd         VARCHAR2(30),
  belong_org_id            VARCHAR2(60),
  tran_amt                 NUMBER(38,8),
  extra_dimen_cd           VARCHAR2(10),
  stl_dt                   DATE,
  ovdue_status             VARCHAR2(450),
  ovdue_flg                VARCHAR2(10),
  pric_ovdue_dt            DATE,
  pric_ovdue_days          NUMBER(10),
  int_ovdue_dt             DATE,
  int_ovdue_days           NUMBER(10),
  acct_char_descb          VARCHAR2(150),
  acct_attr_descb          VARCHAR2(150),
  actl_finer_cust_id       VARCHAR2(60),
  actl_finer_name          VARCHAR2(750),
  actl_finer_group_name    VARCHAR2(500),
  inpwn_vch_id             VARCHAR2(60),
  inpwn_vch_asset_type_id  VARCHAR2(60),
  inpwn_vch_market_type_id VARCHAR2(60),
  inpwn_cert_face_lmt      NUMBER(30,8),
  inpwn_vch_discnt_rat     NUMBER(30,8),
  inpwn_vch_pct            NUMBER(30,8),
  tran_seq_num             VARCHAR2(90),
  job_cd                   VARCHAR2(10),
  asset_uniq_idf_id        VARCHAR2(200),
  trans_loan_flg           VARCHAR2(32),
  int_recvbl               NUMBER(30,8)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
