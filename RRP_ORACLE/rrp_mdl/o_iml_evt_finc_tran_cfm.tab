create table RRP_MDL.O_IML_EVT_FINC_TRAN_CFM
(
  ta_cd                 VARCHAR2(30),
  evt_id                VARCHAR2(60),
  lp_id                 VARCHAR2(60),
  cfm_dt                DATE,
  ta_cfm_flow_num       VARCHAR2(90),
  init_cfm_flow_num     VARCHAR2(150),
  intior_cd             VARCHAR2(10),
  tran_dt               DATE,
  tran_tm               VARCHAR2(15),
  clear_day_term        DATE,
  flow_num              VARCHAR2(90),
  tran_cd               VARCHAR2(100),
  bus_cd                VARCHAR2(10),
  tran_org_id           VARCHAR2(60),
  tran_open_acct_org_id VARCHAR2(100),
  tran_chn_cd           VARCHAR2(10),
  tran_teller_id        VARCHAR2(60),
  int_party_acct_id     VARCHAR2(60),
  finc_acct_id          VARCHAR2(60),
  bank_cd               VARCHAR2(100),
  party_id              VARCHAR2(60),
  bank_acct_id          VARCHAR2(100),
  ta_tran_acct_id       VARCHAR2(60),
  tran_med_type_cd      VARCHAR2(10),
  tran_med_id           VARCHAR2(60),
  ec_flg                VARCHAR2(10),
  finc_prod_id          VARCHAR2(60),
  prod_nv               NUMBER(30,2),
  tran_price            NUMBER(26,12),
  tran_amt              NUMBER(30,2),
  curr_cd               VARCHAR2(10),
  cfm_amt               NUMBER(30,2),
  tran_lot              NUMBER(30,2),
  cfm_lot               NUMBER(30,2),
  huge_redem_proc_flg   VARCHAR2(10),
  force_redem_rs_cd     VARCHAR2(10),
  cotin_froz_amt        NUMBER(30,2),
  lot_accu_accum        NUMBER(30,2),
  dtl_flg               VARCHAR2(10),
  froz_rs_cd            VARCHAR2(10),
  tran_dir_cd           VARCHAR2(10),
  deflt_divd_way_cd     VARCHAR2(10),
  return_cd             VARCHAR2(15),
  remark_info           VARCHAR2(1000),
  tran_status_cd        VARCHAR2(10),
  cust_mgr_id           VARCHAR2(60),
  rela_dt               DATE,
  rela_flow_num         VARCHAR2(90),
  cont_id               VARCHAR2(60),
  host_dt               DATE,
  host_flow_num         VARCHAR2(90),
  tran_post_lot         NUMBER(30,2),
  rsrv_amt3             NUMBER(30,2),
  resv2                 VARCHAR2(375),
  resv_region3          VARCHAR2(375),
  cust_type_cd          VARCHAR2(30),
  target_bank_acct_id   VARCHAR2(100),
  tot_cost              NUMBER(30,2),
  etl_dt                DATE,
  src_table_name        VARCHAR2(100),
  job_cd                VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
