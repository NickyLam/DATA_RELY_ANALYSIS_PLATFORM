create table RRP_MDL.TMP_ADD_DG_002_CREDIT_DISTR
(
  lmt_cont_id VARCHAR2(100),
  distr_amt   NUMBER(20,2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on column RRP_MDL.TMP_ADD_DG_002_CREDIT_DISTR.lmt_cont_id
  is '授信号';
comment on column RRP_MDL.TMP_ADD_DG_002_CREDIT_DISTR.distr_amt
  is '放款金额';

