create table RRP_MDL.M_INDUSTRY_CLASSIFY
(
  industry        VARCHAR2(64),
  subdivision     VARCHAR2(64),
  indus_cate_cd   VARCHAR2(10),
  indus_cate_name VARCHAR2(150),
  classify        VARCHAR2(24),
  industry_cd     VARCHAR2(2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_INDUSTRY_CLASSIFY
  is '行业类别分类表';
comment on column RRP_MDL.M_INDUSTRY_CLASSIFY.industry
  is '产业         ';
comment on column RRP_MDL.M_INDUSTRY_CLASSIFY.subdivision
  is '细分领域     ';
comment on column RRP_MDL.M_INDUSTRY_CLASSIFY.indus_cate_cd
  is '行业类别代码 ';
comment on column RRP_MDL.M_INDUSTRY_CLASSIFY.indus_cate_name
  is '行业类别名称 ';
comment on column RRP_MDL.M_INDUSTRY_CLASSIFY.classify
  is '分类         ';
comment on column RRP_MDL.M_INDUSTRY_CLASSIFY.industry_cd
  is '产业码值     ';

