create table RRP_MDL.O_IML_EVT_INSURE_TRAN_FLOW
(
  evt_id              VARCHAR2(250),
  lp_id               VARCHAR2(60),
  tran_dt             DATE,
  flow_num            VARCHAR2(150),
  rela_flow_num       VARCHAR2(150),
  ta_cd               VARCHAR2(30),
  std_prod_id         VARCHAR2(2000),
  prod_id             VARCHAR2(60),
  insure_pl_num       VARCHAR2(250),
  cust_mgr_id         VARCHAR2(60),
  cust_id             VARCHAR2(60),
  cust_type_cd        VARCHAR2(30),
  tran_cd             VARCHAR2(30),
  tran_cd_name        VARCHAR2(100),
  bank_acct_id        VARCHAR2(60),
  vouch_type_cd       VARCHAR2(30),
  vouch_id            VARCHAR2(60),
  curr_cd             VARCHAR2(30),
  tran_amt            NUMBER(30,2),
  comm_fee            NUMBER(30,2),
  tran_org_id         VARCHAR2(60),
  operr_id            VARCHAR2(60),
  auth_teller_id      VARCHAR2(60),
  tran_chn_cd         VARCHAR2(30),
  return_code         VARCHAR2(45),
  return_info         VARCHAR2(1500),
  policy_dt           DATE,
  policy_cfm_flow_num VARCHAR2(150),
  host_dt             DATE,
  host_flow_num       VARCHAR2(150),
  host_tran_cd        VARCHAR2(30),
  host_return_code    VARCHAR2(45),
  host_return_info    VARCHAR2(1500),
  tran_status_cd      VARCHAR2(30),
  tran_tm             VARCHAR2(45),
  insure_print_id     VARCHAR2(100),
  start_dt            DATE,
  end_dt              DATE,
  id_mark             VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_EVT_INSURE_TRAN_FLOW
  is '保险交易流水';
comment on column RRP_MDL.O_IML_EVT_INSURE_TRAN_FLOW.evt_id
