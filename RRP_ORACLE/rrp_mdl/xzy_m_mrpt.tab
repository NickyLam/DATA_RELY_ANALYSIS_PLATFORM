create table RRP_MDL.XZY_M_MRPT
(
  owner       VARCHAR2(128),
  table_name  VARCHAR2(128),
  comments    VARCHAR2(4000),
  column_name VARCHAR2(128),
  col_com     VARCHAR2(4000)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

