comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.calc_end_date
  is '利息计算截止日';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.last_accrual_date
