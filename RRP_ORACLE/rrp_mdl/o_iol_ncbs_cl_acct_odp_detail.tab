create table RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL
(
  client_no             VARCHAR2(16),
  internal_key          NUMBER(15),
  user_id               VARCHAR2(8),
  company               VARCHAR2(20),
  int_accrued_diff      NUMBER(15,10),
  narrative             VARCHAR2(400),
  stage_no              NUMBER(5),
  tax_type              VARCHAR2(2),
  int_class             VARCHAR2(5),
  calc_begin_date       DATE,
  calc_end_date         DATE,
  last_accrual_date     DATE,
  last_change_date      DATE,
  last_cycle_date       DATE,
  next_cycle_date       DATE,
  tran_timestamp        VARCHAR2(26),
  int_accrued           NUMBER(17,2),
  int_accrued_calc_ctd  NUMBER(25,10),
  int_accrued_ctd       NUMBER(17,2),
  int_adj               NUMBER(17,2),
  int_adj_ctd           NUMBER(17,2),
  int_adj_prev          NUMBER(17,2),
  int_amt               NUMBER(17,2),
  int_posted            NUMBER(17,2),
  int_posted_ctd        NUMBER(17,2),
  tax_posted            NUMBER(17,2),
  tax_posted_ctd        NUMBER(17,2),
  tax_rate              NUMBER(15,8),
  wrn_amt               NUMBER(17,2),
  int_accrued_prev      NUMBER(17,2),
  last_bal_upd_date     DATE,
  last_int_accrued_prev NUMBER(17,2),
  last_int_adj_prev     NUMBER(17,2),
  start_dt              DATE,
  end_dt                DATE,
  id_mark               VARCHAR2(10),
  etl_timestamp         TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL
  is '罚息计息表';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.client_no
  is '客户编号';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.internal_key
  is '账户内部键值';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.user_id
  is '交易柜员编号';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.company
  is '法人';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.int_accrued_diff
  is '计提金额差额';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.narrative
  is '摘要';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.stage_no
  is '期次';
comment on column RRP_MDL.O_IOL_NCBS_CL_ACCT_ODP_DETAIL.tax_type
