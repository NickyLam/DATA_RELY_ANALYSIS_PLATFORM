create table RRP_MDL.O_IML_PTY_INDV_CUST_CORP_H
(
  cust_id            VARCHAR2(100),
  lp_id              VARCHAR2(100),
  cust_name          VARCHAR2(1000),
  cert_type_cd       VARCHAR2(10),
  cert_no            VARCHAR2(100),
  cust_corp_rela_cd  VARCHAR2(30),
  corp_cust_id       VARCHAR2(100),
  corp_name          VARCHAR2(375),
  corp_cert_type_cd  VARCHAR2(30),
  corp_cert_no       VARCHAR2(60),
  corp_cert_exp_dt   DATE,
  corp_mang_addr     VARCHAR2(1000),
  corp_found_dt      DATE,
  corp_size_cd       VARCHAR2(30),
  legal_rep_name     VARCHAR2(500),
  emply_number       NUMBER(10),
  bus_anl_inco       NUMBER(30,8),
  tot_asset          NUMBER(30,8),
  bl_induty_type_cd  VARCHAR2(30),
  bl_induty_name     VARCHAR2(1000),
  create_teller_id   VARCHAR2(100),
  create_org_id      VARCHAR2(100),
  init_create_dt     DATE,
  update_teller_id   VARCHAR2(100),
  update_org_id      VARCHAR2(100),
  update_chn_id      VARCHAR2(30),
  update_sys_name    VARCHAR2(500),
  latest_update_dt   DATE,
  sorc_sys_name      VARCHAR2(100),
  sorc_sys_chn_id    VARCHAR2(30),
  sorc_sys_create_dt DATE,
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
