  is '描述';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.orgid
  is '承办机构编号';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.userid
  is '承办人编号';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.accountmonth
  is '期次';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.classifylevel
