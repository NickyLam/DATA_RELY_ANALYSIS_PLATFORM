create table RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD
(
  objecttype         VARCHAR2(18),
  objectno           VARCHAR2(64),
  serialno           VARCHAR2(64),
  modelno            VARCHAR2(32),
  firstresult        VARCHAR2(18),
  secondresult       VARCHAR2(18),
  result1            VARCHAR2(18),
  resultopinion1     VARCHAR2(200),
  result2            VARCHAR2(18),
  resultopinion2     VARCHAR2(200),
  result3            VARCHAR2(18),
  resultopinion3     VARCHAR2(200),
  result4            VARCHAR2(18),
  resultopinion4     VARCHAR2(200),
  finallyresult      VARCHAR2(18),
  sum1               NUMBER(24,6),
  sum2               NUMBER(24,6),
  sum3               NUMBER(24,6),
  sum4               NUMBER(24,6),
  sum5               NUMBER(24,6),
  expectlosssum      NUMBER(24,6),
  reservesum         NUMBER(24,6),
  classifyuserid     VARCHAR2(32),
  classifyorgid      VARCHAR2(32),
  classifydate       VARCHAR2(10),
  finishdate         VARCHAR2(10),
  inputdate          VARCHAR2(10),
  updatedate         VARCHAR2(10),
  remark             VARCHAR2(2500),
  businessbalance    NUMBER(24,6),
  orgid              VARCHAR2(32),
  userid             VARCHAR2(32),
  accountmonth       VARCHAR2(10),
  result5            VARCHAR2(18),
  resultopinion5     VARCHAR2(200),
  resultusername5    VARCHAR2(80),
  resultusername4    VARCHAR2(80),
  resultusername3    VARCHAR2(80),
  resultusername2    VARCHAR2(80),
  resultusername1    VARCHAR2(80),
  classifylevel      VARCHAR2(18),
  resultuserid2      VARCHAR2(32),
  resultuserid3      VARCHAR2(32),
  resultuserid4      VARCHAR2(32),
  resultuserid5      VARCHAR2(32),
  finishdate2        VARCHAR2(10),
  finishdate3        VARCHAR2(10),
  finishdate4        VARCHAR2(10),
  finishdate5        VARCHAR2(10),
  originalputoutdate VARCHAR2(10),
  lastresult         VARCHAR2(18),
  customerid         VARCHAR2(40),
  contractserialno   VARCHAR2(32),
  flag               VARCHAR2(2),
  isinuse            VARCHAR2(1),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
comment on table RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD
  is '风险分类记录';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.objecttype
  is '对象类型';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.objectno
  is '对象编号';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.serialno
  is '额度编号';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.modelno
  is '模型编号';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.firstresult
  is '第一次分类结果';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.secondresult
  is '第二次分类结果';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.result2
  is '二审判决内容';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.sum1
  is '拆迁、补偿费';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.sum2
  is '相关金额2';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.sum3
  is '土地直接出让成本投入';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.sum4
