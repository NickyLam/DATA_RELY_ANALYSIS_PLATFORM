comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.expectlosssum
  is '预测损失金额';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.reservesum
  is '计提准备金';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.classifyorgid
  is '最新分类认定机构';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.classifydate
  is '风险分类日期';
comment on column RRP_MDL.O_IOL_CRSS_CLASSIFY_RECORD.finishdate
