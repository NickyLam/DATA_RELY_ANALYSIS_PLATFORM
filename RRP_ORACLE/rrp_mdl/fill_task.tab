create table RRP_MDL.FILL_TASK
(
  data_dt VARCHAR2(20 CHAR),
  result  VARCHAR2(10 CHAR)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.FILL_TASK
  is '报送区填报任务下发情况';
comment on column RRP_MDL.FILL_TASK.data_dt
  is '报告期';
comment on column RRP_MDL.FILL_TASK.result
  is '结果Y或者N';

