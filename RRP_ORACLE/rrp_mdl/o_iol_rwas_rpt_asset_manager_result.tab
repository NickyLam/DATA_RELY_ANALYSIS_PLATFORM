create table RRP_MDL.O_IOL_RWAS_RPT_ASSET_MANAGER_RESULT
(
  data_date                   DATE,
  pk_col                      VARCHAR2(150),
  loan_ref_no                 VARCHAR2(150),
  fund_cd                     VARCHAR2(90),
  fund_name                   VARCHAR2(300),
  sa_calculate_id             VARCHAR2(30),
  sa_calculate_name           VARCHAR2(60),
  on_off_id                   VARCHAR2(15),
  accorg_no                   VARCHAR2(30),
  accorg_name                 VARCHAR2(383),
  product_cd                  VARCHAR2(60),
  product_name                VARCHAR2(600),
  five_class_name             VARCHAR2(30),
  overdue_days                NUMBER(22),
  std_default_flag            VARCHAR2(15),
  cust_no                     VARCHAR2(150),
  cust_name                   VARCHAR2(384),
  ccp_type_cd                 VARCHAR2(60),
  ccp_type_name               VARCHAR2(300),
  scale_cd                    VARCHAR2(60),
  scale_name                  VARCHAR2(90),
  ead_tot                     NUMBER(18,2),
  fm_asset_amt                NUMBER(18,2),
  fm_hold_ratio               NUMBER(18,6),
  fm_fin_product_amt          NUMBER(18,2),
  fm_lvg                      NUMBER(18,6),
  fm_rwa_ccp                  NUMBER(18,2),
  fm_rwa_cva                  NUMBER(18,2),
  fm_flag                     VARCHAR2(3),
  fm_avg_rw                   NUMBER(18,6),
  fm_alvg_rw                  NUMBER(18,6),
  ccf                         NUMBER(18,6),
  ccy_cd                      VARCHAR2(15),
  subject_cd                  VARCHAR2(24),
  subject_name                VARCHAR2(300),
  pric_bal_origcurr           NUMBER(18,2),
  pric_bal                    NUMBER(18,2),
  asset_balance               NUMBER(18,2),
  accrued_subject_cd          VARCHAR2(24),
  accrued_subject_name        VARCHAR2(300),
  accrued_int                 NUMBER(18,2),
  receivable_subject_cd       VARCHAR2(24),
  receivable_subject_name     VARCHAR2(300),
  receivable_int              NUMBER(18,2),
  accrued_receiv_subject_cd   VARCHAR2(24),
  accrued_receiv_subject_name VARCHAR2(300),
  accrued_receiv_int          NUMBER(18,2),
  intadj_subject_cd           VARCHAR2(24),
  intadj_subject_name         VARCHAR2(300),
  int_adj                     NUMBER(18,2),
  fairchange_subject_cd       VARCHAR2(24),
  fairchange_subject_name     VARCHAR2(300),
  fairvalue_changes           NUMBER(18,2),
  provision_subject_cd        VARCHAR2(24),
  provision_subject_name      VARCHAR2(300),
  provision                   NUMBER(18,2),
  provesion_ratio             NUMBER(18,6),
  ead_orig                    NUMBER(18,2),
  ead_pen                     NUMBER(18,2),
  rwa_pen                     NUMBER(18,2),
  ead_pen_third               NUMBER(18,2),
  rwa_pen_third               NUMBER(18,2),
  ead_abl                     NUMBER(18,2),
  rwa_abl                     NUMBER(18,2),
  ead_pullb                   NUMBER(18,2),
  rwa_pullb                   NUMBER(18,2),
  rwa_before_adj              NUMBER(18,2),
  rwa_after_adj               NUMBER(18,2),
  adj_flag                    VARCHAR2(15),
  g4b_r_item_code             VARCHAR2(150),
  investment_vaild_flag       VARCHAR2(15),
  recognition_date            DATE,
  load_date                   VARCHAR2(30),
  etl_dt                      DATE,
  etl_timestamp               TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_RWAS_RPT_ASSET_MANAGER_RESULT
