create table RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT
(
  customerid    VARCHAR2(32),
  ratetype      VARCHAR2(1),
  rateorg       VARCHAR2(80),
  raterisklevel VARCHAR2(20),
  ratedate      VARCHAR2(20),
  ratebegindate VARCHAR2(20),
  rateenddate   VARCHAR2(20),
  inputuserid   VARCHAR2(32),
  inputorgid    VARCHAR2(32),
  inputdate     VARCHAR2(20),
  updatetime    VARCHAR2(20),
  serialno      VARCHAR2(32),
  etl_dt        DATE,
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress
nologging;
comment on table RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT
  is '外部评级表';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.customerid
  is '客户号';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.ratetype
  is '评级类型（1.外部机构评级、2.监管评级/分类 评级）';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.rateorg
  is '评级机构';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.raterisklevel
  is '评级结果';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.ratedate
  is '评级日期';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.ratebegindate
  is '评级生效日';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.rateenddate
  is '评级失效日';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.inputuserid
  is '登记人';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.inputorgid
  is '登记机构';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.inputdate
  is '登记时间';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.updatetime
  is '更新时间';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.serialno
  is '流水号';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IOL_CRSS_CUSTOMER_OTHERRATE_RESULT.etl_timestamp
  is 'ETL处理时间戳';

