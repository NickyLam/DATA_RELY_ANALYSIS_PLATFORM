create table RRP_MDL.TMP_PTY_PARTY_CERT_INFO
(
  party_id                  VARCHAR2(60),
  cert_num                  VARCHAR2(60),
  cert_type_cd              VARCHAR2(10),
  licen_issue_autho_dist_cd VARCHAR2(30),
  crdl_eff_dt               VARCHAR2(8),
  crdl_exp_dt               VARCHAR2(8),
  crdl_addr                 VARCHAR2(500),
  sorc_sys_cd               VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.party_id
  is '当事人编号';
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.cert_num
  is '证件号';
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.cert_type_cd
  is '数仓证件类型';
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.licen_issue_autho_dist_cd
  is '发证机关地区代码';
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.crdl_eff_dt
  is '证件生效日期';
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.crdl_exp_dt
  is '证件失效日期';
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.crdl_addr
  is '证件地址';
comment on column RRP_MDL.TMP_PTY_PARTY_CERT_INFO.sorc_sys_cd
  is 'ETL任务名';

