comment on column RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO.customername
  is '客户姓名';
comment on column RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO.customerid
  is '客户号';
comment on column RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO.customertype
