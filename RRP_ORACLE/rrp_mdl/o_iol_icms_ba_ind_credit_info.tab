create table RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO
(
  serialno           VARCHAR2(32),
  baserialno         VARCHAR2(32),
  reportdate         VARCHAR2(10),
  reportid           VARCHAR2(40),
  certtype           VARCHAR2(4),
  certid             VARCHAR2(60),
  customername       VARCHAR2(100),
  customerid         VARCHAR2(30),
  customertype       VARCHAR2(10),
  relativetype       VARCHAR2(10),
  inputuserid        VARCHAR2(40),
  inputorgid         VARCHAR2(40),
  inputdate          DATE,
  updateuserid       VARCHAR2(40),
  updateorgid        VARCHAR2(40),
  updatedate         DATE,
  reportremark       VARCHAR2(2000),
  qryopertp          VARCHAR2(2000),
  authotype          VARCHAR2(20),
  biometrics         VARCHAR2(20),
  status             VARCHAR2(10),
  pbcdata            VARCHAR2(2000),
  migtflag           VARCHAR2(80),
  authodate          DATE,
  authostrdate       DATE,
  authoenddate       DATE,
  supplyflag         VARCHAR2(2),
  supplycomplete     VARCHAR2(1),
  iscreditflag       VARCHAR2(2),
  craserialno        VARCHAR2(32),
  xxdyxserialno      VARCHAR2(32),
  creditvalidatetime VARCHAR2(10),
  etl_dt             DATE,
  etl_timestamp      TIMESTAMP(6),
  authobkid          VARCHAR2(64)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO
  is '个人客户征信信息';
comment on column RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO.serialno
  is '流水号';
comment on column RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO.baserialno
