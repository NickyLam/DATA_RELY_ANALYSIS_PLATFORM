  is '报告ID';
comment on column RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO.certtype
  is '证件类型';
comment on column RRP_MDL.O_IOL_ICMS_BA_IND_CREDIT_INFO.certid
