create table RRP_MDL.B_CUST_CORP_MAG_REL_SUB
(
  data_dt               CHAR(8) not null,
  lgl_rep_id            VARCHAR2(200),
  cust_id               VARCHAR2(200) not null,
  rel_typ_rsk           VARCHAR2(10) not null,
  shrh_rel_ent_nm       VARCHAR2(500) not null,
  shrh_rel_ent_typ      VARCHAR2(10),
  shrh_rel_ent_crdl_typ VARCHAR2(10),
  shrh_rel_ent_crdl_no  VARCHAR2(100),
  regd_cd               VARCHAR2(200),
  shrh_rel_ent_cust_id  VARCHAR2(200),
  ctry_cd               VARCHAR2(10),
  hold_shr_pct          NUMBER(18,4),
  shrh_stru_crpnd_dt    CHAR(8),
  upd_info_dt           CHAR(8),
  act_cntlr_flg         CHAR(1),
  rel_stat              VARCHAR2(10),
  dept_line             VARCHAR2(500),
  data_src              VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_CUST_CORP_MAG_REL_SUB
  is '重要股东及主要关联企业子表';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.cust_id
  is '客户编号';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.rel_typ_rsk
  is '关联类型（客户风险）';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.shrh_rel_ent_nm
  is '股东/关联企业名称';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.shrh_rel_ent_typ
  is '股东/关联企业类型';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.shrh_rel_ent_crdl_typ
  is '股东/关联企业证件类型';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.shrh_rel_ent_crdl_no
  is '股东/关联企业证件号码';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.regd_cd
  is '登记注册代码';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.shrh_rel_ent_cust_id
  is '股东/关联企业客户编号';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.ctry_cd
  is '国家代码';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.hold_shr_pct
  is '持股比例';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.shrh_stru_crpnd_dt
  is '股东结构对应日期';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.upd_info_dt
  is '更新信息日期';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.act_cntlr_flg
  is '实际控制人标志';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.rel_stat
  is '关联关系状态';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.B_CUST_CORP_MAG_REL_SUB.data_src
  is '数据来源';
alter table RRP_MDL.B_CUST_CORP_MAG_REL_SUB
  add constraint PK_B_CUST_CORP_MAG_REL_SUB primary key (DATA_DT, CUST_ID, REL_TYP_RSK, SHRH_REL_ENT_NM)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

