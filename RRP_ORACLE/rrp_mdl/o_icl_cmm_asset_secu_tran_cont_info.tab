create table RRP_MDL.O_ICL_CMM_ASSET_SECU_TRAN_CONT_INFO
(
  etl_dt                       DATE,
  lp_id                        VARCHAR2(60),
  cont_id                      VARCHAR2(100),
  prod_id                      VARCHAR2(60),
  asset_pool_id                VARCHAR2(60),
  prod_type_cd                 VARCHAR2(30),
  prod_status_cd               VARCHAR2(30),
  prod_bus_status_cd           VARCHAR2(30),
  prod_mode_cd                 VARCHAR2(30),
  asset_pool_type_cd           VARCHAR2(30),
  asset_pool_char_cd           VARCHAR2(30),
  asset_pool_status_cd         VARCHAR2(30),
  tran_calc_way_cd             VARCHAR2(30),
  cntpty_org_type_cd           VARCHAR2(30),
  cntpty_id                    VARCHAR2(60),
  cntpty_name                  VARCHAR2(90),
  cntpty_acct_num              VARCHAR2(90),
  cntpty_open_bank_name        VARCHAR2(150),
  cntpty_tran_dt               DATE,
  cntpty_pay_amt               NUMBER(30,2),
  pay_dt_rule_cd               VARCHAR2(60),
  ts_cd                        VARCHAR2(30),
  user_def_coll_ped_flg        VARCHAR2(30),
  clearup_repo_flg             VARCHAR2(30),
  tran_plat_name               VARCHAR2(45),
  prod_name                    VARCHAR2(300),
  pkg_dt                       DATE,
  begin_dt                     DATE,
  exp_dt                       DATE,
  rgst_teller_id               VARCHAR2(60),
  rgst_org_id                  VARCHAR2(60),
  mgmt_org_id                  VARCHAR2(60),
  acct_instit_id               VARCHAR2(60),
  curr_cd                      VARCHAR2(30),
  asset_tot_amt                NUMBER(30,2),
  issue_tot_amt                NUMBER(30,2),
  asset_tran_consideration_amt NUMBER(30,8),
  asset_tran_comm_fee          NUMBER(30,2),
  prod_self_hold_amt           NUMBER(30,8),
  issue_qtty                   VARCHAR2(60),
  bank_rgst_center_amt         NUMBER(30,2),
  job_cd                       VARCHAR2(10),
  cntpty_cert_type             VARCHAR2(60),
  cntpty_cert_no               VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
