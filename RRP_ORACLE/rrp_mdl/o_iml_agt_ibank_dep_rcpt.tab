create table RRP_MDL.O_IML_AGT_IBANK_DEP_RCPT
(
  vouch_id            VARCHAR2(60),
  lp_id               VARCHAR2(60),
  dep_rcpt_cd         VARCHAR2(30),
  asset_type_cd       VARCHAR2(30),
  market_type_cd      VARCHAR2(30),
  curr_cd             VARCHAR2(10),
  quot_way_cd         VARCHAR2(10),
  dep_rcpt_name       VARCHAR2(150),
  prod_type_cd        VARCHAR2(30),
  prod_type_name      VARCHAR2(150),
  int_rat_pct_spd_bp  NUMBER(18,8),
  issue_qtty          NUMBER(30,2),
  issue_price         NUMBER(30,2),
  lowt_issue_price    NUMBER(30,2),
  higt_issue_price    NUMBER(30,2),
  value_dt            DATE,
  exp_dt              DATE,
  tenor_val           NUMBER(10),
  fir_int_rat_cfm_dt  DATE,
  pay_int_freq_cd     VARCHAR2(10),
  issue_way_cd        VARCHAR2(10),
  coupon_type_cd      VARCHAR2(10),
  base_rat_id         VARCHAR2(60),
  base_asset_type_id  VARCHAR2(60),
  base_market_type_id VARCHAR2(60),
  stl_status_cd       VARCHAR2(10),
  pay_dt              DATE,
  cash_dt             DATE,
  issue_dt            DATE,
  annual_int_rat      NUMBER(18,8),
  int_accr_base_cd    VARCHAR2(250),
  fir_pay_int_dt      DATE,
  invt_bid_way_cd     VARCHAR2(10),
  lowt_yld_rat        NUMBER(18,6),
  higt_yld_rat        NUMBER(18,6),
  actl_issue_qtty     NUMBER(30,2),
  issuer_name         VARCHAR2(750),
  range               VARCHAR2(375),
  rating_org          VARCHAR2(750),
  rating              VARCHAR2(30),
  fac_val             NUMBER(30,2),
  start_issue_dt      DATE,
  end_issue_dt        DATE,
  max_subscr_qtty     NUMBER(30,2),
  min_subscr_qtty     NUMBER(30,2),
  sig_max_subscr_qtty NUMBER(30,2),
  create_dt           DATE,
  update_dt           DATE,
  etl_dt              DATE,
  id_mark             VARCHAR2(10),
  src_table_name      VARCHAR2(100),
  job_cd              VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
