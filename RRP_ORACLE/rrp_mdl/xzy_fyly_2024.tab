create table RRP_MDL.XZY_FYLY_2024
(
  商务事项编号           VARCHAR2(2000),
  商务事项名称           VARCHAR2(4000),
  实施需求编号           VARCHAR2(1200),
  实施需求名称           VARCHAR2(4000),
  "是否包含全部科技需求/子项目" VARCHAR2(10),
  包含的科技需求和子项目清单    VARCHAR2(4000),
  年份               VARCHAR2(40)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

