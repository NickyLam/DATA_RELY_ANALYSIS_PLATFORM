  created_tx_stamp               TIMESTAMP(6),
  sharehoder_neew_name           VARCHAR2(255),
  dominant_stockholder           VARCHAR2(20),
  national_economy_code          VARCHAR2(255),
  nature_of_ownership            VARCHAR2(20),
  final_beneficiary              VARCHAR2(255),
  actual_controller              VARCHAR2(255),
  holding_organization           VARCHAR2(20),
  indirector                     VARCHAR2(20),
  controller_ratio               VARCHAR2(10),
  main_stockholder               VARCHAR2(20),
  stock_statistic_type           VARCHAR2(10),
  start_dt                       DATE,
  end_dt                         DATE,
  id_mark                        VARCHAR2(10),
  etl_timestamp                  TIMESTAMP(6),
  east_stockholder_type          VARCHAR2(10),
  stockholder_certificate_type   VARCHAR2(10),
  stockholder_registration_place VARCHAR2(400),
  stockholder_share_bank_amount  NUMBER(20),
  stockholder_hold_bank_amount   NUMBER(20),
  bad_information                VARCHAR2(400),
  is_power_restraint             VARCHAR2(20),
  capital_source                 VARCHAR2(10),
  fund_account                   VARCHAR2(255),
  pledge_proportion              VARCHAR2(60),
  last_time_change_date          DATE,
  east_remark                    VARCHAR2(400),
  foreign_stockholder            VARCHAR2(20),
  nationality                    VARCHAR2(255),
  parent_company_place           VARCHAR2(255)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress
nologging;
