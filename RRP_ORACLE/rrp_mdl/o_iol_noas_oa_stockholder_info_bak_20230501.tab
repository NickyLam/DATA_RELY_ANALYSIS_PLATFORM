  stockholder_property           VARCHAR2(10),
  stock_own_amount               NUMBER(20),
  stock_limit_amount             NUMBER(20),
  stock_pledge_amount            NUMBER(20),
  stock_freeze_amount            NUMBER(20),
  address                        VARCHAR2(400),
  post_code                      VARCHAR2(10),
  linkman                        VARCHAR2(255),
  phone                          VARCHAR2(60),
  stock_certificate_code         VARCHAR2(255),
  interest_account               VARCHAR2(255),
  interest_account_name          VARCHAR2(255),
  interest_account_bank          VARCHAR2(255),
  stockholder_begin_date         DATE,
  stockholder_end_date           DATE,
  is_privillege_make_sure        VARCHAR2(1),
