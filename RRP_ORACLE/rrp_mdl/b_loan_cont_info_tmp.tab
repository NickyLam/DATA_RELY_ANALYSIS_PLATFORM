create table RRP_MDL.B_LOAN_CONT_INFO_TMP
(
  data_dt      CHAR(8),
  cont_id      VARCHAR2(60),
  coop_agrt_id VARCHAR2(46)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.B_LOAN_CONT_INFO_TMP.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_CONT_INFO_TMP.cont_id
  is '合同编号';
comment on column RRP_MDL.B_LOAN_CONT_INFO_TMP.coop_agrt_id
  is '主合作协议编号';

