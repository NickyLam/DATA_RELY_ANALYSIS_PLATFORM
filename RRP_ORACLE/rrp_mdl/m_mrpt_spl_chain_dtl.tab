create table RRP_MDL.M_MRPT_SPL_CHAIN_DTL
(
  data_dt          VARCHAR2(10),
  cust_id          VARCHAR2(30),
  cust_name        VARCHAR2(1000),
  cont_id          VARCHAR2(35),
  dubil_id         VARCHAR2(100),
  org_fh           VARCHAR2(1000),
  org_zh           VARCHAR2(1000),
  spl_chain_prod   VARCHAR2(150),
  bus_breed_name   VARCHAR2(300),
  corp_size        VARCHAR2(300),
  dubil_amt        NUMBER(20,4),
  distr_dt         VARCHAR2(10),
  apot_exp_dt      VARCHAR2(10),
  dubil_bal        NUMBER(20,4),
  margin_ratio     NUMBER(18,6),
  margin_amt       NUMBER(20,4),
  base_rat         NUMBER(18,6),
  exec_int_rat     NUMBER(18,6),
  comm_fee_rat     NUMBER(20,4),
  o_use_lmt_all_id VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_MRPT_SPL_CHAIN_DTL
  is '供应链业务明细表-手工报表专用';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.data_dt
  is '数据日期';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.cust_id
  is '客户号';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.cust_name
  is '客户名称';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.cont_id
  is '业务合同号';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.dubil_id
  is '借据号';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.org_fh
  is '业务归属分行';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.org_zh
  is '业务支行';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.spl_chain_prod
  is '供应链金融业务产品';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.bus_breed_name
  is '业务品种名称';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.corp_size
  is '企业规模';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.dubil_amt
  is '出账金额';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.distr_dt
  is '业务起始日';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.apot_exp_dt
  is '业务终止日';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.dubil_bal
  is '合同余额';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.margin_ratio
  is '初始保证金比例';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.margin_amt
  is '保证金余额';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.base_rat
  is '基准利率';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.exec_int_rat
  is '实际利率';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.comm_fee_rat
  is '保理业务手续费率';
comment on column RRP_MDL.M_MRPT_SPL_CHAIN_DTL.o_use_lmt_all_id
  is '他用额度所有人编号';

