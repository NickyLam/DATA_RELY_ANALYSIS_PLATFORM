create table RRP_MDL.B_TRA_INTL_ACC_DTL_TEMP03
(
  tran_dt       DATE,
  tran_flow_num VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress
nologging;
comment on table RRP_MDL.B_TRA_INTL_ACC_DTL_TEMP03
  is '现金交易流水临时表';
comment on column RRP_MDL.B_TRA_INTL_ACC_DTL_TEMP03.tran_dt
  is '交易日期';
comment on column RRP_MDL.B_TRA_INTL_ACC_DTL_TEMP03.tran_flow_num
  is '交易流水号';

