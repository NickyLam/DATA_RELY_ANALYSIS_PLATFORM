create table RRP_MDL.O_ICL_CMM_REFAC_LOAN_ATTACH_INFO
(
  etl_dt                          DATE,
  lp_id                           VARCHAR2(60),
  level1_batch_pkg_id             VARCHAR2(60),
  level1_batch_pkg_name           VARCHAR2(250),
  level2_batch_pkg_id             VARCHAR2(60),
  level2_batch_pkg_name           VARCHAR2(250),
  dubil_id                        VARCHAR2(100),
  cust_id                         VARCHAR2(60),
  cust_name                       VARCHAR2(250),
  refac_indus_type_cd             VARCHAR2(10),
  indus_type_cd                   VARCHAR2(10),
  loan_type_cd                    VARCHAR2(10),
  corp_size_cd                    VARCHAR2(10),
  corp_number                     VARCHAR2(30),
  last_year_bus_inco              VARCHAR2(60),
  corp_asset_tot                  NUMBER(18,6),
  mang_main_name                  VARCHAR2(250),
  mang_main_crdt_cd_descb         VARCHAR2(60),
  check_sheet_flg                 VARCHAR2(10),
  backup_dubil_flg                VARCHAR2(10),
  loan_usage_descb                VARCHAR2(250),
  remark                          VARCHAR2(1000),
  pbc_doc_num                     VARCHAR2(500),
  pbc_doc_name                    VARCHAR2(250),
  pbc_doc_doc_day                 DATE,
  pbc_lmt                         NUMBER(30,2),
  appl_tm                         DATE,
  applit_id                       VARCHAR2(100),
  appl_org_id                     VARCHAR2(100),
  refac_status_cd                 VARCHAR2(10),
  apv_status_cd                   VARCHAR2(30),
  batch_pkg_status_cd             VARCHAR2(30),
  refac_amt                       NUMBER(30,2),
  surp_lmt                        NUMBER(30,2),
  refac_cont_id                   VARCHAR2(100),
  refac_distr_dt                  DATE,
  refac_exp_dt                    DATE,
  refac_distr_mode_descb          VARCHAR2(100),
  refac_kind_descb                VARCHAR2(100),
  use_int_rat                     NUMBER(18,9),
  int_accr_way_descb              VARCHAR2(100),
  belong_land_pbc_fin_inst_code   VARCHAR2(250),
  belong_land_pbc_name            VARCHAR2(250),
  belong_land_pbc_corp_princ_name VARCHAR2(250),
  corp_phone_num                  VARCHAR2(60),
  corp_addr                       VARCHAR2(250),
  org_name                        VARCHAR2(100),
  recvbl_acct_id                  VARCHAR2(100),
  pbc_pay_acct_id                 VARCHAR2(100),
  pbc_cred_rht_type_descb         VARCHAR2(100),
  pmo_type_cd                     VARCHAR2(30),
  pmo_cont_id                     VARCHAR2(60),
  pmo_amt_evltion                 NUMBER(30,2),
  pmo_amt_evltion_tot             NUMBER(30,2),
  cred_rht_bal                    NUMBER(30,2),
  job_cd                          VARCHAR2(10),
  etl_timestamp                   TIMESTAMP(6),
  actl_loan_distr_dt              DATE,
  actl_loan_termnt_dt             DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
