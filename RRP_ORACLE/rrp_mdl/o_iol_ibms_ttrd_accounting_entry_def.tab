  as_id               VARCHAR2(45),
  acting_entry_name_1 VARCHAR2(383),
  acting_entry_name_2 VARCHAR2(383),
  acting_entry_name_3 VARCHAR2(383),
  acting_code         VARCHAR2(150),
  property            VARCHAR2(45),
  entry_direction     VARCHAR2(15),
  acting_entry_code_1 VARCHAR2(75),
