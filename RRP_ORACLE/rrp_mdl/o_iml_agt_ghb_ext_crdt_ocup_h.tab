comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.market_type_id
  is '市场类型编号';
comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.intnal_vch_acct_id
