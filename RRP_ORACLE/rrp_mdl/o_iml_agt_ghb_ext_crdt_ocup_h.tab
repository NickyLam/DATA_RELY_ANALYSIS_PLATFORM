comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.id_mark
