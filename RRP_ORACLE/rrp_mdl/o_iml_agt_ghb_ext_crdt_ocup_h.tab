create table RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H
(
  agt_id             VARCHAR2(250),
  lp_id              VARCHAR2(60),
  ser_num            VARCHAR2(100),
  apv_form_num       VARCHAR2(100),
  tran_odd_no        VARCHAR2(100),
  fin_instm_id       VARCHAR2(100),
  asset_type_id      VARCHAR2(100),
  market_type_id     VARCHAR2(100),
  intnal_vch_acct_id VARCHAR2(100),
  acct_acctnt_cls_cd VARCHAR2(30),
  acct_b_cate_cd     VARCHAR2(30),
  crdt_side_cust_id  VARCHAR2(100),
  crdt_side_name     VARCHAR2(375),
  lmt_cont_id        VARCHAR2(100),
  occu_lmt           NUMBER(30,8),
  ocup_surp_lmt      NUMBER(30,8),
  start_dt           DATE,
  end_dt             DATE,
  id_mark            VARCHAR2(10),
  src_table_name     VARCHAR2(100),
  job_cd             VARCHAR2(10),
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H
  is '华兴外部授信占用历史';
comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.agt_id
  is '协议编号';
comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.ser_num
  is '序列号';
comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.apv_form_num
  is '审批单号';
comment on column RRP_MDL.O_IML_AGT_GHB_EXT_CRDT_OCUP_H.tran_odd_no
