  online_pur_fund_unfreeze_date  DATE,
  offline_purcapital_unfrz_date  DATE,
  add_issue_total_vol            NUMBER(18,6),
  distribution_sd                DATE,
  distribution_ed                DATE,
  funds_to_account_confirm_time  DATE,
  bond_transfer_time             DATE,
  basic_uw_add_contract_fee_rate NUMBER(18,4),
  contract_fee_rate              NUMBER(18,4),
  ib_financing_tool_reg_info_num NUMBER(20),
  cb_issue_plan_record_num       NUMBER(20),
  currency_code                  VARCHAR2(36),
  currency_name                  VARCHAR2(90),
