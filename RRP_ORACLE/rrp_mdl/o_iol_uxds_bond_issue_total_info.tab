  book_building_date             DATE,
  valid_purpurchase_amt          NUMBER(24,6),
  max_purchase_rate              NUMBER(24,4),
  min_purchase_rate              NUMBER(24,4),
  compliance_purchase_amt        NUMBER(24,6),
