create table RRP_MDL.O_ICL_CMM_IBANK_BOND_INVEST
(
  etl_dt                   DATE,
  lp_id                    VARCHAR2(60),
  ext_secu_acct_id         VARCHAR2(60),
  intnal_secu_acct_id      VARCHAR2(60),
  fin_instm_id             VARCHAR2(100),
  asset_type_id            VARCHAR2(60),
  std_prod_id              VARCHAR2(60),
  market_type_id           VARCHAR2(60),
  bus_id                   VARCHAR2(60),
  prod_type_cd             VARCHAR2(30),
  asset_type_name          VARCHAR2(250),
  acct_name                VARCHAR2(500),
  bond_name                VARCHAR2(90),
  convbl_bond_flg          VARCHAR2(10),
  sub_debt_flg             VARCHAR2(10),
  abs_flg                  VARCHAR2(10),
  subj_id                  VARCHAR2(60),
  tran_market_id           VARCHAR2(60),
  exchg_acct_id            VARCHAR2(60),
  issuer_id                VARCHAR2(60),
  issuer_name              VARCHAR2(375),
  guartor_name             VARCHAR2(750),
  payoff_level_cd          VARCHAR2(10),
  issue_dt                 DATE,
  value_dt                 DATE,
  exp_dt                   DATE,
  tenor_cd                 VARCHAR2(10),
  base_rat_id              VARCHAR2(100),
  int_accr_base_cd         VARCHAR2(30),
  int_rat_adj_way_cd       VARCHAR2(10),
  issue_way_cd             VARCHAR2(10),
  ex_type_cd               VARCHAR2(10),
  fir_ex_dt                DATE,
  fir_ex_price             NUMBER(30,2),
  fir_compst_int_rat       NUMBER(18,8),
  cty_cd                   VARCHAR2(10),
  curr_cd                  VARCHAR2(10),
  fac_val_amt              NUMBER(38,8),
  fac_val_int_rat          NUMBER(18,8),
  pay_int_ped_cd           VARCHAR2(10),
  int_accr_ped_cd          VARCHAR2(10),
  reset_ped_cd             VARCHAR2(10),
  hold_pos                 NUMBER(30,8),
  hold_fac_val             NUMBER(30,8),
  pric_bal                 NUMBER(30,8),
  acru_int                 NUMBER(30,8),
  recvbl_uncol_pric        NUMBER(30,8),
  recvbl_uncol_int         NUMBER(30,8),
  int_adj_amt              NUMBER(30,8),
  evha_val_chag            NUMBER(30,8),
  actl_int_rat             NUMBER(18,8),
  last_update_dt           DATE,
  cap_type_cd              VARCHAR2(10),
  asset_four_cls_cd        VARCHAR2(10),
  belong_org_id            VARCHAR2(60),
  obj_id                   VARCHAR2(60),
  int_subj_id              VARCHAR2(100),
  int_adj_subj_id          VARCHAR2(100),
  base_rat_asset_type_id   VARCHAR2(60),
  base_rat_market_type_id  VARCHAR2(60),
  base_rat                 NUMBER(30,8),
  fair_val_pl              NUMBER(30,8),
  asset_thd_cls_cd         VARCHAR2(30),
  cbond_full_price_evltion NUMBER(30,8),
  cbond_net_price_evltion  NUMBER(30,8),
  estim_coret_duran        NUMBER(30,8),
  bp_val                   NUMBER(30,8),
  estim_cvty               NUMBER(30,8),
  estim_yld_rat            NUMBER(30,8),
  book_bal                 NUMBER(30,8),
  int_recvbl               NUMBER(30,8),
  comb_tran_num            VARCHAR2(90),
  currt_bal                NUMBER(30,8),
  csecu_full_price_evltion NUMBER(30,8),
  csecu_net_price_evltion  NUMBER(30,8),
  csecu_coret_duran        NUMBER(30,8),
  csecu_bp_val             NUMBER(30,8),
  csecu_estim_cvty         NUMBER(30,8),
  extra_dimen_cd           VARCHAR2(10),
  stl_dt                   DATE,
  ovdue_status             VARCHAR2(450),
  ovdue_flg                VARCHAR2(10),
  pric_ovdue_dt            DATE,
  pric_ovdue_days          NUMBER(10),
  int_ovdue_dt             DATE,
  int_ovdue_days           NUMBER(10),
  issuer_cust_id           VARCHAR2(60),
  job_cd                   VARCHAR2(10),
  final_dir_indus_gen      VARCHAR2(450)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
