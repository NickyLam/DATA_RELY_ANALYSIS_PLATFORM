  job_cd                        VARCHAR2(10),
  custs_mang_lab_pbc_cali       VARCHAR2(100),
  custs_mang_lab_bank_supv_cali VARCHAR2(100)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

