  loan_appl_flow_num            VARCHAR2(100),
  partner_appl_flow_num         VARCHAR2(100),
  prod_id                       VARCHAR2(60),
  prod_name                     VARCHAR2(500),
  belong_org_id                 VARCHAR2(60),
  cust_id                       VARCHAR2(60),
  cust_name                     VARCHAR2(750),
  cert_type_cd                  VARCHAR2(10),
  cert_id                       VARCHAR2(60),
  cont_num                      VARCHAR2(90),
  hxb_blklist_flg               VARCHAR2(10),
  crdtc_que_flg                 VARCHAR2(10),
  score_val                     NUMBER(10),
  anti_fraud_check_flg          VARCHAR2(10),
  solv_rating_flg               VARCHAR2(10),
  partner_apv_rest_flg          VARCHAR2(10),
  other_acp_lmt_flg             VARCHAR2(10),
  appl_dt                       DATE,
  appl_amt                      NUMBER(30,2),
  apv_start_tm                  TIMESTAMP(6),
  apv_status_cd                 VARCHAR2(30),
  apv_amt                       NUMBER(30,2),
  apv_end_tm                    TIMESTAMP(6),
  final_jud_end_tm              TIMESTAMP(6),
  advise_sucs_flg               VARCHAR2(10),
  refuse_rs                     VARCHAR2(2000),
