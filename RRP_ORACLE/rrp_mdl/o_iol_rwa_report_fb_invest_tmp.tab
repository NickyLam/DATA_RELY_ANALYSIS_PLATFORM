create table RRP_MDL.O_IOL_RWA_REPORT_FB_INVEST_TMP
(
  data_date                    DATE,
  loan_ref_id                  NUMBER(22),
  loan_ref_no                  VARCHAR2(100),
  i_code                       VARCHAR2(80),
  i_code_name                  VARCHAR2(100),
  product_type                 VARCHAR2(100),
  asset_thd_cls_cd             VARCHAR2(10),
  product_name                 VARCHAR2(100),
  start_date                   DATE,
  due_date                     DATE,
  sourceid                     VARCHAR2(10),
  org_cd                       VARCHAR2(40),
  subject_cd                   VARCHAR2(60),
  interest_receive_subject_cd  VARCHAR2(60),
  accrual_class_subject_cd     VARCHAR2(60),
  interest_adjust_subject_cd   VARCHAR2(60),
  fairvalue_changes_subject_cd VARCHAR2(60),
  provision_single_subject_cd  VARCHAR2(60),
  asset_balance                NUMBER(22,2),
  ccy_name                     VARCHAR2(10),
  asset_balance_hcurr          NUMBER(22,6),
  receivable_int               NUMBER(22,6),
  accrued_int                  NUMBER(22,6),
  int_adj                      NUMBER(22,6),
  fair_value_change            NUMBER(22,6),
  provision                    NUMBER(22,6),
  spv_cust_no                  VARCHAR2(40),
  spv_cust_name                VARCHAR2(100),
  spv_cust_type                VARCHAR2(100),
  cust_name                    VARCHAR2(100),
  uder_actl_finer_cust_char    VARCHAR2(80),
  ccp_type_cd                  VARCHAR2(50),
  ead_orig                     NUMBER(22,6),
  ead_provision                NUMBER(22,6),
  portfoliotypedesc            VARCHAR2(200),
  rwbandid                     NUMBER(22,3),
  allocatedcrm                 NUMBER(22,2),
  crm_rwbandid_wtd             NUMBER(22,3),
  crm_cover_rwaamount          NUMBER(22,2),
  crm_ncover_rwaamount         NUMBER(22,2),
  rwaamount                    NUMBER(22,2),
  register_date                DATE,
  crm_cash_amt                 NUMBER(22,2),
  crm_deposit_amt              NUMBER(22,2),
  crm_national_debt_amt        NUMBER(22,2),
  crm_policy_bank_amt          NUMBER(22,2),
  crm_bank_amt                 NUMBER(22,2),
  crm_pse_sov_amt              NUMBER(22,2),
  crm_oth_amt                  NUMBER(22,2)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.O_IOL_RWA_REPORT_FB_INVEST_TMP.data_date
  is '数据日期';
comment on column RRP_MDL.O_IOL_RWA_REPORT_FB_INVEST_TMP.loan_ref_id
  is '债项ID';
comment on column RRP_MDL.O_IOL_RWA_REPORT_FB_INVEST_TMP.loan_ref_no
  is '债项编号';
