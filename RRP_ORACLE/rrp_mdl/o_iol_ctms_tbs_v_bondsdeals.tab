create table RRP_MDL.O_IOL_CTMS_TBS_V_BONDSDEALS
(
  deal_id              NUMBER(22),
  deal_tablename       VARCHAR2(15),
  aspclient_id         NUMBER(22),
  bondscode            VARCHAR2(45),
  bondsname            VARCHAR2(75),
  bondstype            VARCHAR2(30),
  serial_number        VARCHAR2(23),
  tradedate            NUMBER(22),
  settledate           NUMBER(8),
  buyorsell            VARCHAR2(2),
  cleanprice           NUMBER(38,12),
  dirtyprice           NUMBER(38,12),
  yieldtomaturity      NUMBER(38,12),
  settleamount         NUMBER(30,2),
  portfolio_id         NUMBER(22),
  portfolio_name       VARCHAR2(120),
  keepfolder_id        NUMBER(22),
  keepfolder_shortname VARCHAR2(75),
  folderatts           VARCHAR2(12),
  classfyname          VARCHAR2(30),
  cptys_shortname      VARCHAR2(192),
  cptys_id             NUMBER(22),
  settletype           VARCHAR2(15),
  dealer_id            NUMBER(4),
  dealer_name          VARCHAR2(30),
  ref_number           VARCHAR2(48),
  feeamount            NUMBER(22),
  taxamount            NUMBER(22),
  brokeramount         NUMBER(22),
  note                 VARCHAR2(4000),
  nominal              NUMBER(22),
  accruedamount        NUMBER(22),
  cfets_from           VARCHAR2(2),
  source               VARCHAR2(2),
  lastmodified         TIMESTAMP(6),
  datasymbol_id        NUMBER(22),
  assettype_id         NUMBER(22),
  bondsdeals_id_grand  NUMBER(22),
  stock_id             VARCHAR2(15),
  convert_price        NUMBER(10,4),
  stock_price          NUMBER(10,4),
  convert_quantity     NUMBER(27,12),
  dn_dealer            VARCHAR2(900),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6),
  currency             VARCHAR2(5),
  tradetime            VARCHAR2(60)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
