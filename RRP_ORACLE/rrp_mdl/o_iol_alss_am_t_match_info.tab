create table RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO
(
  cust_no            VARCHAR2(200),
  own_organ          VARCHAR2(200),
  organ_code         VARCHAR2(200),
  acct_num           VARCHAR2(400),
  acct_name          VARCHAR2(750),
  acct_type          VARCHAR2(200),
  licence_regist_num VARCHAR2(400),
  licence_social_num VARCHAR2(400),
  other_credtype     VARCHAR2(400),
  core_people        VARCHAR2(3000),
  core_business      VARCHAR2(3000),
  people_business    VARCHAR2(3000),
  suspend_info       VARCHAR2(4000),
  manage_state       VARCHAR2(200),
  abnormal_con       VARCHAR2(3000),
  illegal_breach     VARCHAR2(3000),
  last_inspect       VARCHAR2(200),
  check_dt           VARCHAR2(200),
  inspect_dt         VARCHAR2(200),
  etl_dt_ora         TIMESTAMP(9),
  org_num            VARCHAR2(100),
  establish_dt       VARCHAR2(200),
  handle_flag        VARCHAR2(20),
  core_proof         VARCHAR2(3000),
  etl_dt             DATE,
  etl_timestamp      TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO
  is '对公年检信息表';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.cust_no
  is '客户号';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.own_organ
  is '开户上级机构';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.organ_code
  is '开户机构';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.acct_num
  is '账号';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.acct_name
  is '账户名称';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.acct_type
  is '账户性质';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.licence_regist_num
  is '营业执照(注册号)编号';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.licence_social_num
  is '营业执照（统一社会信用代码）编号';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.other_credtype
  is '是否为其他证件种类';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.core_people
  is '核心与人行账户管理系统比对';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.core_business
  is '核心与商事信息';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.people_business
  is '人行账户管理系统与商事信息';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.suspend_info
  is '久悬账户情况';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.manage_state
  is '经营状态';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.abnormal_con
  is '是否被列入企业异常名录';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.illegal_breach
  is '是否为严重违法失信企业';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.last_inspect
  is '最后年检年度';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.check_dt
  is '核查日期';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.inspect_dt
  is '年检日期';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.etl_dt_ora
  is '创建日期';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.org_num
  is '所属机构';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.establish_dt
  is '企业开立日期';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.handle_flag
  is '账户处示标示 1-是(已处置)';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.core_proof
  is '核心与验印系统比对';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.etl_dt
  is 'ETL处理日期';
comment on column RRP_MDL.O_IOL_ALSS_AM_T_MATCH_INFO.etl_timestamp
  is 'ETL处理时间戳';

