create table RRP_MDL.O_IOL_CTMS_TBS_V_REPODEALS
(
  deal_id              NUMBER,
  deal_tablename       VARCHAR2(14),
  aspclient_id         NUMBER,
  bondscode            VARCHAR2(24),
  bondsname            VARCHAR2(75),
  serial_number        VARCHAR2(23),
  trade_date           NUMBER(8),
  value_date           NUMBER(8),
  maturity_date        NUMBER(8),
  buyorsell            VARCHAR2(2),
  face_amount          NUMBER(17,2),
  first_price          NUMBER(17,9),
  maturity_price       NUMBER(17,9),
  repo_rate            NUMBER(34,12),
  amount               NUMBER(17,2),
  maturity_amount      NUMBER(17,2),
  fee1                 NUMBER(17,2),
  tax_amt1             NUMBER(17,2),
  broker_amt1          NUMBER(17,2),
  fee2                 NUMBER(17,2),
  tax_amt2             NUMBER(17,2),
  broker_amt2          NUMBER(17,2),
  interest             NUMBER(17,2),
  portfolio_id         NUMBER(5),
  portfolio_name       VARCHAR2(120),
  keepfolder_id        NUMBER,
  keepfolder_shortname VARCHAR2(75),
  cptys_short_name     VARCHAR2(192),
  cptys_id             NUMBER,
  settle_type          VARCHAR2(30),
  settle_type2         VARCHAR2(30),
  dealer_id            NUMBER(5),
  dealer_name          VARCHAR2(30),
  ref_number           VARCHAR2(48),
  cfets_from           VARCHAR2(2),
  lastmodified         TIMESTAMP(6),
  datasymbol_id        NUMBER,
  repo_days            NUMBER,
  repodeals_id_grand   NUMBER,
  repo_id              VARCHAR2(24),
  clearing_type        VARCHAR2(2),
  dn_dealer            VARCHAR2(900),
  start_dt             DATE,
  end_dt               DATE,
  id_mark              VARCHAR2(10),
  etl_timestamp        TIMESTAMP(6),
  trade_time           DATE
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_CTMS_TBS_V_REPODEALS
