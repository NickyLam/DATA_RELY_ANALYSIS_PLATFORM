create table RRP_MDL.B_CPTL_BOND_ISSUE_INFO
(
  data_dt         CHAR(8) not null,
  lgl_rep_id      VARCHAR2(200),
  cust_id         VARCHAR2(200),
  org_id          VARCHAR2(200),
  acc_id          VARCHAR2(200),
  seq_no          VARCHAR2(200),
  ulyg_prod_id    VARCHAR2(200) not null,
  cur             CHAR(3),
  acc_typ         VARCHAR2(10),
  book_bal        NUMBER(30,2),
  gl_cl           VARCHAR2(10),
  val_dt          CHAR(8),
  isu_dt          CHAR(8),
  exp_dt          CHAR(8),
  rate_re_prc_dt  CHAR(8),
  int_calc_flg    CHAR(1),
  pbl_int         NUMBER(30,2),
  bio_flg         CHAR(1),
  fin_debt_sub_cl VARCHAR2(10),
  perp_debt_flg   CHAR(1),
  renewal_cnt     INTEGER,
  bond_sur_amt    NUMBER(30,2),
  bond_isu_amt    NUMBER(30,2),
  int_pay_mode    VARCHAR2(10),
  dept_line       VARCHAR2(500),
  data_src        VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_CPTL_BOND_ISSUE_INFO
  is '债券发行信息';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.data_dt
  is '数据日期';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.cust_id
  is '客户编号';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.org_id
  is '机构编号';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.acc_id
  is '账户编号';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.seq_no
  is '流水号';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.ulyg_prod_id
  is '标的产品编号';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.cur
  is '币种';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.acc_typ
  is '账户类型';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.book_bal
  is '账面余额';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.gl_cl
  is '会计分类';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.val_dt
  is '起息日期';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.isu_dt
  is '发行日期';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.exp_dt
  is '到期日期';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.rate_re_prc_dt
  is '利率重新定价日期';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.int_calc_flg
  is '计息标志';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.pbl_int
  is '应付利息';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.bio_flg
  is '境内外标志';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.fin_debt_sub_cl
  is '金融债细类';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.perp_debt_flg
  is '永续债标志';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.renewal_cnt
  is '续发次数';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.bond_sur_amt
  is '债券剩余金额';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.bond_isu_amt
  is '债券发行金额';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.int_pay_mode
  is '付息方式';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.dept_line
  is '部门条线';
comment on column RRP_MDL.B_CPTL_BOND_ISSUE_INFO.data_src
  is '数据来源';
alter table RRP_MDL.B_CPTL_BOND_ISSUE_INFO
  add constraint PK_B_CPTL_BOND_ISSUE_INFO primary key (DATA_DT, ULYG_PROD_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

