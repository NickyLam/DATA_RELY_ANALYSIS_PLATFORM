create table RRP_MDL.S26_CONFIG
(
  rcpt_id  VARCHAR2(200),
  province VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.S26_CONFIG
  is '过程临时表';
comment on column RRP_MDL.S26_CONFIG.rcpt_id
  is '借据号';
comment on column RRP_MDL.S26_CONFIG.province
  is '省份';

