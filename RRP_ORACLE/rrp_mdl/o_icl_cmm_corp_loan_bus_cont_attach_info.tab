create table RRP_MDL.O_ICL_CMM_CORP_LOAN_BUS_CONT_ATTACH_INFO
(
  etl_dt                               DATE,
  lp_id                                VARCHAR2(60),
  cont_id                              VARCHAR2(60),
  lmt_cont_id                          VARCHAR2(60),
  cont_name                            VARCHAR2(250),
  cont_type_cd                         VARCHAR2(10),
  margin_int_rat                       NUMBER(30,8),
  gover_crdt_flg                       VARCHAR2(10),
  gover_crdt_supt_way_cd               VARCHAR2(30),
  gover_crdt_type_cd                   VARCHAR2(30),
  cdb_crdt_breed_cd                    VARCHAR2(30),
  loan_char_cd                         VARCHAR2(30),
  invest_char_cd                       VARCHAR2(30),
  margin_int_rat_type_cd               VARCHAR2(30),
  margin_int_accr_method_cd            VARCHAR2(30),
  m_l_claus_exist_flg                  VARCHAR2(10),
  obank_open_flg                       VARCHAR2(10),
  three_old_tf_or_city_update_proj_flg VARCHAR2(10),
  cont_begin_dt                        DATE,
  cont_exp_dt                          DATE,
  start_work_dt                        DATE,
  batch_no                             VARCHAR2(250),
  plan_lics_id                         VARCHAR2(1000),
  arch_land_lics_id                    VARCHAR2(1000),
  envir_im_ass_lics_id                 VARCHAR2(1000),
  cnstr_lics_id                        VARCHAR2(1000),
  other_lics_id                        VARCHAR2(1000),
  ncds_num                             VARCHAR2(60),
  margin_tran_out_acct_num             VARCHAR2(60),
  bus_info_desc                        VARCHAR2(250),
  back_info_descb                      VARCHAR2(18),
  cargo_name                           VARCHAR2(250),
  cls_freq                             NUMBER(30,8),
  m_l_ratio                            NUMBER(30,8),
  proj_tot_invest                      NUMBER(18,2),
  capital                              NUMBER(18,2),
  setup_proj_batch_file                VARCHAR2(250),
  other_lics                           VARCHAR2(250),
  ncds_abbr                            VARCHAR2(100),
  margin_int_rat_level                 VARCHAR2(100),
  land_use_cert_id                     VARCHAR2(1000),
  land_use_cert_dt                     DATE,
  land_plan_lics_id                    VARCHAR2(1000),
  land_plan_lics_dt                    DATE,
  cnstr_lics_dt                        DATE,
  proj_plan_lics_dt                    DATE,
  buyer_name                           VARCHAR2(1000),
  seller_name                          VARCHAR2(1000),
  trade_tran_content                   VARCHAR2(3000),
  stat_use_open_bal                    NUMBER(30,8),
  commer_inv_info_desc                 VARCHAR2(100),
  commer_inv_curr_cd                   VARCHAR2(10),
  commer_inv_amt                       NUMBER(30,2),
  commer_inv_kind_cd                   VARCHAR2(100),
  job_cd                               VARCHAR2(10),
  adv_man_indu_flg                     VARCHAR2(100),
  spe_soph_unq_new_med_side_enter_flg  VARCHAR2(100),
  spe_soph_unq_new_lte_gnt_corp_flg    VARCHAR2(100),
  cul_property_flg                     VARCHAR2(100),
  indu_corp_tech_rem_ugd_flg           VARCHAR2(100),
  strate_new_indus_type_cd             VARCHAR2(100),
  high_new_tech_corp_flg               VARCHAR2(100),
  sci_tech_corp_flg                    VARCHAR2(100),
  sci_tech_inovt_corp_flg              VARCHAR2(100),
  provi_for_aged_property_flg          VARCHAR2(10),
  ppp_proj_flg                         VARCHAR2(10),
  new_distr_flg                        VARCHAR2(10),
  seed_loan_flg                        VARCHAR2(10),
  county_loan_flg                      VARCHAR2(10),
  high_tech_property_flg               VARCHAR2(10),
  digit_econ_core_type_cd              VARCHAR2(30),
  high_tech_serv_loan_flg              VARCHAR2(10),
  high_tech_serv_loan_type_cd          VARCHAR2(60),
  rela_peop_guar_loan_flg              VARCHAR2(10),
  cont_bal                             NUMBER(30,8)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
