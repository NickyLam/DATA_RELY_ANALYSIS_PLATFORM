create table RRP_MDL.O_IOL_ISBS_OPPNET
(
  inr                       VARCHAR2(12),
  gltyp                     VARCHAR2(12),
  glinr                     VARCHAR2(12),
  gldate                    VARCHAR2(12),
  trninr                    VARCHAR2(12),
  core_tran_flow_num        VARCHAR2(50),
  biz_seq_num               VARCHAR2(50),
  biz_seq_no                VARCHAR2(3),
  biz_ccy                   VARCHAR2(5),
  biz_amt                   NUMBER(18,3),
  pty_extkey                VARCHAR2(36),
  pty_name                  VARCHAR2(120),
  pty_acct_num              VARCHAR2(75),
  pty_acct_no               VARCHAR2(8),
  tran_type                 VARCHAR2(2),
  tx_cntpty_acct_num        VARCHAR2(75),
  tx_cntpty_name            VARCHAR2(120),
  cntpty_fin_inst_brac_cd   VARCHAR2(75),
  cntpty_fin_inst_brac_name VARCHAR2(120),
  dist                      VARCHAR2(60),
  tx_cntpty_cert_type       VARCHAR2(6),
  tx_cntpty_cert_type_txt   VARCHAR2(120),
  tx_cntpty_cert_no         VARCHAR2(48),
  cd_typ                    VARCHAR2(2),
  start_dt                  DATE,
  end_dt                    DATE,
  id_mark                   VARCHAR2(10),
  etl_timestamp             TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ISBS_OPPNET
  is '国结对手方信息表';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.inr
  is '主键inr';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.gltyp
  is '接口表';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.glinr
  is '接口表的inr';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.gldate
  is '记账日期';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.trninr
  is 'trn表的inr';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.core_tran_flow_num
  is '全局流水号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.biz_seq_num
  is '系统流水号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.biz_seq_no
  is '交易序号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.biz_ccy
  is '币种';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.biz_amt
  is '金额';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.pty_extkey
  is '分录账号的客户号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.pty_name
  is '分录账号的名称';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.pty_acct_num
  is '分录账号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.pty_acct_no
  is '分录账号序号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.tran_type
  is '借贷方向';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.tx_cntpty_acct_num
  is '交易对手账号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.tx_cntpty_name
  is '交易对手名称';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.cntpty_fin_inst_brac_cd
  is '交易对手行号';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.cntpty_fin_inst_brac_name
  is '交易对手行名';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.dist
  is '对手银行所在地行政区划';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.tx_cntpty_cert_type
  is '交易对手证件类型';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.tx_cntpty_cert_type_txt
  is '交易对手证件类型中文描述';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.tx_cntpty_cert_no
  is '交易对手证件号码';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.cd_typ
  is '交易对手行号类型';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.start_dt
  is '开始时间';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.end_dt
  is '结束时间';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.id_mark
  is '增删标志';
comment on column RRP_MDL.O_IOL_ISBS_OPPNET.etl_timestamp
  is 'etl处理时间戳';

