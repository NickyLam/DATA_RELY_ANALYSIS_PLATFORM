comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.prev_share_divd_amt
  is '上年度每股分红金额';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.per_share_idtfy_val
  is '每股认定价值';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.inpwn_tot_val
