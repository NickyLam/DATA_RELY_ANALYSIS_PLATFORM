create table RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO
(
  asset_id                     VARCHAR2(100),
  lp_id                        VARCHAR2(60),
  pledge_share_corp_name       VARCHAR2(375),
  pledge_share_local_corp_cd   VARCHAR2(100),
  issuer_brwer_flg             VARCHAR2(10),
  hold_shares_qtty             NUMBER(38),
  pledge_right_tot_right_ratio NUMBER(30,8),
  pledge_right_cnt             NUMBER(30,8),
  per_share_mk_pri             NUMBER(30,8),
  prev_share_divd_amt          NUMBER(30,8),
  per_share_idtfy_val          NUMBER(30,8),
  inpwn_tot_val                NUMBER(38,8),
  per_share_net_asset          NUMBER(30,8),
  warning_line                 NUMBER(30,8),
  close_pos_line               NUMBER(30,8),
  net_asset_tot                NUMBER(30,8),
  descb                        VARCHAR2(4000),
  curr_cd                      VARCHAR2(30),
  create_dt                    DATE,
  update_dt                    DATE,
  etl_dt                       DATE,
  id_mark                      VARCHAR2(10),
  src_table_name               VARCHAR2(100),
  job_cd                       VARCHAR2(10),
  etl_timestamp                TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO
  is '押品非上市股权信息';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.asset_id
  is '资产编号';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.lp_id
  is '法人编号';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.pledge_share_corp_name
  is '出质股权公司名称';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.pledge_share_local_corp_cd
  is '出质股权所在公司代码';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.issuer_brwer_flg
  is '发行人为借款人标志';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.hold_shares_qtty
  is '持股数量';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.pledge_right_tot_right_ratio
  is '出质股权所占总股权比例';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.pledge_right_cnt
  is '出质股权数';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.per_share_mk_pri
