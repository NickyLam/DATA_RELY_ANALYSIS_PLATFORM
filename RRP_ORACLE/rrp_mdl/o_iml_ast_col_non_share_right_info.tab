comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.warning_line
  is '警戒线';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.close_pos_line
