comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.net_asset_tot
  is '净资产总额';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.descb
  is '描述';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.curr_cd
  is '币种代码';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.create_dt
  is '创建日期';
comment on column RRP_MDL.O_IML_AST_COL_NON_SHARE_RIGHT_INFO.update_dt
