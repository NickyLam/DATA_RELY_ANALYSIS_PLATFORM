  appl_id                    VARCHAR2(100),
  lp_id                      VARCHAR2(100),
  renew_flow_num             VARCHAR2(100),
  rela_dubil_id              VARCHAR2(100),
  obj_id                     VARCHAR2(100),
  obj_type_name              VARCHAR2(500),
  base_rat_type_cd           VARCHAR2(30),
  renew_sucs_flg             VARCHAR2(10),
  renew_cont_id              VARCHAR2(100),
  repay_way_cd               VARCHAR2(30),
  repay_ped_cd               VARCHAR2(30),
  effect_dt                  DATE,
  exp_dt                     DATE,
  mon_tenor                  NUMBER(10),
  base_int_rat               NUMBER(18,8),
  int_rat_float_point        NUMBER(18,8),
  int_rat_float_way_cd       VARCHAR2(60),
  loan_exec_year_int_rat     NUMBER(18,8),
  ovdue_int_rat_float_way_cd VARCHAR2(60),
  ovdue_int_rat_fl_rt        NUMBER(30,2),
  int_rat_adj_way_cd         VARCHAR2(30),
  int_rat_adj_ped_cd         VARCHAR2(100),
  regroup_loan_flg           VARCHAR2(10),
  aldy_call_core_intfc_flg   VARCHAR2(10),
  precon_id                  VARCHAR2(100),
  blon_loan_amort_dt         DATE,
  blon_loan_incrs_amt        NUMBER(38,8),
  blon_loan_incrs_ratio      NUMBER(38,8),
  remark                     VARCHAR2(500),
  init_cont_exp_dt           DATE,
  init_repay_way_cd          VARCHAR2(30),
  init_repay_ped_cd          VARCHAR2(60),
  init_int_rat_float_way_cd  VARCHAR2(60),
  init_int_rat_adj_way_cd    VARCHAR2(100),
  init_int_rat_float_point   NUMBER(18,8),
  init_exec_year_int_rat     NUMBER(18,8),
  start_dt                   DATE,
  end_dt                     DATE,
  id_mark                    VARCHAR2(10),
  src_table_name             VARCHAR2(100),
  job_cd                     VARCHAR2(10),
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
