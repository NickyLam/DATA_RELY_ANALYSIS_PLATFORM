create table RRP_MDL.O_IOL_RWAS_RPT_TRAN_SECURITIES
(
  data_date                   DATE,
  loan_ref_no                 VARCHAR2(150),
  sec_no                      VARCHAR2(90),
  sec_name                    VARCHAR2(150),
  product_no                  VARCHAR2(45),
  product_name                VARCHAR2(45),
  loan_ref_desc               VARCHAR2(600),
  tradetypeid                 VARCHAR2(30),
  asset_thd_cls_cd            VARCHAR2(30),
  s_grade                     VARCHAR2(15),
  grade                       VARCHAR2(15),
  int_rat_adj_way_cd          VARCHAR2(45),
  coupon                      VARCHAR2(15),
  start_date                  DATE,
  due_date                    DATE,
  next_reval_date             DATE,
  rema__reval_date            NUMBER(18,6),
  remainingmaturity           NUMBER(18,6),
  org_cd                      VARCHAR2(90),
  org_name                    VARCHAR2(150),
  cust_no                     VARCHAR2(90),
  cust_name                   VARCHAR2(300),
  ccp_type_cd                 VARCHAR2(90),
  ccp_type_name               VARCHAR2(90),
  sec_type_cd                 VARCHAR2(90),
  subject_cd                  VARCHAR2(24),
  subject_name                VARCHAR2(300),
  accrued_subject_cd          VARCHAR2(24),
  accrued_subject_name        VARCHAR2(300),
  receivable_subject_cd       VARCHAR2(24),
  receivable_subject_name     VARCHAR2(300),
  accrued_receiv_subject_cd   VARCHAR2(24),
  accrued_receiv_subject_name VARCHAR2(300),
  intadj_subject_cd           VARCHAR2(24),
  intadj_subject_name         VARCHAR2(300),
  fairchange_subject_cd       VARCHAR2(24),
  fairchange_subject_name     VARCHAR2(300),
  provision_subject_cd        VARCHAR2(24),
  provision_subject_name      VARCHAR2(300),
  ccy_cd                      VARCHAR2(15),
  ccy_name                    VARCHAR2(90),
  balance                     NUMBER(18,2),
  balance_hcurr               NUMBER(18,2),
  receivable_int              NUMBER(18,2),
  accrued_receiv_int          NUMBER(18,2),
  accrued_int                 NUMBER(18,2),
  int_adj                     NUMBER(18,2),
  fair_value_change           NUMBER(18,2),
  provision                   NUMBER(18,2),
  asset_balance               NUMBER(18,2),
  ead_orig                    NUMBER(18,2),
  rate_sec_type_cd            VARCHAR2(60),
  specific_risk_ratio         VARCHAR2(15),
  spec_risk_capital_amount    NUMBER(18,2),
  coupon_flag                 VARCHAR2(15),
  mat_bucketid                VARCHAR2(90),
  specific_risk_charge        VARCHAR2(15),
  exposureamount              NUMBER(18,2),
  general_risk_capital_amount NUMBER(18,2),
  due_date_risk               NUMBER(18,2),
  rwaamount                   NUMBER(18,2),
  scra_rating                 VARCHAR2(15),
  orig_maturity               NUMBER(18,2),
  load_date                   VARCHAR2(30),
  etl_dt                      DATE,
  etl_timestamp               TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_RWAS_RPT_TRAN_SECURITIES
