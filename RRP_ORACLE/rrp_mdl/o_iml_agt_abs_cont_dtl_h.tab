create table RRP_MDL.O_IML_AGT_ABS_CONT_DTL_H
(
  agt_id                     VARCHAR2(250),
  lp_id                      VARCHAR2(100),
  asset_bag_cont_dtl_seq_num VARCHAR2(60),
  asset_bag_cont_id          VARCHAR2(100),
  loan_num                   VARCHAR2(60),
  distr_flow_num             VARCHAR2(100),
  prod_id                    VARCHAR2(100),
  curr_cd                    VARCHAR2(30),
  acct_id                    VARCHAR2(100),
  cust_id                    VARCHAR2(100),
  accti_status_cd            VARCHAR2(30),
  bal                        NUMBER(30,2),
  asset_acct_status_cd       VARCHAR2(30),
  issue_batch_no             VARCHAR2(60),
  issue_flow_num             VARCHAR2(100),
  issue_convt_prem           NUMBER(30,2),
  issue_revo_batch_no        VARCHAR2(60),
  circl_buy_flg              VARCHAR2(10),
  circl_buy_batch_no         VARCHAR2(60),
  circl_buy_flow_num         VARCHAR2(100),
  circl_buy_dt               DATE,
  revo_pkg_batch_no          VARCHAR2(60),
  revo_pkg_tran_flow_num     VARCHAR2(100),
  revo_tran_ref_no           VARCHAR2(60),
  redem_tran_flow_num        VARCHAR2(100),
  redem_batch_no             VARCHAR2(60),
  redem_convt_prem           NUMBER(30,2),
  pkg_batch_no               VARCHAR2(60),
  pkg_flow_num               VARCHAR2(100),
  pkg_tran_dt                DATE,
  tran_code_descb            VARCHAR2(500),
  final_modif_dt             DATE,
  start_dt                   DATE,
  end_dt                     DATE,
  id_mark                    VARCHAR2(10),
  src_table_name             VARCHAR2(100),
  job_cd                     VARCHAR2(10),
  etl_timestamp              TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IML_AGT_ABS_CONT_DTL_H
  is '资产证券化合同历史';
comment on column RRP_MDL.O_IML_AGT_ABS_CONT_DTL_H.agt_id
