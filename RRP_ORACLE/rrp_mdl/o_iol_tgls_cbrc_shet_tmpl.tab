create table RRP_MDL.O_IOL_TGLS_CBRC_SHET_TMPL
(
  subsys        NUMBER,
  shetcd        VARCHAR2(16),
  verson        NUMBER,
  htmlna        VARCHAR2(256),
  exclna        VARCHAR2(256),
  cellxy        VARCHAR2(32),
  condxy        VARCHAR2(150),
  tmstyl        VARCHAR2(1),
  begndt        DATE,
  overdt        DATE,
  rpvrsn        VARCHAR2(12),
  tbrule        VARCHAR2(64),
  fipath        VARCHAR2(256),
  stacid        NUMBER(19),
  jsdata        VARCHAR2(4000),
  jsondata      VARCHAR2(4000),
  maxrow        VARCHAR2(8),
  maxcol        VARCHAR2(8),
  jsonstyle     VARCHAR2(4000),
  mergecells    VARCHAR2(4000),
  colwidths     VARCHAR2(4000),
  rowheights    VARCHAR2(4000),
  start_dt      DATE,
  end_dt        DATE,
  id_mark       VARCHAR2(10),
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_TGLS_CBRC_SHET_TMPL
