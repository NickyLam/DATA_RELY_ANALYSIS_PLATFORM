create table RRP_MDL.B_LOAN_RL_EST_SUB
(
  data_dt                  CHAR(8) not null,
  lgl_rep_id               VARCHAR2(200),
  org_id                   VARCHAR2(200),
  rcpt_id                  VARCHAR2(200) not null,
  rl_est_loan_typ          VARCHAR2(10),
  afp_typ                  VARCHAR2(10),
  cptl_fnd                 NUMBER(30,2),
  aldy_have_hse_num        INTEGER,
  mon_pty_chgs             NUMBER(30,2),
  hse_pty_bldg_area        NUMBER(30,2),
  opr_pty_loan_flg         CHAR(1),
  term_acm_mon             NUMBER(30,2),
  scrtz_flg                CHAR(1),
  scrtz_dt                 CHAR(8),
  lpr                      NUMBER(20,6),
  ind_hse_loan_typ         VARCHAR2(10),
  ind_hse_mtg_upd_loan_flg CHAR(1),
  first_repy_dt            CHAR(8),
  dept_line                VARCHAR2(500),
  data_src                 VARCHAR2(500)
)
partition by list (DATA_DT)
(
  partition PARTITION_20220101 values ('20220101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255,
  partition PARTITION_19000101 values ('19000101')
    tablespace TBS_EAST_DATA
    pctfree 10
    initrans 1
    maxtrans 255
);
comment on table RRP_MDL.B_LOAN_RL_EST_SUB
  is '房地产贷款子表';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.data_dt
  is '数据日期';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.lgl_rep_id
  is '法人编号';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.org_id
  is '机构编号';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.rcpt_id
  is '借据编号';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.rl_est_loan_typ
  is '房地产贷款类型';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.afp_typ
  is '保障性安居工程类型';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.cptl_fnd
  is '资本金';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.aldy_have_hse_num
  is '已有住房套数';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.mon_pty_chgs
  is '月物业费';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.hse_pty_bldg_area
  is '房产建筑面积';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.opr_pty_loan_flg
  is '经营性物业贷款标志';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.term_acm_mon
  is '期限积（月）';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.scrtz_flg
  is '证券化标志';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.scrtz_dt
  is '证券化日期';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.lpr
  is 'LPR利率';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.ind_hse_loan_typ
  is '个人住房贷款类型';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.ind_hse_mtg_upd_loan_flg
  is '个人住房抵押追加贷款标志';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.first_repy_dt
  is '首次还款日期';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.dept_line
  is '部门条线';
comment on column RRP_MDL.B_LOAN_RL_EST_SUB.data_src
  is '数据来源';
alter table RRP_MDL.B_LOAN_RL_EST_SUB
  add constraint PK_B_LOAN_RL_EST_SUB primary key (DATA_DT, RCPT_ID)
  using index 
  tablespace TBS_EAST_DATA
  pctfree 10
  initrans 2
  maxtrans 255;

