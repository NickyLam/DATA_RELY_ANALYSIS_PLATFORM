create table RRP_MDL.O_IOL_ICMS_LHD_TRANS_FLOW_INFO_HISTORY
(
  serialno      VARCHAR2(64),
  duebillno     VARCHAR2(64),
  accountdate   VARCHAR2(10),
  transno       VARCHAR2(64),
  transtype     VARCHAR2(10),
  transamt      NUMBER(24,6),
  noaccstatus   VARCHAR2(10),
  prioccamt     NUMBER(24,6),
  intoccamt     NUMBER(24,6),
  defintoccamt  NUMBER(24,6),
  czflag        VARCHAR2(10),
  channel       VARCHAR2(20),
  transdate     VARCHAR2(32),
  transorgid    VARCHAR2(20),
  migttype      VARCHAR2(10),
  inputuserid   VARCHAR2(64),
  inputorgid    VARCHAR2(64),
  inputdate     DATE,
  updateuserid  VARCHAR2(64),
  updateorgid   VARCHAR2(64),
  updatedate    DATE,
  compintoccamt NUMBER(24,6),
  hxduebillno   VARCHAR2(30),
  normalintamt  NUMBER(24,6),
  normalodpamt  NUMBER(24,6),
  normalodiamt  NUMBER(24,6),
  intpamt       NUMBER(24,6),
  odppamt       NUMBER(24,6),
  odipamt       NUMBER(24,6),
  batchno       VARCHAR2(36),
  sendflag      VARCHAR2(2),
  compflag      VARCHAR2(2),
  bizdate       VARCHAR2(10),
  type          VARCHAR2(10),
  globseqnum    VARCHAR2(200),
  etl_dt        DATE,
  etl_timestamp TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.O_IOL_ICMS_LHD_TRANS_FLOW_INFO_HISTORY
  is '信贷供交易流水文件临时表历史表';
comment on column RRP_MDL.O_IOL_ICMS_LHD_TRANS_FLOW_INFO_HISTORY.serialno
