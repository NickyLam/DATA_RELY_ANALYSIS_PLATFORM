create table RRP_MDL.O_IML_PTY_IBANK_CNTPTY_INFO
(
  org_cls_cd            VARCHAR2(30),
  dc_pay_sys_bank_no    VARCHAR2(90),
  fin_lics_id           VARCHAR2(60),
  party_type_cd         VARCHAR2(30),
  src_table_name        VARCHAR2(100),
  job_cd                VARCHAR2(10),
  org_id                VARCHAR2(60),
  en_fname              VARCHAR2(750),
  lp_id                 VARCHAR2(60),
  party_cd_cert_id      VARCHAR2(60),
  party_cls_descb       VARCHAR2(375),
  party_pinyin          VARCHAR2(750),
  etl_dt                DATE,
  party_name            VARCHAR2(750),
  create_dt             DATE,
  id_mark               VARCHAR2(10),
  party_id              VARCHAR2(60),
  matn_org_name         VARCHAR2(750),
  bus_lics_num          VARCHAR2(90),
  party_alias           VARCHAR2(750),
  spv_flg               VARCHAR2(30),
  en_name               VARCHAR2(750),
  party_fname           VARCHAR2(750),
  status_cd             VARCHAR2(30),
  fcurr_pay_sys_bank_no VARCHAR2(150),
  matn_org_id           VARCHAR2(60),
  update_dt             DATE,
  found_dt              DATE,
  rgst                  VARCHAR2(150),
  cust_id               VARCHAR2(60),
  rwa_cust_cls_name     VARCHAR2(750),
  src_party_id          VARCHAR2(60),
  super_org_id          VARCHAR2(60),
  mar_maker_flg         VARCHAR2(30),
  org_lev_cd            VARCHAR2(30)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
