create table RRP_MDL.O_IOL_IBMS_TTRD_ACC_SECU
(
  accid           VARCHAR2(45),
  accname         VARCHAR2(180),
  cash_accid      VARCHAR2(45),
  owner           VARCHAR2(45),
  trdkind         VARCHAR2(45),
  trdgrpid        VARCHAR2(45),
  ps1             VARCHAR2(45),
  ps2             VARCHAR2(45),
  ps3             VARCHAR2(45),
  ps4             VARCHAR2(45),
  status          NUMBER,
  trdgrp_auto     VARCHAR2(2),
  is_lock         NUMBER,
  lockstatus      NUMBER,
  accfiscasubject VARCHAR2(75),
  ps5             VARCHAR2(45),
  ps6             VARCHAR2(45),
  ps7             VARCHAR2(45),
  ps8             VARCHAR2(45),
  invest_type     NUMBER,
  acting_type     VARCHAR2(45),
  i_id            NUMBER,
  unit_id         VARCHAR2(45),
  start_dt        DATE,
  end_dt          DATE,
  id_mark         VARCHAR2(10),
  etl_timestamp   TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
