create table RRP_MDL.TEMP_BK_SIGN_INFO
(
  cust_id           VARCHAR2(2000),
  cust_cn_name      VARCHAR2(2000),
  open_acct_brac_id VARCHAR2(2000)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on column RRP_MDL.TEMP_BK_SIGN_INFO.cust_id
  is '客户表主键';
comment on column RRP_MDL.TEMP_BK_SIGN_INFO.cust_cn_name
  is '客户中文名称';
comment on column RRP_MDL.TEMP_BK_SIGN_INFO.open_acct_brac_id
  is '开户网点编号';

