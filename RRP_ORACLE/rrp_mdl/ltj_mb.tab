create table RRP_MDL.LTJ_MB
(
  模块      VARCHAR2(200),
  模块名称    VARCHAR2(200),
  过程名     VARCHAR2(200),
  前台指标编号  VARCHAR2(200),
  后台指标编号  VARCHAR2(200),
  依赖模块    VARCHAR2(200),
  依赖模块名称  VARCHAR2(200),
  依赖过程名   VARCHAR2(200),
  依赖目标表名  VARCHAR2(200),
  依赖目标表字段 VARCHAR2(200),
  条件字段    VARCHAR2(200)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;

