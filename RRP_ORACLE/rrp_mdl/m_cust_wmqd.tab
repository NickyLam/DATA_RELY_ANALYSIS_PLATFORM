create table RRP_MDL.M_CUST_WMQD
(
  cust_name VARCHAR2(2000),
  update_tm VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
comment on table RRP_MDL.M_CUST_WMQD
  is '外贸公司清单';
comment on column RRP_MDL.M_CUST_WMQD.cust_name
  is '客户名称';
comment on column RRP_MDL.M_CUST_WMQD.update_tm
  is '更新时间';

