create table RRP_MDL.O_IOL_BDMS_DPC_DRAFT_TRANS_INFO
(
  id                VARCHAR2(60),
  contract_id       VARCHAR2(60),
  protocol_no       VARCHAR2(60),
  details_id        VARCHAR2(60),
  draft_id          VARCHAR2(60),
  product_no        VARCHAR2(12),
  draft_attr        VARCHAR2(6),
  draft_type        VARCHAR2(6),
  busi_type         VARCHAR2(5),
  busi_attr_no      VARCHAR2(5),
  product_name      VARCHAR2(150),
  draft_number      VARCHAR2(45),
  draft_amount      NUMBER(18,2),
  cust_no           VARCHAR2(30),
  trade_direct      VARCHAR2(8),
  txn_date          VARCHAR2(12),
  req_type          VARCHAR2(6),
  req_name          VARCHAR2(150),
  req_cert_no       VARCHAR2(27),
  req_account       VARCHAR2(48),
  req_mem_no        VARCHAR2(15),
  req_brh_no        VARCHAR2(15),
  req_bank_no       VARCHAR2(18),
  req_misc          VARCHAR2(675),
  rcv_type          VARCHAR2(6),
  rcv_name          VARCHAR2(150),
  rcv_cert_no       VARCHAR2(27),
  rcv_account       VARCHAR2(48),
  rcv_mem_no        VARCHAR2(15),
  rcv_brh_no        VARCHAR2(15),
  rcv_bank_no       VARCHAR2(18),
  rcv_misc          VARCHAR2(675),
  pay_amount        NUMBER(18,2),
  pay_type          VARCHAR2(2),
  pay_interest      NUMBER(18,2),
  payment_date      VARCHAR2(12),
  drawee_name       VARCHAR2(270),
  drawee_account    VARCHAR2(48),
  drawee_bank_name  VARCHAR2(270),
  repurchase_rate   NUMBER(7,6),
  charge            NUMBER(12,2),
  expenses          NUMBER(12,2),
  rpd_mk            VARCHAR2(6),
  agent_name        VARCHAR2(270),
  rate              NUMBER(7,6),
  payer_sale        NUMBER(8,5),
  buyer_interest    NUMBER(18,2),
  interest          NUMBER(18,2),
  move_trs_type     VARCHAR2(6),
  conf_pay_type     VARCHAR2(6),
  conf_pay_add_type VARCHAR2(6),
  conf_pay_rst      VARCHAR2(6),
  stop_pay_type     VARCHAR2(6),
  stop_pay_rsn      VARCHAR2(675),
  relieve_stp_type  VARCHAR2(6),
  relieve_stp_rsn   VARCHAR2(675),
  tenor_days        NUMBER(8),
  settle_amt        NUMBER(18,2),
  buy_back_date     VARCHAR2(12),
  real_back_date    VARCHAR2(12),
  buy_back_status   VARCHAR2(8),
  exchge_status     VARCHAR2(6),
  prmt_result       VARCHAR2(6),
  prmt_refuse_rsn   VARCHAR2(6),
  prmt_stl_rst      VARCHAR2(6),
  refuse_rsn        VARCHAR2(6),
  sig_mk            VARCHAR2(6),
  acct_date         VARCHAR2(12),
  trans_name        VARCHAR2(75),
  last_trans_id     VARCHAR2(60),
  inner_flag        VARCHAR2(3),
  trans_status      VARCHAR2(9),
  settle_type       VARCHAR2(2),
  trans_branch_no   VARCHAR2(30),
  acct_branch_no    VARCHAR2(30),
  store_brh_no      VARCHAR2(30),
  top_branch_no     VARCHAR2(30),
  last_upd_opr      VARCHAR2(45),
  last_upd_time     VARCHAR2(21),
  misc              VARCHAR2(675),
  cd_range          VARCHAR2(38),
  product_type      VARCHAR2(6),
  req_buss_type     VARCHAR2(6),
  rcv_buss_type     VARCHAR2(6),
  req_dist_tp       VARCHAR2(6),
  rcv_dist_tp       VARCHAR2(6),
  create_time       VARCHAR2(21),
  create_by         VARCHAR2(45),
  start_dt          DATE,
  end_dt            DATE,
  id_mark           VARCHAR2(10),
  etl_timestamp     TIMESTAMP(6)
)
tablespace TBS_EAST_DATA
  pctfree 0
  initrans 1
  maxtrans 255
  storage
  (
    initial 64K
    next 1M
    minextents 1
    maxextents unlimited
  )
compress;
