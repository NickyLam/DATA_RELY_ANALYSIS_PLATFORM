create table RRP_MDL.O_IOL_FAMS_FIN_TRADE_PRODUCT
(
  finprod_id          VARCHAR2(50),
  branch              NUMBER(10),
  finprod_type        VARCHAR2(50),
  finprod_type2       VARCHAR2(50),
  profit_type         VARCHAR2(50),
  branch_type         VARCHAR2(50),
  chl_agrt_id         VARCHAR2(32),
  prin                NUMBER(30,2),
  ccy                 VARCHAR2(50),
  vdate               DATE,
  mdate               DATE,
  term                NUMBER(10),
  int_type            VARCHAR2(50),
  int_rate            NUMBER(30,14),
  int_rate_id         VARCHAR2(32),
  basis               VARCHAR2(50),
  m_prin_amt          NUMBER(30,2),
  m_int_amt           NUMBER(30,2),
  m_trade_amt         NUMBER(30,2),
  capi_income_feature VARCHAR2(50),
  o_finprod_id        VARCHAR2(50),
  trade_market        VARCHAR2(50),
  calendar_id         VARCHAR2(32),
  term_type           VARCHAR2(50),
  counter_id          VARCHAR2(32),
  create_user         VARCHAR2(20),
  create_dept         VARCHAR2(32),
  create_time         TIMESTAMP(6),
  update_user         VARCHAR2(20),
  update_time         TIMESTAMP(6),
  m_unit_cprice       NUMBER(30,14),
  m_unit_int          NUMBER(30,14),
  m_unit_fprice       NUMBER(30,14),
  m_yield             NUMBER(30,14),
  m_delivery_type     VARCHAR2(50),
  vpay_date           DATE,
  mpay_date           DATE,
  contract_no         VARCHAR2(200),
  act_cap_days        NUMBER(10),
  irs_type            VARCHAR2(50),
  exc_ps              VARCHAR2(50),
  cur_pair            VARCHAR2(50),
  exc_fxs_term_type   VARCHAR2(50),
  usd_amt             NUMBER(30,2),
  dif_settle_ref_rate VARCHAR2(50),
  conflict_solve_way  VARCHAR2(50),
  period_id           VARCHAR2(50),
  is_rush_back        VARCHAR2(50),
  contract_name       VARCHAR2(200),
  start_dt            DATE,
  end_dt              DATE,
  id_mark             VARCHAR2(10)
)
tablespace TBS_EAST_DATA
  pctfree 10
  initrans 1
  maxtrans 255
compress;
comment on table RRP_MDL.O_IOL_FAMS_FIN_TRADE_PRODUCT
  is '交易类金融产品';
comment on column RRP_MDL.O_IOL_FAMS_FIN_TRADE_PRODUCT.finprod_id
